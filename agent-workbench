            bg=PANEL_ALT,
            fg=TEXT,
            activebackground=SIDEBAR_SEL,
            activeforeground=TEXT,
            relief="flat",
            padx=12,
            pady=6,
            cursor="hand2",
        ).pack(side="right")

        worker_list.bind("<<ListboxSelect>>", show_selected)
        dialog.protocol("WM_DELETE_WINDOW", dialog.destroy)

        def cleanup():
            if self.worker_dialog is dialog:
                self.worker_dialog = None

        dialog.bind("<Destroy>", lambda _e: cleanup(), add="+")
        dialog._refresh_worker_render = render
        render()

        # Keep the "Active agents" list live (busy/idle, sub-agent counts) without
