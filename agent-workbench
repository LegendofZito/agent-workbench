        widget.window_create("end", window=frame, padx=18, pady=8)
        widget.insert("end", "\n")
        self.report_cards.append({"frame": frame, "content": content, "button": button})
        widget.configure(state="disabled")
        self._finish_chat_append(at_bottom)

    def _linkify_chat_range(self, start, end):
        text = self.chat.get(start, end)
        candidates = []
        for match in re.finditer(r"https?://[^\s<>()]+", text):
            target = match.group(0).rstrip(".,;:!?]}")
            candidates.append((match.start(), match.start() + len(target), target))
        for match in re.finditer(r"(?<![\w])(?:~?/|/)[^\s`<>]+", text):
            target = match.group(0).rstrip(".,;:!?]})")
            path = os.path.abspath(os.path.expanduser(target))
            if os.path.exists(path):
                candidates.append((match.start(), match.start() + len(target), path))
        for offset_start, offset_end, target in candidates:
            tag = f"link_{self.link_counter}"
            self.link_counter += 1
            tag_start = self.chat.index(f"{start}+{offset_start}c")
            tag_end = self.chat.index(f"{start}+{offset_end}c")
            self.chat.tag_add(tag, tag_start, tag_end)
            self.chat.tag_config(tag, foreground="#79b8ff", underline=True)
            self.chat.tag_bind(tag, "<Enter>", lambda _e: self.chat.configure(cursor="hand2"))
            self.chat.tag_bind(tag, "<Leave>", lambda _e: self.chat.configure(cursor="xterm"))
            self.chat.tag_bind(
                tag,
                "<Button-1>",
                lambda _e, value=target: subprocess.Popen(["xdg-open", value]),
            )

    def _insert_inline_chat(self, text, base_tag="assistant"):
        cursor = 0
        pattern = re.compile(r"(`[^`\n]+`|\*\*[^*\n]+\*\*)")
        for match in pattern.finditer(text):
            if match.start() > cursor:
                self.chat.insert("end", text[cursor:match.start()], base_tag)
            token = match.group(0)
            if token.startswith("`"):
                self.chat.insert("end", token[1:-1], "chat_code")
            else:
                self.chat.insert("end", token[2:-2], "chat_bold")
            cursor = match.end()
        if cursor < len(text):
            self.chat.insert("end", text[cursor:], base_tag)

    def _insert_formatted_chat(self, text):
        lines = text.rstrip().splitlines()
        in_code_block = False
        for line in lines:
            stripped = line.strip()
            if stripped.startswith("```"):
                in_code_block = not in_code_block
                continue
            if in_code_block:
                self.chat.insert("end", line + "\n", "chat_code")
                continue
            if stripped.startswith("### "):
                self.chat.insert("end", stripped[4:] + "\n", "chat_h2")
            elif stripped.startswith("## "):
                self.chat.insert("end", stripped[3:] + "\n", "chat_h2")
            elif stripped.startswith("# "):
                self.chat.insert("end", stripped[2:] + "\n", "chat_h1")
            elif re.match(r"^[-*]\s+\[[xX]\]\s+", stripped):
                label = re.sub(r"^[-*]\s+\[[xX]\]\s+", "", stripped)
                self.chat.insert("end", "✓ ", "chat_check_done")
                self._insert_inline_chat(label, "chat_check_done")
                self.chat.insert("end", "\n", "chat_check_done")
            elif re.match(r"^[-*]\s+\[\s\]\s+", stripped):
                label = re.sub(r"^[-*]\s+\[\s\]\s+", "", stripped)
                self.chat.insert("end", "□ ", "chat_check_open")
                self._insert_inline_chat(label, "chat_check_open")
                self.chat.insert("end", "\n", "chat_check_open")
            elif re.match(r"^[-*]\s+", stripped):
                label = re.sub(r"^[-*]\s+", "", stripped)
                self.chat.insert("end", "• ", "chat_bullet")
                self._insert_inline_chat(label, "assistant")
                self.chat.insert("end", "\n", "assistant")
            elif re.match(r"^\d+\.\s+", stripped):
                marker, label = stripped.split(" ", 1)
                self.chat.insert("end", marker + " ", "chat_bullet")
                self._insert_inline_chat(label, "assistant")
                self.chat.insert("end", "\n", "assistant")
            else:
                self._insert_inline_chat(line, "assistant")
                self.chat.insert("end", "\n", "assistant")
        self.chat.insert("end", "\n", "assistant")

    def append_work(self, text, tag="system"):
        # Buffer into pages so no single page is huge (keeps Tk fast); the left column
        # gives one clickable "Log N" button per page. Newest page is live.
        if not text:
            return
        if not hasattr(self, "work_pages"):
            self._reset_work_pages()
        self.work_pages[-1].append((text, tag))
        self.work_page_lines += text.count("\n") + 1
        live = len(self.work_pages) - 1
        viewing_live = self.work_view_index == live
        if viewing_live:
            self._insert_work_entry(text, tag)
        if self.work_page_lines >= WORK_LOG_PAGE_LINES and self.work_pages[-1]:
            self.work_pages.append([])
            self.work_page_lines = 0
            self._rebuild_work_page_buttons()
            if viewing_live:
                self._show_work_page(len(self.work_pages) - 1)

    def _work_log_page_text(self, index):
        pages = getattr(self, "work_pages", [[]])
        if not pages:
            return ""
        index = max(0, min(index, len(pages) - 1))
        return "\n".join(text.rstrip() for text, _tag in pages[index]).rstrip() + "\n"

    def _work_log_full_text(self):
        pages = getattr(self, "work_pages", [[]])
        chunks = []
        for index, page in enumerate(pages, start=1):
            if not page:
                continue
            chunks.append(f"## Log {index}\n\n" + "\n".join(
                text.rstrip() for text, _tag in page
            ).rstrip())
        return "\n\n".join(chunks).rstrip() + ("\n" if chunks else "")

    def _work_log_export_name(self, suffix):
        title = clean_text((self.current_session or {}).get("title")) or "work-log"
        title = re.sub(r"[^A-Za-z0-9._-]+", "-", title).strip("-") or "work-log"
        return f"{title}-{suffix}.md"

    def _write_work_log_export(self, path, text):
        with open(path, "w", encoding="utf-8") as handle:
            handle.write(text)
        self.status.set(f"Work log exported: {path}")

    def export_current_work_log_page(self):
        index = getattr(self, "work_view_index", 0)
        text = self._work_log_page_text(index)
        if not clean_text(text):
            self.status.set("Current work log page is empty.")
            return
        path = filedialog.asksaveasfilename(
            parent=self.win,
            title="Export current work log",
            initialfile=self._work_log_export_name(f"log-{index + 1}"),
            defaultextension=".md",
            filetypes=[("Markdown", "*.md"), ("Text", "*.txt"), ("All files", "*")],
        )
        if path:
            try:
                self._write_work_log_export(path, text)
            except OSError as exc:
                messagebox.showerror("Export work log", str(exc), parent=self.win)

    def export_full_work_log(self):
        text = self._work_log_full_text()
        if not clean_text(text):
            self.status.set("Work log is empty.")
            return
        path = filedialog.asksaveasfilename(
            parent=self.win,
            title="Export full work log",
            initialfile=self._work_log_export_name("full-work-log"),
            defaultextension=".md",
            filetypes=[("Markdown", "*.md"), ("Text", "*.txt"), ("All files", "*")],
        )
        if path:
            try:
                self._write_work_log_export(path, text)
            except OSError as exc:
                messagebox.showerror("Export work log", str(exc), parent=self.win)

    def find_work_log_entry(self):
        query = simpledialog.askstring(
            "Find work log",
            "Search work logs for:",
            parent=self.win,
        )
        query = clean_text(query)
        if not query:
            return
        pages = getattr(self, "work_pages", [[]])
        query_lower = query.lower()
        for index, page in enumerate(pages):
            haystack = "\n".join(text for text, _tag in page)
            hit, highlight = self._work_log_query_match(haystack, query_lower)
            if not hit:
                continue
            self._show_work_page(index)
            try:
                self.work.tag_remove("search_hit", "1.0", "end")
                start = self.work.search(highlight or query, "1.0", stopindex="end", nocase=True)
                if start:
                    end = f"{start}+{len(highlight or query)}c"
                    self.work.tag_add("search_hit", start, end)
                    self.work.see(start)
            except tk.TclError:
                pass
            self.status.set(f"Found in Log {index + 1}.")
            return
        self.status.set(f"No work log match for: {query}")

    def _work_log_query_match(self, haystack, query_lower):
        haystack_lower = clean_text(haystack).lower()
        if not haystack_lower or not query_lower:
            return False, ""
        if query_lower in haystack_lower:
            return True, query_lower
        words = [
            word
            for word in re.findall(r"[a-z0-9_./-]+", query_lower)
            if len(word) >= 2
        ]
        if words and all(word in haystack_lower for word in words):
            return True, words[0]
        return False, ""

    def _insert_work_entry(self, text, tag):
        widget = self.work
        # During a bulk render (loading a whole session) the per-entry yview()/see()
        # calls force a full layout recompute every line — O(n²) thrash that freezes
        # the UI on a session with a runaway/huge work log. Suppress them while bulk
        # rendering; the renderer does a single see("end") at the end instead.
        if getattr(self, "_suspend_work_autoscroll", False):
            widget.configure(state="normal")
            widget.insert("end", text.rstrip() + "\n", tag)
            widget.configure(state="disabled")
            return
        at_bottom = widget.yview()[1] >= 0.995
        widget.configure(state="normal")
        widget.insert("end", text.rstrip() + "\n", tag)
        widget.configure(state="disabled")
        if at_bottom:
            try:
                if widget.yview()[1] >= 0.995:
                    widget.see("end")
            except tk.TclError:
                pass

    def _reset_work_pages(self):
        self.work_pages = [[]]
        self.work_page_lines = 0
        self.work_view_index = 0
        if hasattr(self, "work"):
            self.work.configure(state="normal")
            self.work.delete("1.0", "end")
            self.work.configure(state="disabled")
        self._rebuild_work_page_buttons()

    def _show_work_page(self, index):
        if not hasattr(self, "work_pages") or not self.work_pages:
            return
        index = max(0, min(index, len(self.work_pages) - 1))
        if index == getattr(self, "work_view_index", 0):
            self._sync_work_page_button_styles()
            return
        self.work_view_index = index
        widget = self.work
        widget.configure(state="normal")
        widget.delete("1.0", "end")
        for text, tag in self.work_pages[index]:
            widget.insert("end", text.rstrip() + "\n", tag)
        widget.configure(state="disabled")
        try:
            widget.see("end")
        except tk.TclError:
            pass
        self._sync_work_page_button_styles()

    def _choose_work_page(self, index):
        self._show_work_page(index)
        try:
            button = getattr(self, "_work_page_button_widgets", {}).get(
                getattr(self, "work_view_index", index)
            )
            if button:
                button.focus_set()
            else:
                self.work_pages_canvas.focus_set()
        except tk.TclError:
            pass

    def _rebuild_work_page_buttons(self):
        if not hasattr(self, "work_pages_buttons"):
            return
        total = len(getattr(self, "work_pages", [[]]))
        live = total - 1
        self.work_view_index = max(0, min(getattr(self, "work_view_index", 0), live))
        buttons = getattr(self, "_work_page_button_widgets", {})
        for stale in list(buttons):
            if stale >= total:
                try:
                    buttons[stale].destroy()
                except tk.TclError:
                    pass
                buttons.pop(stale, None)
        for i in range(total):
            button = buttons.get(i)
            if button is None:
                button = tk.Button(
                    self.work_pages_buttons,
                    command=lambda n=i: self._choose_work_page(n),
                    activebackground=SIDEBAR_SEL,
                    activeforeground=TEXT,
                    relief="flat",
                    borderwidth=0,
                    highlightthickness=0,
                    anchor="w",
                    padx=8,
                    pady=4,
                    cursor="hand2",
                    takefocus=1,
                )
                buttons[i] = button
                self._bind_work_page_navigation(button)
            else:
                try:
                    button.pack_forget()
                except tk.TclError:
                    pass
            button.pack(fill="x", pady=1)
        self._work_page_button_widgets = buttons
        self._sync_work_page_button_styles()

    def _sync_work_page_button_styles(self):
        buttons = getattr(self, "_work_page_button_widgets", {})
        total = len(getattr(self, "work_pages", [[]]))
        live = total - 1
        selected_index = getattr(self, "work_view_index", 0)
        for i, button in list(buttons.items()):
            if i >= total:
                continue
            selected = i == selected_index
            try:
                button.configure(
                    text=f"Log {i + 1}" + ("  ●" if i == live else ""),
                    bg=SIDEBAR_SEL if selected else PANEL_ALT,
                    fg=TEXT if selected else MUTED,
                    font=("Sans", 9, "bold" if selected else "normal"),
                )
            except tk.TclError:
                pass
        self._see_work_page_button(selected_index)

    def _see_work_page_button(self, index):
        button = getattr(self, "_work_page_button_widgets", {}).get(index)
        canvas = getattr(self, "work_pages_canvas", None)
        if not button or canvas is None:
            return
        try:
            canvas.update_idletasks()
            total = max(1, self.work_pages_buttons.winfo_height())
            view_height = max(1, canvas.winfo_height())
            top = canvas.canvasy(0)
            bottom = top + view_height
            y = button.winfo_y()
            height = max(1, button.winfo_height())
            if y < top:
                canvas.yview_moveto(max(0.0, y / total))
            elif y + height > bottom:
                canvas.yview_moveto(max(0.0, (y + height - view_height) / total))
        except tk.TclError:
            pass

    def _at_tab_limit(self):
        return (
            len([w for w in self.workspace_order if w in self.workspaces])
            >= MAX_WORKSPACE_TABS
        )

    def _notify_tab_limit(self):
        self.status.set(
            f"{MAX_WORKSPACE_TABS} tab limit reached — close a tab to open another."
        )
        messagebox.showinfo(
            "Tab limit reached",
            f"You already have {MAX_WORKSPACE_TABS} tabs open — that's the maximum.\n\n"
            "Close a tab before opening another session.",
            parent=self.win,
        )

    def new_session(self):
        if self.close_when_idle and not self.restart_after_close:
            self.status.set("Workbench is waiting for active tasks to finish before closing.")
            return
        if self._at_tab_limit():
            self._notify_tab_limit()
            return
        # Step 1: choose which client to start with. Step 2 (in _choose) names it.
        self._open_new_session_dialog()

    def _open_new_session_dialog(self):
        dialog = tk.Toplevel(self.win)
        dialog.title("New session")
        dialog.configure(bg=BG)
        dialog.transient(self.win)
        dialog.resizable(False, False)
        dialog.grab_set()
        body = tk.Frame(dialog, bg=BG, padx=20, pady=18)
        body.pack(fill="both", expand=True)
        tk.Label(
            body, text="Start a new session", bg=BG, fg=TEXT, font=("Sans", 14, "bold")
        ).pack(anchor="w")
        tk.Label(
            body,
            text="Pick which client to start with — you'll name the session next.",
            bg=BG,
            fg=MUTED,
            justify="left",
            wraplength=460,
        ).pack(anchor="w", pady=(4, 14))

        def _choose(agent_key):
            dialog.destroy()
            label = self._agent_spec(agent_key).get("label", agent_key)
            title = simpledialog.askstring(
                "New session",
                f"Name this {label} session "
                "(leave blank to title it from your first prompt):",
                parent=self.win,
            )
            self._create_named_session(agent_key, title or "")

        for spec in self.agent_specs:
            agent_key = spec["key"]
            if spec.get("custom"):
                installed = True  # user-added clients (Ollama/CLI) are always available
            elif agent_key == "ollama":
                installed = self._list_ollama_models() is not None
            else:
                installed = bool(self._agent_executable(agent_key)) and shutil.which(
                    self._agent_executable(agent_key)
                )
            row = tk.Frame(body, bg=PANEL, highlightbackground="#2d3b49", highlightthickness=1)
            row.pack(fill="x", pady=4)
            info = tk.Frame(row, bg=PANEL)
            info.pack(side="left", fill="x", expand=True, padx=12, pady=10)
            tk.Label(
                info, text=spec["label"], bg=PANEL, fg=TEXT, font=("Sans", 10, "bold")
            ).pack(anchor="w")
            tk.Label(
                info,
                text="Ready" if installed else "Not installed",
                bg=PANEL,
                fg="#86efac" if installed else "#facc15",
            ).pack(anchor="w")
            tk.Button(
                row,
                text="Start",
                command=lambda key=agent_key: _choose(key),
                bg=spec.get("color", ACCENT) if installed else "#334155",
                fg="white",
                activebackground=SIDEBAR_SEL,
                activeforeground="white",
                relief="flat",
                padx=12,
                pady=5,
                cursor="hand2",
                state="normal" if installed else "disabled",
            ).pack(side="right", padx=10)

    def _create_named_session(self, agent_key, title):
        """Open a named new session for agent_key in its own tab (never swaps the
        current tab or interrupts a running turn)."""
        if agent_key not in self.agent_map:
            agent_key = self.active_agent.get()
        self._save_active_workspace()
        self._schedule_workspace_config_save(immediate=True)
        prev_agent = self.active_agent.get()
        settings = self.agent_settings.get(agent_key, self._default_settings_for(agent_key))
        self.active_agent.set(agent_key)
        self.selected_model.set(settings["model"])
        self.selected_effort.set(settings["effort"])
        workspace_id = self._create_workspace()
        self.active_agent.set(prev_agent)
        self.active_workspace_id = workspace_id
        self._restore_workspace(self.workspaces[workspace_id])
        session = self.store.new_session(agent_key, self.cwd.get(), title=clean_text(title))
        self.current_session = session
        self.local_sessions = self.store.list_all_local(agent_key)
        self.external_sessions = self._discover_sessions_for_picker(
            self.cwd.get(), agent_key
        )
        self.sessions = self._combined_sessions()
        self.transfer_source_session_id = None
        self._render_session_list()
        self.open_session(session["id"], remember=False)
        self._save_active_workspace()
        self._render_workspace_tabs()
        self.input.focus_set()

    def _sessions_for_handoff_title(self, agent_key, project_root):
        local = self.store.list_all_local(agent_key)
        try:
            external = discover_external_sessions(project_root, agent_key)
        except Exception:
            external = []
        return self._merge_session_lists(local, external)

    def _session_matches_project_root(self, session, project_root):
        if not project_root:
            return True
        root = infer_project_root(session, session.get("cwd") or project_root)
        return bool(root and _project_roots_related(project_root, root))

    def _title_sequence_value(self, title, base):
        title = clean_text(title)
        base = clean_text(base)
        if not title or not base:
            return None
        if title.casefold() == base.casefold():
            return 1
        match = re.match(
            rf"^{re.escape(base)}\s+(\d+)$",
            title,
            flags=re.IGNORECASE,
        )
        if not match:
            return None
        return max(1, int(match.group(1)))

    def _source_handoff_base_title(self, source, project_root):
        current = self._display_session_title(source)
        base = clean_text(source.get("handoff_base_title"))
        if base:
            return base
        base = current or "Session"
        match = re.match(r"^(.*?)\s+(\d+)$", current)
        if not match or int(match.group(2)) < 2:
            return base
        candidate_base = clean_text(match.group(1))
        source_agent = clean_text(source.get("agent") or self.active_agent.get())
        if clean_text(source.get("handoff_sequence")):
            return candidate_base
        for session in self._sessions_for_handoff_title(source_agent, project_root):
            if session.get("id") == source.get("id"):
                continue
            if not self._session_matches_project_root(session, project_root):
                continue
            if self._title_sequence_value(self._display_session_title(session), candidate_base):
                return candidate_base
        return base

    def _next_handoff_title(self, source, target_agent=None):
        target_agent = clean_text(target_agent or source.get("agent") or self.active_agent.get())
        project_root = infer_project_root(
            source,
            source.get("cwd") or self.cwd.get(),
        )
        base = self._source_handoff_base_title(source, project_root)
        highest = 0
        for session in self._sessions_for_handoff_title(target_agent, project_root):
            if not self._session_matches_project_root(session, project_root):
                continue
            title = self._display_session_title(session)
            value = self._title_sequence_value(title, base)
            if value:
                highest = max(highest, value)
        sequence = highest + 1
        title = base if sequence == 1 else f"{base} {sequence}"
        return title, base, sequence

    def _handoff_target_candidates(self, source, target_agent):
        target_agent = clean_text(target_agent or (source or {}).get("agent") or self.active_agent.get())
        project_root = infer_project_root(source, (source or {}).get("cwd") or self.cwd.get())
        source_id = clean_text((source or {}).get("id"))
        candidates = []
        seen = set()

        def add(session):
            if not session:
                return
            session_id = clean_text(session.get("id"))
            if not session_id or session_id == source_id or session_id in seen:
                return
            if clean_text(session.get("agent") or target_agent) != target_agent:
                return
            if not self._session_matches_project_root(session, project_root):
                return
            seen.add(session_id)
            candidates.append(deepcopy(session))

        for workspace in self.workspaces.values():
            add(workspace.get("current_session") or {})
        for session in self._sessions_for_handoff_title(target_agent, project_root):
            add(session)
        candidates.sort(
            key=lambda session: clean_text(session.get("updated_at") or session.get("created_at")),
            reverse=True,
        )
        return candidates

    def _handoff_target_label(self, session):
        title = self._display_session_title(session)
        project = project_label(infer_project_root(session, session.get("cwd") or self.cwd.get()))
        updated = clean_text(session.get("updated_at") or session.get("created_at"))
        origin = clean_text(session.get("origin")) or "local"
        suffix = clean_text(session.get("id"))[:8]
        parts = [shorten(title, 52)]
        if project:
            parts.append(project)
        if updated:
            parts.append(updated[:16].replace("T", " "))
        if origin != "local":
            parts.append(origin.replace("-terminal", ""))
        parts.append(suffix)
        return " · ".join(part for part in parts if part)

    def _find_handoff_target_session(self, session_id, target_agent, project_root):
        session_id = clean_text(session_id)
        if not session_id:
            return None
        for workspace in self.workspaces.values():
            session = workspace.get("current_session") or {}
            if clean_text(session.get("id")) == session_id:
                return deepcopy(session)
        session = self.store.get(session_id)
        if session:
            return deepcopy(session)
        for session in self._sessions_for_handoff_title(target_agent, project_root):
            if clean_text(session.get("id")) == session_id:
                return deepcopy(session)
        return None

    def _workspace_for_session_id(self, session_id):
        session_id = clean_text(session_id)
        if not session_id:
            return None, None
        for workspace_id in self.workspace_order:
            workspace = self.workspaces.get(workspace_id) or {}
            session = workspace.get("current_session") or {}
            if clean_text(session.get("id")) == session_id:
                return workspace_id, workspace
        return None, None

    def _handoff_context_text(self, artifact, state_path="", registry_path="", existing=False):
        if artifact:
            intro = (
                "Read the authoritative continuation handoff before acting:\n"
                f"{artifact}"
            )
        else:
            intro = "Continue from the attached handoff context."
        pieces = [intro]
        if state_path:
            pieces.append(f"Also read the shared project state before acting:\n{state_path}")
        if registry_path:
            pieces.append(f"Also read the project registry before acting:\n{registry_path}")
        if existing:
            pieces.append(
                "This handoff is being injected into an existing session. Reconcile it "
                "with the current conversation, then continue the latest unresolved objective."
            )
        return "\n\n".join(piece for piece in pieces if clean_text(piece))

    def _handoff_packet_signature(self, session):
        turns = session.get("turns") or []
        context = session.get("context") or {}
        last_turn = turns[-1] if turns else {}
        return "|".join(
            [
                str(len(turns)),
                clean_text(session.get("updated_at")),
                clean_text(last_turn.get("id")),
                clean_text(last_turn.get("status")),
                str(context.get("used") or 0),
                str(context.get("limit") or 0),
                str(context.get("compact_count") or 0),
            ]
        )

    def _refresh_handoff_stage(self, session=None, force=False):
        session = session or self.current_session
        if not session:
            return
        if self._block_project_scope_conflict(
            session,
            action="staging handoff",
            modal=False,
        ):
            return
        context = session.get("context") or {}
        used = int(context.get("used") or 0)
        limit = int(context.get("limit") or 0)
        percent = round(used * 100 / limit) if used > 0 and limit > 0 else 0
        compact_count = int(context.get("compact_count") or 0)
        usage_active = bool(self._usage_handoff_status(session).get("active"))
        active = percent >= CONTEXT_WARNING_PERCENT or compact_count > 0 or usage_active
        if not active and not force:
            return
        signature = self._handoff_packet_signature(session)
        self.request_project_state_update(
            session,
            reason="stage",
            refine=False,
            force=force,
        )
        packet = structured_handoff_packet(session)
        if (
            not force
            and session.get("handoff_stage_ready")
            and session.get("handoff_stage_signature") == signature
            and os.path.isfile(clean_text(session.get("handoff_stage_artifact")))
        ):
            return
        artifact = self._write_handoff_artifact(session, packet)
        if not artifact:
            return
        session["handoff_stage_ready"] = True
        session["handoff_stage_signature"] = signature
        session["handoff_stage_artifact"] = artifact
        session.pop("handoff_stage_packet", None)
        session["handoff_stage_updated_at"] = now_iso()
        if session.get("origin", "local") == "local":
            self.store.save(session)

    def _default_handoff_target(self, source_agent, auto=False):
        prefs = self.handoff_preferences
        mode = clean_text(prefs.get("mode") or "current")
        sequence = [
            clean_text(agent)
            for agent in prefs.get("sequence") or []
            if clean_text(agent) in self.agent_map
        ]
        if mode == "fixed":
            target_agent = clean_text(prefs.get("fixed_agent")) or source_agent
            if target_agent not in self.agent_map:
                target_agent = source_agent
        elif mode == "sequence" and sequence:
            if source_agent in sequence:
                index = sequence.index(source_agent)
                target_agent = sequence[(index + 1) % len(sequence)]
            else:
                target_agent = sequence[0]
        else:
            target_agent = source_agent
        settings = self.agent_settings.get(
            target_agent,
            self._default_settings_for(target_agent),
        )
        model_options = self._model_options_for(target_agent)
        effort_options = self._effort_options_for(target_agent)
        prefer_cheap = bool(prefs.get("prefer_cheap_models", True))
        preferred_model = self._preferred_worker_model(target_agent)
        if prefer_cheap or auto:
            model = preferred_model if preferred_model in model_options else model_options[0]
        else:
            model = settings.get("model") if settings.get("model") in model_options else model_options[0]
        if auto and prefer_cheap:
            effort = PREFERRED_WORKER_EFFORT.get(target_agent) or (
                settings.get("effort") if settings.get("effort") in effort_options else effort_options[0]
            )
            if effort not in effort_options:
                effort = effort_options[0]
        else:
            effort = settings.get("effort") if settings.get("effort") in effort_options else effort_options[0]
        return target_agent, model, effort

    def _handoff_target_model_options(self, agent_key):
        options = list(self._model_options_for(agent_key))
        if not options:
            options = ["Default"]
        return options

    def _handoff_target_effort_options(self, agent_key):
        options = list(self._effort_options_for(agent_key))
        if not options:
            options = ["Default"]
        return options

    def _deploy_handoff(self, source, target_agent, model, effort, title_override=None):
        if self._block_project_scope_conflict(
            source,
            action="deploying handoff",
            modal=True,
        ):
            return None
        packet = self._staged_handoff_packet(source) or structured_handoff_packet(source)
        state_path = self.request_project_state_update(
            source,
            reason="handoff",
            refine=True,
            force=True,
        )
        title, base_title, sequence = self._next_handoff_title(source, target_agent)
        # Honor a user-edited title from the dialog (pencil field), keeping the computed
        # base/sequence for project numbering continuity.
        if clean_text(title_override):
            title = clean_text(title_override)
        blocked, validation = self._block_invalid_handoff_plan(
            source,
            target_agent,
            title,
            state_path,
        )
        if blocked:
            return None
        registry_path = validation.get("registry_path")
        backend = {"model": model}
        if target_agent != "gemini" and effort and effort != "Default":
            backend["effort"] = effort
        session = self.store.new_handoff_session(
            source,
            title,
            "",
            agent_key=target_agent,
            backend=backend,
        )
        handoff_artifact = self._write_handoff_artifact(session, packet)
        session["handoff_artifact"] = handoff_artifact
        session["handoff_context"] = self._handoff_context_text(
            handoff_artifact,
            state_path=state_path,
            registry_path=registry_path,
        ) if handoff_artifact else packet
        session["handoff_base_title"] = base_title
        session["handoff_sequence"] = sequence
        session["handoff_stage_ready"] = True
        session["handoff_stage_signature"] = self._handoff_packet_signature(source)
        session["handoff_stage_artifact"] = handoff_artifact
        session["handoff_stage_updated_at"] = now_iso()
        ensure_project_registry(
            validation.get("project_root") or session.get("cwd"),
            session=session,
            agent_key=target_agent,
            title=title,
            state_path=state_path,
            sequence=sequence,
        )
        self.store.save(session)
        # Open continuation in a NEW tab inserted right after the source tab,
        # leaving the source workspace open and untouched.
        source_workspace_id = self.active_workspace_id
        source_index = (
            self.workspace_order.index(source_workspace_id)
            if source_workspace_id in self.workspace_order
            else len(self.workspace_order) - 1
        )
        self._save_active_workspace()
        new_workspace_id = self._create_workspace(title)
        # _create_workspace appends; splice it to source_index + 1 instead.
        self.workspace_order.remove(new_workspace_id)
        self.workspace_order.insert(source_index + 1, new_workspace_id)
        self.active_workspace_id = new_workspace_id
        workspace = self.workspaces[new_workspace_id]
        cwd = session.get("cwd") or source.get("cwd") or os.path.expanduser("~")
        local_sessions = self.store.list_all_local(target_agent)
        external_sessions = self._discover_sessions_for_picker(cwd, target_agent)
        workspace.update(
            {
                "title": title,
                "agent": target_agent,
                "cwd": cwd,
                "model": model,
                "effort": effort,
                "current_session": session,
                "transfer_source_session_id": None,
                "local_sessions": local_sessions,
                "external_sessions": external_sessions,
            }
        )
        workspace["sessions"] = self._merge_session_lists(
            workspace["local_sessions"], workspace["external_sessions"]
        )
        self._restore_workspace(workspace)
        self.transfer_source_session_id = None
        self.open_session(session["id"], remember=False)
        self.input.delete("1.0", "end")
        self.input.insert(
            "1.0",
            "Continue from the automatic handoff. Confirm the inherited state briefly, then continue the latest unresolved objective without asking me to repeat it.",
        )
        self.status.set(
            f"Starting fresh {self._agent_spec(target_agent)['label']} session '{title}'…"
        )
        self._render_workspace_tabs()
        self.win.after(0, self.send)
        return session

    def _deploy_handoff_to_existing(self, source, target_session_id, target_agent, model, effort):
        if self._block_project_scope_conflict(
            source,
            action="deploying handoff",
            modal=True,
        ):
            return None
        target_agent = clean_text(target_agent or (source or {}).get("agent") or self.active_agent.get())
        project_root = infer_project_root(source, (source or {}).get("cwd") or self.cwd.get())
        target = self._find_handoff_target_session(target_session_id, target_agent, project_root)
        if not target:
            messagebox.showwarning(
                "Handoff target missing",
                "Choose an existing target session before deploying the handoff.",
                parent=self.win,
            )
            return None
        if clean_text(target.get("id")) == clean_text((source or {}).get("id")):
            messagebox.showwarning(
                "Handoff target invalid",
                "Choose a different session as the handoff target.",
                parent=self.win,
            )
            return None
        if clean_text(target.get("agent")) != target_agent:
            messagebox.showwarning(
                "Handoff target invalid",
                "The selected target session does not belong to the selected agent.",
                parent=self.win,
            )
            return None
        if not self._session_matches_project_root(target, project_root):
            messagebox.showwarning(
                "Handoff target invalid",
                "The selected target session is not registered to this project.",
                parent=self.win,
            )
            return None
        workspace_id, workspace = self._workspace_for_session_id(target.get("id"))
        if workspace and workspace.get("busy"):
            messagebox.showwarning(
                "Handoff target busy",
                "That target session is currently working. Wait for it to finish before handing off into it.",
                parent=self.win,
            )
            return None
        packet = self._staged_handoff_packet(source) or structured_handoff_packet(source)
        state_path = self.request_project_state_update(
            source,
            reason="handoff",
            refine=True,
            force=True,
        )
        registry_path = ensure_project_registry(
            project_root or target.get("cwd"),
            session=target,
            agent_key=target_agent,
            title=self._display_session_title(target),
            state_path=state_path or (project_state_path(project_root) if project_root else ""),
        ) if (project_root or target.get("cwd")) else ""
        if target.get("origin", "local") != "local":
            target = self.store.adopt_external(target)
            target_session_id = target.get("id")
        backend = target.setdefault("backend", {})
        if model and model != "Default":
            backend["model"] = model
        if target_agent == "gemini" or not effort or effort == "Default":
            backend.pop("effort", None)
        else:
            backend["effort"] = effort
        if project_root:
            target["project_root"] = project_root
        handoff_artifact = self._write_handoff_artifact(target, packet)
        target["handoff_artifact"] = handoff_artifact
        target["pending_handoff_context"] = self._handoff_context_text(
            handoff_artifact,
            state_path=state_path,
            registry_path=registry_path,
            existing=True,
        ) if handoff_artifact else packet
        target["handoff_from"] = clean_text((source or {}).get("id"))
        target["handoff_received_at"] = now_iso()
        target["handoff_stage_ready"] = True
        target["handoff_stage_signature"] = self._handoff_packet_signature(source)
        target["handoff_stage_artifact"] = handoff_artifact
        target["handoff_stage_updated_at"] = now_iso()
        self.store.save(target)
        if workspace_id and workspace:
            workspace["current_session"] = deepcopy(target)
            workspace["model"] = model
            workspace["effort"] = effort
            self.switch_workspace(workspace_id)
        else:
            self.open_session_in_new_tab(target.get("id"))
        self.input.delete("1.0", "end")
        self.input.insert(
            "1.0",
            "Continue from the handoff that was just attached to this existing session. Confirm the inherited state briefly, then continue the latest unresolved objective without asking me to repeat it.",
        )
        self.status.set(
            f"Handing off to existing {self._agent_spec(target_agent)['label']} session '{self._display_session_title(target)}'…"
        )
        self._render_workspace_tabs()
        self.win.after(0, self.send)
        return target

    def spawn_worker_job(
        self,
        source,
        prompt,
        target_agent=None,
        model=None,
        effort=None,
        auto=False,
        title=None,
        packet=None,
        reason="worker",
    ):
        source = source or self.current_session
        if not source:
            return None
        if self._block_project_scope_conflict(
            source,
            action="spawning worker handoff",
            modal=True,
        ):
            return None
        target_agent = clean_text(target_agent or source.get("agent") or self.active_agent.get())
        if target_agent not in self.agent_map:
            target_agent = source.get("agent") or self.active_agent.get()
        if not model:
            target_agent, model, effort = self._default_handoff_target(target_agent, auto=auto)
        elif effort is None:
            _, _, effort = self._default_handoff_target(target_agent, auto=auto)
        request_signature = hashlib.sha256(
            "\0".join(
                (
                    clean_text(source.get("id")),
                    clean_text(prompt),
                    target_agent,
                    clean_text(model),
                    clean_text(effort),
                )
            ).encode("utf-8")
        ).hexdigest()
        for job in self._active_worker_jobs():
            if clean_text(job.get("request_signature")) != request_signature:
                continue
            existing = self.store.get(clean_text(job.get("session_id")))
            if existing:
                self.status.set(
                    f"That prompt is already running in '{job.get('title')}'."
                )
                return existing
        packet = clean_text(packet) or structured_handoff_packet(source)
        state_path = self.request_project_state_update(
            source,
            reason="worker",
            refine=True,
            force=True,
        )
        title, base_title, sequence = self._next_handoff_title(source, target_agent) if not title else (clean_text(title), clean_text(title), 1)
        job_id = str(uuid.uuid4())
        backend = {"model": model}
        if target_agent != "gemini" and effort and effort != "Default":
            backend["effort"] = effort
        workspace_id = self._create_workspace(title)
        workspace = self.workspaces[workspace_id]
        session = self.store.new_handoff_session(
            source,
            title,
            "",
            agent_key=target_agent,
            backend=backend,
        )
        handoff_artifact = self._write_handoff_artifact(session, packet)
        session["handoff_artifact"] = handoff_artifact
        session["handoff_context"] = (
            (
                "Read the authoritative continuation handoff before acting:\n"
                f"{handoff_artifact}"
                + (f"\n\nAlso read the shared project state before acting:\n{state_path}" if state_path else "")
            )
            if handoff_artifact
            else packet
        )
        session["worker_job_id"] = job_id
        session["worker_parent_session_id"] = source.get("id")
        session["worker_kind"] = reason
        session["worker_auto"] = bool(auto)
        session["handoff_base_title"] = base_title
        session["handoff_sequence"] = sequence
        self.store.save(session)
        self.local_sessions.insert(0, session)
        self.sessions = self._combined_sessions()
        turn = self.store.ensure_turn(session, prompt=prompt)
        self.store.add_item(
            session,
            turn,
            {"type": "userMessage", "content": [{"type": "text", "text": prompt}]},
        )
        workspace.update(
            {
                "title": title,
                "agent": target_agent,
                "cwd": source.get("cwd") or os.path.expanduser("~"),
                "model": model,
                "effort": effort,
                "status": "Starting worker…",
                "activity_state": "starting",
                "activity_text": "Starting",
                "busy": True,
                "running_model": model,
                "running_effort": effort,
                "turn_started_at": time.monotonic(),
                "last_event_at": time.monotonic(),
                "last_progress_at": time.monotonic(),
                "live_token_count": 0,
                "stale_notice_shown": False,
                "stalled_notice_shown": False,
                "backend_failure_reported": False,
                "current_session": session,
                "current_turn": turn,
                "session_backend_id": session.get("backend", {}).get("thread_id") or session.get("backend", {}).get("session_id"),
                "live_speaker": None,
                "live_model": "",
                "pending_user_input": None,
                "transfer_source_session_id": None,
                "live_source_signature": None,
                "latest_agent_text": "",
                "pending_attachments": [],
                "queued_prompts": [],
                "session_context_active": False,
                "session_context_buffer": "",
            }
        )
        self._render_workspace_tabs()
        self._render_session_list()
        self._record_worker_job(
            {
                "id": job_id,
                "source_session_id": source.get("id"),
                "source_title": self._display_session_title(source),
                "session_id": session.get("id"),
                "workspace_id": workspace_id,
                "title": title,
                "prompt": clean_text(prompt),
                "agent": target_agent,
                "model": model,
                "effort": effort or "Default",
                "status": "running",
                "created_at": now_iso(),
                "updated_at": now_iso(),
                "auto": bool(auto),
                "reason": clean_text(reason),
                "request_signature": request_signature,
            }
        )
        backend_impl = workspace["backends"].get(target_agent)
        if backend_impl:
            worker_context = "\n\n".join(
                part
                for part in (
                    session.get("handoff_context", ""),
                    project_state_context_for_session(source or session, session.get("cwd")),
                )
                if clean_text(part)
            )
            backend_impl.start_turn(
                session,
                turn,
                prompt,
                context_text=worker_context,
            )
        return session

    def _maybe_auto_deploy_handoff(self, source):
        if not source or not self.handoff_preferences.get("auto_deploy"):
            return False
        if self.busy or self.pending_user_input or self.queued_prompts:
            return False
        if not source.get("handoff_stage_ready"):
            return False
        signature = self._handoff_packet_signature(source)
        if clean_text(source.get("auto_handoff_signature")) == signature:
            return False
        target_agent, model, effort = self._default_handoff_target(
            source.get("agent") or self.active_agent.get(),
            auto=True,
        )
        source["auto_handoff_signature"] = signature
        if source.get("origin", "local") == "local":
            self.store.save(source)
        self.status.set(
            f"Auto-deploying {self._agent_spec(target_agent)['label']} worker "
            f"({model})…"
        )
        self.append_work(
            f"Auto-deploying handoff to {self._agent_spec(target_agent)['label']} "
            f"({model})",
            "system",
        )
        self._deploy_handoff(source, target_agent, model, effort)
        return True

    def copy_handoff_packet(self, source=None):
        source = source or self.current_session
        if not source:
            return
        if self._block_project_scope_conflict(
            source,
            action="copying handoff",
            modal=True,
        ):
            return
        self._refresh_handoff_stage(source, force=True)
        self.request_project_state_update(
            source,
            reason="copy",
            refine=True,
            force=True,
        )
        packet = self._staged_handoff_packet(source) or structured_handoff_packet(source)
        self.copy_text(packet)

    def _sync_session_from_transcript(self, session):
        """Synchronously pull the latest turns + context from a session's linked
        client transcript so a point-in-time snapshot (Hand Off) reflects the
        conversation to the LAST word — not just the last 2-second poll. Without this,
        anything typed in the terminal in the ~2s before Hand Off can be missing from
        the packet. Safe no-op when there is no linked transcript on disk."""
        if not session:
            return
        path = linked_client_session_path(session)
        if not path or not os.path.exists(path):
            return
        agent = session.get("agent")
        try:
            if agent == "claude":
                turns = claude_jsonl_turns(path)
                context = (claude_session_metadata(path) or {}).get("context") or {}
            elif agent == "gemini":
                turns = gemini_jsonl_turns(path)
                context = {}
            else:
                turns = codex_rollout_turns(path)
                context = codex_context_from_rollout(path)
        except Exception:
            return
        if turns:
            session["turns"] = turns
        if context:
            session["context"] = context
            if session is self.current_session:
                self.update_context_indicator(context)

    def handoff_session(self):
        if self.busy:
            messagebox.showinfo(
                "Hand off session",
                "Wait for the current turn to finish before handing off.",
                parent=self.win,
            )
            return
        if not self.current_session:
            messagebox.showinfo(
                "Hand off session",
                "Open a session before creating a handoff.",
                parent=self.win,
            )
            return
        if self._block_project_scope_conflict(
            self.current_session,
            action="opening handoff",
            modal=True,
        ):
            return
        # Force a fresh read of the transcript so turns typed in the terminal in the
        # last poll window are captured in the packet — Hand Off must be lossless.
        self._sync_session_from_transcript(self.current_session)
        self._refresh_handoff_stage(self.current_session, force=True)
        self.open_handoff_dialog()

