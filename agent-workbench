    def _update_chat_update_indicator(self):
        if not hasattr(self, "chat_bottom_btn"):
            return
        if self.chat_updates_pending:
            self.chat_bottom_btn.configure(
                text="↓ New",
                bg="#1d4f7a",
                fg="white",
            )
        else:
            self.chat_bottom_btn.configure(
                text="↓",
                bg=PANEL_ALT,
                fg=TEXT,
            )

    def _sync_chat_update_indicator(self):
        if self._chat_is_at_bottom() and self.chat_updates_pending:
            self.chat_updates_pending = False
            self._update_chat_update_indicator()
            self._save_active_workspace()

    def _finish_chat_append(self, was_at_bottom):
        # Re-check current position after insert to guard against
        # the user scrolling away between the pre-insert check and here.
        if was_at_bottom and not self.chat_updates_pending:
            try:
                now_at_bottom = self.chat.yview()[1] >= 0.995
            except tk.TclError:
                now_at_bottom = True
            if now_at_bottom:
                self.chat.see("end")
                return
        self.chat_updates_pending = True
        self._update_chat_update_indicator()

    def _flush_deferred_chat_updates(self):
        if not self.deferred_chat_updates:
            return
        updates = self.deferred_chat_updates
        self.deferred_chat_updates = []
        self.flushing_deferred_chat = True
        try:
            for update in updates:
                kind = update.get("kind")
                if kind == "chat":
                    self.append_chat(
                        update.get("speaker"),
                        update.get("text"),
                        update.get("tag", "assistant"),
                    )
                elif kind == "report":
                    self.append_report(
                        update.get("title"),
                        update.get("text"),
                    )
                elif kind == "stream":
                    self._append_stream_visual(
                        update.get("text", ""),
                        update.get("speaker", "AGENT"),
                        update.get("start", False),
                    )
                elif kind == "separator":
                    self.chat.configure(state="normal")
                    self.chat.insert("end", "\n\n")
                    self.chat.configure(state="disabled")
        finally:
            self.flushing_deferred_chat = False

    def update_chat_margins(self, event=None):
        width = event.width if event is not None else self.chat.winfo_width()
        user_left = max(120, int(width * 0.38))
