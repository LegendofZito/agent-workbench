            body,
            text="Deploy handoff",
            bg=BG,
            fg=TEXT,
            font=("Sans", 14, "bold"),
        ).pack(anchor="w")
        tk.Label(
            body,
            text=shorten(self._display_session_title(source), 84),
            bg=BG,
            fg=MUTED,
            justify="left",
            wraplength=520,
        ).pack(anchor="w", pady=(4, 10))

        agent_var = tk.StringVar(master=dialog, value=default_agent)
        model_var = tk.StringVar(master=dialog, value=default_model)
