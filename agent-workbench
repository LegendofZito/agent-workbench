    def _project_scope_conflict_text(self, conflict, action):
        expected = clean_text(conflict.get("expected_root"))
        conflict_root = clean_text(conflict.get("conflict_root"))
        title = clean_text(conflict.get("title")) or "this session"
        return (
            f"Project scope mismatch blocked {action}.\n\n"
            f"Session title: {title}\n"
            f"Expected project: {expected}\n"
            f"Detected off-project work: {conflict_root}\n\n"
            "This usually means the session contains content from another project. "
            "Open the clean project session, rename/scope the current session, or add the "
            "related project root to this project's .agent-workbench/project.json before handing it off."
        )

    def _block_project_scope_conflict(self, session=None, action="this action", modal=False):
        conflict = project_scope_conflict(session or self.current_session, self.cwd.get())
        if not conflict:
            return False
        message = self._project_scope_conflict_text(conflict, action)
        self.status.set(message.split("\n", 1)[0])
        self._log_event(
            "project_scope_conflict_blocked",
            action=action,
            expected=conflict.get("expected_root"),
            conflict=conflict.get("conflict_root"),
            session=(session or self.current_session or {}).get("id"),
        )
        if modal:
            messagebox.showwarning("Project scope mismatch", message, parent=self.win)
        return True

    def _validate_handoff_plan(self, source, target_agent, title, state_path):
        errors = []
        warnings = []
        root = infer_project_root(source, (source or {}).get("cwd") or self.cwd.get())
        if not root or not os.path.isdir(root):
            errors.append("Could not resolve an existing project root.")
        if target_agent not in self.agent_map:
            errors.append(f"Unknown target agent: {target_agent or '(blank)'}")
        if not clean_text(title):
            errors.append("Continuation title is blank.")
        if not state_path or not os.path.isfile(state_path):
            warnings.append("Shared project state file is missing or could not be refreshed.")
        exact = []
        if root and target_agent in self.agent_map:
            for session in self._sessions_for_handoff_title(target_agent, root):
                if not self._session_matches_project_root(session, root):
                    continue
                if self._display_session_title(session).casefold() == title.casefold():
                    exact.append(session)
        if exact:
            errors.append(
                f"Target {self._agent_spec(target_agent)['label']} already has a project session named '{title}'."
            )
        registry_path = ""
        if not errors:
            registry_path = ensure_project_registry(
                root,
                session=source,
                agent_key=target_agent,
                title=title,
                state_path=state_path or project_state_path(root),
            ) if root else ""
            if not registry_path or not os.path.isfile(registry_path):
                warnings.append("Project registry could not be written.")
        return {
            "ok": not errors,
            "errors": errors,
            "warnings": warnings,
            "project_root": root,
            "registry_path": registry_path,
        }

    def _block_invalid_handoff_plan(self, source, target_agent, title, state_path):
        validation = self._validate_handoff_plan(source, target_agent, title, state_path)
        if validation["ok"]:
            if validation.get("warnings"):
                self._log_event(
                    "handoff_validation_warning",
                    title=title,
                    target_agent=target_agent,
                    warnings=validation["warnings"],
                    project_root=validation.get("project_root"),
                    registry=validation.get("registry_path"),
                )
            else:
                self._log_event(
                    "handoff_validated",
                    title=title,
                    target_agent=target_agent,
                    project_root=validation.get("project_root"),
                    registry=validation.get("registry_path"),
                )
            return False, validation
        message = "Handoff validation failed:\n\n" + "\n".join(
            f"- {error}" for error in validation["errors"]
        )
        if validation.get("warnings"):
            message += "\n\nWarnings:\n" + "\n".join(
                f"- {warning}" for warning in validation["warnings"]
            )
        self.status.set("Handoff validation failed.")
        self._log_event(
            "handoff_validation_blocked",
            title=title,
            target_agent=target_agent,
            errors=validation["errors"],
            warnings=validation["warnings"],
            project_root=validation.get("project_root"),
            registry=validation.get("registry_path"),
        )
        messagebox.showwarning("Handoff validation failed", message, parent=self.win)
        return True, validation

    def _update_project_state_indicator(self, session=None):
        if not hasattr(self, "project_state_text"):
            return
        session = session or self.current_session
        if not session:
            self.project_state_text.set("State --")
            if hasattr(self, "project_state_btn"):
                self.project_state_btn.configure(bg="#24303c", fg="#94a3b8")
            return
        root = infer_project_root(session, self.cwd.get())
        path = project_state_path(root)
        if not path:
            self.project_state_text.set("State --")
            if hasattr(self, "project_state_btn"):
                self.project_state_btn.configure(bg="#24303c", fg="#94a3b8")
            return
        if (
            getattr(self, "_project_state_update_running", False)
            or root in getattr(self, "_project_state_auto_running", set())
        ):
            label = "State updating..."
            bg, fg = "#3b2c0b", "#facc15"
        elif os.path.isfile(path):
            try:
                age = max(0, int(time.time() - os.path.getmtime(path)))
            except OSError:
                age = 0
            if age < 90:
                age_text = "now"
            elif age < 3600:
                age_text = f"{age // 60}m"
            else:
                age_text = f"{age // 3600}h"
            label = f"State {age_text}"
            bg, fg = "#16351f", "#bbf7d0"
        else:
            label = "State missing"
            bg, fg = "#4a2b0b", "#fed7aa"
        self.project_state_text.set(label)
        if hasattr(self, "project_state_btn"):
            self.project_state_btn.configure(bg=bg, fg=fg)

    def update_project_state_file(self, session=None, quiet=False, use_local_llm=False):
        session = session or self.current_session
        cwd = infer_project_root(session, self.cwd.get())
        path = project_state_path(cwd)
        if not path:
            if not quiet:
                self.status.set("Choose an existing project directory before updating project state.")
            return ""
        if not session:
            session = {
                "title": project_label(cwd),
                "agent": self.active_agent.get(),
                "cwd": cwd,
                "turns": [],
                "context": {},
            }
        session["project_root"] = cwd
        ensure_project_registry(
            cwd,
            session=session,
            agent_key=session.get("agent"),
            title=session.get("title"),
            state_path=path,
        )
        packet = self._staged_handoff_packet(session) or structured_handoff_packet(session)
        _, existing = read_project_state(cwd, max_chars=60000)
        content = local_project_state_summary(existing, packet, cwd) if use_local_llm else ""
        if not content or "# Agent State" not in content[:200]:
            content = fallback_project_state(existing, packet, cwd)
        content = content.rstrip() + "\n"
        temporary = f"{path}.tmp-{os.getpid()}-{threading.get_ident()}"
        try:
            with open(temporary, "w", encoding="utf-8") as handle:
                handle.write(content)
                handle.flush()
                os.fsync(handle.fileno())
            os.replace(temporary, path)
        except OSError:
            try:
                os.unlink(temporary)
            except OSError:
                pass
            return ""
        if not quiet:
            self.status.set(f"Updated shared project state: {path}")
        if threading.current_thread() is threading.main_thread():
            self._update_project_state_indicator(session)
        return path

    def update_project_state(self, session=None):
        if getattr(self, "_project_state_update_running", False):
            self.status.set("Project state update is already running.")
            return
        session = deepcopy(session or self.current_session) if (session or self.current_session) else None
        cwd = infer_project_root(session, self.cwd.get())
        path = project_state_path(cwd)
        if not path:
            self.status.set("Choose an existing project directory before updating project state.")
            return
        if not session:
            session = {
                "title": project_label(cwd),
                "agent": self.active_agent.get(),
                "cwd": cwd,
                "turns": [],
                "context": {},
            }
        session["project_root"] = cwd
        if self._block_project_scope_conflict(
            session,
            action="updating project state",
            modal=True,
        ):
            return
        self._project_state_update_running = True
        self._update_project_state_indicator(session)
        self.status.set("Updating project state in the background...")

        def worker():
            error = ""
            try:
                result = self.update_project_state_file(
                    session,
                    quiet=True,
                    use_local_llm=True,
                )
            except Exception as exc:
                result = ""
                error = str(exc)

            def finish():
                self._project_state_update_running = False
                if result:
                    self.status.set(f"Updated shared project state: {result}")
                elif error:
                    self.status.set(f"Could not update project state: {error}")
                else:
                    self.status.set("Could not update project state.")
                self._update_project_state_indicator(session)

            try:
                self.win.after(0, finish)
            except tk.TclError:
                # Window destroyed mid-run: finish() never executes, so reset the
                # guard flag here or update_project_state is blocked forever.
                self._project_state_update_running = False

        threading.Thread(target=worker, daemon=True).start()

    def request_project_state_update(self, session=None, reason="auto", refine=True, force=False):
        session = session or self.current_session
        if not session:
            return ""
        if self._block_project_scope_conflict(
            session,
            action=f"project-state update ({reason})",
            modal=False,
        ):
            return ""
        root = infer_project_root(session, self.cwd.get())
        if not root:
            self._update_project_state_indicator(session)
            return ""
        # Guard: only auto-write state when the root was confirmed by a direct
        # title-slug match OR by file-edit path scoring — not by alias lookup alone.
        # Alias lookup is right for READING (state injection) but too permissive for
        # WRITING: a "Next Agent Workbench" Codex session resolves to OG AWB via alias
        # but its content is about AWB Next, so it would overwrite OG AWB's AGENT_STATE.
        # Skip auto-write for alias-only inferences; only explicit user-triggered updates
        # (update_project_state()) bypass this guard via force=True.
        if not force:
            cwd_fb = self.cwd.get()
            direct_root = _project_root_from_title(session, cwd_fb)
            has_direct = direct_root and os.path.abspath(direct_root) == os.path.abspath(root)
            if not has_direct:
                # Root resolved by alias or path-scoring only — too ambiguous for auto-write.
                # Path-score evidence is unreliable: a "Next Agent Workbench" session can have
                # OG AWB file paths in its JSONL (from injected context), making scored truthy
                # even though the session belongs to a different project. Require a direct
                # title→directory match for all background writes.
                self._update_project_state_indicator(session)
                return project_state_path(root)
        session["project_root"] = root
        key = root
        path = project_state_path(root)
        now = time.monotonic()
        if not force and now - self._project_state_last_auto.get(key, 0.0) < PROJECT_STATE_AUTO_MIN_SECONDS:
            self._update_project_state_indicator(session)
            return path
        self._project_state_last_auto[key] = now
        if session.get("origin", "local") == "local":
            self.store.save(session, durable=False)

        should_refine = bool(
            refine
            and path
            and (
                force
                or now - self._project_state_last_refine.get(key, 0.0)
                >= PROJECT_STATE_REFINE_INTERVAL_SECONDS
            )
        )

        if force:
            path = self.update_project_state_file(session, quiet=True, use_local_llm=False)
            self._update_project_state_indicator(session)
            if not should_refine or key in self._project_state_auto_running:
                return path
        elif key in self._project_state_auto_running:
            self._update_project_state_indicator(session)
            return path

        self._project_state_auto_running.add(key)
        if should_refine:
            self._project_state_last_refine[key] = now
        snapshot = deepcopy(session)
        self._update_project_state_indicator(session)

        def worker():
            result = ""
            try:
                result = self.update_project_state_file(
                    snapshot,
                    quiet=True,
                    use_local_llm=should_refine,
                )
            finally:
                def finish():
                    self._project_state_auto_running.discard(key)
                    if result and should_refine:
                        self.status.set(f"Refined shared project state: {result}")
                    self._update_project_state_indicator(session)

                try:
                    self.win.after(0, finish)
                except tk.TclError:
                    pass

        threading.Thread(target=worker, daemon=True).start()
        return path

    def open_project_state(self):
        path = project_state_path_for_session(self.current_session, self.cwd.get())
        if not path or not os.path.isfile(path):
            path = self.update_project_state_file(
                self.current_session,
                quiet=True,
                use_local_llm=False,
            )
        if not path:
            return
        try:
            subprocess.Popen(["xdg-open", path])
        except OSError as exc:
            messagebox.showerror("Open project state", str(exc), parent=self.win)

    def _staged_handoff_packet(self, session):
        artifact = clean_text((session or {}).get("handoff_stage_artifact"))
        if artifact and os.path.isfile(artifact):
            try:
                with open(artifact, encoding="utf-8") as handle:
                    return clean_text(handle.read())
            except OSError:
                pass
        return clean_text((session or {}).get("handoff_stage_packet"))

    def choose_artifacts(self, attach_to_prompt=True):
        paths = filedialog.askopenfilenames(
            title="Add artifacts",
            parent=self.win,
            initialdir=self.cwd.get(),
        )
        if paths:
            stored = self.store_artifacts(paths, reveal=not attach_to_prompt)
