        def _do_add_mcp():
            name = mcp_name_var.get().strip()
            command = mcp_cmd_var.get().strip()
            if not name or not command:
                mcp_status.configure(text="Name and command are required.", fg="#e57373")
                return
            # Check for duplicate name
            existing_names = {m.get("name") for m in self.secrets.get("mcp", [])}
            if name in existing_names:
                mcp_status.configure(text=f"MCP server '{name}' already exists.", fg="#e57373")
                return
            self.secrets["mcp"].append({"name": name, "command": command, "scope": "user"})
            self._save_secrets()
            # Register with Claude Code
            try:
                parts = shlex.split(command)
                result = subprocess.run(
                    ["claude", "mcp", "add", "-s", "user", name, "--"] + parts,
                    capture_output=True,
                    text=True,
                    timeout=10,
                )
                if result.returncode == 0:
                    mcp_status.configure(text=f"Registered '{name}' with Claude Code.", fg="#4caf50")
                else:
                    err = (result.stderr or result.stdout or "").strip()[:120]
                    mcp_status.configure(text=f"Saved but Claude returned: {err}", fg="#e57373")
            except FileNotFoundError:
                mcp_status.configure(text=f"Saved '{name}'. Register manually: claude mcp add -s user {name} -- {command}", fg=MUTED)
            except Exception as exc:
                mcp_status.configure(text=f"Saved '{name}'; register error: {exc}", fg="#e57373")
