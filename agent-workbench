            search_frame,
            textvariable=search_var,
            bg=PANEL_ALT,
            fg=TEXT,
            insertbackground=TEXT,
            relief="flat",
            font=("Sans", 10),
        )
        search_entry.pack(side="left", fill="x", expand=True, padx=(0, 8), pady=4)

        separator = tk.Frame(pop, bg=BORDER, height=1)
        separator.pack(fill="x")

        # Scrollable list area
        list_container = tk.Frame(pop, bg=PANEL)
        list_container.pack(fill="both", expand=True)

        canvas = tk.Canvas(list_container, bg=PANEL, highlightthickness=0, height=320)
        scrollbar = tk.Scrollbar(list_container, orient="vertical", command=canvas.yview)
        canvas.configure(yscrollcommand=scrollbar.set)
        scrollbar.pack(side="right", fill="y")
        canvas.pack(side="left", fill="both", expand=True)

        rows_frame = tk.Frame(canvas, bg=PANEL)
        canvas_window = canvas.create_window((0, 0), window=rows_frame, anchor="nw")

        def _update_scroll_region(event=None):
            canvas.configure(scrollregion=canvas.bbox("all"))

        rows_frame.bind("<Configure>", _update_scroll_region)

        def _resize_rows(event=None):
            canvas.itemconfigure(canvas_window, width=canvas.winfo_width())

        canvas.bind("<Configure>", _resize_rows)

        # Two staggered title-box colors only (regular / faded), alternating per row.
        ROW_REG = "#26405c"
        ROW_FADED = "#1e2c3d"

        def _on_wheel(event):
            self._hide_skill_name_overlay()
            if getattr(event, "num", None) == 4:
                canvas.yview_scroll(-1, "units")
            elif getattr(event, "num", None) == 5:
                canvas.yview_scroll(1, "units")
            else:
                canvas.yview_scroll(-1 if getattr(event, "delta", 0) > 0 else 1, "units")
            return "break"

        for _w in (canvas, rows_frame):
            _w.bind("<MouseWheel>", _on_wheel)
            _w.bind("<Button-4>", _on_wheel)
            _w.bind("<Button-5>", _on_wheel)

        row_widgets = []

        def _build_rows(filter_text=""):
            self._hide_skill_name_overlay()
            for w in rows_frame.winfo_children():
                w.destroy()
            row_widgets.clear()
            query = filter_text.lower()
            idx = 0
            for skill in all_skills:
                sname = skill["name"]
                sdesc = skill["description"]
                if query and query not in sname.lower() and query not in sdesc.lower():
                    continue
                is_fav = sname in self.skill_favorites
                display_name = sname.replace("-", " ").replace("_", " ").title()
                box_bg = ROW_REG if idx % 2 == 0 else ROW_FADED
                idx += 1
                row = tk.Frame(rows_frame, bg=PANEL)
                row.pack(fill="x")
                # Skill name: own color-coded box on the LEFT — floats free (no divider
                # under it), with vertical padding to separate it from neighbors.
                name_lbl = tk.Label(
                    row,
                    text=("✓ " if is_fav else "") + display_name,
                    bg=box_bg,
                    fg="#ffffff" if is_fav else "#cbd5e1",
                    font=("Sans", 9, "bold"),
                    anchor="w",
                    width=22,
                    padx=10,
                    pady=6,
                    justify="left",
                )
                name_lbl.pack(side="left", padx=(6, 8), pady=4)
                # Right column: description + a divider UNDER THE DESCRIPTION ONLY, so the
                # separating lines stop at the title box and never cram against it.
                right_col = tk.Frame(row, bg=PANEL)
                right_col.pack(side="left", fill="both", expand=True)
                desc_lbl = tk.Label(
                    right_col,
                    text=sdesc,
                    bg=PANEL,
                    fg=MUTED,
                    anchor="w",
                    font=("Sans", 9),
                    justify="left",
                    wraplength=300,
                )
                desc_lbl.pack(fill="x", anchor="w", pady=(8, 6))
                tk.Frame(right_col, bg=BORDER, height=1).pack(fill="x")
                for w in (row, right_col, name_lbl, desc_lbl):
                    w.configure(cursor="hand2")
                    w.bind("<Button-1>", lambda _e, n=sname: _toggle_and_refresh(n))
                    w.bind("<MouseWheel>", _on_wheel)
                    w.bind("<Button-4>", _on_wheel)
                    w.bind("<Button-5>", _on_wheel)
                # If the title is too long for its box, hover (same 143ms delay as the
                # session list) reveals the full name by extending the box over the desc.
                if len(display_name) > 19:
                    name_lbl.bind(
                        "<Enter>",
                        lambda _e, w=name_lbl, t=display_name, b=box_bg: self._schedule_skill_name_reveal(w, t, b),
                    )
                    name_lbl.bind("<Leave>", lambda _e: self._cancel_skill_name_reveal())
                row_widgets.append(row)

        def _toggle_and_refresh(name):
            self._toggle_skill_favorite(name)
            _build_rows(search_var.get())

        def _on_search(*_args):
            _build_rows(search_var.get())

        search_var.trace_add("write", _on_search)
        _build_rows()

        sep2 = tk.Frame(pop, bg=BORDER, height=1)
        sep2.pack(fill="x")
        tk.Button(
            pop,
            text="Close",
            command=lambda: _on_close(),
            bg=PANEL_ALT,
            fg=MUTED,
            activebackground=SIDEBAR_SEL,
            activeforeground=TEXT,
            relief="flat",
            padx=12,
            pady=5,
            cursor="hand2",
        ).pack(anchor="e", padx=8, pady=6)

        pop.update_idletasks()
        pw = max(pop.winfo_reqwidth(), 500)
        ph = min(pop.winfo_reqheight(), 480)
        pop.geometry(f"{pw}x{ph}+{bx}+{max(by - ph - 4, 10)}")
        pop.lift()
        search_entry.focus_set()

        def _on_close():
            self._hide_skill_name_overlay()
            if pop.winfo_exists():
                pop.destroy()
            self._skills_menu = None

        pop.protocol("WM_DELETE_WINDOW", _on_close)

    def _toggle_skill_favorite(self, name):
        """Add or remove a skill from favorites, persist, and re-render chips."""
        if name in self.skill_favorites:
            self.skill_favorites.remove(name)
        else:
            self.skill_favorites.append(name)
        self._save_skill_favorites()
        self._render_skill_chips()

    def _open_skill_prompt(self, name):
        """Open a prompt popover hard-anchored above THIS skill's chip, visually joined
        to it so it's clear which skill the box belongs to."""
        accent = "#1a56db"
        chip = getattr(self, "_skill_chip_widgets", {}).get(name)

        # Toggle: if a popover is open, close it and un-highlight its chip.
        if getattr(self, "_skill_popover", None) and self._skill_popover.winfo_exists():
            self._skill_popover.destroy()
            self._skill_popover = None
            self._unhighlight_skill_chip()
            return

        pop = tk.Toplevel(self.win)
        pop.overrideredirect(True)
        pop.configure(bg=accent, highlightbackground=accent, highlightthickness=2)
        self._skill_popover = pop

        # Colored header bearing the skill name — ties the box to its chip.
        tk.Label(
            pop,
            text=f"✦ {name}",
            bg=accent,
            fg="white",
            font=("Sans", 10, "bold"),
            padx=10,
            pady=5,
            anchor="w",
        ).pack(fill="x")
        body = tk.Frame(pop, bg=PANEL)
        body.pack(fill="both", expand=True)
        tk.Label(
            body,
            text="Tell it what to do — or leave blank to let the skill ask you / use its defaults.",
            bg=PANEL,
            fg=MUTED,
            font=("Sans", 8),
            anchor="w",
            padx=10,
        ).pack(fill="x", pady=(6, 0))

        text_widget = tk.Text(
            body,
            height=3,
            bg=PANEL_ALT,
            fg=TEXT,
            insertbackground=TEXT,
            relief="flat",
            padx=10,
            pady=8,
            font=("Sans", 10),
            wrap="word",
        )
        text_widget.pack(fill="x", padx=8, pady=(4, 0))

        btn_row = tk.Frame(body, bg=PANEL)
        btn_row.pack(fill="x", padx=8, pady=6)

        def _close():
            if pop.winfo_exists():
                pop.destroy()
            self._skill_popover = None
            self._unhighlight_skill_chip()

        def _run():
            typed = clean_text(text_widget.get("1.0", "end"))
            _close()
            self._run_skill(name, typed)

        tk.Button(
            btn_row, text="Run", command=_run, bg=accent, fg="white",
            activebackground="#1e40af", activeforeground="white", relief="flat",
            padx=14, pady=4, cursor="hand2", font=("Sans", 9, "bold"),
        ).pack(side="right")
        tk.Button(
            btn_row, text="Cancel", command=_close, bg=PANEL_ALT, fg=MUTED,
            relief="flat", padx=10, pady=4, cursor="hand2", font=("Sans", 9),
        ).pack(side="right", padx=(0, 6))

        text_widget.bind("<Return>", lambda e: (_run(), "break")[1])
        pop.bind("<Escape>", lambda e: _close())

        # Anchor flush above the chip (overlap 2px so the accent borders merge into one
        # connected unit). Highlight the chip with the same accent. Clamp on-screen.
        self.win.update_idletasks()
        pop.update_idletasks()
        pw = max(pop.winfo_reqwidth(), 360)
        ph = pop.winfo_reqheight()
        anchor_widget = chip if (chip and chip.winfo_exists()) else self.skills_bar
        try:
            ax = anchor_widget.winfo_rootx()
            ay = anchor_widget.winfo_rooty()
        except tk.TclError:
            ax, ay = 100, 200
        screen_w = self.win.winfo_screenwidth()
        x = max(6, min(ax, screen_w - pw - 6))
        y = max(10, ay - ph + 2)
        pop.geometry(f"{pw}x{ph}+{x}+{y}")
        if chip and chip.winfo_exists():
            self._active_skill_chip = chip
            # Only recolor the existing 1px border — never change its thickness, or
            # the chip resizes and the whole composer/background shifts.
            chip.configure(highlightbackground=accent)
        pop.lift()
        text_widget.focus_set()

    def _unhighlight_skill_chip(self):
        chip = getattr(self, "_active_skill_chip", None)
        if chip:
            try:
                if chip.winfo_exists():
                    chip.configure(highlightbackground=BORDER)  # recolor only; keep 1px (no shift)
            except tk.TclError:
                pass
        self._active_skill_chip = None

    def _schedule_skill_name_reveal(self, widget, full_text, box_bg):
