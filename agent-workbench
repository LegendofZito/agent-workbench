        def render():
            nonlocal displayed_jobs
            active_jobs = self._active_worker_jobs()
            history_jobs = [
                job
                for job in self.worker_jobs
                if clean_text(job.get("status")) not in {"queued", "starting", "running"}
            ]
            jobs = active_jobs + history_jobs if show_history_var.get() else active_jobs
            displayed_jobs = jobs
            worker_list.delete(0, "end")
            active = len(active_jobs)
            if active:
                status = f"{active} active manual worker{'s' if active != 1 else ''}."
            elif history_jobs:
                status = (
                    f"No active manual workers; {len(history_jobs)} historical "
                    f"record{'s' if len(history_jobs) != 1 else ''} hidden."
                )
            else:
                status = "No active manual workers."
            status_label.configure(text=status)
            for index, job in enumerate(jobs, start=1):
                title = clean_text(job.get("title")) or "Worker"
                state = clean_text(job.get("status")) or "queued"
                agent = self._agent_spec(job.get("agent") or "claude")["label"]
                model = clean_text(job.get("model"))
                label = f"{index}. {title} — {state} — {agent}"
                if model:
                    label += f" ({model})"
                worker_list.insert("end", label)
            if jobs:
                worker_list.selection_set(0)
                worker_list.activate(0)
                worker_list.see(0)
            show_selected()

        def show_selected(_event=None):
            selection = worker_list.curselection()
            jobs = displayed_jobs
            if not selection or not jobs:
                detail.configure(state="normal")
                detail.delete("1.0", "end")
                detail.insert(
                    "1.0",
