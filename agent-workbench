        content.pack(fill="both", expand=True, pady=(8, 0))
        list_frame = tk.Frame(content, bg=BG)
        list_frame.pack(side="left", fill="both", expand=True)
        worker_list = tk.Listbox(
            list_frame,
            bg=PANEL,
            fg=TEXT,
            selectbackground=SIDEBAR_SEL,
            selectforeground=TEXT,
            relief="flat",
            borderwidth=0,
            highlightthickness=1,
            highlightbackground=BORDER,
            font=("Sans", 10),
            activestyle="none",
        )
        worker_list.pack(side="left", fill="both", expand=True, padx=(0, 8))
