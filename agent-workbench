def load_json(path, default):
    try:
        with open(path, encoding="utf-8") as handle:
            data = json.load(handle)
            return data if data is not None else default
    except (OSError, ValueError):
        return default


def save_json(path, value, durable=True):
    # durable=False skips fsync — the os.replace is still atomic (no corruption),
    # we just don't force a disk sync. Used for high-frequency writes (config draft,
    # session autosave during streaming) so the UI thread never blocks on fsync.
    ensure_dir(os.path.dirname(path))
    temporary = f"{path}.tmp-{os.getpid()}-{threading.get_ident()}"
    with open(temporary, "w", encoding="utf-8") as handle:
        json.dump(value, handle, indent=2, sort_keys=True)
        handle.write("\n")
        if durable:
            handle.flush()
            os.fsync(handle.fileno())
    os.replace(temporary, path)


def shorten(text, limit=72):
    text = clean_text(text).replace("\n", " ")
    if len(text) <= limit:
        return text
    return text[: limit - 1].rstrip() + "…"


def format_duration(seconds):
    seconds = max(0, int(seconds))
    minutes, seconds = divmod(seconds, 60)
    hours, minutes = divmod(minutes, 60)
    if hours:
        return f"{hours}h {minutes:02d}m"
    if minutes:
        return f"{minutes}m {seconds:02d}s"
    return f"{seconds}s"


def format_token_count(count):
    count = int(count or 0)
    if count >= 1_000_000:
        value = count / 1_000_000
        return f"{value:.1f}M" if value < 10 else f"{round(value)}M"
    if count >= 1_000:
        value = count / 1_000
        return f"{value:.1f}K" if value < 10 else f"{round(value)}K"
    return f"{count:,}"


def format_token_usage(usage):
    if not isinstance(usage, dict):
        return ""
    input_tokens = int(
        usage.get("input_tokens")
        or usage.get("inputTokens")
        or usage.get("used_tokens")
        or usage.get("usedTokens")
        or 0
    )
    output_tokens = int(usage.get("output_tokens") or usage.get("outputTokens") or 0)
    total_tokens = int(
        usage.get("total_tokens")
        or usage.get("totalTokens")
        or usage.get("used")
        or 0
    )
    parts = []
    if input_tokens:
        parts.append(f"in {format_token_count(input_tokens)}")
    if output_tokens:
        parts.append(f"out {format_token_count(output_tokens)}")
    if not parts and total_tokens:
        parts.append(f"used {format_token_count(total_tokens)}")
    return " · ".join(parts)


def estimate_tokens(text):
    text = clean_text(text)
    if not text:
        return 0
    return max(1, round(len(text) / 4))


def project_label(cwd):
