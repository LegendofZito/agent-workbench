    def _paste_text_marked(self, text):
        """Insert pasted text and bracket it with marks so Ctrl+Z can later remove
        EXACTLY this block. Typed text is never tracked — so undo never touches it.
        Marks: start has 'right' gravity and end has 'left', so characters typed at
        either boundary fall OUTSIDE the pasted range."""
        if not text:
            return
        try:
            self.input.delete("sel.first", "sel.last")  # paste-over-selection like normal
        except tk.TclError:
            pass
        start = self.input.index("insert")
        self.input.insert("insert", text)
        end = self.input.index("insert")
        self._paste_seq = getattr(self, "_paste_seq", 0) + 1
        sm, em = f"_paste_s{self._paste_seq}", f"_paste_e{self._paste_seq}"
        self.input.mark_set(sm, start)
        self.input.mark_gravity(sm, "right")
        self.input.mark_set(em, end)
        self.input.mark_gravity(em, "left")
        if getattr(self, "_paste_stack", None) is None:
            self._paste_stack = []
        self._paste_stack.append((sm, em))
        self.input.see("insert")
        self.input.edit_modified(True)

    def _on_paste_event(self, _event=None):
        try:
            text = self.win.clipboard_get()
        except tk.TclError:
            text = ""
        if text:
            self._paste_text_marked(text)
        return "break"

    def _input_undo(self, _event=None):
        # Undo only removes the most recent PASTE (typed text is never tracked).
        stack = getattr(self, "_paste_stack", None) or []
        while stack:
            sm, em = stack.pop()
            try:
                start, end = self.input.index(sm), self.input.index(em)
            except tk.TclError:
                continue  # marks already gone
            try:
                still_there = self.input.compare(start, "<", end)
            except tk.TclError:
                still_there = False
            if still_there:
                if getattr(self, "_paste_redo", None) is None:
                    self._paste_redo = []
                self._paste_redo.append(self.input.get(start, end))
                self.input.delete(start, end)
                self.input.edit_modified(True)
            for m in (sm, em):
                try:
                    self.input.mark_unset(m)
                except tk.TclError:
                    pass
            if still_there:
                self.input.see("insert")
                break
        return "break"

    def _input_redo(self, _event=None):
        # Re-insert the last undone paste (re-tracked, so it can be undone again).
        redo = getattr(self, "_paste_redo", None) or []
        if redo:
            self._paste_text_marked(redo.pop())
        return "break"

    def _input_select_all(self, _event=None):
        # Tk's default Ctrl+A is "go to line start"; make it select-all instead.
        self.input.tag_add("sel", "1.0", "end-1c")
        self.input.mark_set("insert", "end-1c")
        self.input.see("insert")
        return "break"

    def _route_key_to_composer(self, event):
        """Read-only views (Work Log, Artifacts) must never capture typing — a
        printable key there is redirected into the composer so everything the user
        types reaches the conversation, nowhere else. Ctrl combos (copy/find) and
        navigation keys pass through so selection/scrolling still work."""
        if event.state & 0x4:  # Ctrl held → let copy / find / select-all through
            return None
        ch = event.char
        if not ch or not ch.isprintable():  # arrows, Enter, F-keys, etc. → leave alone
            return None
        self.input.focus_set()
        self.input.insert("insert", ch)
        self.input.see("insert")
        return "break"

    def paste_into_prompt(self, _event=None):
        # Image paste (Wayland) → attach as a file. Everything else → a MARKED text
        # paste, so Ctrl+Z can remove the pasted block while leaving typed text alone.
        if not shutil.which("wl-paste") or not os.environ.get("WAYLAND_DISPLAY"):
            return self._on_paste_event()
        try:
            types = subprocess.run(
                ["wl-paste", "--list-types"],
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                text=True,
                timeout=2,
                check=False,
            ).stdout.splitlines()
        except (OSError, subprocess.TimeoutExpired):
            return self._on_paste_event()
        mime_type = next(
            (
                mime
                for mime in (
                    "image/png",
                    "image/jpeg",
                    "image/webp",
                    "image/bmp",
                    "image/tiff",
                )
                if mime in types
            ),
            None,
        )
        if not mime_type:
            return self._on_paste_event()
        if not self.current_session:
            self.status.set("Start or open a session before pasting an image.")
            return "break"
        try:
            result = subprocess.run(
                ["wl-paste", "--no-newline", "--type", mime_type],
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                timeout=8,
                check=False,
            )
        except (OSError, subprocess.TimeoutExpired):
            self.status.set("Could not read the image from the clipboard.")
            return "break"
        if result.returncode != 0 or not result.stdout:
            self.status.set("Could not read the image from the clipboard.")
            return "break"
        extension = mimetypes.guess_extension(mime_type) or ".png"
        if extension == ".jpe":
            extension = ".jpg"
        filename = f"clipboard-{datetime.now().strftime('%Y%m%d-%H%M%S')}{extension}"
        destination = unique_destination(self._artifact_directory(), filename)
        try:
            with open(destination, "wb") as handle:
                handle.write(result.stdout)
        except OSError:
            self.status.set("Could not save the clipboard image.")
            return "break"
        self.refresh_artifacts_view(self.current_session)
        self.queue_attachments([destination])
        self.notebook.select(self.chat_tab)
        self.input.focus_set()
        self.status.set("Clipboard image attached to the next message.")
        return "break"

    def store_artifacts(self, paths, reveal=False):
        if not self.current_session:
            self.status.set("Start or open a session before adding files.")
            return []
        directory = self._artifact_directory()
        stored = []
        for source in paths:
            source = urllib.parse.unquote(str(source or "").strip())
            if source.startswith("file://"):
                source = urllib.parse.urlparse(source).path
            source = os.path.abspath(os.path.expanduser(source))
            if not os.path.isfile(source):
                continue
            destination = unique_destination(directory, os.path.basename(source))
            try:
                shutil.copy2(source, destination)
                stored.append(destination)
            except OSError:
                continue
        self.refresh_artifacts_view(self.current_session)
        if stored:
            if reveal:
                self.notebook.select(self.artifacts_tab)
            self.status.set(f"Stored {len(stored)} artifact{'s' if len(stored) != 1 else ''}.")
        else:
            self.status.set("No readable files were added.")
        return stored

    def queue_attachments(self, paths):
        for path in paths:
            if path and path not in self.pending_attachments and os.path.isfile(path):
                self.pending_attachments.append(path)
        self._update_attachment_bar()

    def attach_selected_artifact(self):
        item = self._selected_artifact()
        if item:
            self.queue_attachments([item["path"]])
            self.notebook.select(self.chat_tab)
            self.input.focus_set()

    def clear_attachments(self):
        self.pending_attachments = []
        self._update_attachment_bar()

    def remove_attachment(self, path):
        """Remove a single attached/pasted file (the per-chip red ✕)."""
        self.pending_attachments = [p for p in self.pending_attachments if p != path]
        self._update_attachment_bar()

    def _update_attachment_bar(self):
        if not hasattr(self, "attachment_chips"):
            return
        for child in self.attachment_chips.winfo_children():
            child.destroy()
        if not self.pending_attachments:
            self.attachment_bar.pack_forget()
            return
        for path in self.pending_attachments:
            chip = tk.Frame(
                self.attachment_chips,
                bg=PANEL_ALT,
                highlightbackground=BORDER,
                highlightthickness=1,
            )
            chip.pack(side="left", padx=(0, 6), pady=2)
            tk.Label(
                chip,
                text=shorten(os.path.basename(path), 24),
                bg=PANEL_ALT,
                fg="#bfdbfe",
                font=("Sans", 9),
                padx=8,
                pady=3,
            ).pack(side="left")
            tk.Button(
                chip,
                text="✕",
                command=lambda p=path: self.remove_attachment(p),
                bg=PANEL_ALT,
                fg="#f87171",
                activebackground="#7f1d1d",
                activeforeground="white",
                relief="flat",
                padx=5,
                pady=3,
                cursor="hand2",
                font=("Sans", 9, "bold"),
            ).pack(side="left")
        self.attachment_bar.pack(fill="x", padx=8, pady=(0, 6), before=self.input)

    def _setup_drag_and_drop(self):
        try:
            self.win.tk.call("package", "require", "tkdnd")
            artifact_command = self.win.register(self._handle_artifact_drop)
            conversation_command = self.win.register(self._handle_conversation_drop)
            for widget, command in (
                (self.artifacts_tab, artifact_command),
                (self.chat_tab, conversation_command),
                (self.chat, conversation_command),
                (self.input, conversation_command),
            ):
                self.win.tk.call(
                    "tkdnd::drop_target",
                    "register",
                    widget._w,
                    "DND_Files",
                )
                self.win.tk.call(
                    "bind",
                    widget._w,
                    "<<Drop>>",
                    f"{command} %D",
                )
            self.dnd_available = True
            self.artifact_hint.configure(
                text="Files used in this conversation are saved here automatically."
            )
        except tk.TclError:
            self.artifact_hint.configure(
                text="Files attached in Conversation are saved here automatically. Use Add files to store more."
            )

    def _drop_paths(self, data):
        try:
            return list(self.win.tk.splitlist(data))
        except tk.TclError:
            return [data]

    def _handle_artifact_drop(self, data):
        self.store_artifacts(self._drop_paths(data), reveal=True)
        return "copy"

    def _handle_conversation_drop(self, data):
        stored = self.store_artifacts(self._drop_paths(data), reveal=False)
        self.queue_attachments(stored)
        if stored:
            self.notebook.select(self.chat_tab)
            self.input.focus_set()
            self.status.set(
                f"Attached {len(stored)} file{'s' if len(stored) != 1 else ''} to the next message."
            )
        return "copy"

    def refresh_artifacts_view(self, session=None):
        session = session or self.current_session
        self.artifact_list.delete(0, "end")
        self.artifacts = self._artifact_items_for_session(session) if session else []
        for item in self.artifacts:
            prefix = "● " if item.get("stored") else "↗ "
            self.artifact_list.insert("end", prefix + item["label"])
        if self.artifacts:
            self.artifact_list.selection_set(0)
            self.preview_selected_artifact()
        else:
            self._clear_artifact_preview()

    def open_selected_artifact(self):
        item = self._selected_artifact()
        if not item:
            return
        path = item["path"]
        if not path:
            return
        try:
            subprocess.Popen(["xdg-open", path])
        except Exception as exc:
            messagebox.showerror("Open artifact", str(exc))

    def _selected_artifact(self):
        if not getattr(self, "artifacts", None):
            return None
        selection = self.artifact_list.curselection()
        if not selection or selection[0] >= len(self.artifacts):
            return None
        return self.artifacts[selection[0]]

    def _clear_artifact_preview(self):
        self.artifact_preview_image = None
        self.artifact_preview_title.configure(text="No artifacts yet")
        self.artifact_preview_meta.configure(
            text="Drop a file into Conversation or use Add files."
        )
        self.artifact_preview_image_label.configure(image="", text="")
        self.artifact_preview_text.pack_forget()

    def preview_selected_artifact(self):
        item = self._selected_artifact()
        if not item:
            self._clear_artifact_preview()
            return
        path = item["path"]
        self.artifact_preview_image = None
        self.artifact_preview_text.pack_forget()
        self.artifact_preview_image_label.configure(image="", text="")
        size = os.path.getsize(path) if os.path.isfile(path) else 0
        mime = mimetypes.guess_type(path)[0] or "file"
        self.artifact_preview_title.configure(text=os.path.basename(path))
        self.artifact_preview_meta.configure(
            text=f"{mime} · {size / 1024:.1f} KB · {path}"
        )
        if Image and ImageTk and mime.startswith("image/"):
            try:
                image = Image.open(path)
                image.thumbnail((760, 520))
                self.artifact_preview_image = ImageTk.PhotoImage(image)
                self.artifact_preview_image_label.configure(image=self.artifact_preview_image)
                return
            except (OSError, ValueError):
                pass
        if mime.startswith("text/") or os.path.splitext(path)[1].lower() in {
            ".md", ".json", ".jsonl", ".log", ".py", ".js", ".ts", ".tsx",
            ".jsx", ".css", ".html", ".yaml", ".yml", ".toml", ".ini",
        }:
            try:
                with open(path, encoding="utf-8", errors="replace") as handle:
                    text = handle.read(200_000)
                self.artifact_preview_text.configure(state="normal")
                self.artifact_preview_text.delete("1.0", "end")
                self.artifact_preview_text.insert("1.0", text)
                self.artifact_preview_text.configure(state="disabled")
                self.artifact_preview_text.pack(
                    fill="both", expand=True, padx=18, pady=14
                )
                return
            except OSError:
                pass
        self.artifact_preview_image_label.configure(
            text="Preview unavailable\n\nOpen the artifact with its default desktop application.",
            justify="center",
        )

    def copy_selected_artifact_path(self):
        item = self._selected_artifact()
        if item:
            self.copy_text(item["path"])

    def rename_selected_artifact(self):
        item = self._selected_artifact()
        if not item or not item.get("stored"):
            self.status.set("Only stored session artifacts can be renamed.")
            return
        name = simpledialog.askstring(
            "Rename artifact",
            "New file name:",
            initialvalue=os.path.basename(item["path"]),
            parent=self.win,
        )
        if not clean_text(name):
            return
        destination = unique_destination(
            os.path.dirname(item["path"]),
            safe_filename(name),
        )
        try:
            os.rename(item["path"], destination)
        except OSError as exc:
            messagebox.showerror("Rename artifact", str(exc))
            return
        self.refresh_artifacts_view(self.current_session)

    def delete_selected_artifact(self):
        item = self._selected_artifact()
        if not item or not item.get("stored"):
            self.status.set("Only stored session artifacts can be deleted here.")
            return
        if not messagebox.askyesno(
            "Delete artifact",
            f"Delete {os.path.basename(item['path'])} from this session?",
            parent=self.win,
        ):
            return
        try:
            os.unlink(item["path"])
        except OSError as exc:
            messagebox.showerror("Delete artifact", str(exc))
            return
        self.refresh_artifacts_view(self.current_session)

    def show_artifact_menu(self, event):
        index = self.artifact_list.nearest(event.y)
        if index < 0 or index >= len(getattr(self, "artifacts", [])):
            return
        self.artifact_list.selection_clear(0, "end")
        self.artifact_list.selection_set(index)
        self.preview_selected_artifact()
        menu = tk.Menu(self.win, tearoff=False, bg=PANEL_ALT, fg=TEXT)
        menu.add_command(label="Attach to prompt", command=self.attach_selected_artifact)
        menu.add_command(label="Open", command=self.open_selected_artifact)
        menu.add_command(label="Copy path", command=self.copy_selected_artifact_path)
        menu.add_command(label="Rename", command=self.rename_selected_artifact)
        menu.add_command(label="Delete", command=self.delete_selected_artifact)
        if not self.artifacts[index].get("stored"):
            menu.entryconfigure(3, state="disabled")
            menu.entryconfigure(4, state="disabled")
        menu.tk_popup(event.x_root, event.y_root)

    def append_terminal(self, text):
        if not text:
            return
        at_bottom = self.terminal.yview()[1] >= 0.995
        # Widget stays "normal" (interactive); shell output is appended at the end and
        # the insert cursor follows so typing continues at the live prompt.
        self.terminal.insert("end", text)
        self.terminal.mark_set("insert", "end")
        if at_bottom:
            self.terminal.see("end")

    def clear_terminal(self):
        self.terminal.delete("1.0", "end")

    def _terminal_send(self, seq):
        if not seq:
            return
        if not self.terminal_shell.send(seq):
            self.restart_terminal()
            self.terminal_shell.send(seq)

    def _terminal_paste(self, _event=None):
        try:
            text = self.win.clipboard_get()
        except tk.TclError:
            text = ""
        self._terminal_send(text)
        return "break"

    def _terminal_key(self, event):
        """Forward a keystroke from the main terminal area straight to the pty so it
        behaves like a real terminal. bash -i echoes input, so we never insert
        locally — every binding returns 'break' to suppress the Text widget's own
        editing."""
        ks = event.keysym
        if ks in (
            "Shift_L", "Shift_R", "Control_L", "Control_R", "Alt_L", "Alt_R",
            "Meta_L", "Meta_R", "Super_L", "Super_R", "Caps_Lock", "Num_Lock",
        ):
            return "break"
        ctrl = bool(event.state & 0x4)
        shift = bool(event.state & 0x1)
        # Terminal-standard copy/paste: Ctrl+Shift+C copies; Ctrl+(Shift+)V pastes.
        # Ctrl+C alone stays an interrupt (sent as \x03 below).
        if ctrl and shift and ks in ("C", "c"):
            try:
                self.win.clipboard_clear()
                self.win.clipboard_append(self.terminal.get("sel.first", "sel.last"))
            except tk.TclError:
                pass
            return "break"
        if ctrl and ks in ("V", "v"):
            return self._terminal_paste()
        special = {
            "Return": "\r", "KP_Enter": "\r", "BackSpace": "\x7f", "Tab": "\t",
            "ISO_Left_Tab": "\x1b[Z", "Up": "\x1b[A", "Down": "\x1b[B",
            "Right": "\x1b[C", "Left": "\x1b[D", "Home": "\x1b[H", "End": "\x1b[F",
            "Delete": "\x1b[3~", "Prior": "\x1b[5~", "Next": "\x1b[6~", "Escape": "\x1b",
        }
        seq = None
        if ctrl and len(ks) == 1 and ks.isalpha():
            seq = chr(ord(ks.lower()) - ord("a") + 1)  # Ctrl-A..Z -> 0x01..0x1a
        elif ks in special:
            seq = special[ks]
        elif event.char and (event.char >= " " or event.char == "\t"):
            seq = event.char
        if seq is not None:
            self._terminal_send(seq)
        return "break"

    def submit_terminal_command(self, _event=None):
        command = self.terminal_input.get()
        self.terminal_input.delete(0, "end")
        if not command.strip():
            self.terminal_shell.send("\n")
            return "break"
        if command.strip() in {"clear", "reset"}:
            self.clear_terminal()
        self.terminal_history.append(command)
        self.terminal_history = self.terminal_history[-200:]
        self.terminal_history_index = len(self.terminal_history)
        if not self.terminal_shell.send(command + "\n"):
            self.restart_terminal()
            self.terminal_shell.send(command + "\n")
        return "break"

    def recall_terminal_history(self, direction):
        if not self.terminal_history:
            return "break"
        self.terminal_history_index = max(
            0,
            min(
                len(self.terminal_history),
                self.terminal_history_index + direction,
            ),
        )
        text = (
            self.terminal_history[self.terminal_history_index]
            if self.terminal_history_index < len(self.terminal_history)
            else ""
        )
        self.terminal_input.delete(0, "end")
        self.terminal_input.insert(0, text)
        self.terminal_input.icursor("end")
        return "break"

    def interrupt_terminal(self):
        self.terminal_shell.interrupt()
        return "break"

    def restart_terminal(self):
        self.clear_terminal()
        self.terminal_shell.start(self.cwd.get())

