def set_window_icon(window):
    data_home = os.environ.get(
        "XDG_DATA_HOME", os.path.expanduser("~/.local/share")
    )
    candidates = [
        os.path.join(os.path.dirname(os.path.abspath(__file__)), "assets", ICON_NAME),
        os.path.join(data_home, "icons", ICON_NAME),
    ]
    for path in candidates:
        if not os.path.isfile(path):
            continue
        try:
            window._app_icon = tk.PhotoImage(file=path)
            window.iconphoto(True, window._app_icon)
            return
        except tk.TclError:
            pass


def acquire_lock():
    runtime = os.environ.get("XDG_RUNTIME_DIR", os.path.expanduser("~/.cache"))
    ensure_dir(runtime)
    handle = open(os.path.join(runtime, APP_ID + ".lock"), "w")
    try:
        fcntl.flock(handle, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        print(f"{APP_NAME} is already running.")
        sys.exit(0)
    return handle


INSTANCE_LOCK = acquire_lock()


def load_json(path, default):
    try:
        with open(path, encoding="utf-8") as handle:
            data = json.load(handle)
            return data if data is not None else default
    except (OSError, ValueError):
        return default


def save_json(path, value):
    ensure_dir(os.path.dirname(path))
    with open(path, "w", encoding="utf-8") as handle:
        json.dump(value, handle, indent=2, sort_keys=True)
        handle.write("\n")


def shorten(text, limit=72):
    text = clean_text(text).replace("\n", " ")
    if len(text) <= limit:
        return text
    return text[: limit - 1].rstrip() + "…"


def project_label(cwd):
    cwd = clean_text(cwd).rstrip(os.sep)
    base = os.path.basename(cwd)
    return base or cwd or "~"


def project_key(cwd):
    return clean_text(cwd).replace("/", "-") or "-home"


def session_alias_key(session):
    return clean_text(session.get("id"))


def session_search_blob(session, alias=""):
    parts = [
        clean_text(alias),
        clean_text(session.get("title")),
        clean_text(session.get("preview")),
        clean_text(session.get("agent")),
        clean_text(session.get("origin")),
        clean_text(session.get("source_session_id")),
        clean_text(session.get("id")),
    ]
    backend = session.get("backend") or {}
    parts.append(clean_text(backend.get("thread_id")))
    parts.append(clean_text(backend.get("session_id")))
    return " ".join(part for part in parts if part).lower()


def iso_from_unix(ts):
    try:
        return datetime.fromtimestamp(float(ts), tz=timezone.utc).isoformat()
    except Exception:
        return now_iso()


def read_jsonl_lines(path, limit=6):
    try:
        with open(path, encoding="utf-8") as handle:
            for _ in range(limit):
                line = handle.readline()
                if not line:
                    break
                yield json.loads(line)
    except (OSError, ValueError):
        return


def first_text_from_claude_jsonl(path):
    for obj in read_jsonl_lines(path, limit=40):
        if not isinstance(obj, dict):
            continue
        if obj.get("type") != "user":
            continue
        message = obj.get("message") or {}
        content = message.get("content")
        if isinstance(content, str):
            text = clean_text(content)
            if text:
                return text
        if isinstance(content, list):
            parts = []
            for bit in content:
                if isinstance(bit, dict) and bit.get("type") == "text":
                    parts.append(bit.get("text", ""))
            text = clean_text(" ".join(parts))
            if text:
                return text
    return ""


def title_from_claude_jsonl(path):
    title = ""
    try:
        with open(path, encoding="utf-8") as handle:
            for line in handle:
                try:
                    obj = json.loads(line)
                except (TypeError, ValueError):
                    continue
                if isinstance(obj, dict) and obj.get("type") == "ai-title":
                    candidate = clean_text(obj.get("aiTitle"))
                    if candidate:
                        title = candidate
    except OSError:
        return ""
    return title


def claude_jsonl_turns(path):
    turns = []
    current = None
    pending_text = []
    seen = set()
    tool_context = {}

    def ensure_turn(timestamp=""):
        nonlocal current
        if current is None:
            current = {
                "id": str(uuid.uuid4()),
                "created_at": clean_text(timestamp) or now_iso(),
                "status": "completed",
                "items": [],
            }
            turns.append(current)
        return current

    def flush_assistant_text(final=False):
        nonlocal pending_text
        if not pending_text:
            return
        turn = ensure_turn()
        for text in pending_text[:-1] if final else pending_text:
            turn["items"].append({"type": "system", "text": text, "tag": "progress"})
        if final:
            turn["items"].append({"type": "agentMessage", "text": pending_text[-1]})
        pending_text = []

    try:
        with open(path, encoding="utf-8") as handle:
            for line in handle:
                try:
                    obj = json.loads(line)
                except ValueError:
                    continue
                record_id = clean_text(obj.get("uuid"))
                if record_id and record_id in seen:
                    continue
                if record_id:
                    seen.add(record_id)
                if obj.get("isSidechain"):
                    continue
                record_type = obj.get("type")
                if record_type not in {"user", "assistant"}:
                    continue
                message = obj.get("message") or {}
                content = message.get("content")
                blocks = content if isinstance(content, list) else [{"type": "text", "text": content}]

                if record_type == "user":
                    text_parts = [
                        clean_text(block.get("text"))
                        for block in blocks
                        if isinstance(block, dict) and block.get("type") == "text"
                    ]
                    prompt = "\n".join(part for part in text_parts if part)
                    tool_results = [
                        block
                        for block in blocks
                        if isinstance(block, dict) and block.get("type") == "tool_result"
                    ]
                    if prompt:
                        flush_assistant_text(final=True)
                        current = {
                            "id": record_id or str(uuid.uuid4()),
                            "created_at": clean_text(obj.get("timestamp")) or now_iso(),
                            "status": "completed",
                            "items": [
                                {
                                    "type": "userMessage",
                                    "content": [{"type": "text", "text": prompt}],
                                }
                            ],
                        }
                        turns.append(current)
                    for result in tool_results:
                        output = result.get("content")
                        if isinstance(output, list):
                            output = "\n".join(
                                clean_text(bit.get("text"))
                                for bit in output
                                if isinstance(bit, dict) and bit.get("type") == "text"
                            )
                        text = clean_text(output)
                        if text:
                            tool_id = clean_text(result.get("tool_use_id"))
                            context = tool_context.get(tool_id) or {}
                            tool_name = context.get("name")
                            if tool_name in {"WebSearch", "WebFetch"}:
                                raw_text = ""
                                report_text = text
                                marker = "\n\nI found "
                                if marker in text:
                                    raw_text, readable = text.split(marker, 1)
                                    report_text = "I found " + readable
                                if raw_text:
                                    ensure_turn(obj.get("timestamp"))["items"].append(
                                        {"type": "system", "text": raw_text, "tag": "tool"}
                                    )
                                subject = clean_text(
                                    context.get("query") or context.get("url")
                                )
                                title = (
                                    "Research results"
                                    if not subject
                                    else "Research: " + shorten(subject, 72)
                                )
                                ensure_turn(obj.get("timestamp"))["items"].append(
                                    {
                                        "type": "report",
                                        "title": title,
                                        "text": report_text,
                                    }
                                )
                            else:
                                ensure_turn(obj.get("timestamp"))["items"].append(
                                    {
                                        "type": "system",
                                        "text": text,
                                        "tag": "system",
                                    }
                                )
                    continue

                for block in blocks:
                    if not isinstance(block, dict):
                        continue
                    block_type = block.get("type")
                    if block_type == "text":
                        text = clean_text(block.get("text"))
                        if text:
                            pending_text.append(text)
                    elif block_type == "thinking":
                        summary = clean_text(block.get("thinking"))
                        if summary:
                            ensure_turn(obj.get("timestamp"))["items"].append(
                                {"type": "reasoning", "summary": [summary]}
                            )
                    elif block_type == "tool_use":
                        flush_assistant_text(final=False)
                        name = clean_text(block.get("name"))
                        tool_input = block.get("input") or {}
                        tool_id = clean_text(block.get("id"))
                        if tool_id:
                            tool_context[tool_id] = {
                                "name": name,
                                "query": clean_text(tool_input.get("query")),
                                "url": clean_text(tool_input.get("url")),
                            }
                        if name == "Bash":
                            command = clean_text(tool_input.get("command"))
                            if command:
                                ensure_turn(obj.get("timestamp"))["items"].append(
                                    {"type": "commandExecution", "command": command}
                                )
                        elif name in {"Edit", "Write", "NotebookEdit"}:
                            path_value = clean_text(
                                tool_input.get("file_path")
                                or tool_input.get("notebook_path")
                                or tool_input.get("path")
                            )
                            changes = [{"path": path_value}] if path_value else []
                            ensure_turn(obj.get("timestamp"))["items"].append(
                                {"type": "fileChange", "changes": changes, "tool": name}
                            )
                        else:
                            detail = clean_text(
                                tool_input.get("description")
                                or tool_input.get("query")
                                or tool_input.get("file_path")
                            )
                            label = f"Tool: {name}" + (f" — {detail}" if detail else "")
                            ensure_turn(obj.get("timestamp"))["items"].append(
                                {"type": "system", "text": label, "tag": "tool"}
                            )
        flush_assistant_text(final=True)
    except OSError:
        return []
    return [turn for turn in turns if turn.get("items")]


def codex_history_prompts():
    path = os.path.expanduser("~/.codex/history.jsonl")
    prompts = {}
    try:
        with open(path, encoding="utf-8") as handle:
            for line in handle:
                try:
                    obj = json.loads(line)
                except ValueError:
                    continue
                session_id = obj.get("session_id")
                text = clean_text(obj.get("text"))
                if not session_id or not text:
                    continue
                prompts.setdefault(session_id, []).append((obj.get("ts") or 0, text))
    except OSError:
        return {}
    return prompts


def codex_rollout_turns(path):
    if not path or not os.path.isfile(path):
        return []
    turns = []
    current = None
    try:
        with open(path, encoding="utf-8") as handle:
            for line in handle:
                try:
                    obj = json.loads(line)
                except ValueError:
                    continue
                record_type = obj.get("type")
                if record_type not in {"event_msg", "response_item"}:
                    continue
                payload = obj.get("payload") or {}
                event_type = payload.get("type")
                text = ""
                item = None
                if record_type == "event_msg" and event_type == "user_message":
                    text = clean_text(payload.get("message"))
                    if not text:
                        continue
                    current = {
                        "id": str(uuid.uuid4()),
                        "created_at": clean_text(obj.get("timestamp")) or now_iso(),
                        "status": "completed",
                        "items": [],
                    }
                    turns.append(current)
                    item = {
                        "type": "userMessage",
                        "content": [{"type": "text", "text": text}],
                    }
                elif record_type == "event_msg" and event_type == "agent_message":
                    text = clean_text(payload.get("message"))
                    if not text:
                        continue
                    if current is None:
                        current = {
                            "id": str(uuid.uuid4()),
                            "created_at": clean_text(obj.get("timestamp")) or now_iso(),
                            "status": "completed",
                            "items": [],
                        }
                        turns.append(current)
                    if payload.get("phase") == "commentary":
                        item = {"type": "system", "text": text, "tag": "progress"}
                    else:
                        item = {"type": "agentMessage", "text": text}
                elif record_type == "response_item":
                    if current is None:
                        continue
                    if event_type == "function_call":
                        name = clean_text(payload.get("name"))
                        arguments = payload.get("arguments")
                        command = ""
                        if name == "exec_command" and isinstance(arguments, str):
                            try:
                                command = clean_text(json.loads(arguments).get("cmd"))
                            except (ValueError, AttributeError):
                                command = clean_text(arguments)
                        if command:
                            item = {"type": "commandExecution", "command": command}
                        elif name:
                            item = {
                                "type": "system",
                                "text": f"Tool: {name}",
                                "tag": "tool",
                            }
                    elif event_type == "custom_tool_call":
                        name = clean_text(payload.get("name"))
                        item = {
                            "type": "system",
                            "text": f"Tool: {name or 'custom tool'}",
                            "tag": "tool",
                        }
                    elif event_type in {"function_call_output", "custom_tool_call_output"}:
                        output = payload.get("output")
                        if isinstance(output, dict):
                            output = output.get("content") or output.get("output")
                        text = clean_text(output)
                        if text:
                            item = {"type": "system", "text": text, "tag": "system"}
                    elif event_type == "reasoning":
                        summary = payload.get("summary") or []
                        parts = []
                        for value in summary:
                            if isinstance(value, dict):
                                parts.append(value.get("text", ""))
                            else:
                                parts.append(str(value))
                        text = clean_text(" ".join(parts))
                        if text:
                            item = {"type": "reasoning", "summary": [text]}
                if item is not None:
                    current["items"].append(item)
    except OSError:
        return []
    return [turn for turn in turns if turn.get("items")]


def rename_codex_thread_title(thread_id, title):
    db = os.path.expanduser("~/.codex/state_5.sqlite")
    if not thread_id or not os.path.exists(db):
        return False
    title = clean_text(title)
    if not title:
        return False
    try:
        import sqlite3

        con = sqlite3.connect(db)
        con.execute(
            "update threads set title = ?, preview = ?, updated_at = ?, updated_at_ms = ? where id = ?",
            (
                title,
                title,
                int(time.time()),
                int(time.time() * 1000),
                thread_id,
            ),
        )
        con.commit()
        return True
    except Exception:
        return False
    finally:
        try:
            con.close()
        except Exception:
            pass


def rename_claude_session_title(path, session_id, title):
    title = clean_text(title)
    if not path or not session_id or not title or not os.path.isfile(path):
        return False
    record = {
        "type": "ai-title",
        "aiTitle": title,
        "sessionId": session_id,
    }
    try:
        with open(path, "a", encoding="utf-8") as handle:
            fcntl.flock(handle.fileno(), fcntl.LOCK_EX)
            handle.write(json.dumps(record, separators=(",", ":")) + "\n")
            handle.flush()
            os.fsync(handle.fileno())
            fcntl.flock(handle.fileno(), fcntl.LOCK_UN)
        return True
    except OSError:
        return False


def gemini_sessions_for_cwd(cwd):
    cmd = [
        "gemini",
        "--list-sessions",
        "--skip-trust",
        "--yolo",
        "--include-directories",
        cwd,
    ]
    try:
        result = subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=12,
            check=False,
        )
    except Exception:
        return []
    sessions = []
    for line in (result.stdout or "").splitlines():
        line = clean_text(line)
        if not line:
            continue
        if line.startswith("Available sessions for this project"):
            continue
        if line.startswith("YOLO mode is enabled"):
            continue
        if line.startswith("[SessionSummary]"):
            continue
        if "]" not in line or "(" not in line:
            continue
        try:
            left, sid = line.rsplit("[", 1)
            sid = sid.rstrip("]")
            title = left.split(".", 1)[1].rsplit("(", 1)[0].strip()
            age = left.rsplit("(", 1)[1].split(")", 1)[0].strip()
        except Exception:
            continue
        sessions.append(
            {
                "id": f"gemini-terminal:{sid}",
                "source_session_id": sid,
                "agent": "gemini",
                "origin": "gemini-terminal",
                "cwd": cwd,
                "title": title or "Gemini session",
                "preview": title or "Gemini session",
                "created_at": now_iso(),
                "updated_at": now_iso(),
                "age": age,
                "backend": {"session_id": sid},
                "turns": [
                    {
                        "id": sid,
                        "created_at": now_iso(),
                        "status": "completed",
                        "items": [
                            {
                                "type": "userMessage",
                                "content": [{"type": "text", "text": title or "Gemini session"}],
                            }
                        ],
                    }
                ],
            }
        )
    return sessions


def claude_sessions_for_cwd(cwd):
    root = os.path.expanduser("~/.claude/projects/" + project_key(cwd))
    sessions = []
    if not os.path.isdir(root):
        return sessions
    for path in sorted(Path(root).glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True):
        sid = path.stem
        preview = first_text_from_claude_jsonl(str(path))
        generated_title = title_from_claude_jsonl(str(path))
        try:
            mtime = path.stat().st_mtime
        except OSError:
            mtime = time.time()
        sessions.append(
            {
                "id": f"claude-terminal:{sid}",
                "source_session_id": sid,
                "agent": "claude",
                "origin": "claude-terminal",
                "cwd": cwd,
                "title": generated_title or preview or path.stem,
                "preview": preview or path.stem,
                "created_at": iso_from_unix(mtime),
                "updated_at": iso_from_unix(mtime),
                "source_path": str(path),
                "backend": {"session_id": sid},
                "turns": [],
                "transcript_loaded": False,
            }
        )
    return sessions


def codex_sessions_for_cwd(cwd):
    db = os.path.expanduser("~/.codex/state_5.sqlite")
    if not os.path.exists(db):
        return []
    try:
        import sqlite3

        con = sqlite3.connect(db)
        con.row_factory = sqlite3.Row
        rows = con.execute(
            "select id, rollout_path, cwd, title, preview, created_at, updated_at, source, archived "
            "from threads where cwd = ? and archived = 0 order by updated_at desc limit 100",
            (cwd,),
        ).fetchall()
    except Exception:
        return []
    history = codex_history_prompts()
    sessions = []
    for row in rows:
        sid = row["id"]
        turns = codex_rollout_turns(row["rollout_path"])
        prompts = history.get(sid) or []
        if not turns and prompts:
            transcript = []
            for _, text in prompts[:8]:
                transcript.append(
                    {
                        "type": "userMessage",
                        "content": [{"type": "text", "text": text}],
                    }
                )
            turns = [
                {
                    "id": sid,
                    "created_at": iso_from_unix(row["created_at"]),
                    "status": "completed",
                    "items": transcript,
                }
            ]
        preview = clean_text(row["preview"] or row["title"] or "")
        if not preview and prompts:
            preview = prompts[0][1]
        sessions.append(
            {
                "id": f"codex-terminal:{sid}",
                "source_session_id": sid,
                "agent": "codex",
                "origin": "codex-terminal",
                "cwd": row["cwd"],
                "title": row["title"] or preview or "Codex session",
                "preview": preview or "Codex session",
                "created_at": iso_from_unix(row["created_at"]),
                "updated_at": iso_from_unix(row["updated_at"]),
                "source_path": row["rollout_path"],
                "backend": {"thread_id": sid},
                "turns": turns,
            }
        )
    return sessions


def discover_external_sessions(cwd, agent_key):
    if agent_key == "codex":
        return codex_sessions_for_cwd(cwd)
    if agent_key == "claude":
        return claude_sessions_for_cwd(cwd)
    if agent_key == "gemini":
        return gemini_sessions_for_cwd(cwd)
    return []


def summarize_turn_items(turns, max_chars=7000):
    lines = []
    remaining = max_chars
    for turn in turns[-12:]:
        for item in turn.get("items") or []:
            typ = item.get("type", "")
            text = ""
            if typ == "userMessage":
                parts = []
                for bit in item.get("content") or []:
                    if isinstance(bit, dict) and bit.get("type") == "text":
                        parts.append(bit.get("text", ""))
                text = " ".join(parts)
                prefix = "USER"
            elif typ == "agentMessage":
                text = item.get("text") or item.get("content") or ""
                prefix = "AGENT"
            elif typ == "commandExecution":
                text = item.get("command") or ""
                prefix = "COMMAND"
            elif typ == "fileChange":
                paths = []
                for change in item.get("changes") or []:
                    path = change.get("path") or change.get("filePath")
                    if path:
                        paths.append(str(path))
                text = ", ".join(paths)
                prefix = "FILES"
            elif typ == "reasoning":
                text = " ".join(item.get("summary") or [])
                prefix = "REASONING"
            elif typ == "plan":
                text = item.get("text") or ""
                prefix = "PLAN"
            else:
                text = item.get("text") or item.get("summary") or ""
                prefix = typ.upper() or "NOTE"
            text = clean_text(text)
            if not text:
                continue
            line = f"{prefix}: {text}"
            if len(line) > remaining:
                lines.append(line[: max(0, remaining - 1)] + "…")
                return "\n".join(lines)
            lines.append(line)
            remaining -= len(line) + 1
            if remaining <= 0:
                return "\n".join(lines)
    return "\n".join(lines)


class SessionStore:
    def __init__(self):
        ensure_dir(CONFIG_DIR)
        ensure_dir(SESSIONS_DIR)
        self.sessions = {}
        self.load()

    def load(self):
        self.sessions = {}
        for name in sorted(os.listdir(SESSIONS_DIR)):
            if not name.endswith(".json"):
                continue
            path = os.path.join(SESSIONS_DIR, name)
            data = load_json(path, None)
            if isinstance(data, dict) and data.get("id"):
                changed = False
                for turn in data.get("turns") or []:
                    if turn.get("status") == "running":
                        turn["status"] = "interrupted"
                        changed = True
                if not data.get("origin"):
                    data["origin"] = "local"
                self.sessions[data["id"]] = data
                if changed:
                    save_json(path, data)

    def save(self, session):
        if session.get("origin", "local") != "local":
            return
        session["updated_at"] = now_iso()
        if not session.get("created_at"):
            session["created_at"] = session["updated_at"]
        self.sessions[session["id"]] = session
        save_json(os.path.join(SESSIONS_DIR, session["id"] + ".json"), session)

    def delete(self, session_id):
        self.sessions.pop(session_id, None)
        path = os.path.join(SESSIONS_DIR, session_id + ".json")
        try:
            os.unlink(path)
        except OSError:
            pass

    def new_session(self, agent_key, cwd):
        session = self._make_session(
            agent_key=agent_key,
            cwd=cwd,
            title=f"New {agent_key} session",
            backend={},
            turns=[],
            origin="local",
        )
        self.save(session)
        return session

    def _make_session(self, agent_key, cwd, title, backend, turns, origin="local", source_session_id=None):
        session = {
            "id": str(uuid.uuid4()),
            "agent": agent_key,
            "cwd": cwd,
            "title": title,
            "created_at": now_iso(),
            "updated_at": now_iso(),
            "backend": backend or {},
            "turns": turns or [],
            "origin": origin,
        }
        if source_session_id:
            session["source_session_id"] = source_session_id
        return session

    def clone_for_continuation(self, source):
        backend = {}
        if source.get("agent") in {"claude", "gemini"}:
            backend = deepcopy(source.get("backend") or {})
        turns = deepcopy(source.get("turns") or [])
        title = source.get("title") or source.get("preview") or f"New {source.get('agent', 'agent')} session"
        session = self._make_session(
            agent_key=source.get("agent", "codex"),
            cwd=source.get("cwd") or os.path.expanduser("~"),
            title=title,
            backend=backend,
            turns=turns,
            origin="local",
            source_session_id=source.get("source_session_id") or source.get("id"),
        )
        self.save(session)
        return session

    def list_for(self, cwd, agent_key):
        items = [
            s
            for s in self.sessions.values()
            if s.get("cwd") == cwd and s.get("agent") == agent_key and (s.get("turns") or [])
        ]
        items.sort(key=lambda s: s.get("updated_at") or "", reverse=True)
        unique = []
        seen = set()
        for session in items:
            key = session.get("source_session_id") or session.get("id")
            if key in seen:
                continue
            seen.add(key)
            unique.append(session)
        return unique

    def get(self, session_id):
        return self.sessions.get(session_id)

    def set_title_from_prompt(self, session, prompt):
        title = shorten(prompt, 60)
        if title:
            session["title"] = title
            self.save(session)

    def ensure_turn(self, session, prompt=None):
        turns = session.setdefault("turns", [])
        turn = {
            "id": str(uuid.uuid4()),
            "created_at": now_iso(),
            "status": "running",
            "items": [],
        }
        if prompt:
            turn["prompt"] = prompt
        turns.append(turn)
        self.save(session)
        return turn

    def add_item(self, session, turn, item):
        turn.setdefault("items", []).append(item)
        self.save(session)

    def finish_turn(self, session, turn, status="completed"):
        turn["status"] = status
        turn["completed_at"] = now_iso()
        self.save(session)

    def summary_for_handoff(self, session, max_chars=7000):
        header = f"Previous {session.get('agent', 'agent')} session for {project_label(session.get('cwd'))}:\n"
        body = summarize_turn_items(session.get("turns") or [], max_chars=max_chars)
        return header + body if body else header + "No prior details available."


class BaseBackend:
    def __init__(self, events):
        self.events = events
        self.stop_flag = threading.Event()
        self.active = False

    def emit(self, kind, **payload):
        self.events.put({"kind": kind, **payload})

    def stop(self):
        self.stop_flag.set()


class CodexBackend(BaseBackend):
    def __init__(self, events):
        super().__init__(events)
        self.proc = None
        self.cwd = None
        self.thread_id = None
        self.turn_id = None
        self.next_id = 1
        self.pending = {}
        self.lock = threading.Lock()
        self.ready = threading.Event()
        self.active_threads = set()

    def start(self, cwd):
        self.cwd = cwd
        self.proc = subprocess.Popen(
            ["codex", "app-server"],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,
        )
        threading.Thread(target=self._read_stdout, daemon=True).start()
        threading.Thread(target=self._read_stderr, daemon=True).start()
        self.request(
            "initialize",
            {
                "clientInfo": {
                    "name": "agent_workbench",
                    "title": APP_NAME,
                    "version": "0.2.0",
                }
            },
            self._on_initialized,
        )

    def _on_initialized(self, _result):
        self.notify("initialized", {})
        self.ready.set()

    def request(self, method, params, callback=None, error_callback=None):
        with self.lock:
            req_id = self.next_id
            self.next_id += 1
            if callback or error_callback:
                self.pending[req_id] = (callback, error_callback)
        message = {"method": method, "id": req_id, "params": params}
        self._send(message)
        return req_id

    def notify(self, method, params):
        self._send({"method": method, "params": params})

    def respond(self, req_id, result):
        self._send({"id": req_id, "result": result})

    def _send(self, message):
        try:
            self.proc.stdin.write(json.dumps(message) + "\n")
            self.proc.stdin.flush()
        except Exception as exc:
            self.emit("error", text=str(exc))

    def _read_stdout(self):
        for line in self.proc.stdout:
            if self.stop_flag.is_set():
                break
            try:
                message = json.loads(line)
            except ValueError:
                self.emit("work", text=line.rstrip(), tag="system")
                continue

            req_id = message.get("id")
            if req_id is not None and message.get("method"):
                self._handle_server_request(message)
                continue
            if req_id is not None:
                callbacks = self.pending.pop(req_id, (None, None))
                callback, error_callback = callbacks
                if "error" in message:
                    err = message["error"]
                    text = err.get("message", "Codex error")
                    if error_callback:
                        error_callback(text)
                    else:
                        self.emit("error", text=text)
                elif callback:
                    callback(message.get("result") or {})
                continue

            self._handle_notification(message)
        self.emit("backend_exit", text="Codex app server stopped")

    def _handle_server_request(self, message):
        method = message.get("method", "")
        if method == "item/tool/requestUserInput":
            self.emit(
                "user_input_request",
                request_id=message.get("id"),
                params=message.get("params") or {},
            )
            return
        self.respond(message.get("id"), {})

    def _read_stderr(self):
        for line in self.proc.stderr:
            if self.stop_flag.is_set():
                break
            line = line.strip()
            if line:
                self.emit("work", text=line, tag="system")

    def _handle_notification(self, message):
        method = message.get("method", "")
        params = message.get("params") or {}
        item = params.get("item") or {}
        typ = item.get("type", "")

        if method == "turn/started":
            turn = params.get("turn") or {}
            self.turn_id = turn.get("id") or self.turn_id
            self.emit("work", text="--- New turn ---", tag="system")
        elif method == "item/started":
            if typ and typ != "agentMessage":
                self.emit("work", text="▶ " + typ, tag="tool")
        elif method == "item/completed":
            if typ == "agentMessage":
                text = item.get("text") or item.get("content") or ""
                if not text:
                    content = []
                    for bit in item.get("content") or []:
                        if isinstance(bit, dict) and bit.get("type") == "text":
                            content.append(bit.get("text", ""))
                    text = " ".join(content)
                if text:
                    if item.get("phase") == "commentary":
                        self.emit("work", text=text, tag="progress")
                    else:
                        self.emit("assistant_message", text=text, speaker="CODEX")
            elif typ == "userMessage":
                self.emit("user", text=self._extract_text(item))
            elif typ == "commandExecution":
                command = clean_text(item.get("command"))
                if command:
                    self.emit("work", text=f"$ {command}", tag="command")
                output = clean_text(item.get("aggregatedOutput"))
                if output:
                    self.emit("work", text=output, tag="system")
            elif typ == "fileChange":
                paths = []
                for change in item.get("changes") or []:
                    path = change.get("path") or change.get("filePath")
                    if path:
                        paths.append(str(path))
                if paths:
                    self.emit("work", text="files: " + ", ".join(paths), tag="fileChange")
            elif typ == "reasoning":
                summary = " ".join(item.get("summary") or [])
                if summary:
                    self.emit("work", text=summary, tag="reasoning")
            elif typ == "plan":
                text = clean_text(item.get("text"))
                if text:
                    self.emit("work", text=text, tag="plan")
            elif typ == "mcpToolCall":
                self.emit(
                    "work",
                    text=f"{clean_text(item.get('server'))}.{clean_text(item.get('tool'))}",
                    tag="tool",
                )
        elif method == "item/commandExecution/outputDelta":
            delta = clean_text(params.get("delta"))
            if delta:
                self.emit("work", text=delta, tag="system")
        elif method == "item/fileChange/outputDelta":
            delta = clean_text(params.get("delta"))
            if delta:
                self.emit("work", text=delta, tag="fileChange")
        elif method == "turn/completed":
            turn = params.get("turn") or {}
            self.emit("turn_done", status=(turn.get("status") or "completed"))
        elif method == "thread/created" or method == "thread/resumed":
            thread = params.get("thread") or {}
            self.thread_id = thread.get("id") or self.thread_id

    def _extract_text(self, item):
        parts = []
        for bit in item.get("content") or []:
            if isinstance(bit, dict) and bit.get("type") == "text":
                parts.append(bit.get("text", ""))
        return clean_text(" ".join(parts))

    def ensure_session(self, session):
        backend = session.setdefault("backend", {})
        backend.setdefault("kind", "codex")
        existing_thread_id = backend.get("thread_id")
        if existing_thread_id and existing_thread_id in self.active_threads:
            self.thread_id = existing_thread_id
            return

        result_holder = {}
        error_holder = {}
        done = threading.Event()

        def on_ready(result):
            result_holder.update(result)
            done.set()

        def on_error(text):
            error_holder["text"] = text
            done.set()

        params = {
            "cwd": session["cwd"],
            "approvalPolicy": "never",
            "sandbox": "danger-full-access",
            "personality": "pragmatic",
        }
        model = clean_text(backend.get("model"))
        if model:
            params["model"] = model
        method = "thread/start"
        if existing_thread_id:
            method = "thread/resume"
            params["threadId"] = existing_thread_id
        self.request(method, params, on_ready, on_error)
        if not done.wait(timeout=30):
            raise RuntimeError(f"Timed out while trying to {method.replace('/', ' ')}")
        if error_holder:
            raise RuntimeError(error_holder["text"])
        thread = result_holder.get("thread") or {}
        thread_id = thread.get("id") or existing_thread_id
        if not thread_id:
            raise RuntimeError("Codex did not return a thread ID")
        backend["thread_id"] = thread_id
        self.thread_id = thread_id
        self.active_threads.add(thread_id)
        session["backend"] = backend

    def start_turn(self, session, turn, prompt, context_text=""):
        try:
            self.ensure_session(session)
        except Exception as exc:
            self.emit("error", text=str(exc))
            return
        self.turn_id = None
        payload_text = prompt
        if context_text:
            payload_text = context_text.strip() + "\n\n" + prompt.strip()
        done = threading.Event()

        def on_turn(result):
            turn_obj = result.get("turn") or {}
            self.turn_id = turn_obj.get("id")
            backend = session.setdefault("backend", {})
            backend["thread_id"] = backend.get("thread_id") or self.thread_id
            backend["turn_id"] = self.turn_id
            done.set()

        def on_error(text):
            self.emit("error", text=text)
            done.set()

        request = {
            "threadId": self.thread_id,
            "cwd": session["cwd"],
            "input": [{"type": "text", "text": payload_text}],
        }
        backend = session.get("backend") or {}
        if clean_text(backend.get("model")):
            request["model"] = backend["model"]
        if clean_text(backend.get("effort")):
            request["effort"] = backend["effort"]
        self.request(
            "turn/start",
            request,
            on_turn,
            on_error,
        )
        if not done.wait(timeout=30):
            self.emit("error", text="Codex timed out while starting the turn")

    def answer_user_input(self, request_id, questions, text):
        lines = [line.strip() for line in text.splitlines() if line.strip()]
        answers = {}
        for index, question in enumerate(questions):
            answer = lines[index] if index < len(lines) else (text.strip() if index == 0 else "")
            answers[question.get("id", str(index))] = {"answers": [answer]}
        self.respond(request_id, {"answers": answers})

    def interrupt(self):
        if self.thread_id and self.turn_id:
            self.request(
                "turn/interrupt",
                {"threadId": self.thread_id, "turnId": self.turn_id},
            )

    def close(self):
        self.stop_flag.set()
        if self.proc and self.proc.poll() is None:
            self.proc.terminate()


class StreamCliBackend(BaseBackend):
    def __init__(self, events, kind):
        super().__init__(events)
        self.kind = kind
        self.running = None
        self.lock = threading.Lock()

    def interrupt(self):
        with self.lock:
            if self.running and self.running.poll() is None:
                self.running.terminate()

    def close(self):
        self.stop_flag.set()
        self.interrupt()


class CustomCliBackend(StreamCliBackend):
    def __init__(self, events, spec):
        super().__init__(events, spec["key"])
        self.spec = spec

    def start_turn(self, session, turn, prompt, context_text=""):
        def run():
            template = clean_text(self.spec.get("command"))
            payload = prompt
            if context_text:
                payload = context_text.strip() + "\n\n" + prompt.strip()
            if not template:
                self.emit("error", text="Custom client command is empty.")
                return
            uses_placeholder = "{prompt}" in template
            if uses_placeholder:
                command = template.replace("{prompt}", shlex.quote(payload))
                stdin_data = None
            else:
                command = template
                stdin_data = payload + "\n"
            self.emit("work", text="$ " + command, tag="command")
            with self.lock:
                self.running = subprocess.Popen(
                    ["bash", "-lc", command],
                    cwd=session["cwd"],
                    stdin=subprocess.PIPE if stdin_data is not None else None,
                    stdout=subprocess.PIPE,
                    stderr=subprocess.PIPE,
                    text=True,
                )
            try:
                stdout, stderr = self.running.communicate(input=stdin_data)
                if stderr:
                    self.emit("work", text=stderr, tag="system")
                if stdout:
                    self.emit(
                        "assistant_message",
                        text=clean_text(stdout),
                        speaker=clean_text(self.spec.get("label")).upper(),
                    )
                status = "completed" if self.running.returncode == 0 else "error"
                if status == "error" and not stderr:
                    self.emit(
                        "error",
                        text=f"Custom client exited with status {self.running.returncode}.",
                    )
                self.emit("turn_done", status=status)
            except Exception as exc:
                self.emit("error", text=str(exc))
                self.emit("turn_done", status="error")
            finally:
                with self.lock:
                    self.running = None

        threading.Thread(target=run, daemon=True).start()


class TerminalShell:
    def __init__(self, events):
        self.events = events
        self.proc = None
        self.master_fd = None
        self.cwd = None
        self.lock = threading.Lock()
        self.generation = 0

    def emit(self, kind, **payload):
        self.events.put({"kind": kind, **payload})

    def start(self, cwd):
        cwd = cwd if os.path.isdir(cwd) else os.path.expanduser("~")
        self.close()
        master_fd, slave_fd = pty.openpty()
        try:
            fcntl.ioctl(
                slave_fd,
                termios.TIOCSWINSZ,
                struct.pack("HHHH", 32, 140, 0, 0),
            )
        except OSError:
            pass
        env = os.environ.copy()
        env["TERM"] = env.get("TERM") or "xterm-256color"
        env["AGENT_WORKBENCH"] = "1"
        shell = env.get("SHELL") or "/bin/bash"
        with self.lock:
            self.generation += 1
            generation = self.generation
            self.cwd = cwd
            self.master_fd = master_fd
            self.proc = subprocess.Popen(
                [shell, "-i"],
                cwd=cwd,
                stdin=slave_fd,
                stdout=slave_fd,
                stderr=slave_fd,
                env=env,
                preexec_fn=os.setsid,
                close_fds=True,
            )
        os.close(slave_fd)
        threading.Thread(target=self._read, args=(generation,), daemon=True).start()

    def _read(self, generation):
        while True:
            with self.lock:
                if generation != self.generation:
                    return
                fd = self.master_fd
                proc = self.proc
            if fd is None or proc is None:
                return
            try:
                data = os.read(fd, 4096)
            except OSError:
                break
            if not data:
                break
            text = data.decode("utf-8", errors="replace").replace("\r", "")
            clear_screen = "\x1b[2J" in text or "\x1b[3J" in text
            text = ANSI_ESCAPE.sub("", text)
            text = text.replace("\\[", "").replace("\\]", "")
            if clear_screen:
                self.emit("terminal_clear")
            if text:
                with self.lock:
                    if generation != self.generation:
                        return
                self.emit("terminal_output", text=text)
        with self.lock:
            if generation != self.generation:
                return
            proc = self.proc
        if proc is not None:
            self.emit("terminal_exit", status=proc.poll())

    def send(self, text):
        with self.lock:
            fd = self.master_fd
        if fd is None:
            return False
        try:
            os.write(fd, text.encode("utf-8"))
            return True
        except OSError:
            return False

    def interrupt(self):
        with self.lock:
            proc = self.proc
            fd = self.master_fd
        if proc and proc.poll() is None:
            try:
                foreground_pgid = os.tcgetpgrp(fd) if fd is not None else proc.pid
                os.killpg(foreground_pgid, signal.SIGINT)
            except OSError:
                pass

    def close(self):
        with self.lock:
            self.generation += 1
            proc = self.proc
            fd = self.master_fd
            self.proc = None
            self.master_fd = None
        if proc and proc.poll() is None:
            try:
                os.killpg(proc.pid, signal.SIGHUP)
            except OSError:
                pass
            try:
                proc.wait(timeout=2)
            except subprocess.TimeoutExpired:
                proc.terminate()
        if fd is not None:
            try:
                os.close(fd)
            except OSError:
                pass


class ClaudeBackend(StreamCliBackend):
    def __init__(self, events):
        super().__init__(events, "claude")

    def start_turn(self, session, turn, prompt, context_text=""):
        def run():
            session_id = session.setdefault("backend", {}).get("session_id") or str(uuid.uuid4())
            first_turn = not session["backend"].get("session_id")
            cmd = [
                "claude",
                "-p",
                "--output-format",
                "stream-json",
                "--input-format",
                "text",
                "--verbose",
                "--permission-mode",
                "bypassPermissions",
                "--dangerously-skip-permissions",
            ]
            model = clean_text(session["backend"].get("model"))
            effort = clean_text(session["backend"].get("effort"))
            if model:
                cmd += ["--model", model]
            if effort:
                cmd += ["--effort", effort]
            if first_turn:
                cmd += ["--session-id", session_id]
            else:
                cmd += ["--resume", session_id]

            payload = prompt
            if context_text and first_turn:
                payload = context_text.strip() + "\n\n" + prompt.strip()

            self.emit("work", text="$ " + shlex.join(cmd + [payload]), tag="command")
            buffer = []
            with self.lock:
                self.running = subprocess.Popen(
                    cmd + [payload],
                    cwd=session["cwd"],
                    stdout=subprocess.PIPE,
                    stderr=subprocess.PIPE,
                    text=True,
                    bufsize=1,
                )
            try:
                threading.Thread(target=self._stream_stderr, daemon=True).start()
                for raw in self.running.stdout:
                    if self.stop_flag.is_set():
                        break
                    line = raw.strip()
                    if not line:
                        continue
                    try:
                        event = json.loads(line)
                    except ValueError:
                        self.emit("work", text=line, tag="system")
                        continue
                    etype = event.get("type")
                    if etype == "system" and event.get("subtype") == "init":
                        sid = event.get("session_id")
                        if sid:
                            session.setdefault("backend", {})["session_id"] = sid
                        self.emit(
                            "work",
                            text=f"claude session {sid or session_id}",
                            tag="system",
                        )
                    elif etype == "assistant":
                        message = event.get("message") or {}
                        for block in message.get("content") or []:
                            if not isinstance(block, dict):
                                continue
                            block_type = block.get("type")
                            content = clean_text(block.get("text"))
                            if block_type == "text" and content:
                                if not buffer:
                                    self.emit("assistant_begin", speaker="CLAUDE")
                                buffer.append(content)
                                self.emit("assistant_delta", text=content, speaker="CLAUDE")
                            elif block_type == "tool_use":
                                self.emit(
                                    "work",
                                    text=f"Tool: {clean_text(block.get('name'))}",
                                    tag="tool",
                                )
                    elif etype == "user":
                        self.emit("work", text=line, tag="system")
                    elif etype == "result":
                        result = event.get("result") or ""
                        if result and not buffer:
                            self.emit("assistant_begin", speaker="CLAUDE")
                            self.emit("assistant_delta", text=clean_text(result), speaker="CLAUDE")
                        status = event.get("subtype") or "success"
                        stats = event.get("usage") or {}
                        self.emit(
                            "work",
                            text=f"Claude {status} · input {stats.get('input_tokens', 0)} · output {stats.get('output_tokens', 0)}",
                            tag="done" if status == "success" else "system",
                        )
                        break
                    else:
                        self.emit("work", text=line, tag="system")
                if buffer:
                    self.emit("assistant_done", speaker="CLAUDE")
                self.emit("turn_done", status="completed")
            except Exception as exc:
                self.emit("error", text=str(exc))
                self.emit("turn_done", status="error")
            finally:
                with self.lock:
                    self.running = None

        threading.Thread(target=run, daemon=True).start()

    def _stream_stderr(self):
        proc = self.running
        if not proc or not proc.stderr:
            return
        for raw in proc.stderr:
            if self.stop_flag.is_set():
                break
            line = raw.strip()
            if line:
                self.emit("work", text=line, tag="system")


class GeminiBackend(StreamCliBackend):
    def __init__(self, events):
        super().__init__(events, "gemini")

    def start_turn(self, session, turn, prompt, context_text=""):
        def run():
            session_id = session.setdefault("backend", {}).get("session_id") or str(uuid.uuid4())
            first_turn = not session["backend"].get("session_id")
            cmd = [
                "gemini",
                "-p",
                prompt,
                "--output-format",
                "stream-json",
                "--yolo",
                "--skip-trust",
            ]
            model = clean_text(session["backend"].get("model"))
            if model and model != "Auto":
                cmd += ["--model", model]
            if first_turn:
                cmd += ["--session-id", session_id]
            else:
                cmd += ["--resume", session_id]

            payload = prompt
            if context_text and first_turn:
                payload = context_text.strip() + "\n\n" + prompt.strip()
                cmd[2] = payload

            self.emit("work", text="$ " + shlex.join(cmd), tag="command")
            buffer = []
            with self.lock:
                self.running = subprocess.Popen(
                    cmd,
                    cwd=session["cwd"],
                    stdout=subprocess.PIPE,
                    stderr=subprocess.PIPE,
                    text=True,
                    bufsize=1,
                )
            try:
                threading.Thread(target=self._stream_stderr, daemon=True).start()
                for raw in self.running.stdout:
                    if self.stop_flag.is_set():
                        break
                    line = raw.strip()
                    if not line:
                        continue
                    try:
                        event = json.loads(line)
                    except ValueError:
                        self.emit("work", text=line, tag="system")
                        continue
                    etype = event.get("type")
                    if etype == "init":
                        sid = event.get("session_id")
                        if sid:
                            session.setdefault("backend", {})["session_id"] = sid
                        self.emit(
                            "work",
                            text=f"Gemini session {sid or session_id}",
                            tag="system",
                        )
                    elif etype == "message":
                        role = event.get("role")
                        content = clean_text(event.get("content"))
                        if role == "assistant" and content:
                            if not buffer:
                                self.emit("assistant_begin", speaker="GEMINI")
                            buffer.append(content)
                            self.emit("assistant_delta", text=content, speaker="GEMINI")
                        elif role == "user":
                            self.emit("user", text=content)
                    elif etype == "result":
                        result = event.get("result") or ""
                        if result and not buffer:
                            self.emit("assistant_begin", speaker="GEMINI")
                            self.emit("assistant_delta", text=clean_text(result), speaker="GEMINI")
                        status = event.get("status") or "success"
                        stats = event.get("stats") or {}
                        self.emit(
                            "work",
                            text=f"Gemini {status} · input {stats.get('input_tokens', 0)} · output {stats.get('output_tokens', 0)}",
                            tag="done" if status == "success" else "system",
                        )
                        break
                    else:
                        self.emit("work", text=line, tag="system")
                if buffer:
                    self.emit("assistant_done", speaker="GEMINI")
                self.emit("turn_done", status="completed")
            except Exception as exc:
                self.emit("error", text=str(exc))
                self.emit("turn_done", status="error")
            finally:
                with self.lock:
                    self.running = None

        threading.Thread(target=run, daemon=True).start()

    def _stream_stderr(self):
        proc = self.running
        if not proc or not proc.stderr:
            return
        for raw in proc.stderr:
            if self.stop_flag.is_set():
                break
            line = raw.strip()
            if line:
                self.emit("work", text=line, tag="system")


