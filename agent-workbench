    def _run_skill(self, name, text):
        """Invoke a skill via the active agent's send path. An EMPTY box runs the skill
        bare (just /name) so it uses its own prerequisites/defaults and asks you itself —
        your text never overrides the skill's own questionnaire."""
        if self.active_agent.get() != "claude":
            self.append_work("Skills run best on the Claude agent.", "system")
        body = text.strip()
        self.append_work(f"✦ Skill: {name}", "system")
        self.set_activity("working")
        self.send(prompt=f"/{name} {body}".strip())
        self._log_event("skill_run", skill=name, chars=len(body))

    def set_activity(self, state, text=None):
        self.activity_state = state
        colors = {
            "idle": ("#16351f", "#86efac"),
            "working": ("#3b2c0b", "#facc15"),
            "input": ("#3b1d4a", "#e9a8ff"),
            "warning": ("#4a2b0b", "#fed7aa"),
            "error": ("#4a1d1d", "#fca5a5"),
            "stalled": ("#4a1d1d", "#fecaca"),
            "starting": ("#24303c", "#cbd5e1"),
        }
        bg, fg = colors.get(state, colors["starting"])
        self.activity_badge.configure(bg=bg)
        self.activity_word_label.configure(bg=bg, fg=fg)
        self.activity_dots_label.configure(bg=bg, fg=fg)
        if text is not None:
            self.activity_word.set(text)
        elif state == "idle":
            self.activity_word.set("Ready")
        elif state == "input":
            self.activity_word.set("Needs input")
        elif state == "error":
            self.activity_word.set("Error")
        elif state == "warning":
            self.activity_word.set("No output")
        elif state == "stalled":
            self.activity_word.set("Stalled")
        elif state == "working":
            self.activity_word.set("Working")
        else:
            self.activity_word.set("Starting")

    def _model_options_for(self, agent_key):
        if agent_key == "codex":
            options = [self.codex_default_model, "gpt-5.4", "gpt-5.4-mini"]
        else:
            options = list(MODEL_OPTIONS.get(agent_key, ("Default",)))
        deduped = []
        seen = set()
        for option in options:
            option = clean_text(option)
            if option and option not in seen:
                seen.add(option)
                deduped.append(option)
        return tuple(deduped or ["Default"])

    def _effort_options_for(self, agent_key):
        if agent_key == "claude":
            help_text = self.runtime_help.get("claude", "")
            options = parse_effort_options(help_text, EFFORT_OPTIONS.get(agent_key, ("Default",)))
            options = tuple(options) or tuple(EFFORT_OPTIONS.get(agent_key, ("Default",)))
            # "Ultracode" is a synthetic top tier above "max": selecting it maps at
            # launch to --effort max + ultra multi-agent orchestration (see the
            # command builder). It is not a real CLI --effort value.
            if "Ultracode" not in options:
                options = options + ("Ultracode",)
            return options
        if agent_key == "gemini":
            return ("Default",)
        return tuple(EFFORT_OPTIONS.get(agent_key, ("Default",)))

    def _default_settings_for(self, agent_key):
        defaults = deepcopy(
            DEFAULT_AGENT_SETTINGS.get(agent_key, {"model": "Default", "effort": "Default"})
        )
        if agent_key == "codex":
            defaults["model"] = self.codex_default_model
        return defaults

    def _preferred_worker_model(self, agent_key):
        if agent_key == "codex":
            candidates = (
                self.codex_default_model,
                "gpt-5.4-mini",
                "gpt-5.4",
                "gpt-5.5",
            )
        else:
            candidates = PREFERRED_WORKER_MODELS.get(agent_key, ())
        for candidate in candidates:
            if candidate in self._model_options_for(agent_key):
                return candidate
        return self._model_options_for(agent_key)[0]

    def _worker_label(self, agent_key=None, model=None):
        agent_key = clean_text(agent_key or self.active_agent.get())
        spec = self._agent_spec(agent_key)
        label = spec.get("label") or agent_key.capitalize()
        model = clean_text(model or self.selected_model.get())
        if model and model not in {"Default", "Auto"}:
            return f"{label} · {model}"
        return label

    def _active_worker_jobs(self):
        active = []
        for job in self.worker_jobs:
            if clean_text(job.get("status")) in {"queued", "starting", "running"}:
                active.append(job)
        return active

    def _compact_worker_job(self, job):
        allowed = {
            "id",
            "source_session_id",
            "source_title",
            "session_id",
            "workspace_id",
            "title",
            "prompt",
            "agent",
            "model",
            "effort",
            "status",
            "created_at",
            "updated_at",
            "completed_at",
            "auto",
            "reason",
            "error",
            "request_signature",
        }
        return {
            key: value
            for key, value in dict(job or {}).items()
            if key in allowed and value not in (None, "")
        }

    def _save_worker_jobs(self):
        self.worker_jobs = [
            self._compact_worker_job(job)
            for job in self.worker_jobs[:100]
            if isinstance(job, dict)
        ]
        self.config["worker_jobs"] = self.worker_jobs
        save_json(CONFIG_FILE, self.config)

    def _record_worker_job(self, job):
        job = self._compact_worker_job(job)
        job_id = clean_text(job.get("id"))
        if not job_id:
            return
        for index, existing in enumerate(self.worker_jobs):
            if clean_text(existing.get("id")) == job_id:
                self.worker_jobs[index] = job
                break
        else:
            self.worker_jobs.insert(0, job)
        self._save_worker_jobs()
        self._update_worker_indicator()
        self._refresh_worker_dialog()

    def _mark_worker_job(self, session, status, error=None):
        job_id = clean_text((session or {}).get("worker_job_id"))
        if not job_id:
            return
        for job in self.worker_jobs:
            if clean_text(job.get("id")) != job_id:
                continue
            job["status"] = status
            job["updated_at"] = now_iso()
            if status in {"completed", "error", "cancelled", "interrupted"}:
                job["completed_at"] = now_iso()
            if error:
                job["error"] = clean_text(error)
            if session.get("id"):
                job["session_id"] = session.get("id")
            self._save_worker_jobs()
            self._update_worker_indicator()
            self._refresh_worker_dialog()
            return

    def _live_subagents(self):
        subs = self.workspaces.get(self.active_workspace_id, {}).get("live_subagents", [])
        return [s for s in subs if s.get("status", "running") == "running"]

    def _session_subagents(self):
        subs = self.workspaces.get(self.active_workspace_id, {}).get("live_subagents", [])
        return [s for s in subs if not s.get("model_inferred")]

    def _update_worker_indicator(self):
        workspace = self.workspaces.get(self.active_workspace_id) or {}
        agent_key = workspace.get("agent") or self.active_agent.get()
        model = workspace.get("model") or self.selected_model.get()
        active_count = len(self._active_worker_jobs()) + len(self._live_subagents())
        label = f"Sub-agents {active_count}"
        if len(self._active_worker_jobs()):
            label += f" · {self._worker_label(agent_key, model)}"
        self.worker_text.set(label)

    def _update_queue_indicator(self):
        workspace = self.workspaces.get(self.active_workspace_id) or {}
        queued = len(workspace.get("queued_prompts") or [])
        if queued:
            self.queue_text.set(f"Queue {queued}")
            self.queue_badge.configure(state="normal")
            self.queue_badge.pack(side="right", padx=(6, 0))
