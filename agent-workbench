    def new_workspace(self, agent_key=None):
        if self.close_when_idle and not self.restart_after_close:
            self.status.set("Workbench is waiting for active tasks to finish before closing.")
            return
        if agent_key is None:
            self.open_new_agent_dialog()
            return
        if agent_key not in self.agent_map:
            return
        self._save_active_workspace()
        self._schedule_workspace_config_save(immediate=True)
        previous_agent = self.active_agent.get()
        settings = self.agent_settings.get(
            agent_key,
            self._default_settings_for(agent_key),
        )
        self.active_agent.set(agent_key)
        self.selected_model.set(settings["model"])
        self.selected_effort.set(settings["effort"])
        workspace_id = self._create_workspace()
        self.active_agent.set(previous_agent)
        self.active_workspace_id = workspace_id
        self._restore_workspace(self.workspaces[workspace_id])
        session = self.store.new_session(
            agent_key,
            self.cwd.get(),
        )
        self.current_session = session
        self.local_sessions = [session]
        self.external_sessions = discover_external_sessions(
            self.cwd.get(), agent_key
        )
        self.sessions = self._combined_sessions()
        self.open_session(session["id"], remember=False)
        self._save_active_workspace()
        self._render_workspace_tabs()
        self.input.focus_set()

    def close_workspace(self, workspace_id):
        if len(self.workspace_order) == 1:
            return
        workspace = self.workspaces.get(workspace_id)
        if not workspace:
            return
        if workspace.get("busy") and not messagebox.askyesno(
            "Close working tab",
            "This agent is still working. Stop it and close the tab?",
            parent=self.win,
        ):
            return
        for backend in workspace["backends"].values():
            backend.close()
        was_active = workspace_id == self.active_workspace_id
        closing_index = self.workspace_order.index(workspace_id)
        self.workspace_order.remove(workspace_id)
        self.workspaces.pop(workspace_id, None)
        if was_active:
            next_index = min(closing_index, len(self.workspace_order) - 1)
            self.active_workspace_id = self.workspace_order[next_index]
            self._restore_workspace(self.workspaces[self.active_workspace_id])
        self._schedule_workspace_config_save(immediate=True)
        self._render_workspace_tabs()

    def cycle_workspace(self, direction):
        if len(self.workspace_order) < 2:
            return "break"
        index = self.workspace_order.index(self.active_workspace_id)
        target = self.workspace_order[(index + direction) % len(self.workspace_order)]
        self.switch_workspace(target)
        return "break"

    def _workspace_label(self, workspace):
        session = workspace.get("current_session") or {}
        title = clean_text(session.get("title")) or workspace.get("title") or "New session"
        agent = self._agent_spec(workspace.get("agent", "codex")).get("label", "Agent")
        marker = " •" if workspace.get("busy") else ""
        queued = len(workspace.get("queued_prompts") or [])
        queue_marker = f" · {queued} queued" if queued else ""
        return shorten(f"{agent}{queue_marker}: {title}{marker}", 42)

    def _working_workspace_labels(self):
        labels = []
        for workspace in self.workspaces.values():
            if not workspace.get("busy"):
                continue
            label = self._workspace_label(workspace)
            labels.append(label[:-2] if label.endswith(" •") else label)
        return labels

    def _maybe_finish_deferred_close(self):
        if not self.close_when_idle or self.finalizing_close:
            return
        working = self._working_workspace_labels()
        if working:
            self.win.title(f"{APP_NAME} · Waiting for {len(working)} task(s)")
            return
        self.finalize_close()

    def warn_interrupted_turns(self):
        interrupted = []
        for session in self.store.sessions.values():
            turns = session.get("turns") or []
            if not turns or turns[-1].get("status") != "running":
                continue
            turns[-1]["status"] = "interrupted"
            turns[-1]["completed_at"] = now_iso()
            self.store.save(session)
            agent = self._agent_spec(session.get("agent", "codex"))["label"]
            title = clean_text(session.get("title")) or "Untitled session"
            interrupted.append(f"{agent}: {shorten(title, 54)}")
        if not interrupted:
            return
        shown = interrupted[:8]
        suffix = (
            f"\n- +{len(interrupted) - len(shown)} more"
            if len(interrupted) > len(shown)
            else ""
        )
        messagebox.showwarning(
            "Previous work was interrupted",
            (
                "Agent Workbench previously closed before this work reported "
                "completion. Review or resume these sessions:\n\n- "
                + "\n- ".join(shown)
                + suffix
            ),
            parent=self.win,
        )

    def poll_update_request(self):
        if self.finalizing_close:
            return
        request = load_json(UPDATE_REQUEST_FILE, {})
        if request:
            try:
                os.unlink(UPDATE_REQUEST_FILE)
            except OSError:
                pass
            if int(request.get("pid") or 0) == os.getpid():
                self.request_restart()
        self.win.after(1000, self.poll_update_request)

    def _render_workspace_tabs(self):
        if self._workspace_tabs_render_after is not None:
            try:
                self.win.after_cancel(self._workspace_tabs_render_after)
            except tk.TclError:
                pass
        self._workspace_tabs_render_after = self.win.after_idle(self._render_workspace_tabs_now)

    def _render_workspace_tabs_now(self):
        if not hasattr(self, "workspace_tabs_frame"):
            return
        self._workspace_tabs_render_after = None
        signature = tuple(
            (
                workspace_id,
                workspace_id == self.active_workspace_id,
                self._workspace_label(self.workspaces[workspace_id]),
            )
            for workspace_id in self.workspace_order
            if workspace_id in self.workspaces
        )
        if signature == self._workspace_tabs_signature:
            return
        self._workspace_tabs_signature = signature
        for child in self.workspace_tabs_frame.winfo_children():
            child.destroy()
        for workspace_id in self.workspace_order:
            workspace = self.workspaces[workspace_id]
            selected = workspace_id == self.active_workspace_id
            frame = tk.Frame(
                self.workspace_tabs_frame,
                bg=SIDEBAR_SEL if selected else PANEL,
            )
            frame.pack(side="left", padx=(4, 0), pady=4)
            tk.Button(
                frame,
                text=self._workspace_label(workspace),
                command=lambda wid=workspace_id: self.switch_workspace(wid),
                bg=SIDEBAR_SEL if selected else PANEL,
                fg=TEXT,
                activebackground=SIDEBAR_SEL,
                activeforeground=TEXT,
                relief="flat",
                padx=10,
                pady=5,
                cursor="hand2",
            ).pack(side="left")
            tk.Button(
                frame,
                text="×",
                command=lambda wid=workspace_id: self.close_workspace(wid),
                bg=SIDEBAR_SEL if selected else PANEL,
                fg=MUTED,
                activebackground="#7f1d1d",
                activeforeground="white",
                relief="flat",
                padx=5,
                pady=5,
                cursor="hand2",
            ).pack(side="left")
        tk.Button(
