def session_search_blob(session, alias=""):
    parts = [
        clean_text(alias),
        clean_text(session.get("title")),
        clean_text(session.get("preview")),
        clean_text(session.get("agent")),
        clean_text(session.get("origin")),
        clean_text(session.get("source_session_id")),
        clean_text(session.get("id")),
    ]
    backend = session.get("backend") or {}
    parts.append(clean_text(backend.get("thread_id")))
    parts.append(clean_text(backend.get("session_id")))
    return " ".join(part for part in parts if part).lower()


def iso_from_unix(ts):
    try:
        return datetime.fromtimestamp(float(ts), tz=timezone.utc).isoformat()
    except Exception:
        return now_iso()


def read_jsonl_lines(path, limit=6):
    try:
        with open(path, encoding="utf-8") as handle:
            for _ in range(limit):
                line = handle.readline()
                if not line:
                    break
                yield json.loads(line)
    except (OSError, ValueError):
        return


def first_text_from_claude_jsonl(path):
    for obj in read_jsonl_lines(path, limit=40):
        if not isinstance(obj, dict):
            continue
        if obj.get("type") != "user":
            continue
        if obj.get("isMeta"):
            continue
        message = obj.get("message") or {}
        content = message.get("content")
        if isinstance(content, str):
            command = re.search(r"<command-name>(.*?)</command-name>", content, re.DOTALL)
            if command:
                text = clean_text(command.group(1))
                if text:
                    return text
            text = clean_text(content)
            if text:
                return text
        if isinstance(content, list):
            parts = []
            for bit in content:
                if isinstance(bit, dict) and bit.get("type") == "text":
                    parts.append(bit.get("text", ""))
            text = clean_text(" ".join(parts))
            if text:
                return text
    return ""


def claude_session_is_resumable(path):
    for obj in read_jsonl_lines(path, limit=80):
        if not isinstance(obj, dict):
            continue
        if obj.get("type") != "user" or obj.get("isMeta") or obj.get("isSidechain"):
            continue
        message = obj.get("message") or {}
        if message.get("role") == "user" and message.get("content"):
            return True
    return False


def claude_context_limit(model):
    model = clean_text(model).lower()
    if re.search(r"(?:opus-4-[678]|sonnet-4-6|fable-5)", model):
        return 1_000_000
    return 200_000


def context_from_usage(usage, model="", compact_count=0):
    if not isinstance(usage, dict):
        return {}
    used = sum(
        int(usage.get(key) or 0)
        for key in ("input_tokens", "cache_creation_input_tokens", "cache_read_input_tokens")
    )
    if used <= 0:
        return {}
    limit = claude_context_limit(model)
    return {
        "used": used,
        "limit": limit,
        "percent": min(100.0, used * 100.0 / limit),
        "model": clean_text(model),
        "compact_count": int(compact_count or 0),
    }


def claude_session_metadata(path):
    title = ""
    context = {}
    compact_count = 0
    has_custom_title = False
    has_ai_title = False
    try:
        with open(path, encoding="utf-8") as handle:
            for line in handle:
                try:
                    obj = json.loads(line)
                except (TypeError, ValueError):
                    continue
                if isinstance(obj, dict) and obj.get("type") in {
                    "ai-title",
                    "custom-title",
                }:
                    has_custom_title = (
                        has_custom_title or obj.get("type") == "custom-title"
                    )
                    has_ai_title = has_ai_title or obj.get("type") == "ai-title"
                    candidate = clean_text(
                        obj.get("customTitle") or obj.get("aiTitle")
                    )
                    if candidate:
                        title = candidate
                if (
                    isinstance(obj, dict)
                    and obj.get("type") == "system"
                    and obj.get("subtype") == "compact_boundary"
                ):
                    compact_count += 1
                    continue
                if not isinstance(obj, dict) or obj.get("type") != "assistant":
                    continue
                if obj.get("isSidechain"):
                    continue
                message = obj.get("message") or {}
                model = clean_text(message.get("model"))
                if not model or model == "<synthetic>":
                    continue
                candidate = context_from_usage(
                    message.get("usage") or {},
                    model,
                    compact_count,
                )
                if candidate:
                    context = candidate
    except OSError:
        return {
            "title": "",
            "context": {},
            "has_custom_title": False,
            "has_ai_title": False,
        }
    return {
        "title": title,
        "context": context,
        "has_custom_title": has_custom_title,
        "has_ai_title": has_ai_title,
    }


def claude_model_alias(model):
    value = clean_text(model).lower()
    for alias in ("fable", "opus", "sonnet", "haiku"):
        if alias in value:
            return alias
    return "Default"


def claude_jsonl_turns(path):
    turns = []
    current = None
    pending_text = []
    seen = set()
    tool_context = {}

    def ensure_turn(timestamp=""):
        nonlocal current
        if current is None:
            current = {
                "id": str(uuid.uuid4()),
                "created_at": clean_text(timestamp) or now_iso(),
                "status": "completed",
                "items": [],
            }
            turns.append(current)
        return current

    def flush_assistant_text(final=False):
        nonlocal pending_text
        if not pending_text:
            return
        turn = ensure_turn()
        for text in pending_text[:-1] if final else pending_text:
            turn["items"].append({"type": "system", "text": text, "tag": "progress"})
        if final:
            turn["items"].append({"type": "agentMessage", "text": pending_text[-1]})
        pending_text = []

    try:
        with open(path, encoding="utf-8") as handle:
            for line in handle:
                try:
                    obj = json.loads(line)
                except ValueError:
                    continue
                record_id = clean_text(obj.get("uuid"))
                if record_id and record_id in seen:
                    continue
                if record_id:
                    seen.add(record_id)
                if obj.get("isSidechain"):
                    continue
                record_type = obj.get("type")
                if record_type not in {"user", "assistant"}:
                    continue
                message = obj.get("message") or {}
                content = message.get("content")
                blocks = content if isinstance(content, list) else [{"type": "text", "text": content}]

                if record_type == "user":
                    text_parts = [
                        clean_text(block.get("text"))
                        for block in blocks
                        if isinstance(block, dict) and block.get("type") == "text"
                    ]
                    prompt = "\n".join(part for part in text_parts if part)
                    tool_results = [
                        block
                        for block in blocks
                        if isinstance(block, dict) and block.get("type") == "tool_result"
                    ]
                    if prompt:
                        # Strip harness-injected blocks (task notifications, system
                        # reminders) the user never typed. If nothing user-authored
                        # remains, this is a machine turn: flush the prior assistant text
                        # at the boundary but render NO "YOU" bubble for it.
                        visible_prompt = strip_harness_injections(prompt)
                        flush_assistant_text(final=True)
                        if visible_prompt:
                            current = {
                                "id": record_id or str(uuid.uuid4()),
                                "created_at": clean_text(obj.get("timestamp")) or now_iso(),
                                "status": "completed",
                                "items": [
                                    {
                                        "type": "userMessage",
                                        "content": [{"type": "text", "text": visible_prompt}],
                                    }
                                ],
                            }
                            turns.append(current)
                        else:
                            current = None
                    for result in tool_results:
                        output = result.get("content")
                        if isinstance(output, list):
                            output = "\n".join(
                                clean_text(bit.get("text"))
                                for bit in output
                                if isinstance(bit, dict) and bit.get("type") == "text"
                            )
                        text = clean_text(output)
                        if text:
                            tool_id = clean_text(result.get("tool_use_id"))
                            context = tool_context.get(tool_id) or {}
                            tool_name = context.get("name")
                            if tool_name in {"WebSearch", "WebFetch"}:
                                raw_text = ""
                                report_text = text
                                marker = "\n\nI found "
                                if marker in text:
                                    raw_text, readable = text.split(marker, 1)
                                    report_text = "I found " + readable
                                if raw_text:
                                    ensure_turn(obj.get("timestamp"))["items"].append(
                                        {"type": "system", "text": raw_text, "tag": "tool"}
                                    )
                                subject = clean_text(
                                    context.get("query") or context.get("url")
                                )
                                title = (
                                    "Research results"
                                    if not subject
                                    else "Research: " + shorten(subject, 72)
                                )
                                ensure_turn(obj.get("timestamp"))["items"].append(
                                    {
                                        "type": "report",
                                        "title": title,
                                        "text": report_text,
                                    }
                                )
                            else:
                                ensure_turn(obj.get("timestamp"))["items"].append(
                                    {
                                        "type": "system",
                                        "text": text,
                                        "tag": "system",
                                    }
                                )
                    continue

                for block in blocks:
                    if not isinstance(block, dict):
                        continue
                    block_type = block.get("type")
                    if block_type == "text":
                        text = clean_text(block.get("text"))
                        if text:
                            pending_text.append(text)
                    elif block_type == "thinking":
                        summary = clean_text(block.get("thinking"))
                        if summary:
                            ensure_turn(obj.get("timestamp"))["items"].append(
                                {"type": "reasoning", "summary": [summary]}
                            )
                    elif block_type == "tool_use":
                        flush_assistant_text(final=False)
                        name = clean_text(block.get("name"))
                        tool_input = block.get("input") or {}
                        tool_id = clean_text(block.get("id"))
                        if tool_id:
                            tool_context[tool_id] = {
                                "name": name,
                                "query": clean_text(tool_input.get("query")),
                                "url": clean_text(tool_input.get("url")),
                            }
                        if name == "Bash":
                            command = clean_text(tool_input.get("command"))
                            if command:
                                ensure_turn(obj.get("timestamp"))["items"].append(
                                    {"type": "commandExecution", "command": command}
                                )
                        elif name in {"Edit", "Write", "NotebookEdit"}:
                            path_value = clean_text(
                                tool_input.get("file_path")
                                or tool_input.get("notebook_path")
                                or tool_input.get("path")
                            )
                            changes = [{"path": path_value}] if path_value else []
                            ensure_turn(obj.get("timestamp"))["items"].append(
                                {"type": "fileChange", "changes": changes, "tool": name}
                            )
                        else:
                            detail = clean_text(
                                tool_input.get("description")
                                or tool_input.get("query")
                                or tool_input.get("file_path")
                            )
                            label = f"Tool: {name}" + (f" — {detail}" if detail else "")
                            ensure_turn(obj.get("timestamp"))["items"].append(
                                {"type": "system", "text": label, "tag": "tool"}
                            )
        flush_assistant_text(final=True)
    except OSError:
        return []
    return [turn for turn in turns if turn.get("items")]


def codex_rollout_turns(path):
    if not path or not os.path.isfile(path):
        return []
    turns = []
    current = None
    try:
        with open(path, encoding="utf-8") as handle:
            for line in handle:
                try:
                    obj = json.loads(line)
                except ValueError:
                    continue
                record_type = obj.get("type")
                if record_type not in {"event_msg", "response_item"}:
                    continue
                payload = obj.get("payload") or {}
                event_type = payload.get("type")
                text = ""
                item = None
                if record_type == "event_msg" and event_type == "user_message":
                    text = clean_text(payload.get("message"))
                    if not text:
                        continue
                    visible_text = visible_user_prompt_text(text) or text
                    current = {
                        "id": str(uuid.uuid4()),
                        "created_at": clean_text(obj.get("timestamp")) or now_iso(),
                        "status": "completed",
                        "items": [],
                    }
                    turns.append(current)
                    item = {
                        "type": "userMessage",
                        "content": [{"type": "text", "text": visible_text}],
                    }
                elif record_type == "event_msg" and event_type == "agent_message":
                    text = clean_text(payload.get("message"))
                    if not text:
                        continue
                    if current is None:
                        current = {
                            "id": str(uuid.uuid4()),
                            "created_at": clean_text(obj.get("timestamp")) or now_iso(),
                            "status": "completed",
                            "items": [],
                        }
                        turns.append(current)
                    if payload.get("phase") == "commentary":
                        item = {"type": "system", "text": text, "tag": "progress"}
                    else:
                        item = {"type": "agentMessage", "text": text}
                elif record_type == "response_item":
                    if current is None:
                        continue
                    if event_type == "function_call":
                        name = clean_text(payload.get("name"))
                        arguments = payload.get("arguments")
                        command = ""
                        if name == "exec_command" and isinstance(arguments, str):
                            try:
                                command = clean_text(json.loads(arguments).get("cmd"))
                            except (ValueError, AttributeError):
                                command = clean_text(arguments)
                        if command:
                            item = {"type": "commandExecution", "command": command}
                        elif name:
                            item = {
                                "type": "system",
                                "text": f"Tool: {name}",
                                "tag": "tool",
                            }
                    elif event_type == "custom_tool_call":
                        name = clean_text(payload.get("name"))
                        item = {
                            "type": "system",
                            "text": f"Tool: {name or 'custom tool'}",
                            "tag": "tool",
                        }
                    elif event_type in {"function_call_output", "custom_tool_call_output"}:
                        output = payload.get("output")
                        if isinstance(output, dict):
                            output = output.get("content") or output.get("output")
                        text = clean_text(output)
                        if text:
                            item = {"type": "system", "text": text, "tag": "system"}
                    elif event_type == "reasoning":
                        summary = payload.get("summary") or []
                        parts = []
                        for value in summary:
                            if isinstance(value, dict):
                                parts.append(value.get("text", ""))
                            else:
                                parts.append(str(value))
                        text = clean_text(" ".join(parts))
                        if text:
                            item = {"type": "reasoning", "summary": [text]}
                if item is not None:
                    current["items"].append(item)
    except OSError:
        return []
    return [turn for turn in turns if turn.get("items")]


def codex_context_from_rollout(path):
    context = {}
    if not path or not os.path.isfile(path):
        return context
    try:
        with open(path, encoding="utf-8") as handle:
            for line in handle:
                try:
                    obj = json.loads(line)
                except (TypeError, ValueError):
                    continue
                if obj.get("type") != "event_msg":
                    continue
                payload = obj.get("payload") or {}
                if payload.get("type") != "token_count":
                    continue
                info = payload.get("info") or {}
                usage = info.get("last_token_usage") or {}
                used = int(usage.get("input_tokens") or usage.get("total_tokens") or 0)
                limit = int(info.get("model_context_window") or 0)
                if used > 0 and limit > 0:
                    context = {
                        "used": used,
                        "limit": limit,
                        "percent": min(100.0, used * 100.0 / limit),
                        "model": "Codex",
                        "compact_count": 0,
                    }
    except OSError:
        return {}
    return context


def codex_thread_metadata(thread_id):
    db = os.path.expanduser("~/.codex/state_5.sqlite")
    thread_id = clean_text(thread_id)
    if not thread_id or not os.path.exists(db):
        return {}
    try:
        import sqlite3

        con = sqlite3.connect(db)
        con.row_factory = sqlite3.Row
        row = con.execute(
            "select id, rollout_path, title, preview, cwd, archived "
            "from threads where id = ?",
            (thread_id,),
        ).fetchone()
        return dict(row) if row else {}
    except Exception:
        return {}
    finally:
        try:
            con.close()
        except Exception:
            pass


