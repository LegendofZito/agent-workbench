    def _working_model_effort_label(self, workspace=None):
        workspace = workspace or self.workspaces.get(self.active_workspace_id) or {}
        agent = clean_text(workspace.get("agent")) or clean_text(self.active_agent.get())
        session = workspace.get("current_session") or {}
        backend = session.get("backend") or {}
        active_workspace = self.workspaces.get(self.active_workspace_id)
        selected_matches_workspace = (
            workspace is active_workspace
            or clean_text(workspace.get("id")) == clean_text(self.active_workspace_id)
        )

        def meaningful_model(value, live=False):
            value = clean_text(value)
            if not value or value in {"Default", "Auto"}:
                return ""
            value = re.sub(r"^ollama(_chat)?/", "", value)
            if agent == "claude" and live:
                alias = claude_model_alias(value)
                if alias != "Default":
                    return alias.title()
            return value

        model = (
            meaningful_model(workspace.get("running_model"))
            or meaningful_model(workspace.get("live_model"), live=True)
            or meaningful_model(backend.get("model"))
            or meaningful_model(workspace.get("model"))
        )
        if not model:
            client = next(
                (
                    item
                    for item in self.custom_clients
                    if clean_text(item.get("key")) == agent
                ),
                None,
            )
            if client:
                model = (
                    meaningful_model(client.get("model"))
                    or clean_text(client.get("label"))
                    or clean_text(client.get("key"))
                )
        if not model:
            if selected_matches_workspace and agent == clean_text(self.active_agent.get()):
                model = meaningful_model(self.selected_model.get())
        if not model:
            configured = (
                clean_text(backend.get("model"))
                or clean_text(workspace.get("model"))
                or (
                    clean_text(self.selected_model.get())
                    if selected_matches_workspace and agent == clean_text(self.active_agent.get())
                    else ""
                )
            )
            if configured in {"Default", "Auto"}:
                model = f"{self._agent_spec(agent).get('label', agent.title())} {configured.lower()}"
            else:
                model = self._agent_spec(agent).get("label", agent.title())

        effort = (
            clean_text(workspace.get("running_effort"))
            or
            clean_text(backend.get("effort"))
            or clean_text(workspace.get("effort"))
            or (
                clean_text(self.selected_effort.get())
                if selected_matches_workspace and agent == clean_text(self.active_agent.get())
                else ""
            )
        )
        if effort and effort != "Default":
            return f"{model} - {effort}"
        return model

    def _set_routine_working_status(self, workspace=None):
        # The right-side prompt-state badge already shows model/effort, elapsed
        # time, and tokens while working. Keep the left hint free for warnings.
        if workspace is not None:
            workspace["status"] = ""
        if workspace is None or workspace is self.workspaces.get(self.active_workspace_id):
            self.status.set("")

    def refresh_prompt_state(self):
        workspace = self.workspaces.get(self.active_workspace_id)
        if not workspace or self.finalizing_close:
            return
        self._update_worker_indicator()
        self._update_queue_indicator()
        token_text = format_token_usage(workspace.get("last_token_usage") or self.last_token_usage)
        if self.pending_user_input:
            text = "Awaiting your reply"
            bg, fg = "#3b1d4a", "#e9a8ff"
        elif self.busy or workspace.get("busy"):
            started = float(workspace.get("turn_started_at") or 0.0)
            last_event = float(workspace.get("last_event_at") or 0.0)
            elapsed = format_duration(time.monotonic() - started) if started else "0s"
            silence = time.monotonic() - last_event if last_event else 0.0
            queued = len(workspace.get("queued_prompts") or [])
            queue_text = f" · {queued} queued" if queued else ""
            live_tokens = int(workspace.get("live_token_count") or self.live_token_count or 0)
            token_suffix = (
                f" · streamed ~{format_token_count(live_tokens)} out"
                if live_tokens > 0
                else (f" · {token_text}" if token_text else "")
            )
            if silence >= TURN_STALLED_SECONDS:
                text = f"{elapsed}{token_suffix}{queue_text}"
                bg, fg = "#4a2b0b", "#fed7aa"
            else:
                text = f"{elapsed}{token_suffix}{queue_text}"
                bg, fg = "#3b2c0b", "#facc15"
        else:
            # The green activity badge already shows "Ready"; don't duplicate the
            # word here — show only the token / queue readout (blank when idle and
            # no turn has run yet).
            queued = len(workspace.get("queued_prompts") or [])
            parts = []
            if token_text:
                parts.append(token_text)
            if queued:
                parts.append(f"{queued} queued")
            text = " · ".join(parts)
            bg, fg = "#101824", "#cbd5e1"
        self.prompt_state_text.set(text)
        self.prompt_state_label.configure(bg=bg, fg=fg)
        self._update_project_state_indicator(self.current_session)
        self.win.after(1000, self.refresh_prompt_state)

    def animate_activity(self):
        if self.finalizing_close:
            return
        if self.activity_state == "working":
            dots = "." * ((self.activity_frame % 3) + 1)
            self.activity_dots.set(dots)
            self.activity_frame += 1
        else:
            self.activity_dots.set("")
        self.win.after(350, self.animate_activity)

    def _usage_handoff_status(self, session=None):
        target_id = clean_text((session or self.current_session or {}).get("id"))
        workspace_ids = []
        if self.active_workspace_id:
            workspace_ids.append(self.active_workspace_id)
        workspace_ids.extend(
            wid for wid in self.workspace_order if wid not in workspace_ids
        )
        for workspace_id in workspace_ids:
            workspace = self.workspaces.get(workspace_id)
            if not workspace:
                continue
            if target_id:
                current = workspace.get("current_session") or {}
                if clean_text(current.get("id")) != target_id:
                    continue
            usage = workspace.get("usage") or {}
            windows = usage.get("windows") or []
            if not windows:
                continue
            peak = None
            for window in windows:
                try:
                    percent = int(window.get("used_percent") or 0)
                except (TypeError, ValueError):
                    percent = 0
                if peak is None or percent > peak["percent"]:
                    peak = {
                        "percent": percent,
                        "label": clean_text(window.get("label")),
                        "reset": clean_text(window.get("reset")),
                        "provider": clean_text(usage.get("provider")),
                    }
            if peak and peak["percent"] >= 90:
                peak["active"] = True
                return peak
        return {"active": False, "percent": 0, "label": "", "reset": "", "provider": ""}

    def update_context_indicator(self, context=None):
        context = context or {}
        used = int(context.get("used") or 0)
        limit = int(context.get("limit") or 0)
        compact_count = int(context.get("compact_count") or 0)
        usage_handoff = self._usage_handoff_status()
        if used <= 0 or limit <= 0:
            self.context_text.set("Context Limit --")
            bg, fg, thumb = "#24303c", "#cbd5e1", "#64748b"
        else:
            percent = min(100, round(used * 100 / limit))
            used_label = f"{used / 1_000_000:.1f}M" if used >= 1_000_000 else f"{round(used / 1000)}K"
            limit_label = f"{limit // 1_000_000}M" if limit >= 1_000_000 else f"{limit // 1000}K"
            compact_label = f" · compacted {compact_count}×" if compact_count else ""
            self.context_text.set(
                f"Context Limit {percent}% · {used_label}/{limit_label}{compact_label}"
            )
            if percent < 40:
                bg, fg, thumb = "#16351f", "#bbf7d0", "#22c55e"
            elif percent < 60:
                bg, fg, thumb = "#3b350b", "#fef08a", "#eab308"
            elif percent < 80:
                bg, fg, thumb = "#4a2b0b", "#fed7aa", "#f97316"
            else:
                bg, fg, thumb = "#4a1d1d", "#fecaca", "#ef4444"
        self.context_badge.configure(bg=bg, fg=fg)
        self.chat.vbar.configure(background=thumb, activebackground=fg)
        percent = min(100, round(used * 100 / limit)) if used > 0 and limit > 0 else 0
        usage_active = bool(usage_handoff.get("active"))
        handoff_available = (
            percent >= CONTEXT_WARNING_PERCENT
            or compact_count > 0
            or usage_active
        )
        # "Urgent" = context is high OR rate-limit is active.
        # "Calm" = available only because the session has been compacted at low context —
        # the user may want a lossless handoff but it's not urgent.
        handoff_urgent = percent >= CONTEXT_WARNING_PERCENT or usage_active
        self.topbar_handoff_btn.configure(
            state="normal" if handoff_available else "disabled",
            cursor="hand2" if handoff_available else "arrow",
            bg="#c2410c" if handoff_urgent else ("#1a3a5c" if handoff_available else "#24303c"),
            fg="white" if handoff_urgent else ("#93c5fd" if handoff_available else "#64748b"),
            activebackground="#ea580c",
        )
        if handoff_available:
            show_banner = True
            if percent >= CONTEXT_CRITICAL_PERCENT:
                self.context_warning.configure(bg="#4a1d1d")
                self.context_warning_text.set(
                    f"Context is {percent}% full. Response quality and recall may degrade. "
                    "Hand off now to preserve the full working history."
                )
                self.topbar_handoff_btn.configure(
                    bg="#b91c1c", activebackground="#dc2626"
                )
                for child in self.context_warning.winfo_children():
                    if isinstance(child, tk.Label):
                        child.configure(bg="#4a1d1d", fg="#fecaca")
            elif usage_active:
                provider = usage_handoff.get("provider") or self._current_agent_label()
                label = usage_handoff.get("label") or "usage"
                reset = usage_handoff.get("reset")
                reset_note = f" Resets {reset}." if reset else ""
                self.context_warning.configure(bg="#4a1d1d")
                self.context_warning_text.set(
                    f"{provider} {label} usage is {usage_handoff.get('percent')}% used."
                    f"{reset_note} Hand off to another client to continue without waiting."
                )
                self.topbar_handoff_btn.configure(
                    bg="#b91c1c", activebackground="#dc2626"
                )
                for child in self.context_warning.winfo_children():
                    if isinstance(child, tk.Label):
                        child.configure(bg="#4a1d1d", fg="#fecaca")
            elif compact_count > 0 and percent < CONTEXT_WARNING_PERCENT:
                # Compaction-at-low-context: the footer "Context Limit … compacted N×"
                # badge already conveys this. Don't duplicate it as a top banner.
                show_banner = False
            else:
                self.context_warning.configure(bg="#4a2b0b")
                self.context_warning_text.set(
                    f"Context is {percent}% full. A fresh session is recommended before "
                    "quality begins to decline."
                )
                for child in self.context_warning.winfo_children():
                    if isinstance(child, tk.Label):
                        child.configure(bg="#4a2b0b", fg="#ffedd5")
            if show_banner:
                self.context_warning.grid(row=0, column=0, sticky="ew", pady=(0, 3))
            else:
                self.context_warning.grid_remove()
        else:
            self.context_warning.grid_remove()

    def _display_usage(self, usage):
        # HARD LOCK: percentages only. Never render request-count ("N req/24h") text.
        windows = usage.get("windows") or []
        if not windows:
            # No percentage available — keep the last good % if we have one, else "--".
            if not clean_text(self.usage_text.get()).replace("Usage:", "").strip(" -"):
                self.usage_text.set("Usage: --")
            self.usage_badge.configure(bg="#1a2432", fg="#dbeafe")
            return
        shown = [
            f"{int(window.get('used_percent') or 0)}% {window.get('label')}"
            for window in windows
            if window.get("label") in {"5h", "week"}
        ]
        if not shown:
            shown = [
                f"{int(window.get('used_percent') or 0)}% {window.get('label')}"
                for window in windows[:2]
            ]
        self.usage_text.set("Usage: " + " · ".join(shown))
        peak = max(int(window.get("used_percent") or 0) for window in windows)
        if peak >= 90:
            colors = ("#4a1d1d", "#fecaca")
        elif peak >= 70:
            colors = ("#4a2b0b", "#fed7aa")
        else:
            colors = ("#16351f", "#bbf7d0")
        self.usage_badge.configure(bg=colors[0], fg=colors[1])
        # Update the limits popover if it is open
        populate = getattr(self, "_limits_popover_populate", None)
        if callable(populate):
            populate(usage)

    def refresh_usage(self, manual=True):
        workspace = self.workspaces.get(self.active_workspace_id)
        if not workspace:
            return
        agent = workspace.get("agent")
        if agent not in {"claude", "codex"}:
            if manual:
                self.status.set(
                    f"Account-limit telemetry is not available for "
                    f"{self._agent_spec(agent)['label']}."
                )
            return
        if workspace.get("usage_refreshing"):
            if manual:
                cached_usage = workspace.get("usage") or {}
                if cached_usage:
                    self._display_usage(cached_usage)
                self.status.set(
                    f"{self._agent_spec(agent)['label']} limits are already refreshing…"
                )
            return
        cached_usage = workspace.get("usage") or {}
        if cached_usage:
            self._display_usage(cached_usage)
        workspace["usage_refreshing"] = True
        if manual:
            if cached_usage:
                self.status.set(
                    f"Refreshing {self._agent_spec(agent)['label']} account limits in the background…"
                )
            else:
                self.status.set(
                    f"Loading {self._agent_spec(agent)['label']} account limits…"
                )
        session = workspace.get("current_session") or {}
        source_path = clean_text(session.get("source_path"))
        workspace_id = workspace["id"]

        def load():
            usage = (
                claude_usage_limits()
                if agent == "claude"
                else codex_usage_limits(source_path)
            )
            self.events.put(
                {
                    "kind": "usage_updated",
                    "workspace_id": workspace_id,
                    "agent": agent,
                    "usage": usage,
                    "manual": manual,
                }
            )

        threading.Thread(target=load, daemon=True).start()

    def _usage_workspace_for_agent(self, agent):
        active = self.workspaces.get(self.active_workspace_id)
        if active and active.get("agent") == agent:
            return active
        for workspace_id in self.workspace_order:
            workspace = self.workspaces.get(workspace_id)
            if workspace and workspace.get("agent") == agent:
                return workspace
        return None

    def refresh_agent_usage(self, agent, manual=False):
        agent = clean_text(agent)
        if agent not in {"claude", "codex"}:
            return
        if agent in self.agent_usage_refreshing:
            return
        workspace = self._usage_workspace_for_agent(agent)
        if not workspace:
            return
        self.agent_usage_refreshing.add(agent)
        workspace["usage_refreshing"] = True
        session = workspace.get("current_session") or {}
        source_path = clean_text(session.get("source_path"))
        workspace_id = workspace.get("id")

        def load():
            usage = (
                claude_usage_limits()
                if agent == "claude"
                else codex_usage_limits(source_path)
            )
            self.events.put(
                {
                    "kind": "usage_updated",
                    "workspace_id": workspace_id,
                    "agent": agent,
                    "usage": usage,
                    "manual": manual,
                    "global_agent_usage": True,
                }
            )

        threading.Thread(target=load, daemon=True).start()

    def poll_usage(self):
        if self.finalizing_close:
            return
        open_agents = {
            clean_text((self.workspaces.get(workspace_id) or {}).get("agent"))
            for workspace_id in self.workspace_order
        }
        for agent in sorted(open_agents):
            if agent in {"claude", "codex"}:
                self.refresh_agent_usage(agent, manual=False)
        self.win.after(90000, self.poll_usage)

    def _open_limits_popover(self):
        """Open a small popover below the Limits badge showing reset times."""
        # Dismiss any existing popover
        if hasattr(self, "_limits_popover") and self._limits_popover and self._limits_popover.winfo_exists():
            self._limits_popover.destroy()
            self._limits_popover = None
            self._limits_popover_populate = None
            self._limits_popover_body = None
            return
        pop = tk.Toplevel(self.win)
        pop.overrideredirect(True)
        pop.configure(bg=PANEL, highlightbackground=BORDER, highlightthickness=1)
        self._limits_popover = pop

        def _place_popover():
            """Size to content and place it right-aligned under the badge, clamped
            on-screen so the reset times never get clipped at the window edge."""
            try:
                pop.update_idletasks()
                pw = max(pop.winfo_reqwidth(), 300)
                ph = pop.winfo_reqheight()
                screen_w = self.win.winfo_screenwidth()
                bx = self.usage_badge.winfo_rootx()
                badge_w = self.usage_badge.winfo_width()
                by = self.usage_badge.winfo_rooty() + self.usage_badge.winfo_height() + 4
                x = bx + badge_w - pw  # right edge aligns with the badge's right edge
                x = max(8, min(x, screen_w - pw - 8))  # never run off either edge
                pop.geometry(f"{pw}x{ph}+{x}+{by}")
            except tk.TclError:
                pass

        tk.Label(
            pop,
            text="Account Usage",
            bg=PANEL,
            fg=TEXT,
            font=("Sans", 10, "bold"),
            anchor="w",
            padx=10,
            pady=6,
        ).pack(fill="x")
        tk.Frame(pop, bg=BORDER, height=1).pack(fill="x")

        body = tk.Frame(pop, bg=PANEL)
        body.pack(fill="x", padx=10, pady=8)
        self._limits_popover_body = body

        def _populate_limits_body(usage):
            if not hasattr(self, "_limits_popover_body"):
                return
            if not self._limits_popover_body.winfo_exists():
                return
            b = self._limits_popover_body
            for child in b.winfo_children():
                child.destroy()
            windows = usage.get("windows") or []
            if usage.get("error") and not windows:
                tk.Label(
                    b,
                    text=usage.get("error", "No limit data available."),
                    bg=PANEL,
                    fg=MUTED,
                    font=("Sans", 9),
                    anchor="w",
                    wraplength=280,
                    justify="left",
                ).pack(fill="x", pady=(0, 4))
            else:
                for window in windows:
                    lbl = clean_text(window.get("label")) or ""
                    pct = int(window.get("used_percent") or 0)
                    reset = clean_text(window.get("reset")) or "—"
                    row = tk.Frame(b, bg=PANEL)
                    row.pack(fill="x", pady=2)
                    tk.Label(
                        row,
                        text=f"{lbl}:",
                        bg=PANEL,
                        fg=MUTED,
                        font=("Sans", 9),
                        anchor="w",
                        width=10,
                    ).pack(side="left")
                    tk.Label(
                        row,
                        text=f"{pct}% used · resets {reset}",
                        bg=PANEL,
                        fg=TEXT,
                        font=("Sans", 9),
                        anchor="w",
                    ).pack(side="left", fill="x", expand=True)
            # Re-fit + reposition (usage arrives async; keep it on-screen so the
            # reset times never get clipped at the window edge).
            _place_popover()

        # Store the populator so _display_usage can call it
        self._limits_popover_populate = _populate_limits_body

        # Show cached data immediately if available
        workspace = self.workspaces.get(self.active_workspace_id) or {}
        cached = workspace.get("usage") or {}
        if cached.get("windows"):
            _populate_limits_body(cached)
        else:
            tk.Label(
                body,
                text="Loading…",
                bg=PANEL,
                fg=MUTED,
                font=("Sans", 9),
                anchor="w",
            ).pack(fill="x")

        tk.Frame(pop, bg=BORDER, height=1).pack(fill="x")
        btn_row = tk.Frame(pop, bg=PANEL)
        btn_row.pack(fill="x", padx=8, pady=6)
        tk.Button(
            btn_row,
            text="Refresh",
            command=lambda: self.refresh_usage(manual=True),
            bg=PANEL_ALT,
            fg=MUTED,
            activebackground=SIDEBAR_SEL,
            activeforeground=TEXT,
            font=("Sans", 9),
            relief="flat",
            padx=10,
            pady=4,
            cursor="hand2",
        ).pack(side="left")
        tk.Button(
            btn_row,
            text="Close",
            command=pop.destroy,
            bg=PANEL_ALT,
            fg=MUTED,
            activebackground=SIDEBAR_SEL,
            activeforeground=TEXT,
            font=("Sans", 9),
            relief="flat",
            padx=10,
            pady=4,
            cursor="hand2",
        ).pack(side="right")

        # Position below the badge, right-aligned and clamped on-screen
        self.win.update_idletasks()
        _place_popover()
        pop.lift()
        pop.focus_force()

        def _dismiss(event=None):
            if pop.winfo_exists():
                pop.destroy()
            self._limits_popover = None
            self._limits_popover_populate = None
            self._limits_popover_body = None

        pop.bind("<FocusOut>", _dismiss)
        pop.bind("<Escape>", _dismiss)

        # Kick off a refresh so the popover gets live data
        self.refresh_usage(manual=False)

