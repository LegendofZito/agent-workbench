def detect_provider(key):
    """Return the first matching API_PROVIDERS tuple for *key*, or None."""
    key = key.strip() if key else ""
    if not key:
        return None
    for entry in API_PROVIDERS:
        label, env_var, pattern, inject_default = entry
        if pattern and re.search(pattern, key):
            return entry
    return None


