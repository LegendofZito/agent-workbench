        sequence_frame.pack(fill="x", pady=(0, 8))
        tk.Label(sequence_frame, text="Sequence", bg=BG, fg=MUTED).pack(anchor="w")
        sequence_pickers = []
        for index in range(HANDOFF_SEQUENCE_SLOTS):
            picker = ttk.Combobox(
                sequence_frame,
                textvariable=sequence_vars[index],
                values=[spec["key"] for spec in self.agent_specs],
                state="readonly",
                style="Agent.TCombobox",
            )
            picker.pack(fill="x", pady=(4 if index == 0 else 2, 0))
            sequence_pickers.append(picker)

        policy_frame = tk.Frame(body, bg=BG)
        policy_frame.pack(fill="x", pady=(0, 10))
        tk.Checkbutton(
            policy_frame,
            text="Auto deploy staged handoffs when ready",
            variable=auto_deploy_var,
            bg=BG,
            fg=TEXT,
            selectcolor=BG,
            activebackground=BG,
            activeforeground=TEXT,
        ).pack(anchor="w")
        tk.Checkbutton(
            policy_frame,
            text="Prefer cheaper worker models",
            variable=prefer_cheap_var,
            bg=BG,
            fg=TEXT,
            selectcolor=BG,
            activebackground=BG,
            activeforeground=TEXT,
        ).pack(anchor="w", pady=(2, 0))

        def sync_controls(*_args):
            fixed_picker.configure(state="readonly" if mode_var.get() == "fixed" else "disabled")
            enabled = mode_var.get() == "sequence"
            for picker in sequence_pickers:
                picker.configure(state="readonly" if enabled else "disabled")

        mode_var.trace_add("write", sync_controls)
        sync_controls()

        def save():
            sequence = []
            for var in sequence_vars:
                value = clean_text(var.get())
                if value and value in self.agent_map and value not in sequence:
                    sequence.append(value)
            self.handoff_preferences = {
                "mode": clean_text(mode_var.get()) or "current",
                "fixed_agent": clean_text(fixed_agent_var.get()),
                "sequence": sequence,
                "auto_deploy": bool(auto_deploy_var.get()),
                "prefer_cheap_models": bool(prefer_cheap_var.get()),
