def _humanize_skill_desc(raw):
    """Turn a model-facing SKILL.md description into a short human one: strip the
    'This skill should be used when…' boilerplate and keep the first sentence."""
    text = clean_text(raw)
    if not text:
        return ""
    low = text.lower()
    for prefix in (
        "this skill should be used when the user asks to",
        "this skill should be used when the user",
        "this skill should be used when",
        "this skill should be used to",
        "use this skill when the user",
        "use this skill to",
        "use this skill when",
        "use when the user asks",
        "use when the user",
        "use when",
        "use this when",
    ):
        if low.startswith(prefix):
            text = text[len(prefix):].lstrip(" ,:-")
            break
    for sep in (". ", ".\n", "; "):
        idx = text.find(sep)
        if idx != -1:
            text = text[: idx + 1]
            break
    text = text.strip().strip('"')
    if text and text[0].islower():
        text = text[0].upper() + text[1:]
    return text[:120]


def discover_skills(cwd):
    """Return a sorted, de-duped list of skill dicts {name, description, source}.

    Scans SKILL.md files under personal, project, and plugin directories in
    addition to the built-in list.  Never raises; returns what it can find.
    """
    try:
        seen = {}  # name -> dict; first-seen wins
        # Built-ins first (win over plugins on collision)
        for name, desc in BUILTIN_SKILLS:
            seen[name] = {"name": name, "description": desc, "source": "built-in"}

        scan_dirs = []
        home = os.path.expanduser("~")
        # personal skills
        scan_dirs.append((os.path.join(home, ".claude", "skills"), "personal"))
        # project skills
        if cwd:
            scan_dirs.append((os.path.join(cwd, ".claude", "skills"), "project"))
        # plugin skills (two sub-layouts)
        plugins_root = os.path.join(home, ".claude", "plugins", "marketplaces")
        if os.path.isdir(plugins_root):
            for mp in os.listdir(plugins_root):
                mp_path = os.path.join(plugins_root, mp)
                for sub in ("plugins", "external_plugins"):
                    sub_path = os.path.join(mp_path, sub)
                    if os.path.isdir(sub_path):
                        for plugin in os.listdir(sub_path):
                            skills_dir = os.path.join(sub_path, plugin, "skills")
                            scan_dirs.append((skills_dir, "plugin"))

        for skills_root, source in scan_dirs:
            if not os.path.isdir(skills_root):
                continue
            try:
                for skill_dir in os.listdir(skills_root):
                    skill_md = os.path.join(skills_root, skill_dir, "SKILL.md")
                    if not os.path.isfile(skill_md):
                        continue
                    try:
                        name = None
                        desc = None
                        with open(skill_md, encoding="utf-8", errors="replace") as fh:
                            lines = fh.readlines()
                        in_front = False
                        dash_count = 0
                        for raw_line in lines:
                            stripped = raw_line.strip()
                            if stripped == "---":
                                dash_count += 1
                                if dash_count == 1:
                                    in_front = True
                                    continue
                                if dash_count == 2:
                                    break
                            if not in_front:
                                continue
                            if stripped.startswith("name:"):
                                name = stripped[5:].strip().strip('"').strip("'")
                            elif stripped.startswith("description:"):
                                desc = stripped[12:].strip().strip('"').strip("'")
                        if not name:
                            name = skill_dir
                        if not desc:
                            desc = ""
                        desc = desc[:140]
                        if name not in seen:
                            seen[name] = {"name": name, "description": desc, "source": source}
                    except Exception:
                        pass
            except Exception:
                pass

        # Prefer a clear human blurb; otherwise strip boilerplate from the raw text.
        for entry in seen.values():
            entry["description"] = SKILL_BLURBS.get(entry["name"]) or _humanize_skill_desc(
                entry["description"]
            )
        return sorted(seen.values(), key=lambda s: s["name"])
    except Exception:
        return [{"name": n, "description": d, "source": "built-in"} for n, d in BUILTIN_SKILLS]


def discover_external_sessions(cwd, agent_key):
    if agent_key == "codex":
        return codex_sessions_for_cwd(cwd)
    if agent_key == "claude":
        return claude_sessions_for_cwd(cwd)
    if agent_key == "gemini":
        return gemini_sessions_for_cwd(cwd)
    return []


def summarize_turn_items(turns, max_chars=7000):
    lines = []
    remaining = max_chars
    for turn in turns[-12:]:
        for item in turn.get("items") or []:
            typ = item.get("type", "")
            text = ""
            if typ == "userMessage":
                parts = []
                for bit in item.get("content") or []:
                    if isinstance(bit, dict) and bit.get("type") == "text":
                        parts.append(bit.get("text", ""))
                text = " ".join(parts)
                prefix = "USER"
            elif typ == "agentMessage":
                text = item.get("text") or item.get("content") or ""
                prefix = "AGENT"
            elif typ == "commandExecution":
                text = item.get("command") or ""
                prefix = "COMMAND"
            elif typ == "fileChange":
                paths = []
                for change in item.get("changes") or []:
                    path = change.get("path") or change.get("filePath")
                    if path:
                        paths.append(str(path))
                text = ", ".join(paths)
                prefix = "FILES"
            elif typ == "reasoning":
                text = " ".join(item.get("summary") or [])
                prefix = "REASONING"
            elif typ == "plan":
                text = item.get("text") or ""
                prefix = "PLAN"
            else:
                text = item.get("text") or item.get("summary") or ""
                prefix = typ.upper() or "NOTE"
            text = clean_text(text)
            if not text:
                continue
            line = f"{prefix}: {text}"
            if len(line) > remaining:
                lines.append(line[: max(0, remaining - 1)] + "…")
                return "\n".join(lines)
            lines.append(line)
            remaining -= len(line) + 1
            if remaining <= 0:
                return "\n".join(lines)
    return "\n".join(lines)


def item_text(item):
    typ = item.get("type", "")
    if typ == "userMessage":
        return clean_text(
            " ".join(
                bit.get("text", "")
                for bit in item.get("content") or []
                if isinstance(bit, dict) and bit.get("type") == "text"
            )
        )
    if typ == "fileChange":
        return clean_text(
            ", ".join(
                str(change.get("path") or change.get("filePath") or "")
                for change in item.get("changes") or []
                if change.get("path") or change.get("filePath")
            )
        )
    if typ == "reasoning":
        return clean_text(" ".join(item.get("summary") or []))
    return clean_text(
        item.get("text")
        or item.get("content")
        or item.get("command")
        or item.get("summary")
        or ""
    )


def structured_handoff_packet(session, max_chars=HANDOFF_MAX_CHARS):
    title = clean_text(session.get("title") or session.get("preview") or "Untitled")
    agent = clean_text(session.get("agent") or "agent").title()
    cwd = clean_text(session.get("cwd") or os.path.expanduser("~"))
    context = session.get("context") or {}

    first_user_request = ""
    last_agent_conclusion = ""
    upgrades = []
    failures = []
    unresolved = []
    commands = []
    file_changes = []
    decisions = []

    def last_line(text):
        """Return the last non-empty line of text, stripped."""
        lines = [l.strip() for l in text.splitlines() if l.strip()]
        return lines[-1] if lines else text.strip()

    def truncate(text, limit=160):
        text = re.sub(r"\s+", " ", clean_text(text)).strip()
        return text[:limit - 1].rstrip() + "…" if len(text) > limit else text

    def deduped(values, limit=12):
        seen = set()
        result = []
        for v in values:
            key = re.sub(r"\s+", " ", v).strip().lower()
            if key and key not in seen:
                seen.add(key)
                result.append(v)
                if len(result) >= limit:
                    break
        return result

    def bullets(values, fallback="None recorded."):
        items = deduped(values)
        return ("\n".join(f"- {v}" for v in items)) if items else f"- {fallback}"

    def section(header, values, fallback="None recorded."):
        return f"## {header}\n{bullets(values, fallback)}"

    for turn_index, turn in enumerate(session.get("turns") or [], start=1):
        user_texts = []
        agent_texts = []
        for item in turn.get("items") or []:
            typ = item.get("type", "")
            text = item_text(item)
            if not text:
                continue
            if typ == "userMessage":
                user_texts.append(text)
                if not first_user_request:
                    first_user_request = truncate(text, 300)
            elif typ == "agentMessage":
                agent_texts.append(text)
                last_agent_conclusion = text
                lowered = text.lower()
                if re.search(
                    r"\b(added|built|implemented|upgraded|updated|fixed|created|installed|"
                    r"changed|wired|enabled|completed|now supports)\b",
                    lowered,
                ):
                    upgrades.append(truncate(last_line(text)))
                if re.search(
                    r"\b(failed|failure|error|blocked|unable|could not|couldn't|"
                    r"timeout|timed out|stalled|broken|regression)\b",
                    lowered,
                ):
                    failures.append(truncate(last_line(text)))
                if re.search(
                    r"\b(todo|remaining|unresolved|not yet|still needs|follow[- ]?up|"
                    r"deferred|later|next step|open question)\b",
                    lowered,
                ):
                    unresolved.append(truncate(last_line(text)))
                if re.search(
                    r"\b(decided|decision|chose|choosing|approach|strategy|will use|going with)\b",
                    lowered,
                ):
                    decisions.append(truncate(last_line(text)))
            elif typ == "commandExecution":
                commands.append(truncate(text))
            elif typ == "fileChange":
                file_changes.append(truncate(text))
            elif typ == "plan":
                decisions.append(truncate(last_line(text)))
            elif typ == "note":
                if text.startswith("ERROR:"):
                    failures.append(truncate(f"Turn {turn_index}: {text}"))
        if user_texts and not agent_texts:
            unresolved.append(truncate(last_line(user_texts[-1])))
        if turn.get("status") not in {None, "completed"}:
            failures.append(truncate(
                f"Turn {turn_index} ended as {turn.get('status')}: "
                f"{clean_text(turn.get('prompt')) or 'no prompt'}"
            ))

    def detect_project_commands(cwd):
        """Return (bullets: list[str], is_software_project: bool) for the project at cwd."""
        result = []
        is_software = False
        if not cwd or not os.path.isdir(cwd):
            result += [
                f'cd "{cwd or os.path.expanduser("~")}"',
                "git status",
                "git log --oneline -10",
                "ls",
            ]
            return result, False

        pkg_json = os.path.join(cwd, "package.json")
        if os.path.isfile(pkg_json):
            is_software = True
            try:
                with open(pkg_json, encoding="utf-8") as fh:
                    pkg = json.load(fh)
            except Exception:
                pkg = {}
            scripts = pkg.get("scripts") or {}
            deps_all = {**pkg.get("dependencies", {}), **pkg.get("devDependencies", {})}
            script_text = json.dumps(scripts).lower()
            has_tauri = os.path.isdir(os.path.join(cwd, "src-tauri")) or "tauri" in script_text or "tauri" in " ".join(deps_all).lower()
            result.append("pnpm install — install deps")
            for name, desc in [("dev", "start dev server"), ("build", "production build"),
                                ("test", "run tests"), ("check", "type-check"),
                                ("lint", "lint code")]:
                if name in scripts:
                    result.append(f"pnpm {name} — {desc}")
            if has_tauri:
                result.append("pnpm tauri dev — launch Tauri desktop app")
                result.append("pnpm tauri build — build distributable")

        cargo = os.path.join(cwd, "Cargo.toml")
        if os.path.isfile(cargo):
            is_software = True
            result += ["cargo build — compile", "cargo test — run tests", "cargo run — run binary"]

        has_py = os.path.isfile(os.path.join(cwd, "pyproject.toml")) or \
                 os.path.isfile(os.path.join(cwd, "requirements.txt")) or \
                 any(f.endswith(".py") for f in (os.listdir(cwd) if os.path.isdir(cwd) else []))
        if has_py:
            is_software = True
            if os.path.isfile(os.path.join(cwd, "pyproject.toml")):
                result.append("python3 -m pytest — run tests")
            else:
                result.append("python3 <script>.py — run entry point")

        result += [f'cd "{cwd}"', "git status", "git log --oneline -10", "ls"]
        # Cap to 6 most relevant; dedupe
        seen, final = set(), []
        for item in result:
            k = item.lower().strip()
            if k not in seen:
                seen.add(k)
                final.append(item)
            if len(final) >= 6:
                break
        return final, is_software

    # Build overview: goal from first user request, state from last agent conclusion
    last_conclusion_line = truncate(last_line(last_agent_conclusion), 300) if last_agent_conclusion else "No agent response recorded."
    overview_goal = first_user_request or "No user request recorded."
    overview = f"Goal: {overview_goal}\nState: {last_conclusion_line}"

    # Current status: what's being built + latest turn outcome
    last_turn = (session.get("turns") or [{}])[-1]
    last_turn_status = last_turn.get("status") or "completed"
    last_action = truncate(last_line(last_agent_conclusion), 200) if last_agent_conclusion else "No agent response recorded."
    outcome_note = "" if last_turn_status in {None, "completed"} else f" (last turn ended: {last_turn_status})"
    current_status = f"Working on: {overview_goal}\nLatest: {last_action}{outcome_note}"

    used = int(context.get("used") or 0)
    limit_val = int(context.get("limit") or 0)
    context_line = (
        f"{round(used * 100 / limit_val)}% ({used:,}/{limit_val:,} tokens)"
        if used > 0 and limit_val > 0
        else "unknown"
    )

    cmd_bullets, is_sw_project = detect_project_commands(cwd)
    parts = [
        "# Automatic Session Handoff",
        f"- Source title: {title}",
        f"- Source client: {agent}",
        f"- Project directory: {cwd}",
        f"- Source context usage: {context_line}",
        f"- Generated: {now_iso()}",
        "",
        f"## Overview\n{overview}",
        "",
        f"## Current status\n{current_status}",
        "",
        section("What went right", upgrades[-12:]),
        "",
        section("What went wrong / blockers", failures[-12:]),
        "",
        section("Updates applied", (file_changes + commands)[-12:]),
        "",
        section("Key decisions", decisions[-12:]),
        "",
        section("Open items & next steps", unresolved[-12:]),
        "",
        "## Useful commands\n" + "\n".join(f"- {b}" for b in cmd_bullets),
        "",
        "## Continuation Instructions",
        "- Treat this packet as authoritative context from the previous session.",
        "- Preserve completed work and do not repeat failed approaches without a reason.",
        "- Address unresolved items when they are relevant, even if the prior conversation moved on.",
        "- Inspect the current filesystem before assuming recorded file state is still current.",
        "- Continue the user's latest objective directly after a brief acknowledgment.",
    ] + (["- Before changing anything, orient yourself in the program — read its structure, run `git status`, and run the build/check command listed above — so you know the current state before acting."] if is_sw_project else [])
    packet = "\n".join(parts)
    if len(packet) > max_chars:
        packet = packet[: max_chars - 160].rstrip() + (
            "\n\n[Handoff truncated at the configured safety limit. "
            "The categorized sections above take priority.]"
        )
    return packet


def turn_failure_text(status, error, session):
    error = clean_text(error)
    if error:
        return error
    backend = (session or {}).get("backend") or {}
    model = clean_text(backend.get("model"))
    model_note = f" using {model}" if model else ""
    return (
        f"The client ended this turn as '{status}'{model_note} without producing "
        "an assistant response. Retry the turn or choose another supported model."
    )


def format_reset_time(timestamp):
    try:
        moment = datetime.fromtimestamp(float(timestamp), tz=timezone.utc).astimezone()
        return moment.strftime("%b %-d, %-I:%M%p").replace("AM", "am").replace("PM", "pm")
    except (TypeError, ValueError, OSError):
        return ""


def codex_usage_limits(source_path=""):
    candidates = []
    if source_path and os.path.isfile(source_path):
        candidates.append(source_path)
    root = Path(os.path.expanduser("~/.codex/sessions"))
    try:
        candidates.extend(
            str(path)
            for path in sorted(
                root.rglob("*.jsonl"),
                key=lambda path: path.stat().st_mtime_ns,
                reverse=True,
            )[:12]
            if str(path) not in candidates
        )
    except OSError:
        pass
    for path in candidates:
        latest = None
        try:
            with open(path, encoding="utf-8") as handle:
                for line in handle:
                    if '"rate_limits"' not in line:
                        continue
                    try:
                        event = json.loads(line)
                    except ValueError:
                        continue
                    rate_limits = (event.get("payload") or {}).get("rate_limits")
                    if isinstance(rate_limits, dict):
                        latest = rate_limits
        except OSError:
            continue
        if not latest:
            continue
        windows = []
        for key in ("primary", "secondary"):
            value = latest.get(key) or {}
            if not isinstance(value, dict) or value.get("used_percent") is None:
                continue
            minutes = int(value.get("window_minutes") or 0)
            label = "5h" if minutes and minutes <= 360 else "week"
            windows.append(
                {
                    "label": label,
                    "used_percent": round(float(value.get("used_percent") or 0)),
                    "reset": format_reset_time(value.get("resets_at")),
                }
            )
        if windows:
            return {"provider": "Codex", "windows": windows}
    return {"provider": "Codex", "windows": [], "error": "No rate-limit telemetry yet."}


def claude_usage_limits():
    try:
        result = subprocess.run(
            [
                "claude",
                "-p",
                "/usage",
                "--output-format",
                "json",
                "--permission-mode",
                "default",
                "--tools",
                "",
                "--no-session-persistence",
            ],
            cwd=os.path.expanduser("~"),
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=20,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired) as exc:
        return {"provider": "Claude", "windows": [], "error": str(exc)}
    try:
        payload = json.loads(result.stdout or "{}")
        text = clean_text(payload.get("result"))
    except ValueError:
        text = clean_text(result.stdout)
    windows = []
    patterns = (
        ("5h", r"Current session:\s*(\d+)% used\s*·\s*resets\s*(.+)"),
        ("week", r"Current week \(all models\):\s*(\d+)% used\s*·\s*resets\s*(.+)"),
        ("sonnet", r"Current week \(Sonnet only\):\s*(\d+)% used\s*·\s*resets\s*(.+)"),
    )
    for label, pattern in patterns:
        match = re.search(pattern, text, flags=re.IGNORECASE)
        if match:
            windows.append(
                {
                    "label": label,
                    "used_percent": int(match.group(1)),
                    "reset": clean_text(match.group(2)),
                }
            )
    if windows:
        return {"provider": "Claude", "windows": windows}
    return {
        "provider": "Claude",
        "windows": [],
        "error": text or "Claude did not return usage details.",
    }


class SessionStore:
    def __init__(self):
        ensure_dir(CONFIG_DIR)
        ensure_dir(SESSIONS_DIR)
        ensure_dir(ARTIFACTS_DIR)
        self.sessions = {}
        self.load()

    def load(self):
        self.sessions = {}
        for name in sorted(os.listdir(SESSIONS_DIR)):
            if not name.endswith(".json"):
                continue
            path = os.path.join(SESSIONS_DIR, name)
            data = load_json(path, None)
            if isinstance(data, dict) and data.get("id"):
                changed = False
                for turn in data.get("turns") or []:
                    if turn.get("status") == "running":
                        turn["status"] = "interrupted"
                        changed = True
                if not data.get("origin"):
                    data["origin"] = "local"
                self.sessions[data["id"]] = data
                if changed:
                    save_json(path, data)
        self.compact_linked_duplicates()

    def save(self, session, durable=True):
        if session.get("origin", "local") != "local":
            return
        session["updated_at"] = now_iso()
        if not session.get("created_at"):
            session["created_at"] = session["updated_at"]
        self.sessions[session["id"]] = session
        save_json(
            os.path.join(SESSIONS_DIR, session["id"] + ".json"), session, durable=durable
        )

    def delete(self, session_id):
        self.sessions.pop(session_id, None)
        path = os.path.join(SESSIONS_DIR, session_id + ".json")
        try:
            os.unlink(path)
        except OSError:
            pass

    def new_session(self, agent_key, cwd, title=""):
        session = self._make_session(
            agent_key=agent_key,
            cwd=cwd,
            title=clean_text(title) or f"New {agent_key} session",
            backend={},
            turns=[],
            origin="local",
        )
        self.save(session)
        return session

    def _make_session(self, agent_key, cwd, title, backend, turns, origin="local", source_session_id=None):
        session = {
            "id": str(uuid.uuid4()),
            "agent": agent_key,
            "cwd": cwd,
            "title": title,
            "created_at": now_iso(),
            "updated_at": now_iso(),
            "backend": backend or {},
            "turns": turns or [],
            "origin": origin,
        }
        if source_session_id:
            session["source_session_id"] = source_session_id
        return session

    def linked_session(self, agent_key, cwd, client_id):
        client_id = clean_text(client_id)
        if not client_id:
            return None
        candidates = []
        for session in self.sessions.values():
            if (
                session.get("origin", "local") != "local"
                or session.get("agent") != agent_key
                or session.get("cwd") != cwd
            ):
                continue
            backend = session.get("backend") or {}
            linked_id = clean_text(
                backend.get("session_id")
                or backend.get("thread_id")
                or session.get("source_session_id")
            )
            if linked_id == client_id:
                candidates.append(session)
        if not candidates:
            return None
        return max(
            candidates,
            key=lambda session: (
                len(session.get("turns") or []),
                session.get("updated_at") or "",
            ),
        )

    def adopt_external(self, source):
        backend = deepcopy(source.get("backend") or {})
        client_id = clean_text(
            backend.get("session_id")
            or backend.get("thread_id")
            or source.get("source_session_id")
        )
        existing = self.linked_session(
            source.get("agent", "codex"),
            source.get("cwd") or os.path.expanduser("~"),
            client_id,
        )
        if existing:
            existing["title"] = clean_text(
                source.get("title") or source.get("preview")
            ) or existing.get("title")
            existing["backend"] = backend or existing.get("backend") or {}
            existing["source_session_id"] = client_id
            existing["source_path"] = clean_text(source.get("source_path"))
            if source.get("turns"):
                existing["turns"] = deepcopy(source.get("turns") or [])
            existing["transcript_loaded"] = bool(source.get("transcript_loaded"))
            self.save(existing)
            return existing
        session = self._make_session(
            agent_key=source.get("agent", "codex"),
            cwd=source.get("cwd") or os.path.expanduser("~"),
            title=clean_text(source.get("title") or source.get("preview"))
            or f"New {source.get('agent', 'agent')} session",
            backend=backend,
            turns=deepcopy(source.get("turns") or []),
            origin="local",
            source_session_id=client_id,
        )
        session["source_path"] = clean_text(source.get("source_path"))
        session["transcript_loaded"] = bool(source.get("transcript_loaded"))
        self.save(session)
        return session

    def compact_linked_duplicates(self):
        groups = {}
        for session in self.sessions.values():
            if session.get("origin", "local") != "local":
                continue
            backend = session.get("backend") or {}
            client_id = clean_text(
                backend.get("session_id") or backend.get("thread_id")
            )
            if not client_id:
                continue
            key = (
                session.get("agent"),
                session.get("cwd"),
                client_id,
            )
            groups.setdefault(key, []).append(session)
        for group in groups.values():
            if len(group) < 2:
                continue
            keep = max(
                group,
                key=lambda session: (
                    len(session.get("turns") or []),
                    session.get("updated_at") or "",
                ),
            )
            for duplicate in group:
                if duplicate.get("id") == keep.get("id"):
                    continue
                self.sessions.pop(duplicate.get("id"), None)
                try:
                    os.unlink(
                        os.path.join(
                            SESSIONS_DIR,
                            duplicate.get("id") + ".json",
                        )
                    )
                except OSError:
                    pass

    def new_handoff_session(self, source, title, packet, agent_key=None, backend=None):
        session = self._make_session(
            agent_key=agent_key or source.get("agent", "codex"),
            cwd=source.get("cwd") or os.path.expanduser("~"),
            title=title,
            backend=backend or {},
            turns=[],
            origin="local",
        )
        session["handoff_context"] = packet
        session["handoff_from"] = source.get("id")
        self.save(session)
        return session

    def list_all_local(self, agent_key=None):
        """Stored sessions newest-first, deduped. With agent_key, only that agent's
        sessions (across all working dirs); without it, every agent's. The picker
        passes the active agent so switching agents shows that agent's sessions."""
        items = [
            s
            for s in self.sessions.values()
            if agent_key is None or s.get("agent") == agent_key
        ]
        items.sort(key=lambda s: s.get("updated_at") or "", reverse=True)
        unique = []
        seen = set()
        empty_draft_agents = set()
        for session in items:
            backend = session.get("backend") or {}
            client_id = clean_text(
                backend.get("session_id") or backend.get("thread_id")
            )
            empty_draft = not client_id and not (session.get("turns") or [])
            if empty_draft:
                agent = session.get("agent")
                if agent in empty_draft_agents:
                    continue
                empty_draft_agents.add(agent)
            key = client_id or session.get("source_session_id") or session.get("id")
            if key in seen:
                continue
            seen.add(key)
            unique.append(session)
        return unique

    def get(self, session_id):
        return self.sessions.get(session_id)

    def set_title_from_prompt(self, session, prompt):
        _, visible = strip_session_context(prompt)
        title = shorten(visible or prompt, 60)
        if title:
            session["title"] = title
            self.save(session)

    def ensure_turn(self, session, prompt=None):
        turns = session.setdefault("turns", [])
        turn = {
            "id": str(uuid.uuid4()),
            "created_at": now_iso(),
            "status": "running",
            "items": [],
        }
        if prompt:
            turn["prompt"] = prompt
        turns.append(turn)
        self.save(session)
        return turn

    def add_item(self, session, turn, item):
        item.setdefault("created_at", now_iso())
        turn.setdefault("items", []).append(item)
        self.save(session)

    def finish_turn(self, session, turn, status="completed"):
        turn["status"] = status
        turn["completed_at"] = now_iso()
        self.save(session)

    def summary_for_handoff(self, session, max_chars=7000):
        header = f"Previous {session.get('agent', 'agent')} session for {project_label(session.get('cwd'))}:\n"
        body = summarize_turn_items(session.get("turns") or [], max_chars=max_chars)
        return header + body if body else header + "No prior details available."


class BaseBackend:
    def __init__(self, events, workspace_id=None):
        self.events = events
        self.workspace_id = workspace_id
        self.stop_flag = threading.Event()
        self.active = False

    def emit(self, kind, **payload):
        event = {"kind": kind, **payload}
        if self.workspace_id:
            event["workspace_id"] = self.workspace_id
        self.events.put(event)

    def stop(self):
        self.stop_flag.set()


class CodexBackend(BaseBackend):
    def __init__(self, events, workspace_id=None):
        super().__init__(events, workspace_id)
        self.proc = None
        self.cwd = None
        self.thread_id = None
        self.turn_id = None
        self.next_id = 1
        self.pending = {}
        self.lock = threading.Lock()
        self.ready = threading.Event()
        self.active_threads = set()

    def start(self, cwd):
        self.cwd = cwd
        self.proc = subprocess.Popen(
            ["codex", "app-server"],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,
        )
        threading.Thread(target=self._read_stdout, daemon=True).start()
        threading.Thread(target=self._read_stderr, daemon=True).start()
        self.request(
            "initialize",
            {
                "clientInfo": {
                    "name": "agent_workbench",
                    "title": APP_NAME,
                    "version": "0.2.0",
                }
            },
            self._on_initialized,
        )

    def _on_initialized(self, _result):
        self.notify("initialized", {})
        self.ready.set()

    def request(self, method, params, callback=None, error_callback=None):
        with self.lock:
            req_id = self.next_id
            self.next_id += 1
            if callback or error_callback:
                self.pending[req_id] = (callback, error_callback)
        message = {"method": method, "id": req_id, "params": params}
        self._send(message)
        return req_id

    def notify(self, method, params):
        self._send({"method": method, "params": params})

    def respond(self, req_id, result):
        self._send({"id": req_id, "result": result})

    def _send(self, message):
        try:
            self.proc.stdin.write(json.dumps(message) + "\n")
            self.proc.stdin.flush()
        except Exception as exc:
            self.emit("error", text=str(exc))

    def _read_stdout(self):
        proc = self.proc
        for line in proc.stdout:
            if self.stop_flag.is_set():
                break
            try:
                message = json.loads(line)
            except ValueError:
                self.emit("work", text=line.rstrip(), tag="system")
                continue

            req_id = message.get("id")
            if req_id is not None and message.get("method"):
                self._handle_server_request(message)
                continue
            if req_id is not None:
                callbacks = self.pending.pop(req_id, (None, None))
                callback, error_callback = callbacks
                if "error" in message:
                    err = message["error"]
                    text = err.get("message", "Codex error")
                    if error_callback:
                        error_callback(text)
                    else:
                        self.emit("error", text=text)
                elif callback:
                    callback(message.get("result") or {})
                continue

            self._handle_notification(message)
        if self.proc is proc and not self.stop_flag.is_set():
            self.emit("backend_exit", text="Codex app server stopped")

    def _handle_server_request(self, message):
        method = message.get("method", "")
        if method == "item/tool/requestUserInput":
            self.emit(
                "user_input_request",
                request_id=message.get("id"),
                params=message.get("params") or {},
            )
            return
        self.respond(message.get("id"), {})

    def _read_stderr(self):
        proc = self.proc
        for line in proc.stderr:
            if self.stop_flag.is_set():
                break
            line = line.strip()
            if line:
                self.emit("work", text=line, tag="system")

    def _handle_notification(self, message):
        method = message.get("method", "")
        params = message.get("params") or {}
        item = params.get("item") or {}
        typ = item.get("type", "")

        if method == "turn/started":
            turn = params.get("turn") or {}
            self.turn_id = turn.get("id") or self.turn_id
            self.emit("work", text="--- New turn ---", tag="system")
        elif method == "item/started":
            if typ and typ != "agentMessage":
                self.emit("work", text="▶ " + typ, tag="tool")
        elif method == "item/completed":
            if typ == "agentMessage":
                text = item.get("text") or item.get("content") or ""
                if not text:
                    content = []
                    for bit in item.get("content") or []:
                        if isinstance(bit, dict) and bit.get("type") == "text":
                            content.append(bit.get("text", ""))
                    text = " ".join(content)
                if text:
                    if item.get("phase") == "commentary":
                        self.emit("work", text=text, tag="progress")
                    else:
                        self.emit("assistant_message", text=text, speaker="CODEX")
            elif typ == "userMessage":
                self.emit("user", text=self._extract_text(item))
            elif typ == "commandExecution":
                command = clean_text(item.get("command"))
                if command:
                    self.emit("work", text=f"$ {command}", tag="command")
                output = clean_text(item.get("aggregatedOutput"))
                if output:
                    self.emit("work", text=output, tag="system")
            elif typ == "fileChange":
                paths = []
                for change in item.get("changes") or []:
                    path = change.get("path") or change.get("filePath")
                    if path:
                        paths.append(str(path))
                if paths:
                    self.emit("work", text="files: " + ", ".join(paths), tag="fileChange")
            elif typ == "reasoning":
                summary = " ".join(item.get("summary") or [])
                if summary:
                    self.emit("work", text=summary, tag="reasoning")
            elif typ == "plan":
                text = clean_text(item.get("text"))
                if text:
                    self.emit("work", text=text, tag="plan")
            elif typ == "mcpToolCall":
                self.emit(
                    "work",
                    text=f"{clean_text(item.get('server'))}.{clean_text(item.get('tool'))}",
                    tag="tool",
                )
        elif method == "item/commandExecution/outputDelta":
            delta = clean_text(params.get("delta"))
            if delta:
                self.emit("work", text=delta, tag="system")
        elif method == "item/fileChange/outputDelta":
            delta = clean_text(params.get("delta"))
            if delta:
                self.emit("work", text=delta, tag="fileChange")
        elif method == "turn/completed":
            turn = params.get("turn") or {}
            error = turn.get("error") or {}
            error_text = clean_text(
                error.get("message") if isinstance(error, dict) else error
            )
            self.emit(
                "turn_done",
                status=(turn.get("status") or "completed"),
                error=error_text,
            )
        elif method == "thread/tokenUsage/updated":
            token_usage = params.get("tokenUsage") or {}
            usage = token_usage.get("last") or {}
            used = int(usage.get("inputTokens") or usage.get("totalTokens") or 0)
            limit = int(token_usage.get("modelContextWindow") or 0)
            if used > 0 and limit > 0:
                self.emit("token_usage", usage={
                    "used": used,
                    "limit": limit,
                    "input_tokens": int(usage.get("inputTokens") or 0),
                    "output_tokens": int(usage.get("outputTokens") or 0),
                    "total_tokens": int(usage.get("totalTokens") or 0),
                    "provider": "Codex",
                })
                self.emit(
                    "context_usage",
                    context={
                        "used": used,
                        "limit": limit,
                        "percent": min(100.0, used * 100.0 / limit),
                        "model": "Codex",
                        "compact_count": 0,
                    },
                )
        elif method == "thread/created" or method == "thread/resumed":
            thread = params.get("thread") or {}
            self.thread_id = thread.get("id") or self.thread_id

    def _extract_text(self, item):
        parts = []
        for bit in item.get("content") or []:
            if isinstance(bit, dict) and bit.get("type") == "text":
                parts.append(bit.get("text", ""))
        return clean_text(" ".join(parts))

    def ensure_session(self, session):
        backend = session.setdefault("backend", {})
        backend.setdefault("kind", "codex")
        existing_thread_id = backend.get("thread_id")
        if existing_thread_id and existing_thread_id in self.active_threads:
            self.thread_id = existing_thread_id
            return

        result_holder = {}
        error_holder = {}
        done = threading.Event()

        def on_ready(result):
            result_holder.update(result)
            done.set()

        def on_error(text):
            error_holder["text"] = text
            done.set()

        params = {
            "cwd": session["cwd"],
            "approvalPolicy": "never",
            "sandbox": "danger-full-access",
            "personality": "pragmatic",
        }
        model = clean_text(backend.get("model"))
        if model:
            params["model"] = model
        method = "thread/start"
        if existing_thread_id:
            method = "thread/resume"
            params["threadId"] = existing_thread_id
        self.request(method, params, on_ready, on_error)
        if not done.wait(timeout=30):
            raise RuntimeError(f"Timed out while trying to {method.replace('/', ' ')}")
        if error_holder:
            raise RuntimeError(error_holder["text"])
        thread = result_holder.get("thread") or {}
        thread_id = thread.get("id") or existing_thread_id
        if not thread_id:
            raise RuntimeError("Codex did not return a thread ID")
        backend["thread_id"] = thread_id
        self.thread_id = thread_id
        self.active_threads.add(thread_id)
        session["backend"] = backend

    def start_turn(self, session, turn, prompt, context_text=""):
        try:
            self.ensure_session(session)
        except Exception as exc:
            self.emit("error", text=str(exc))
            return
        self.turn_id = None
        payload_text = prompt
        if context_text:
            payload_text = context_text.strip() + "\n\n" + prompt.strip()
        done = threading.Event()

        def on_turn(result):
            turn_obj = result.get("turn") or {}
            self.turn_id = turn_obj.get("id")
            backend = session.setdefault("backend", {})
            backend["thread_id"] = backend.get("thread_id") or self.thread_id
            backend["turn_id"] = self.turn_id
            done.set()

        def on_error(text):
            self.emit("error", text=text)
            done.set()

        request = {
            "threadId": self.thread_id,
            "cwd": session["cwd"],
            "input": [{"type": "text", "text": payload_text}],
        }
        backend = session.get("backend") or {}
        if clean_text(backend.get("model")):
            request["model"] = backend["model"]
        if clean_text(backend.get("effort")):
            request["effort"] = backend["effort"]
        self.request(
            "turn/start",
            request,
            on_turn,
            on_error,
        )
        if not done.wait(timeout=30):
            self.emit("error", text="Codex timed out while starting the turn")

    def answer_user_input(self, request_id, questions, text):
        lines = [line.strip() for line in text.splitlines() if line.strip()]
        answers = {}
        for index, question in enumerate(questions):
            answer = lines[index] if index < len(lines) else (text.strip() if index == 0 else "")
            answers[question.get("id", str(index))] = {"answers": [answer]}
        self.respond(request_id, {"answers": answers})

    def interrupt(self):
        if self.thread_id and self.turn_id:
            self.request(
                "turn/interrupt",
                {"threadId": self.thread_id, "turnId": self.turn_id},
            )

    def restart(self, cwd):
        self.stop_flag.set()
        if self.proc and self.proc.poll() is None:
            self.proc.terminate()
        self.stop_flag.clear()
        self.ready.clear()
        self.pending.clear()
        self.active_threads.clear()
        self.thread_id = None
        self.turn_id = None
        self.start(cwd)

    def close(self):
        self.stop_flag.set()
        if self.proc and self.proc.poll() is None:
            self.proc.terminate()


class StreamCliBackend(BaseBackend):
    def __init__(self, events, kind, workspace_id=None):
        super().__init__(events, workspace_id)
        self.kind = kind
        self.running = None
        self.lock = threading.Lock()

    def interrupt(self):
        with self.lock:
            if self.running and self.running.poll() is None:
                self.running.terminate()

    def close(self):
        self.stop_flag.set()
        self.interrupt()


class OllamaBackend(StreamCliBackend):
    """Local LLM (Ollama) agent with a real tool-use loop: the model can run shell
    commands and read/write files on this machine, not just chat."""

    MAX_STEPS = 25
    TOOLS = [
        {
            "type": "function",
            "function": {
                "name": "run_shell",
                "description": (
                    "Run a bash command on the user's local Fedora Linux machine and "
                    "return its combined stdout and stderr. Use this to inspect and "
                    "change the system: audio (pactl/wpctl), bluetooth (bluetoothctl), "
                    "packages, services, processes, files — anything."
                ),
                "parameters": {
                    "type": "object",
                    "properties": {
                        "command": {"type": "string", "description": "The bash command to run."}
                    },
                    "required": ["command"],
                },
            },
        },
        {
            "type": "function",
            "function": {
                "name": "read_file",
                "description": "Read and return the contents of a file on the local machine.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "path": {"type": "string", "description": "Absolute or ~-relative file path."}
                    },
                    "required": ["path"],
                },
            },
        },
        {
            "type": "function",
            "function": {
                "name": "write_file",
                "description": "Create or overwrite a file on the local machine with text content.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "path": {"type": "string"},
                        "content": {"type": "string"},
                    },
                    "required": ["path", "content"],
                },
            },
        },
        {
            "type": "function",
            "function": {
                "name": "list_dir",
                "description": "List entries in a directory on the local machine.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "path": {"type": "string", "description": "Directory path (defaults to the working dir)."}
                    },
                },
            },
        },
        {
            "type": "function",
            "function": {
                "name": "web_fetch",
                "description": (
                    "HTTP GET a URL and return the response body — use this to call web / REST "
                    "APIs or read documentation. Returns up to ~8000 chars."
                ),
                "parameters": {
                    "type": "object",
                    "properties": {"url": {"type": "string", "description": "The URL to fetch."}},
                    "required": ["url"],
                },
            },
        },
    ]

    # The five tools above, by name — used to validate text-embedded tool calls so
    # we don't mistake ordinary JSON in a model's prose for a tool invocation.
    TOOL_NAMES = {"run_shell", "read_file", "write_file", "list_dir", "web_fetch"}

    def __init__(self, events, spec, workspace_id=None):
        super().__init__(events, spec.get("key", "ollama"), workspace_id)
        self.spec = spec
        self.base_url = "http://localhost:11434"
        raw_model = spec.get("model") or spec.get("label") or "qwen3-coder:30b"
        # /api/chat needs the bare model id, not the aider-style "ollama_chat/" prefix.
        self.model = re.sub(r"^ollama(_chat)?/", "", clean_text(raw_model))
        self.messages = []  # Multi-turn conversation history (incl. tool turns)

    def _ollama_chat(self, messages):
        import urllib.request

        body = json.dumps(
            {"model": self.model, "messages": messages, "tools": self.TOOLS, "stream": False}
        ).encode("utf-8")
        req = urllib.request.Request(
            f"{self.base_url}/api/chat",
            data=body,
            headers={"Content-Type": "application/json"},
        )
        with urllib.request.urlopen(req, timeout=600) as resp:
            data = json.loads(resp.read().decode("utf-8"))
        return data.get("message") or {}

    def _run_tool(self, name, args, cwd):
        if not isinstance(args, dict):
            args = {}
        try:
            if name == "run_shell":
                command = str(args.get("command") or "").strip()
                if not command:
                    return "error: no command provided"
                self.emit("work", text="$ " + command, tag="command")
                proc = subprocess.run(
                    ["bash", "-lc", command],
                    cwd=cwd,
                    capture_output=True,
                    text=True,
                    timeout=180,
                )
                out = ((proc.stdout or "") + (proc.stderr or "")).strip() or "(no output)"
                if len(out) > 6000:
                    out = out[:6000] + "\n…[truncated]"
                self.emit("work", text=out, tag="system")
                if proc.returncode != 0:
                    return f"[exit {proc.returncode}]\n{out}"
                return out
            if name == "read_file":
                path = os.path.expanduser(str(args.get("path") or ""))
                self.emit("work", text=f"read {path}", tag="tool")
                with open(path, "r", errors="replace") as fh:
                    data = fh.read()
                if len(data) > 8000:
                    data = data[:8000] + "\n…[truncated]"
                return data or "(empty file)"
            if name == "write_file":
                path = os.path.expanduser(str(args.get("path") or ""))
                content = str(args.get("content") or "")
                self.emit("work", text=f"write {path} ({len(content)} bytes)", tag="fileChange")
                parent = os.path.dirname(path)
                if parent:
                    os.makedirs(parent, exist_ok=True)
                with open(path, "w") as fh:
                    fh.write(content)
                return f"wrote {len(content)} bytes to {path}"
            if name == "list_dir":
                path = os.path.expanduser(str(args.get("path") or cwd))
                self.emit("work", text=f"ls {path}", tag="tool")
                if not os.path.isdir(path):
                    return f"error: not a directory: {path}"
                listing = "\n".join(sorted(os.listdir(path))) or "(empty directory)"
                if len(listing) > 6000:
                    listing = listing[:6000] + "\n…[truncated]"
                return listing
            if name == "web_fetch":
                import urllib.request

                url = str(args.get("url") or "").strip()
                if not url:
                    return "error: no url provided"
                self.emit("work", text=f"GET {url}", tag="tool")
                request = urllib.request.Request(
                    url, headers={"User-Agent": "AgentWorkbench-qwen"}
                )
                with urllib.request.urlopen(request, timeout=30) as resp:
                    body = resp.read(200000).decode("utf-8", errors="replace")
                if len(body) > 8000:
                    body = body[:8000] + "\n…[truncated]"
                self.emit("work", text=f"({len(body)} chars received)", tag="system")
                return body
            return f"error: unknown tool '{name}'"
        except subprocess.TimeoutExpired:
            msg = "error: command timed out after 180s"
            self.emit("work", text=msg, tag="system")
            return msg
        except Exception as exc:
            msg = f"error: {exc}"
            self.emit("work", text=msg, tag="system")
            return msg

    @classmethod
    def _parse_text_tool_calls(cls, content):
        """Recover tool calls that a model emitted as TEXT instead of in Ollama's
        structured `tool_calls` field. Handles the three formats seen in the wild:

          1. qwen3-coder XML:  <function=run_shell><parameter=command>date</parameter></function>
          2. Hermes/Qwen JSON: <tool_call>{"name":"run_shell","arguments":{...}}</tool_call>
          3. bare / fenced JSON: {"name":"run_shell","arguments":{...}}  (optionally in ```json)

        Returns (calls, cleaned_content): calls normalized to the structured shape
        [{"function": {"name", "arguments"}}], and the prose with the call blocks
        stripped out so the user never sees a raw tool-call blob. Only calls whose
        name is a real tool (TOOL_NAMES) are accepted, so plain JSON in an answer is
        not mistaken for a tool invocation."""
        if not content or not content.strip():
            return [], content
        calls = []
        cleaned = content

        # 1) qwen3-coder XML: <function=NAME>…<parameter=KEY>VALUE</parameter>…</function>
        for fm in re.finditer(r"<function=([A-Za-z0-9_]+)\s*>(.*?)</function>", content, re.DOTALL):
            name = fm.group(1)
            if name not in cls.TOOL_NAMES:
                continue
            args = {}
            for pm in re.finditer(
                r"<parameter=([A-Za-z0-9_]+)\s*>(.*?)</parameter>", fm.group(2), re.DOTALL
            ):
                args[pm.group(1)] = pm.group(2).strip("\n")
            calls.append({"function": {"name": name, "arguments": args}})
        if calls:
            cleaned = re.sub(r"<function=.*?</function>", "", cleaned, flags=re.DOTALL)
            cleaned = re.sub(r"</?tool_call>", "", cleaned)
            return calls, cleaned.strip()

        # 2) and 3) JSON forms — inside <tool_call>…</tool_call>, ```json fences, or bare.
        candidates = []
        candidates += re.findall(r"<tool_call>\s*(\{.*?\}|\[.*?\])\s*</tool_call>", content, re.DOTALL)
        candidates += re.findall(r"```(?:json)?\s*(\{.*?\}|\[.*?\])\s*```", content, re.DOTALL)
        if not candidates:
            stripped = content.strip()
            if stripped[:1] in "{[":
                candidates.append(stripped)
        for blob in candidates:
            try:
                data = json.loads(blob)
            except (ValueError, TypeError):
                continue
            for obj in (data if isinstance(data, list) else [data]):
                if not isinstance(obj, dict):
                    continue
                fn = obj.get("function") if isinstance(obj.get("function"), dict) else obj
                name = clean_text(fn.get("name") or fn.get("tool"))
                if name not in cls.TOOL_NAMES:
                    continue
                args = fn.get("arguments")
                if args is None:
                    args = fn.get("parameters")
                calls.append({"function": {"name": name, "arguments": args if args is not None else {}}})
        if calls:
            cleaned = re.sub(r"<tool_call>.*?</tool_call>", "", cleaned, flags=re.DOTALL)
            cleaned = re.sub(r"```(?:json)?\s*(?:\{.*?\}|\[.*?\])\s*```", "", cleaned, flags=re.DOTALL)
            if cleaned.strip()[:1] in "{[":
                cleaned = ""  # whole message was the bare JSON call
        return calls, cleaned.strip()

    def start_turn(self, session, turn, prompt, context_text=""):
        import urllib.error

        def run():
            cwd = session.get("cwd") or os.path.expanduser("~")
            if not os.path.isdir(cwd):
                cwd = os.path.expanduser("~")
            speaker = self.spec.get("label", "LOCAL").upper()
            if not self.messages:
                self.messages.append({
                    "role": "system",
                    "content": (
                        "You are an autonomous, fully-capable system-administration and coding "
                        "agent running directly on the user's Fedora Linux laptop, inside the "
                        "Agent Workbench app. You are NOT sandboxed. You have REAL tools: "
                        "run_shell (ANY bash command — install packages with `sudo dnf`, manage "
                        "services with systemctl, control audio with pactl/wpctl, bluetooth with "
                        "bluetoothctl, use git, call APIs with curl, etc.), read_file, write_file, "
                        "list_dir, and web_fetch (HTTP GET any URL / REST API). Use them to "
                        "actually inspect and change this machine and reach the network — never "
                        "tell the user to run commands themselves and never claim you lack access "
                        "or files. Work one step at a time: call a tool, read its result, then "
                        "decide the next step. Verify your work with follow-up commands. When the "
                        "task is fully complete, reply with a short plain-text summary and NO tool "
                        f"call. The current working directory is {cwd}."
                    ),
                })
            payload = prompt
            if context_text:
                payload = context_text.strip() + "\n\n" + prompt.strip()
            self.messages.append({"role": "user", "content": payload})

            final_text = ""
            status = "completed"
            try:
                for _step in range(self.MAX_STEPS):
                    if self.stop_flag.is_set():
                        status = "error"
                        break
                    msg = self._ollama_chat(self.messages)
                    content = clean_text(msg.get("content"))
                    tool_calls = msg.get("tool_calls") or []
                    visible = content
                    if not tool_calls and content:
                        # Models like qwen3-coder / qwen2.5-coder emit tool calls as
                        # TEXT (XML or JSON) rather than in the structured field.
                        # Recover them so the tool actually runs — and strip the call
                        # markup so the user sees prose, not a raw blob.
                        recovered, visible = self._parse_text_tool_calls(content)
                        if recovered:
                            tool_calls = recovered
                    assistant_turn = {"role": "assistant", "content": msg.get("content") or ""}
                    if tool_calls:
                        assistant_turn["tool_calls"] = tool_calls
                    self.messages.append(assistant_turn)
                    if visible:
                        final_text = visible
                        self.emit("assistant_message", text=visible, speaker=speaker)
                    if not tool_calls:
                        break
                    for call in tool_calls:
                        if self.stop_flag.is_set():
                            status = "error"
                            break
                        fn = call.get("function") or {}
                        name = clean_text(fn.get("name"))
                        args = fn.get("arguments")
                        if isinstance(args, str):
                            try:
                                args = json.loads(args)
                            except ValueError:
                                args = {}
                        result = self._run_tool(name, args or {}, cwd)
                        self.messages.append(
                            {"role": "tool", "tool_name": name, "content": result}
                        )
                    else:
                        continue
                    break
                else:
                    self.emit(
                        "work",
                        text=f"[stopped after {self.MAX_STEPS} tool steps]",
                        tag="system",
                    )
            except urllib.error.URLError as exc:
                self.emit("error", text=f"Ollama not reachable at {self.base_url}: {exc}")
                status = "error"
            except Exception as exc:
                self.emit("error", text=f"Local agent error: {exc}")
                status = "error"

            if status == "completed" and not final_text:
                self.emit("assistant_message", text="(done — no summary returned)", speaker=speaker)
            self.emit("turn_done", status=status)

        threading.Thread(target=run, daemon=True).start()

    def close(self):
        self.stop_flag.set()


class CustomCliBackend(StreamCliBackend):
    def __init__(self, events, spec, workspace_id=None):
        super().__init__(events, spec["key"], workspace_id)
        self.spec = spec

    def start_turn(self, session, turn, prompt, context_text=""):
        def _find_git_root(path):
            """Walk up from path looking for a .git directory."""
            current = os.path.abspath(path)
            while True:
                if os.path.isdir(os.path.join(current, ".git")):
                    return current
                parent = os.path.dirname(current)
                if parent == current:
                    return None
                current = parent

        def run():
            template = clean_text(self.spec.get("command"))
            payload = prompt
            if context_text:
                payload = context_text.strip() + "\n\n" + prompt.strip()
            if not template:
                self.emit("error", text="Custom client command is empty.")
                self.emit("turn_done", status="error")
                return
            uses_placeholder = "{prompt}" in template
            if uses_placeholder:
                command = template.replace("{prompt}", shlex.quote(payload))
                stdin_data = None
            else:
                command = template
                stdin_data = (payload + "\n").encode()
            self.emit("work", text="$ " + command, tag="command")
            # Aider git-repo hint
            if "aider" in command.lower():
                cwd = session.get("cwd") or os.path.expanduser("~")
                if not _find_git_root(cwd):
                    self.emit(
                        "work",
                        text="[hint] aider needs a git project directory — set this session's working directory to your project, or it can only chat.",
                        tag="system",
                    )
            # Open PTY
            master_fd, slave_fd = pty.openpty()
            try:
                fcntl.ioctl(
                    slave_fd,
                    termios.TIOCSWINSZ,
                    struct.pack("HHHH", 40, 160, 0, 0),
                )
            except OSError:
                pass
            env = os.environ.copy()
            env["TERM"] = env.get("TERM") or "xterm-256color"
            cwd = session.get("cwd") or os.path.expanduser("~")
            try:
                proc = subprocess.Popen(
                    ["bash", "-lc", command],
                    cwd=cwd,
                    stdin=slave_fd,
                    stdout=slave_fd,
                    stderr=slave_fd,
                    env=env,
                    preexec_fn=os.setsid,
                    close_fds=True,
                )
            except Exception as exc:
                os.close(slave_fd)
                os.close(master_fd)
                self.emit("error", text=f"Custom client failed to start: {exc}")
                self.emit("turn_done", status="error")
                return
            os.close(slave_fd)
            with self.lock:
                self.running = proc
            # Write stdin payload if needed
            if stdin_data is not None:
                try:
                    os.write(master_fd, stdin_data)
                except OSError:
                    pass
            # Read output from master_fd
            final_status = "completed"
            try:
                while not self.stop_flag.is_set():
                    try:
                        data = os.read(master_fd, 4096)
                    except OSError:
                        break
                    if not data:
                        break
                    text = data.decode("utf-8", errors="replace").replace("\r\n", "\n").replace("\r", "\n")
                    text = ANSI_ESCAPE.sub("", text)
                    text = text.replace("\\[", "").replace("\\]", "")
                    if text:
                        self.emit("work", text=text, tag="stream")
            finally:
                try:
                    os.close(master_fd)
                except OSError:
                    pass
                with self.lock:
                    running = self.running
                if running is not None:
                    try:
                        running.wait(timeout=5)
                    except Exception:
                        pass
                    rc = running.poll()
                    if rc is not None and rc != 0:
                        final_status = "error"
                with self.lock:
                    self.running = None
                if self.stop_flag.is_set():
                    final_status = "error"
                self.emit("turn_done", status=final_status)

        threading.Thread(target=run, daemon=True).start()


class TerminalShell:
    def __init__(self, events):
        self.events = events
        self.proc = None
        self.master_fd = None
        self.cwd = None
        self.lock = threading.Lock()
        self.generation = 0

    def emit(self, kind, **payload):
        self.events.put({"kind": kind, **payload})

    def start(self, cwd):
        cwd = cwd if os.path.isdir(cwd) else os.path.expanduser("~")
        self.close()
        master_fd, slave_fd = pty.openpty()
        try:
            fcntl.ioctl(
                slave_fd,
                termios.TIOCSWINSZ,
                struct.pack("HHHH", 32, 140, 0, 0),
            )
        except OSError:
            pass
        env = os.environ.copy()
        env["TERM"] = env.get("TERM") or "xterm-256color"
        env["AGENT_WORKBENCH"] = "1"
        shell = env.get("SHELL") or "/bin/bash"
        try:
            with self.lock:
                self.generation += 1
                generation = self.generation
                self.cwd = cwd
                self.master_fd = master_fd
                self.proc = subprocess.Popen(
                    [shell, "-i"],
                    cwd=cwd,
                    stdin=slave_fd,
                    stdout=slave_fd,
                    stderr=slave_fd,
                    env=env,
                    preexec_fn=os.setsid,
                    close_fds=True,
                )
            os.close(slave_fd)
        except Exception as exc:
            self.emit("terminal_output", text=f"[terminal failed to start: {exc}]\n")
            return
        threading.Thread(target=self._read, args=(generation,), daemon=True).start()
        self.emit("terminal_output", text=f"[terminal ready · {cwd}]\n")

    def _read(self, generation):
        while True:
            with self.lock:
                if generation != self.generation:
                    return
                fd = self.master_fd
                proc = self.proc
            if fd is None or proc is None:
                return
            try:
                data = os.read(fd, 4096)
            except OSError:
                break
            if not data:
                break
            text = data.decode("utf-8", errors="replace").replace("\r", "")
            clear_screen = "\x1b[2J" in text or "\x1b[3J" in text
            text = ANSI_ESCAPE.sub("", text)
            text = text.replace("\\[", "").replace("\\]", "")
            if clear_screen:
                self.emit("terminal_clear")
            if text:
                with self.lock:
                    if generation != self.generation:
                        return
                self.emit("terminal_output", text=text)
        with self.lock:
            if generation != self.generation:
                return
            proc = self.proc
        if proc is not None:
            self.emit("terminal_exit", status=proc.poll())

    def send(self, text):
        with self.lock:
            fd = self.master_fd
        if fd is None:
            return False
        try:
            os.write(fd, text.encode("utf-8"))
            return True
        except OSError:
            return False

    def interrupt(self):
        with self.lock:
            proc = self.proc
            fd = self.master_fd
        if proc and proc.poll() is None:
            try:
                foreground_pgid = os.tcgetpgrp(fd) if fd is not None else proc.pid
                os.killpg(foreground_pgid, signal.SIGINT)
            except OSError:
                pass

    def close(self):
        with self.lock:
            self.generation += 1
            proc = self.proc
            fd = self.master_fd
            self.proc = None
            self.master_fd = None
        if proc and proc.poll() is None:
            try:
                os.killpg(proc.pid, signal.SIGHUP)
            except OSError:
                pass
            try:
                proc.wait(timeout=2)
            except subprocess.TimeoutExpired:
                proc.terminate()
        if fd is not None:
            try:
                os.close(fd)
            except OSError:
                pass


class ClaudeBackend(StreamCliBackend):
    def __init__(self, events, workspace_id=None):
        super().__init__(events, "claude", workspace_id)

    def start_turn(self, session, turn, prompt, context_text=""):
        def run():
            session_id = session.setdefault("backend", {}).get("session_id") or str(uuid.uuid4())
            first_turn = not session["backend"].get("session_id")
            cmd = [
                "claude",
                "-p",
                "--output-format",
                "stream-json",
                "--input-format",
                "text",
                "--verbose",
                "--permission-mode",
                "bypassPermissions",
                "--dangerously-skip-permissions",
            ]
            model = clean_text(session["backend"].get("model"))
            effort = clean_text(session["backend"].get("effort"))
            orchestration_mode = clean_text(
                session["backend"].get("orchestration_mode") or "smart"
            )
            # "Ultracode" is a synthetic Effort tier, not a real --effort value
            # (the CLI tops out at "max"). Map it to max effort + ultra
            # multi-agent orchestration. Picking Ultracode in Effort therefore
            # enables ultracode for the run regardless of the orchestration dialog.
            if effort == "Ultracode":
                orchestration_mode = "ultra"
                effort = "max"
            if orchestration_mode in ("smart", "ultra"):
                cmd += [
                    "--append-system-prompt",
                    CLAUDE_ULTRACODE_ORCHESTRATION_PROMPT
                    if orchestration_mode == "ultra"
                    else CLAUDE_SMART_ORCHESTRATION_PROMPT,
                    "--agents",
                    CLAUDE_SMART_AGENTS_JSON,
                ]
                # Offer the free local-LLM delegation tool (mcp__local-delegate__
                # delegate_local). Added on top of any existing MCP config (no
                # --strict), and skipped if the server isn't deployed. A failing
                # MCP server is non-fatal to the turn — Claude just won't see the tool.
                delegate_cfg = ensure_local_delegate_mcp_config()
                if delegate_cfg:
                    cmd += ["--mcp-config", delegate_cfg]
            if model and model != "Default":
                cmd += ["--model", model]
            if effort:
                cmd += ["--effort", effort]
            if first_turn:
                cmd += ["--session-id", session_id]
                title = clean_text(session.get("title"))
                if title and not title.startswith("New "):
                    cmd += ["--name", title]
            else:
                cmd += ["--resume", session_id]

            payload = prompt
            if context_text and first_turn:
                payload = context_text.strip() + "\n\n" + prompt.strip()

            logged_cmd = list(cmd)
            if "--append-system-prompt" in logged_cmd:
                policy_index = logged_cmd.index("--append-system-prompt") + 1
                if policy_index < len(logged_cmd):
                    logged_cmd[policy_index] = "<smart orchestration policy>"
            if "--agents" in logged_cmd:
                agents_index = logged_cmd.index("--agents") + 1
                if agents_index < len(logged_cmd):
                    logged_cmd[agents_index] = "<smart agent profiles>"
            self.emit(
                "work",
                text="$ " + shlex.join(logged_cmd + [payload]),
                tag="command",
            )
            buffer = []
            visible_chunks = []
            emitted_visible = False
            final_status = "completed"
            final_error = ""
            with self.lock:
                self.running = subprocess.Popen(
                    cmd + [payload],
                    cwd=session["cwd"],
                    stdout=subprocess.PIPE,
                    stderr=subprocess.PIPE,
                    text=True,
                    bufsize=1,
                )
            try:
                threading.Thread(target=self._stream_stderr, daemon=True).start()
                for raw in self.running.stdout:
                    if self.stop_flag.is_set():
                        break
                    line = raw.strip()
                    if not line:
                        continue
                    try:
                        event = json.loads(line)
                    except ValueError:
                        self.emit("work", text=line, tag="system")
                        continue
                    etype = event.get("type")
                    if etype == "system":
                        subtype = event.get("subtype")
                        if subtype == "init":
                            sid = event.get("session_id")
                            if sid:
                                session.setdefault("backend", {})["session_id"] = sid
                            self.emit(
                                "work",
                                text=f"claude session {sid or session_id}",
                                tag="system",
                            )
                        elif subtype == "task_started":
                            self.emit("subagent_start",
                                agent_id=clean_text(event.get("tool_use_id")),
                                task_id=clean_text(event.get("task_id")),
                                name=clean_text(event.get("subagent_type") or event.get("description") or "sub-agent"),
                                detail=clean_text(event.get("description") or event.get("prompt")))
                        elif subtype == "task_updated":
                            patch = event.get("patch") or {}
                            self.emit("subagent_update",
                                task_id=clean_text(event.get("task_id")),
                                status=clean_text(patch.get("status")))
                        elif subtype == "task_notification":
                            usage = event.get("usage") or {}
                            self.emit("subagent_done",
                                agent_id=clean_text(event.get("tool_use_id")),
                                task_id=clean_text(event.get("task_id")),
                                status=clean_text(event.get("status")) or "completed",
                                summary=clean_text(event.get("summary")),
                                total_tokens=int(usage.get("total_tokens") or 0),
                                duration_ms=int(usage.get("duration_ms") or 0))
                    elif etype == "assistant":
                        message = event.get("message") or {}
                        context = context_from_usage(
                            message.get("usage") or {},
                            message.get("model") or model,
                        )
                        if context:
                            self.emit("context_usage", context=context)
                        actual_model = clean_text(message.get("model"))
                        if actual_model:
                            self.emit("active_model", model=actual_model)
                        for block in message.get("content") or []:
                            if not isinstance(block, dict):
                                continue
                            block_type = block.get("type")
                            content = clean_text(block.get("text"))
                            if block_type == "text" and content:
                                if not buffer:
                                    self.emit("assistant_begin", speaker="CLAUDE")
                                buffer.append(content)
                                self.emit("assistant_delta", text=content, speaker="CLAUDE")
                            elif block_type == "tool_use":
                                tool_name = clean_text(block.get("name"))
                                # Claude Code names the subagent tool "Agent"
                                # (older versions: "Task") — match both, or the
                                # Sub-agents counter never registers a fan-out.
                                if tool_name in ("Task", "Agent"):
                                    inp = block.get("input") or {}
                                    sub_type = clean_text(
                                        inp.get("subagent_type") or inp.get("description") or "sub-agent"
                                    )
                                    desc = clean_text(inp.get("description") or inp.get("prompt"))
                                    # Surface the delegation in the Work Log so the
                                    # user can SEE what each sub-agent was told to do
                                    # — in-turn sub-agents finish fast and the live
                                    # popover empties, so this is the durable record.
                                    line = f"🤖 Delegated → {sub_type}"
                                    if desc:
                                        line += f": {shorten(desc, 240)}"
                                    self.emit("work", text=line, tag="tool")
                                    self.emit(
                                        "subagent_start",
                                        agent_id=clean_text(block.get("id")),
                                        name=sub_type,
                                        detail=desc,
                                    )
                                else:
                                    self.emit("work", text=f"Tool: {tool_name}", tag="tool")
                    elif etype == "user":
                        # A tool_result block carries the id of the tool_use it answers;
                        # when that id matches a live Task/Agent, that subagent finished.
                        message = event.get("message") or {}
                        for block in message.get("content") or []:
                            if isinstance(block, dict) and block.get("type") == "tool_result":
                                tool_id = clean_text(block.get("tool_use_id"))
                                if tool_id:
                                    self.emit("subagent_stop", agent_id=tool_id)
                        self.emit("work", text=line, tag="system")
                    elif etype == "result":
                        result = event.get("result") or ""
                        if result and not buffer:
                            self.emit("assistant_begin", speaker="CLAUDE")
                            self.emit("assistant_delta", text=clean_text(result), speaker="CLAUDE")
                        status = event.get("subtype") or "success"
                        if status not in {"success", "completed"}:
                            final_status = "error"
                            final_error = clean_text(
                                event.get("error") or event.get("result")
                            )
                        stats = event.get("usage") or {}
                        if stats:
                            self.emit(
                                "token_usage",
                                usage={
                                    "input_tokens": int(stats.get("input_tokens") or 0),
                                    "output_tokens": int(stats.get("output_tokens") or 0),
                                    "total_tokens": int(
                                        stats.get("total_tokens")
                                        or int(stats.get("input_tokens") or 0)
                                        + int(stats.get("output_tokens") or 0)
                                    ),
                                    "provider": "Claude",
                                },
                            )
                        self.emit(
                            "work",
                            text=f"Claude {status} · input {stats.get('input_tokens', 0)} · output {stats.get('output_tokens', 0)}",
                            tag="done" if status == "success" else "system",
                        )
                        break
                    else:
                        self.emit("work", text=line, tag="system")
                if buffer:
                    self.emit("assistant_done", speaker="CLAUDE")
                process = self.running
                if process and process.poll() is None:
                    try:
                        process.wait(timeout=2)
                    except subprocess.TimeoutExpired:
                        pass
                self.emit(
                    "turn_done",
                    status=final_status,
                    error=final_error,
                )
            except Exception as exc:
                self.emit("error", text=str(exc))
                self.emit("turn_done", status="error")
            finally:
                with self.lock:
                    self.running = None

        threading.Thread(target=run, daemon=True).start()

    def _stream_stderr(self):
        proc = self.running
        if not proc or not proc.stderr:
            return
        for raw in proc.stderr:
            if self.stop_flag.is_set():
                break
            line = raw.strip()
            if line:
                self.emit("work", text=line, tag="system")


class GeminiBackend(StreamCliBackend):
    def __init__(self, events, workspace_id=None):
        super().__init__(events, "gemini", workspace_id)

    def start_turn(self, session, turn, prompt, context_text=""):
        def run():
            session_id = session.setdefault("backend", {}).get("session_id") or str(uuid.uuid4())
            first_turn = not session["backend"].get("session_id")
            cmd = [
                "gemini",
                "-p",
                prompt,
                "--output-format",
                "stream-json",
                "--yolo",
                "--skip-trust",
            ]
            model = clean_text(session["backend"].get("model"))
            if model and model != "Auto":
                cmd += ["--model", model]
            if first_turn:
                cmd += ["--session-id", session_id]
            else:
                cmd += ["--resume", session_id]

            payload = prompt
            if context_text and first_turn:
                payload = context_text.strip() + "\n\n" + prompt.strip()
                cmd[2] = payload

            self.emit("work", text="$ " + shlex.join(cmd), tag="command")
            visible_chunks = []
            emitted_visible = False
            with self.lock:
                self.running = subprocess.Popen(
                    cmd,
                    cwd=session["cwd"],
                    stdout=subprocess.PIPE,
                    stderr=subprocess.PIPE,
                    text=True,
                    bufsize=1,
                )
            try:
                threading.Thread(target=self._stream_stderr, daemon=True).start()
                for raw in self.running.stdout:
                    if self.stop_flag.is_set():
                        break
                    line = raw.strip()
                    if not line:
                        continue
                    try:
                        event = json.loads(line)
                    except ValueError:
                        self.emit("work", text=line, tag="system")
                        continue
                    etype = event.get("type")
                    if etype == "init":
                        sid = event.get("session_id")
                        if sid:
                            session.setdefault("backend", {})["session_id"] = sid
                        self.emit(
                            "work",
                            text=f"Gemini session {sid or session_id}",
                            tag="system",
                        )
                    elif etype == "message":
                        role = event.get("role")
                        content = clean_text(event.get("content"))
                        if role == "assistant" and content:
                            thought_text, visible_text = split_gemini_visible_text(content)
                            if thought_text:
                                self.emit("work", text=thought_text, tag="reasoning")
                            if visible_text:
                                visible_chunks.append(visible_text)
                        elif role == "user":
                            self.emit("user", text=content)
                    elif etype == "result":
                        result = clean_text(event.get("result") or "")
                        thought_text, visible_text = split_gemini_visible_text(result)
                        if thought_text:
                            self.emit("work", text=thought_text, tag="reasoning")
                        final_text = visible_text or clean_text(" ".join(visible_chunks))
                        if final_text:
                            emitted_visible = True
                            self.emit("assistant_message", speaker="GEMINI", text=final_text)
                        status = event.get("status") or "success"
                        stats = event.get("stats") or {}
                        if stats:
                            self.emit(
                                "token_usage",
                                usage={
                                    "input_tokens": int(stats.get("input_tokens") or 0),
                                    "output_tokens": int(stats.get("output_tokens") or 0),
                                    "total_tokens": int(
                                        stats.get("total_tokens")
                                        or int(stats.get("input_tokens") or 0)
                                        + int(stats.get("output_tokens") or 0)
                                    ),
                                    "provider": "Gemini",
                                },
                            )
                        self.emit(
                            "work",
                            text=f"Gemini {status} · input {stats.get('input_tokens', 0)} · output {stats.get('output_tokens', 0)}",
                            tag="done" if status == "success" else "system",
                        )
                        break
                    else:
                        self.emit("work", text=line, tag="system")
                if emitted_visible:
                    self.emit("assistant_done", speaker="GEMINI")
                self.emit("turn_done", status="completed")
            except Exception as exc:
                self.emit("error", text=str(exc))
                self.emit("turn_done", status="error")
            finally:
                with self.lock:
                    self.running = None

        threading.Thread(target=run, daemon=True).start()

    def _stream_stderr(self):
        proc = self.running
        if not proc or not proc.stderr:
            return
        for raw in proc.stderr:
            if self.stop_flag.is_set():
                break
            line = raw.strip()
            if line:
                self.emit("work", text=line, tag="system")


