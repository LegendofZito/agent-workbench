def session_charter_prompt(charter):
    """Wrap the operator's per-session scope text into a system-prompt block that
    makes the agent refuse / push back on clearly off-scope requests instead of
    silently carrying them out (the Pig Farm ↔ Agent Workbench mix-up)."""
    return (
        "SESSION SCOPE / CHARTER — set by the operator for THIS session:\n"
        f"{charter}\n\n"
        "If a request clearly falls OUTSIDE this scope (e.g. it belongs to a "
        "different project or session), do NOT silently carry it out. If a human "
        "is present, stop and push back briefly — e.g. \"That looks outside this "
        "session's scope; this may be the wrong chat. Confirm and I'll proceed.\" "
        "If you are running unattended/autonomously, STOP and note the mismatch "
        "rather than acting. A staged handoff that inherited an off-scope objective "
        "still counts as off-scope. Only push back when the mismatch is clear — "
        "don't nitpick borderline or supporting work."
    )


def now_iso():
    return datetime.now(timezone.utc).isoformat()


def local_timezone_name(moment=None):
    configured = clean_text(os.environ.get("TZ"))
    if configured:
        return configured
    try:
        resolved = os.path.realpath("/etc/localtime")
        marker = f"{os.sep}zoneinfo{os.sep}"
        if marker in resolved:
            return resolved.split(marker, 1)[1]
    except OSError:
        pass
    moment = moment or datetime.now().astimezone()
    return clean_text(moment.tzname()) or "local system time"


def authoritative_time_context():
    moment = datetime.now().astimezone()
    offset = moment.strftime("%z")
    offset_label = (
        f"UTC{offset[:3]}:{offset[3:]}"
        if len(offset) == 5
        else clean_text(offset)
    )
    timezone_name = local_timezone_name(moment)
    return (
        f"{SESSION_CONTEXT_OPEN}\n"
        "Authoritative local system time for this turn:\n"
        f"- Local date and time: {moment.strftime('%A, %B %-d, %Y at %-I:%M:%S %p %Z')}\n"
        f"- ISO 8601: {moment.isoformat(timespec='seconds')}\n"
        f"- Time zone: {timezone_name}"
        + (f" ({offset_label})" if offset_label else "")
        + "\n"
        "Use this as the source of truth for today, yesterday, tomorrow, elapsed "
        "dates, deadlines, and any other relative time reference. If conversation "
        "history conflicts with this clock, this clock wins.\n"
        f"{SESSION_CONTEXT_CLOSE}"
    )


def prompt_with_authoritative_time(prompt):
    return authoritative_time_context() + "\n\n" + clean_text(prompt)


def clean_text(value):
    return str(value or "").replace("\r", "").strip()


def split_gemini_visible_text(text):
    raw = clean_text(text)
    if not raw:
        return "", ""
    if "[thought:" not in raw.lower():
        return "", raw
    return raw, ""


def strip_session_context(text):
    raw = clean_text(text)
    if not raw:
        return "", ""
    stripped = clean_text(SESSION_CONTEXT_BLOCK.sub("", raw))
    if stripped == raw:
        return "", raw
    return raw, stripped


def strip_harness_injections(text):
    """Return only what the USER actually typed in a user-role transcript turn, after
    removing every harness/system injection Claude Code stores as user turns to feed the
    model: background-agent task notifications, system reminders, session context,
    local-command output, the post-compaction continuation summary, and the AWB
    attachment wrapper. Returns "" when the whole turn was injected machine content, so a
    mirrored view never shows it as a YOU bubble."""
    raw = clean_text(text)
    if not raw:
        return ""
    # Block-form injections (open/close tagged).
    cleaned = SESSION_CONTEXT_BLOCK.sub("", raw)
    cleaned = HARNESS_INJECTION_BLOCK.sub("", cleaned)
    cleaned = clean_text(cleaned)
    if not cleaned:
        return ""
    # The harness injects a large "This session is being continued…" summary as a USER
    # turn after each auto-compaction. It is machine content, not user input.
    if cleaned.lstrip().lower().startswith(
        "this session is being continued from a previous conversation"
    ):
        return ""
    # AWB-generated bare attachment prompt (file attached with no typed message).
    if cleaned.lstrip().lower().startswith(
        "please inspect and respond to the attached file"
    ):
        return ""
    # Strip AWB handoff / project-state / registry prefixes + the attachment wrapper
    # (reuses the comprehensive helper). Leaves only what the user actually typed.
    cleaned = clean_text(visible_user_prompt_text(cleaned))
    if not cleaned:
        return ""
    # Bare image-attachment artifacts ("[Image: source: /path]", "[Image #N]"). If the
    # turn is ONLY image references with no real words, it's an attachment echo — hide it.
    # Mixed turns (image marker + real text) keep their text untouched.
    if not clean_text(re.sub(r"\[Image[^\]]*\]", "", cleaned)):
        return ""
    return cleaned


def _strip_attachment_injection(text):
    """Strip the AWB attachment injection wrapper, returning only the user request text.

    AWB wraps file attachments as:
        The user attached the following local files. Inspect each relevant file
        with the appropriate file or image-reading tool before answering:
        - /path/to/file

        User request:
        <actual user prompt>

    When Codex echoes back the full request payload that wrapper is visible in the
    stored transcript; this strips it so only the real message shows.
    """
    if not text:
        return text
    if not text.lstrip().lower().startswith("the user attached the following local files"):
        return text
    marker = "\n\nuser request:\n"
    idx = text.lower().find(marker)
    if idx != -1:
        return clean_text(text[idx + len(marker):])
    return ""


def visible_user_prompt_text(text):
    """Return only the user-authored part of a backend user echo.

    Codex and some CLIs persist the full request payload as a userMessage. That
    payload can include Workbench-only project state, handoff context, time blocks,
    and file-attachment injection before the actual prompt; the conversation pane
    should only ever show what the user typed.
    """
    raw = clean_text(text)
    if not raw:
        return ""
    lowered = raw.lstrip().lower()
    has_hidden_prefix = lowered.startswith(
        (
            "project shared state",
            "read the authoritative continuation handoff",
            "also read the shared project state",
            "also read the project registry before acting",
        )
    )
    if has_hidden_prefix:
        if SESSION_CONTEXT_CLOSE in raw:
            suffix = raw.rsplit(SESSION_CONTEXT_CLOSE, 1)[1]
            _, visible = strip_session_context(suffix)
            result = clean_text(visible or suffix)
        else:
            # Fallback for payloads predating session_context injection:
            # strip known AWB prefix lines and any stray session_context blocks.
            fallback = SESSION_CONTEXT_BLOCK.sub("", raw)
            for pattern in (
                r"^Read the authoritative continuation handoff before acting:\s*\S+\s*",
                r"^Also read the shared project state before acting:\s*\S+\s*",
                r"^Also read the project registry before acting:\s*\S+\s*",
                r"^This handoff is being injected into an existing session\..*",
            ):
                fallback = re.sub(pattern, "", fallback, flags=re.IGNORECASE | re.MULTILINE)
            result = clean_text(fallback)
    else:
        _, visible = strip_session_context(raw)
        result = visible
    # After stripping PROJECT SHARED STATE and session_context time blocks, the
    # remaining text may still begin with the AWB file-attachment injection wrapper.
    # Strip that too so only the real user message reaches the conversation pane.
    return _strip_attachment_injection(result)


def _session_context_carry_suffix(text, markers):
    value = clean_text(text)
    if not value:
        return ""
    lowered = value.lower()
    max_length = max(len(marker) for marker in markers)
    limit = min(len(value), max_length - 1)
    for length in range(limit, 0, -1):
        suffix = lowered[-length:]
        if any(marker.startswith(suffix) for marker in markers):
            return value[-length:]
    return ""


def sanitize_session_context_stream(workspace, text):
    raw = clean_text(text)
    if not raw:
        return "", ""
    if workspace is None:
        return strip_session_context(raw)
    buffer = clean_text(workspace.get("session_context_buffer"))
    active = bool(workspace.get("session_context_active"))
    chunk = buffer + raw
    open_marker = SESSION_CONTEXT_OPEN.lower()
    close_marker = SESSION_CONTEXT_CLOSE.lower()
    lower_chunk = chunk.lower()
    cursor = 0
    visible = []
    while cursor < len(chunk):
        marker = close_marker if active else open_marker
        found = lower_chunk.find(marker, cursor)
        if found == -1:
            tail = chunk[cursor:]
            if active:
                carry = _session_context_carry_suffix(tail, (close_marker,))
                workspace["session_context_buffer"] = carry
                workspace["session_context_active"] = True
                return raw, clean_text("".join(visible))
            carry = _session_context_carry_suffix(tail, (open_marker, close_marker))
            emit = tail[:-len(carry)] if carry else tail
            if emit:
                visible.append(emit)
            workspace["session_context_buffer"] = carry
            workspace["session_context_active"] = False
            return raw, clean_text("".join(visible))
        if not active:
            if found > cursor:
                visible.append(chunk[cursor:found])
            cursor = found + len(SESSION_CONTEXT_OPEN)
            active = True
            continue
        cursor = found + len(SESSION_CONTEXT_CLOSE)
        active = False
    workspace["session_context_buffer"] = ""
    workspace["session_context_active"] = active
    return raw, clean_text("".join(visible))


