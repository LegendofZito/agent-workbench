    def _persist_workspace_config(self):
        active_index = 0
        if self.active_workspace_id in self.workspace_order:
            active_index = self.workspace_order.index(self.active_workspace_id)
        self.config.update(
            {
                "cwd": self.cwd.get(),
                "geometry": self.win.geometry(),
                "recent_projects": self.recent_projects,
                "active_agent": self.active_agent.get(),
                "agent_settings": self.agent_settings,
                "last_session_id": self.current_session.get("id") if self.current_session else None,
                "session_aliases": self.session_aliases,
                "session_order": self.session_order,
                "handoff_preferences": self.handoff_preferences,
                "custom_clients": self.custom_clients,
                "workspace_tabs": self._workspace_specs(),
                "active_workspace_index": active_index,
                "worker_jobs": self.worker_jobs,
            }
        )
        save_json(CONFIG_FILE, self.config, durable=False)

    def _agent_favorites(self, agent_key):
        """Return the mutable favorites list for *agent_key*, creating it on first access."""
        key = agent_key or "claude"
        if key not in self.skill_favorites_by_agent:
            self.skill_favorites_by_agent[key] = []
        lst = self.skill_favorites_by_agent[key]
        if not isinstance(lst, list):
            lst = []
            self.skill_favorites_by_agent[key] = lst
        return lst

    def _save_skill_favorites(self):
        """Persist per-agent skill favorites to config.json (non-durable write)."""
        self.config["skill_favorites_by_agent"] = self.skill_favorites_by_agent
        save_json(CONFIG_FILE, self.config, durable=False)

    def _schedule_workspace_config_save(self, immediate=False):
        if self.finalizing_close:
            return
        if immediate:
            if self._draft_persist_after is not None:
                try:
                    self.win.after_cancel(self._draft_persist_after)
                except tk.TclError:
                    pass
            self._draft_persist_after = None
            self._save_active_workspace()
            self._persist_workspace_config()
            return
        if self._draft_persist_after is not None:
            try:
                self.win.after_cancel(self._draft_persist_after)
            except tk.TclError:
                pass
        def run():
            self._draft_persist_after = None
            self._save_active_workspace()
            self._persist_workspace_config()

        self._draft_persist_after = self.win.after(350, run)

    def _restore_workspace(self, workspace):
        self.backends = workspace["backends"]
        self.active_agent.set(workspace["agent"])
        self.cwd.set(workspace["cwd"])
        self.selected_model.set(workspace["model"])
        self.selected_effort.set(workspace["effort"])
        self.status.set(workspace["status"])
        # Show cached usage immediately; fall back to the global per-provider cache so
        # switching tabs never shows "--" when another tab of the same provider already
        # fetched up-to-date data.
        agent_key = clean_text(workspace.get("agent"))
        display_usage = (
            workspace.get("usage")
            or (self.agent_usage.get(agent_key) if agent_key else None)
            or {}
        )
        self._display_usage(display_usage)
        self.usage_last_updated = clean_text(workspace.get("usage_last_updated")) or ""
        # Auto-fetch usage whenever a tab becomes active so the badge stays current.
        self.refresh_usage(manual=False)
        if (
            workspace.get("busy")
            and workspace.get("activity_state") == "starting"
            and float(workspace.get("turn_started_at") or 0.0)
        ):
            workspace["activity_state"] = "working"
            workspace["activity_text"] = "Working"
        self.activity_state = workspace["activity_state"]
        self.set_activity(
            workspace["activity_state"],
            workspace["activity_text"],
        )
        self.busy = workspace["busy"]
        self.live_speaker = workspace["live_speaker"]
        self.live_model = workspace.get("live_model") or ""
        self.transfer_source_session_id = workspace["transfer_source_session_id"]
        self.pending_user_input = workspace["pending_user_input"]
        self.live_source_signature = workspace["live_source_signature"]
        self.latest_agent_text = workspace["latest_agent_text"]
        self.last_token_usage = workspace.get("last_token_usage") or {}
        self.live_token_count = int(workspace.get("live_token_count") or 0)
        self.pending_attachments = list(workspace["pending_attachments"])
        self.queued_prompts = list(workspace.get("queued_prompts") or [])
        self.chat_updates_pending = bool(
            workspace.get("chat_updates_pending")
        )
        self.deferred_chat_updates = list(
            workspace.get("deferred_chat_updates") or []
        )
        self.current_session = workspace["current_session"]
        self.current_turn = workspace["current_turn"]
        self.session_backend_id = workspace["session_backend_id"]
        self.sessions = workspace["sessions"]
        self.local_sessions = workspace["local_sessions"]
        self.external_sessions = workspace["external_sessions"]
        self.refresh_agent_controls()
        self._update_worker_indicator()
        self._update_queue_indicator()
        self.apply_agent_theme(self.active_agent.get())
        self._render_session_list()
        self._clear_views(clear_attachments=False)
        if self.current_session:
            linked_path = linked_client_session_path(self.current_session)
            if linked_path:
                self.current_session["source_path"] = linked_path
                backend = self.current_session.get("backend") or {}
                if self.current_session.get("agent") == "claude":
                    self.current_session["source_session_id"] = clean_text(
                        backend.get("session_id")
                        or self.current_session.get("source_session_id")
                    )
                elif self.current_session.get("agent") == "codex":
                    self.current_session["source_session_id"] = clean_text(
                        backend.get("thread_id")
                        or self.current_session.get("source_session_id")
                    )
            self._render_session(
                self.current_session,
                on_complete=self.scroll_chat_to_latest,
                defer_start=True,
                batch_size=4,
            )
            if linked_path:
                signature = self._source_signature(linked_path)
                if signature and (
                    not self.current_session.get("transcript_loaded")
                    or signature != self.live_source_signature
                ):
                    self.live_source_signature = signature
                    self._load_external_session(
                        self.current_session, self.active_workspace_id
                    )
            self.refresh_artifacts_view(self.current_session, preview=False)
            self.update_context_indicator(self.current_session.get("context"))
            self._update_project_state_indicator(self.current_session)
            title = self._session_header_title(self.current_session)
            self.session_title.set(shorten(title, 110))
            self.session_label.set(
                f"{self._agent_spec(self.current_session.get('agent')).get('label')} · "
                f"{self._session_project_label(self.current_session)}"
            )
        else:
            self.session_title.set(APP_NAME)
            self.session_label.set("No session")
            self.update_context_indicator({})
            self._update_project_state_indicator(None)
            self.refresh_artifacts_view(None, preview=False)
        self._input_save_suppressed = True
        try:
            self.input.delete("1.0", "end")
            self.input.insert("1.0", workspace.get("input_text") or "")
            self.input.edit_modified(False)
            # Restored draft has no tracked pastes — Ctrl+Z must never erase it.
            self._paste_stack = []
            self._paste_redo = []
        finally:
            self._input_save_suppressed = False
        self._update_attachment_bar()
        self._update_chat_update_indicator()
        self.send_btn.configure(
            text="Reply" if self.pending_user_input else "Send",
            state="normal",
        )
        if self.busy:
            self.stop_btn.configure(state="normal")
            self.stop_btn.pack(side="right", padx=(0, 6))
        else:
            self.stop_btn.pack_forget()
            self.win.after(0, self._send_next_queued_prompt)
        # Re-render the skills chips bar (favorites are PER-AGENT — update when switching tabs)
        if hasattr(self, "skill_chips"):
            self._render_skill_chips()

    def switch_workspace(self, workspace_id):
        if workspace_id == self.active_workspace_id or workspace_id not in self.workspaces:
            return
        self._save_active_workspace()
        self._schedule_workspace_config_save(immediate=False)
        self.active_workspace_id = workspace_id
        self.workspaces[workspace_id]["tab_done"] = False  # viewing it clears the green
        self._restore_workspace(self.workspaces[workspace_id])
        self._update_worker_indicator()
        self._update_queue_indicator()
        self._render_workspace_tabs()

    def open_new_agent_dialog(self):
        dialog = tk.Toplevel(self.win)
        dialog.title("New agent tab")
        dialog.configure(bg=BG)
        dialog.transient(self.win)
        dialog.resizable(False, True)  # vertical resize so the scroll list can grow
        dialog.grab_set()  # modal: block the main window until closed / agent chosen
        dialog.focus_force()
        self._modal_scroll_lock += 1  # block the session list from scrolling underneath
        dialog.bind(
            "<Destroy>",
            lambda e: e.widget is dialog and setattr(
                self, "_modal_scroll_lock", max(0, self._modal_scroll_lock - 1)
            ),
            add="+",
        )

        body = tk.Frame(dialog, bg=BG, padx=20, pady=18)
        body.pack(fill="both", expand=True)
        tk.Label(
            body,
            text="Open a new agent",
            bg=BG,
            fg=TEXT,
            font=("Sans", 14, "bold"),
        ).pack(anchor="w")
        tk.Label(
            body,
            text="Each agent runs in its own tab. The left controls follow the selected tab.",
            bg=BG,
            fg=MUTED,
            justify="left",
            wraplength=460,
        ).pack(anchor="w", pady=(4, 14))

        # Ollama is HTTP-backed (no CLI executable). It's "installed" when the local
        # server is reachable — reuse this list for the Local-models section below too.
        ollama_models = self._list_ollama_models()

        # Scrollable body: the agent + local-model list can be taller than the screen
        # (8+ local models ran off the bottom with no way to reach them). Host every
        # row in a capped-height canvas with a working mouse wheel + scrollbar.
        scroll_wrap = tk.Frame(body, bg=BG)
        scroll_wrap.pack(fill="both", expand=True)
        scroll_canvas = tk.Canvas(scroll_wrap, bg=BG, highlightthickness=0, height=460)
        scroll_bar = tk.Scrollbar(scroll_wrap, orient="vertical", command=scroll_canvas.yview)
        scroll_content = tk.Frame(scroll_canvas, bg=BG)
        scroll_window = scroll_canvas.create_window((0, 0), window=scroll_content, anchor="nw")
        scroll_canvas.configure(yscrollcommand=scroll_bar.set)
        scroll_canvas.pack(side="left", fill="both", expand=True)
        scroll_bar.pack(side="right", fill="y")
        scroll_content.bind(
            "<Configure>",
            lambda _e: scroll_canvas.configure(scrollregion=scroll_canvas.bbox("all")),
        )
        scroll_canvas.bind(
            "<Configure>",
            lambda e: scroll_canvas.itemconfigure(scroll_window, width=e.width),
        )

        dialog_path = str(dialog)

        def _new_agent_wheel(event):
            # Only scroll when the pointer is actually over THIS dialog. bind_all
            # otherwise captures wheel events from the whole app, so scrolling the
            # session list behind the dialog double-scrolled this list too.
            # Compare Tcl path strings — winfo_toplevel() returns a new Python object
            # each call, so `is` identity check always fails; str() gives the stable path.
            under = dialog.winfo_containing(event.x_root, event.y_root)
            if under is None or str(under.winfo_toplevel()) != dialog_path:
                return
            step = -1 if (getattr(event, "num", 0) == 4 or getattr(event, "delta", 0) > 0) else 1
            scroll_canvas.yview_scroll(step, "units")

        for _seq in ("<MouseWheel>", "<Button-4>", "<Button-5>"):
            scroll_canvas.bind_all(_seq, _new_agent_wheel)
        dialog.bind(
            "<Destroy>",
            lambda e: e.widget is dialog
            and [scroll_canvas.unbind_all(s) for s in ("<MouseWheel>", "<Button-4>", "<Button-5>")],
        )

        for spec in self.agent_specs:
            agent_key = spec["key"]
            if spec.get("custom"):
                # Connected custom/local client (Ollama HTTP-backed or a validated
                # custom CLI) — no system executable to probe; it's ready.
                installed = True
            elif agent_key == "ollama":
                # Reachable Ollama server (models list is non-None) = ready.
                installed = ollama_models is not None
            else:
                exe = self._agent_executable(agent_key)
                installed = bool(exe) and shutil.which(exe)
            row = tk.Frame(
                scroll_content,
                bg=PANEL,
                highlightbackground="#2d3b49",
                highlightthickness=1,
            )
            row.pack(fill="x", pady=4)
            info = tk.Frame(row, bg=PANEL)
            info.pack(side="left", fill="x", expand=True, padx=12, pady=10)
            tk.Label(
                info,
                text=spec["label"],
                bg=PANEL,
                fg=TEXT,
                font=("Sans", 10, "bold"),
            ).pack(anchor="w")
            tk.Label(
                info,
                text="Ready" if installed else "Not installed",
                bg=PANEL,
                fg="#86efac" if installed else "#facc15",
            ).pack(anchor="w")
            tk.Button(
                row,
                text="Open tab",
                command=lambda key=agent_key: (
                    dialog.destroy(),
                    self.new_workspace(key),
                ),
                bg=spec.get("color", ACCENT) if installed else "#334155",
                fg="white",
                activebackground=SIDEBAR_SEL,
                activeforeground="white",
                relief="flat",
                padx=10,
                pady=5,
                cursor="hand2",
                state="normal" if installed else "disabled",
            ).pack(side="right", padx=10)

        # Local models (Ollama): auto-list installed models that aren't connected
        # yet, so a pulled model is startable here directly. "Start" connects it and
        # opens a new tab. (Reuses the ollama_models probed above.)
        if ollama_models:
            connected = {clean_text(c.get("model")) for c in self.custom_clients}
            available = [m for m in ollama_models if f"ollama_chat/{m}" not in connected]
            if available:
                tk.Label(
                    scroll_content,
                    text="Local models (Ollama) — free, runs on this machine",
                    bg=BG,
                    fg=MUTED,
                    font=("Sans", 9, "bold"),
                    anchor="w",
                ).pack(fill="x", pady=(14, 2))
                for model in available:
                    row = tk.Frame(scroll_content, bg=PANEL, highlightbackground="#2d3b49", highlightthickness=1)
                    row.pack(fill="x", pady=4)
                    info = tk.Frame(row, bg=PANEL)
                    info.pack(side="left", fill="x", expand=True, padx=12, pady=10)
                    tk.Label(info, text=model, bg=PANEL, fg=TEXT, font=("Sans", 10, "bold")).pack(anchor="w")
                    tk.Label(info, text="Local · ready", bg=PANEL, fg="#86efac").pack(anchor="w")
                    tk.Button(
                        row,
                        text="Start",
                        command=lambda m=model: self._start_local_model(m, dialog),
                        bg="#10b981",
                        fg="white",
                        activebackground=SIDEBAR_SEL,
                        activeforeground="white",
                        relief="flat",
                        padx=10,
                        pady=5,
                        cursor="hand2",
                    ).pack(side="right", padx=10)

        # Finalize scrolling now that every row exists:
        #  - set scrollregion to span ALL rows so the scrollbar thumb sizes/moves right
        #    (it wasn't reflecting position before), and
        #  - cap the window's max height to the content height so dragging the bottom
        #    reveals more agent rows and then STOPS — instead of opening a black buffer
        #    below the list.
        scroll_content.update_idletasks()
        content_h = scroll_content.winfo_reqheight()
        visible_h = min(content_h, 520)
        scroll_canvas.configure(
            scrollregion=scroll_canvas.bbox("all") or (0, 0, 0, content_h),
            height=visible_h,
        )
        dialog.update_idletasks()
        chrome = max(0, dialog.winfo_reqheight() - visible_h)
        dialog.maxsize(dialog.winfo_reqwidth() + 400, content_h + chrome)

        dialog.bind("<Escape>", lambda _e: dialog.destroy())
        dialog.update_idletasks()
        x = self.win.winfo_rootx() + max(
            0, (self.win.winfo_width() - dialog.winfo_reqwidth()) // 2
        )
        y = self.win.winfo_rooty() + max(
            0, (self.win.winfo_height() - dialog.winfo_reqheight()) // 3
        )
        dialog.geometry(f"+{x}+{y}")

    def new_workspace(self, agent_key=None):
        if self.close_when_idle and not self.restart_after_close:
            self.status.set("Workbench is waiting for active tasks to finish before closing.")
            return
        if agent_key is None:
            self.open_new_agent_dialog()
            return
        if agent_key not in self.agent_map:
            return
        if self._at_tab_limit():
            self._notify_tab_limit()
            return
        self._save_active_workspace()
        self._schedule_workspace_config_save(immediate=True)
        previous_agent = self.active_agent.get()
        settings = self.agent_settings.get(
            agent_key,
            self._default_settings_for(agent_key),
        )
        self.active_agent.set(agent_key)
        self.selected_model.set(settings["model"])
        self.selected_effort.set(settings["effort"])
        workspace_id = self._create_workspace()
        self.active_agent.set(previous_agent)
        self.active_workspace_id = workspace_id
        self._restore_workspace(self.workspaces[workspace_id])
        session = self.store.new_session(
            agent_key,
            self.cwd.get(),
        )
        self.current_session = session
        self.local_sessions = self.store.list_all_local(agent_key)
        self.external_sessions = self._discover_sessions_for_picker(
            self.cwd.get(), agent_key
        )
        self.sessions = self._combined_sessions()
        self.open_session(session["id"], remember=False)
        self._save_active_workspace()
        self._render_workspace_tabs()
        self.input.focus_set()

    def close_workspace(self, workspace_id):
        if len(self.workspace_order) == 1:
            return
        workspace = self.workspaces.get(workspace_id)
        if not workspace:
            return
        if workspace.get("busy") and not messagebox.askyesno(
            "Close working tab",
            "This agent is still working. Stop it and close the tab?",
            parent=self.win,
        ):
            return
        for backend in workspace["backends"].values():
            backend.close()
        was_active = workspace_id == self.active_workspace_id
        closing_index = self.workspace_order.index(workspace_id)
        self.workspace_order.remove(workspace_id)
        self.workspaces.pop(workspace_id, None)
        if was_active:
            next_index = min(closing_index, len(self.workspace_order) - 1)
            self.active_workspace_id = self.workspace_order[next_index]
            self._restore_workspace(self.workspaces[self.active_workspace_id])
        self._schedule_workspace_config_save(immediate=True)
        self._render_workspace_tabs()

    def cycle_workspace(self, direction):
        if len(self.workspace_order) < 2:
            return "break"
        index = self.workspace_order.index(self.active_workspace_id)
        target = self.workspace_order[(index + direction) % len(self.workspace_order)]
        self.switch_workspace(target)
        return "break"

    def _workspace_label(self, workspace):
        session = workspace.get("current_session") or {}
        title = clean_text(session.get("title")) or workspace.get("title") or "New session"
        agent = self._agent_spec(workspace.get("agent", "codex")).get("label", "Agent")
        marker = " •" if workspace.get("busy") else ""
        queued = len(workspace.get("queued_prompts") or [])
        queue_marker = f" · {queued} queued" if queued else ""
        return shorten(f"{agent}{queue_marker}: {title}", 40) + marker

    def _working_workspace_labels(self):
        labels = []
        for workspace in self.workspaces.values():
            if not workspace.get("busy"):
                continue
            label = self._workspace_label(workspace)
            labels.append(label[:-2] if label.endswith(" •") else label)
        return labels

    def _maybe_finish_deferred_close(self):
        if not self.close_when_idle or self.finalizing_close:
            return
        working = self._working_workspace_labels()
        if working:
            self.win.title(f"{APP_NAME} · Waiting for {len(working)} task(s)")
            return
        self.finalize_close()

    def warn_interrupted_turns(self):
        interrupted = []
        for session in self.store.sessions.values():
            turns = session.get("turns") or []
            if not turns or turns[-1].get("status") != "running":
                continue
            turns[-1]["status"] = "interrupted"
            turns[-1]["completed_at"] = now_iso()
            self.store.save(session)
            agent = self._agent_spec(session.get("agent", "codex"))["label"]
            title = clean_text(session.get("title")) or "Untitled session"
            interrupted.append(f"{agent}: {shorten(title, 54)}")
        if not interrupted:
            return
        shown = interrupted[:8]
        suffix = (
            f"\n- +{len(interrupted) - len(shown)} more"
            if len(interrupted) > len(shown)
            else ""
        )
        messagebox.showwarning(
            "Previous work was interrupted",
            (
                "Agent Workbench previously closed before this work reported "
                "completion. Review or resume these sessions:\n\n- "
                + "\n- ".join(shown)
                + suffix
            ),
            parent=self.win,
        )

    def poll_update_request(self):
        if self.finalizing_close:
            return
        request = load_json(UPDATE_REQUEST_FILE, {})
        if request:
            try:
                os.unlink(UPDATE_REQUEST_FILE)
            except OSError:
                pass
            if int(request.get("pid") or 0) == os.getpid():
                self.request_restart()
        self.win.after(1000, self.poll_update_request)

    def _render_workspace_tabs(self):
        if self._workspace_tabs_render_after is not None:
            try:
                self.win.after_cancel(self._workspace_tabs_render_after)
            except tk.TclError:
                pass
        self._workspace_tabs_render_after = self.win.after_idle(self._render_workspace_tabs_now)

    def _on_win_configure(self, _event=None):
        # Reflow tabs to fit when the window WIDTH changes (so they shrink only when
        # they'd overflow). Width-gated so it never loops on our own re-renders.
        try:
            width = self.win.winfo_width()
        except tk.TclError:
            return
        if abs(width - getattr(self, "_last_win_width", 0)) < 24:
            return
        self._last_win_width = width
        self._workspace_tabs_signature = None  # force a width-aware recompute
        self._render_workspace_tabs()

    def _tab_wheel_direction(self, event):
        num = getattr(event, "num", 0)
        if num in (4, 6):
            return -1
        if num in (5, 7):
            return 1
        delta = getattr(event, "delta", 0)
        if delta > 0:
            return -1
        if delta < 0:
            return 1
        return 0

    def _on_tab_mousewheel(self, event, horizontal_handler):
        if getattr(event, "state", 0) & 0x0001:
            return horizontal_handler(event)
        return "break"

    def _on_workspace_tab_horizontal_wheel(self, event):
        direction = self._tab_wheel_direction(event)
        if direction:
            self.cycle_workspace(direction)
        return "break"

    def _on_notebook_horizontal_wheel(self, event):
        if not hasattr(self, "notebook"):
            return "break"
        tabs = list(self.notebook.tabs())
        if len(tabs) < 2:
            return "break"
        direction = self._tab_wheel_direction(event)
        if not direction:
            return "break"
        try:
            index = self.notebook.index("current")
            self.notebook.select(tabs[(index + direction) % len(tabs)])
        except tk.TclError:
            pass
        return "break"

    def _bind_tab_wheel_handlers(self, widget, horizontal_handler):
        # Vertical wheel over tab controls must not switch tabs; horizontal wheel can.
        for seq in ("<MouseWheel>", "<Button-4>", "<Button-5>"):
            widget.bind(
                seq,
                lambda event, handler=horizontal_handler: self._on_tab_mousewheel(
                    event,
                    handler,
                ),
            )
        for seq in (
            "<Shift-MouseWheel>",
            "<Shift-Button-4>",
            "<Shift-Button-5>",
            "<Button-6>",
            "<Button-7>",
        ):
            widget.bind(seq, horizontal_handler)

    def _usage_exhausted(self, usage):
        for window in (usage or {}).get("windows") or []:
            try:
                percent = int(window.get("used_percent") or 0)
            except (TypeError, ValueError):
                percent = 0
            remaining = window.get("remaining")
            try:
                remaining = float(remaining) if remaining is not None else None
            except (TypeError, ValueError):
                remaining = None
            if percent >= 100 or remaining == 0:
                return True
        return False

    def _workspace_usage_exhausted(self, workspace):
        if self._usage_exhausted(workspace.get("usage")):
            return True
        agent = clean_text(workspace.get("agent"))
        if not agent:
            return False
        if self._usage_exhausted(self.agent_usage.get(agent)):
            return True
        for other in self.workspaces.values():
            if other is workspace or clean_text(other.get("agent")) != agent:
                continue
            if self._usage_exhausted(other.get("usage")):
                return True
        return False

    def _tab_status(self, workspace):
        """Tab color state: red for exhausted usage, yellow while a turn runs,
        green after it finishes until that tab is viewed, else default."""
        if self._workspace_usage_exhausted(workspace):
            return "usage_maxed"
        if workspace.get("busy"):
            return "working"
        if workspace.get("tab_done"):
            return "done"
        return None

    def _render_workspace_tabs_now(self):
        if not hasattr(self, "workspace_tabs_frame"):
            return
        self._workspace_tabs_render_after = None
        order = [wid for wid in self.workspace_order if wid in self.workspaces]
        n = len(order)
        pad_in = 10
        # CONSTANT width for every tab — never derived from available space or tab
        # count. A dynamic width meant tabs were different sizes during transitions
        # (and the first couple stayed a stale size), so the × moved and you had to
        # chase it with the cursor. With a fixed width, every tab is identical from
        # the first paint, so closing one drops the next tab's × exactly under the
        # cursor for spam-close. Overflow is handled by the existing horizontal scroll.
        tab_width = 160  # uniform px width for every tab (spam-close alignment)
        tab_height = 30  # fixed px height — pack_propagate(False) needs this or the
        #                  frame collapses and clips the label/× vertically.
        avg_char_px = 7
        close_px = 24
        maxlen = max(4, int((tab_width - pad_in * 2 - close_px) / avg_char_px))
        signature = ((tab_width, tab_height),) + tuple(
            (
                workspace_id,
                workspace_id == self.active_workspace_id,
                shorten(self._workspace_label(self.workspaces[workspace_id]), maxlen),
                self._tab_status(self.workspaces[workspace_id]),
            )
            for workspace_id in order
        )
        signature += (("tail", "limit" if n >= MAX_WORKSPACE_TABS else "new"),)
        if signature == self._workspace_tabs_signature:
            return
        self._workspace_tabs_signature = signature

        widgets = getattr(self, "_workspace_tab_widgets", {})
        for stale_id in list(widgets):
            if stale_id not in order:
                try:
                    widgets[stale_id]["frame"].destroy()
                except tk.TclError:
                    pass
                widgets.pop(stale_id, None)
        self._workspace_tab_widgets = widgets

        # Only reorder (pack_forget + pack) when the set or sequence of tabs changed.
        # For color/selection-only changes, configure() in place to avoid the blink
        # that happens when all frames briefly disappear and reappear simultaneously.
        tail_kind = "limit" if n >= MAX_WORKSPACE_TABS else "new"
        order_sig = tuple(order) + (tail_kind,)
        needs_reorder = order_sig != getattr(self, "_workspace_tabs_order_sig", None)

        for pos, workspace_id in enumerate(order):
            workspace = self.workspaces[workspace_id]
            selected = workspace_id == self.active_workspace_id
            label = shorten(self._workspace_label(workspace), maxlen)
            # Whole-tab color: the entire box turns yellow while a turn is working and
            # green when it just finished (green clears when you view that tab) —
            # visible even for background tabs. Dark text for contrast on the colors.
            status = self._tab_status(workspace)
            if status == "usage_maxed":
                tab_bg, tab_fg, close_fg = "#b91c1c", "#ffffff", "#fee2e2"
            elif status == "working":
                tab_bg, tab_fg, close_fg = "#eab308", "#1c1500", "#7f1d1d"
            elif status == "done":
                tab_bg, tab_fg, close_fg = "#22c55e", "#04230f", "#7f1d1d"
            else:
                tab_bg = SIDEBAR_SEL if selected else PANEL
                tab_fg = TEXT
                close_fg = MUTED

            tab = widgets.get(workspace_id)
            is_new = not tab
            if is_new:
                # Fixed-width frame: pack_propagate(False) locks it to tab_width so
                # all tabs are the same size. × is packed RIGHT so it always lands
                # at the same pixel — closing one tab puts the next tab's × exactly
                # where the cursor already is (spam-close without moving the mouse).
                frame = tk.Frame(
                    self.workspace_tabs_frame,
                    bg=tab_bg,
                    width=tab_width,
                    height=tab_height,
                )
                frame.pack_propagate(False)
                self._bind_tab_wheel_handlers(frame, self._on_workspace_tab_horizontal_wheel)
                close_button = tk.Button(
                    frame,
                    text="×",
                    command=lambda wid=workspace_id: self.close_workspace(wid),
                    activebackground="#7f1d1d",
                    activeforeground="white",
                    relief="flat",
                    borderwidth=0,
                    highlightthickness=0,
                    padx=4,
                    pady=5,
                    cursor="hand2",
                )
                close_button.pack(side="right")
                self._bind_tab_wheel_handlers(close_button, self._on_workspace_tab_horizontal_wheel)
                tab_button = tk.Button(
                    frame,
                    command=lambda wid=workspace_id: self.switch_workspace(wid),
                    relief="flat",
                    borderwidth=0,
                    highlightthickness=0,
                    padx=pad_in,
                    pady=5,
                    cursor="hand2",
                    anchor="w",
                )
                tab_button.pack(side="left", fill="x", expand=True)
                self._bind_tab_wheel_handlers(tab_button, self._on_workspace_tab_horizontal_wheel)
                tab = {"frame": frame, "button": tab_button, "close": close_button}
                widgets[workspace_id] = tab

            # Reorder only when the tab sequence changed or this is a brand-new tab.
            # Pure color/label/selection updates skip the pack cycle entirely so
            # tabs never blink when switching active tabs or updating status colors.
            if is_new or needs_reorder:
                try:
                    tab["frame"].pack_forget()
                except tk.TclError:
                    pass  # new frames were never packed; ignore and fall through to pack()
                tab["frame"].configure(
                    bg=tab_bg,
                    width=tab_width,
                    height=tab_height,
                    highlightbackground="#e2e8f0" if selected else tab_bg,
                    highlightthickness=2 if selected else 0,
                )
                tab["button"].configure(
                    text=label,
                    bg=tab_bg,
                    fg=tab_fg,
                    activebackground=tab_bg,
                    activeforeground=tab_fg,
                )
                tab["close"].configure(
                    bg=tab_bg,
                    fg=close_fg,
                )
                tab["frame"].pack(side="left", padx=(4, 0), pady=4)
            else:
                try:
                    tab["frame"].configure(
                        bg=tab_bg,
                        width=tab_width,
                        height=tab_height,
                        highlightbackground="#e2e8f0" if selected else tab_bg,
                        highlightthickness=2 if selected else 0,
                    )
                    tab["button"].configure(
                        text=label,
                        bg=tab_bg,
                        fg=tab_fg,
                        activebackground=tab_bg,
                        activeforeground=tab_fg,
                    )
                    tab["close"].configure(
                        bg=tab_bg,
                        fg=close_fg,
                    )
                except tk.TclError:
                    pass

        self._workspace_tabs_order_sig = order_sig

        tail = getattr(self, "_workspace_tabs_tail", None)
        if not tail or tail.get("kind") != tail_kind:
            if tail:
                try:
                    tail["widget"].destroy()
                except tk.TclError:
                    pass
            tail_widget = None
            if tail_kind == "limit":
                tail_widget = tk.Label(
                    self.workspace_tabs_frame,
                    text=f"({MAX_WORKSPACE_TABS} tab limit reached)",
                    bg=PANEL,
                    fg=MUTED,
                    font=("Sans", 8, "italic"),
                    padx=10,
                    pady=6,
                )
            else:
                tail_widget = tk.Button(
                    self.workspace_tabs_frame,
                    text="+",
                    command=self.open_new_agent_dialog,
                    bg=PANEL_ALT,
                    fg=TEXT,
                    activebackground=SIDEBAR_SEL,
                    activeforeground=TEXT,
                    relief="flat",
                    borderwidth=0,
                    highlightthickness=0,
                    padx=12,
                    pady=6,
                    cursor="hand2",
                )
            self._bind_tab_wheel_handlers(tail_widget, self._on_workspace_tab_horizontal_wheel)
            tail = {"kind": tail_kind, "widget": tail_widget}
            self._workspace_tabs_tail = tail
        try:
            tail["widget"].pack_forget()
        except tk.TclError:
            pass
        if n >= MAX_WORKSPACE_TABS:
            tail["widget"].configure(
                text=f"({MAX_WORKSPACE_TABS} tab limit reached)",
                bg=PANEL,
                fg=MUTED,
            )
        else:
            tail["widget"].configure(
                bg=PANEL_ALT,
                fg=TEXT,
                activebackground=SIDEBAR_SEL,
                activeforeground=TEXT,
            )
        tail["widget"].pack(side="left", padx=(6, 0), pady=4)

