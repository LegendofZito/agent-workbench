    def _readonly_artifact_key(self, event):
        """Artifact previews are selectable/copyable, but never editable and never
        route typed text into the composer while the preview has focus."""
        ctrl = bool(event.state & 0x4)
        key = clean_text(event.keysym)
        if ctrl and key.lower() == "c":
            return self.copy_widget_selection(self.artifact_preview_text)
        if ctrl and key.lower() == "a":
