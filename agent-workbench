def ensure_local_delegate_mcp_config():
    """Write the MCP config pointing at the local-delegate server and return its
    path — but only if the server script is actually deployed. Returns None
    otherwise so the caller skips --mcp-config gracefully (never breaks a turn)."""
    if not os.path.isfile(LOCAL_DELEGATE_SERVER):
        return None
    try:
        model = LOCAL_DELEGATE_DEFAULT_MODEL
        config = {
            "mcpServers": {
                "local-delegate": {
                    "command": "python3",
                    "args": [LOCAL_DELEGATE_SERVER],
                    "env": {"DELEGATE_MODEL": model},
                }
            }
        }
        with open(LOCAL_DELEGATE_MCP_CONFIG, "w", encoding="utf-8") as handle:
            json.dump(config, handle)
        return LOCAL_DELEGATE_MCP_CONFIG
    except OSError:
        return None

