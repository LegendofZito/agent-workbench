        worker_scroll.pack(side="right", fill="y")
        worker_list.configure(yscrollcommand=worker_scroll.set)

        detail = ScrolledText(
            content,
            wrap="word",
            bg=PANEL_ALT,
            fg=TEXT,
            relief="flat",
            borderwidth=0,
            padx=14,
            pady=12,
            font=("Sans", 10),
            height=16,
            width=56,
