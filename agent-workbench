def delete_client_session(session):
    agent = clean_text((session or {}).get("agent"))
    backend = (session or {}).get("backend") or {}
    if agent == "codex":
        session_id = clean_text(
            backend.get("thread_id") or (session or {}).get("source_session_id")
        )
    else:
        session_id = clean_text(
            (session or {}).get("source_session_id")
            or backend.get("session_id")
            or backend.get("thread_id")
        )
    if not session_id:
        return False, True, ""

    if agent == "claude":
        try:
            session_id = clean_text(session_id)
            path = linked_claude_session_path(session)
            marker = os.path.splitext(os.path.basename(path))[0] if path else session_id
            cache_root = claude_session_cache_root((session or {}).get("cwd"))
            candidates = [Path(path)] if path else []
            if os.path.isdir(cache_root):
                candidates.extend(Path(cache_root).glob(f"{marker}.jsonl"))
            project_root = Path(os.path.expanduser("~/.claude/projects"))
            if project_root.is_dir():
                candidates.extend(project_root.glob(f"*/{marker}.jsonl"))
            if not candidates:
                return True, True, ""
            for candidate in {candidate for candidate in candidates if candidate.is_file()}:
                try:
                    candidate.unlink()
                except OSError:
                    pass
            return True, True, ""
        except OSError as exc:
            return True, False, str(exc)

    if agent == "codex":
        try:
            result = subprocess.run(
                ["codex", "archive", session_id],
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                timeout=15,
                check=False,
            )
        except (OSError, subprocess.TimeoutExpired) as exc:
            return True, False, str(exc)
        if result.returncode == 0:
            return True, True, ""
        return True, False, clean_text(result.stdout) or "Codex could not archive the session."

    if agent == "gemini":
        cwd = clean_text((session or {}).get("cwd")) or os.path.expanduser("~")
        command = [
            "gemini",
            "--list-sessions",
            "--skip-trust",
            "--yolo",
            "--include-directories",
            cwd,
        ]
        try:
            listed = subprocess.run(
                command,
                cwd=cwd,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                timeout=15,
                check=False,
            )
        except (OSError, subprocess.TimeoutExpired) as exc:
            return True, False, str(exc)
        index = ""
        for line in (listed.stdout or "").splitlines():
            if f"[{session_id}]" not in line:
                continue
            match = re.match(r"\s*(\d+)\.", line)
            if match:
                index = match.group(1)
                break
        if not index:
            return True, False, "Gemini session was not found in its session list."
        try:
            deleted = subprocess.run(
                [
                    "gemini",
                    "--delete-session",
                    index,
                    "--skip-trust",
                    "--yolo",
                    "--include-directories",
                    cwd,
                ],
                cwd=cwd,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                timeout=15,
                check=False,
            )
        except (OSError, subprocess.TimeoutExpired) as exc:
            return True, False, str(exc)
        if deleted.returncode == 0:
            return True, True, ""
        return True, False, clean_text(deleted.stdout) or "Gemini could not delete the session."

    return False, True, ""


def gemini_sessions_for_cwd(cwd):
    cmd = [
        "gemini",
        "--list-sessions",
        "--skip-trust",
        "--yolo",
        "--include-directories",
        cwd,
    ]
    try:
        result = subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=12,
            check=False,
        )
    except Exception:
        return []
    title_cache = load_json(GEMINI_TITLE_CACHE_FILE, {})
    if not isinstance(title_cache, dict):
        title_cache = {}
    cache_changed = False
    sessions = []
    seen = set()
    for line in (result.stdout or "").splitlines():
        line = clean_text(ANSI_ESCAPE.sub("", line))
        if not line:
            continue
        if line.startswith("Available sessions for this project"):
            continue
        if line.startswith("YOLO mode is enabled"):
            continue
        if line.startswith("[SessionSummary]"):
            continue
        match = re.match(
            r"^\s*\d+\.\s+(.*?)\s+\(([^()]*)\)\s+"
            r"\[([0-9a-fA-F-]{36})\]\s*$",
            line,
        )
        if not match:
            continue
        title, age, sid = (clean_text(value) for value in match.groups())
        if sid in seen:
            continue
        seen.add(sid)
        _, visible_title = strip_session_context(title)
        if visible_title:
            title = visible_title
        elif title.lower().startswith(SESSION_CONTEXT_OPEN):
            title = "Gemini session"
        if title and title != "Gemini session":
            if clean_text(title_cache.get(sid)) != title:
                title_cache[sid] = title
                cache_changed = True
        source_path = gemini_session_path(sid)
        try:
            mtime = os.path.getmtime(source_path) if source_path else time.time()
        except OSError:
            mtime = time.time()
        sessions.append(
            {
                "id": f"gemini-terminal:{sid}",
                "source_session_id": sid,
                "agent": "gemini",
                "origin": "gemini-terminal",
                "cwd": cwd,
                "title": title or "Gemini session",
                "preview": title or "Gemini session",
                "created_at": iso_from_unix(mtime),
                "updated_at": iso_from_unix(mtime),
                "age": age,
                "source_path": source_path,
                "backend": {"session_id": sid},
                "turns": [],
                "transcript_loaded": not bool(source_path),
            }
        )
    project_hash = hashlib.sha256(
        os.path.abspath(os.path.expanduser(cwd)).encode("utf-8")
    ).hexdigest()
    for sid, metadata in gemini_session_index().items():
        if sid in seen or metadata.get("project_hash") != project_hash:
            continue
        source_path = metadata.get("path") or ""
        title = (
            clean_text(title_cache.get(sid))
            or gemini_title_from_jsonl(source_path)
            or "Gemini session"
        )
        sessions.append(
            {
                "id": f"gemini-terminal:{sid}",
                "source_session_id": sid,
                "agent": "gemini",
                "origin": "gemini-terminal",
                "cwd": cwd,
                "title": title,
                "preview": title,
                "created_at": metadata.get("start_time") or now_iso(),
                "updated_at": metadata.get("last_updated") or now_iso(),
                "age": "",
                "source_path": source_path,
                "backend": {"session_id": sid},
                "turns": [],
                "transcript_loaded": not bool(source_path),
            }
        )
    if cache_changed:
        save_json(GEMINI_TITLE_CACHE_FILE, title_cache)
    sessions.sort(key=lambda session: session.get("updated_at") or "", reverse=True)
    return sessions


def gemini_session_index():
    home = Path(os.path.expanduser("~/.gemini"))
    index = {}
    for root in (home / "tmp", home / "history"):
        if not root.is_dir():
            continue
        for candidate in root.glob("*/chats/session-*.jsonl"):
            try:
                with candidate.open(encoding="utf-8") as handle:
                    header = json.loads(handle.readline())
                sid = clean_text(header.get("sessionId"))
                if not sid:
                    continue
                mtime = candidate.stat().st_mtime_ns
            except (OSError, ValueError, TypeError):
                continue
            existing = index.get(sid)
            if existing and int(existing.get("mtime") or 0) >= mtime:
                continue
            index[sid] = {
                "path": str(candidate),
                "project_hash": clean_text(header.get("projectHash")),
                "start_time": clean_text(header.get("startTime")),
                "last_updated": iso_from_unix(candidate.stat().st_mtime),
                "mtime": mtime,
            }
    return index


def gemini_session_path(session_id):
    sid = clean_text(session_id)
    if not sid:
        return ""
    return clean_text((gemini_session_index().get(sid) or {}).get("path"))


@lru_cache(maxsize=256)
def gemini_title_from_jsonl(path):
    if not path or not os.path.isfile(path):
        return ""

    def visible_user_text(message):
        if not isinstance(message, dict) or message.get("type") != "user":
            return ""
        parts = []
        for block in message.get("content") or []:
            if isinstance(block, dict) and block.get("text"):
                parts.append(clean_text(block.get("text")))
        prompt = clean_text("\n".join(parts))
        _, visible = strip_session_context(prompt)
        visible = visible or (
            "" if prompt.lower().startswith(SESSION_CONTEXT_OPEN) else prompt
        )
        visible = re.sub(
            r"^Previous\s+\w+\s+session\s+for\s+[^:]+:\s*"
            r"No prior details available\.\s*",
            "",
            visible,
            flags=re.IGNORECASE,
        )
        return clean_text(visible)

    try:
        with open(path, encoding="utf-8") as handle:
            for index, line in enumerate(handle):
                if index > 500:
                    break
                try:
                    obj = json.loads(line)
                except ValueError:
                    continue
                messages = []
                if isinstance(obj, dict) and isinstance(obj.get("$set"), dict):
                    value = obj["$set"].get("messages")
                    if isinstance(value, list):
                        messages = value
                elif isinstance(obj, dict):
                    messages = [obj]
                for message in messages:
                    text = visible_user_text(message)
                    if text:
                        return shorten(text, 80)
    except OSError:
        pass
    return ""


def gemini_jsonl_turns(path):
    if not path or not os.path.isfile(path):
        return []
    try:
        with open(path, encoding="utf-8") as handle:
            messages = []
            seen_message_ids = set()
            for line in handle:
                try:
                    obj = json.loads(line)
                except ValueError:
                    continue
                if isinstance(obj, dict) and isinstance(obj.get("$set"), dict):
                    payload = obj["$set"].get("messages")
                    if isinstance(payload, list):
                        messages = payload
                        seen_message_ids = {
                            clean_text(message.get("id"))
                            for message in messages
                            if isinstance(message, dict)
                            and clean_text(message.get("id"))
                        }
                    continue
                if not isinstance(obj, dict) or obj.get("type") not in {
                    "user",
                    "gemini",
                }:
                    continue
                message_id = clean_text(obj.get("id"))
                if message_id and message_id in seen_message_ids:
                    continue
                messages.append(obj)
                if message_id:
                    seen_message_ids.add(message_id)
    except OSError:
        return []
    turns = []
    current = None

    def ensure_turn(timestamp=""):
        nonlocal current
        if current is None:
            current = {
                "id": str(uuid.uuid4()),
                "created_at": clean_text(timestamp) or now_iso(),
                "status": "completed",
                "items": [],
            }
            turns.append(current)
        return current

    def append_reasoning(text):
        if isinstance(text, list):
            text = "\n".join(clean_text(part) for part in text if clean_text(part))
        text = clean_text(text)
        if text:
            ensure_turn().setdefault("items", []).append(
                {"type": "reasoning", "summary": [text]}
            )

    def append_system(text, tag="system"):
        text = clean_text(text)
        if text:
            ensure_turn().setdefault("items", []).append(
                {"type": "system", "text": text, "tag": tag}
            )

    for message in messages:
        if not isinstance(message, dict):
            continue
        message_type = message.get("type")
        timestamp = clean_text(message.get("timestamp"))
        content = message.get("content") or []
        if not isinstance(content, list):
            content = []
        if message_type == "user":
            text_parts = []
            tool_results = []
            for block in content:
                if not isinstance(block, dict):
                    continue
                if block.get("text"):
                    text_parts.append(clean_text(block.get("text")))
                elif block.get("functionResponse"):
                    tool_results.append(block["functionResponse"])
                elif block.get("type") == "tool_result":
                    tool_results.append(block)
            prompt = clean_text("\n".join(part for part in text_parts if part))
            raw_prompt, visible_prompt = strip_session_context(prompt)
            if raw_prompt and not visible_prompt:
                append_system(raw_prompt, "system")
                prompt = ""
            elif raw_prompt and visible_prompt:
                append_system(raw_prompt, "system")
                prompt = visible_prompt
            if prompt:
                current = {
                    "id": message.get("id") or str(uuid.uuid4()),
                    "created_at": timestamp or now_iso(),
                    "status": "completed",
                    "items": [
                        {
                            "type": "userMessage",
                            "content": [{"type": "text", "text": prompt}],
                        }
                    ],
                }
                turns.append(current)
            if tool_results:
                ensure_turn(timestamp)
                for tool_result in tool_results:
                    response = tool_result.get("response") or tool_result.get("content") or tool_result
                    text = ""
                    if isinstance(response, dict):
                        text = clean_text(
                            response.get("output")
                            or response.get("text")
                            or response.get("message")
                            or response.get("error")
                        )
                    elif isinstance(response, list):
                        text = "\n".join(
                            clean_text(bit.get("text"))
                            for bit in response
                            if isinstance(bit, dict) and bit.get("text")
                        )
                    else:
                        text = clean_text(response)
                    if text:
                        append_system(text, "tool")
            continue
        if message_type != "gemini":
            continue
        ensure_turn(timestamp)
        for thought in message.get("thoughts") or []:
            if isinstance(thought, dict):
                append_reasoning(
                    thought.get("description")
                    or thought.get("thinking")
                    or thought.get("summary")
                    or thought.get("subject")
                )
        assistant_text = []
        for block in content:
            if not isinstance(block, dict):
                continue
            if block.get("text"):
                assistant_text.append(clean_text(block.get("text")))
                continue
            if block.get("functionCall"):
                call = block["functionCall"]
                name = clean_text(call.get("name"))
                args = call.get("args") or {}
                detail = clean_text(
                    args.get("command")
                    or args.get("file_path")
                    or args.get("path")
                    or args.get("url")
                    or args.get("query")
                    or call.get("id")
                )
                if name == "run_shell_command":
                    label = f"$ {detail}" if detail else "$ shell command"
                    append_system(label, "command")
                elif name in {"read_file", "list_directory", "glob"}:
                    append_system(
                        f"{name} {detail}".strip(),
                        "tool",
                    )
                else:
                    append_system(
                        f"Tool: {name}" + (f" — {detail}" if detail else ""),
                        "tool",
                    )
        text = clean_text("\n".join(part for part in assistant_text if part))
        raw_text, visible_text = split_gemini_visible_text(text)
        if raw_text and not visible_text:
            append_system(raw_text, "reasoning")
            continue
        if raw_text and visible_text:
            append_system(raw_text, "reasoning")
            text = visible_text
        if text:
            current.setdefault("items", []).append(
                {"type": "agentMessage", "text": text}
            )
    return [turn for turn in turns if turn.get("items")]


def claude_sessions_for_cwd(cwd):
    root = os.path.expanduser("~/.claude/projects/" + project_key(cwd))
    sessions = []
    if not os.path.isdir(root):
        return sessions
    for path in sorted(Path(root).glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True):
        if not claude_session_is_resumable(str(path)):
            continue
        sid = path.stem
        preview = first_text_from_claude_jsonl(str(path))
        metadata = claude_session_metadata(str(path))
        generated_title = metadata["title"]
        try:
            mtime = path.stat().st_mtime
        except OSError:
            mtime = time.time()
        sessions.append(
            {
                "id": f"claude-terminal:{sid}",
                "source_session_id": sid,
                "agent": "claude",
                "origin": "claude-terminal",
                "cwd": cwd,
                "title": generated_title or preview or path.stem,
                "preview": preview or path.stem,
                "created_at": iso_from_unix(mtime),
                "updated_at": iso_from_unix(mtime),
                "source_path": str(path),
                "backend": {
                    "session_id": sid,
                    "model": claude_model_alias(
                        (metadata.get("context") or {}).get("model")
                    ),
                },
                "context": metadata["context"],
                "turns": [],
                "transcript_loaded": False,
            }
        )
    return sessions


