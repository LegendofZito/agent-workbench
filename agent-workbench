    def _render_skill_chips(self):
        """Rebuild the chip buttons inside self.skill_chips from the active agent's favorites."""
        active_agent = self.active_agent.get() if hasattr(self, "active_agent") else "claude"
        favorites = list(self._agent_favorites(active_agent))
        # Skip the destroy/recreate when nothing actually changed — rebuilding on every
        # tab switch made the skills bar BLINK (and reflow). Only rebuild when the agent
        # or its favorite set differs from what's already rendered.
        signature = (active_agent, tuple(favorites))
        if getattr(self, "_skill_chips_signature", None) == signature:
            return
        self._skill_chips_signature = signature
        for child in self.skill_chips.winfo_children():
            child.destroy()
        self._skill_chip_widgets = {}
        for name in favorites:
            # highlightthickness gives each chip a top/edge border we can recolor to
            # "connect" it to its prompt popover when open.
            chip = tk.Frame(
                self.skill_chips,
                bg=PANEL_ALT,
                highlightthickness=1,
                highlightbackground=BORDER,
            )
            chip.pack(side="left", padx=3)
            self._skill_chip_widgets[name] = chip
            tk.Button(
                chip,
                text=name,
                command=lambda n=name: self._open_skill_prompt(n),
                bg=PANEL_ALT,
                fg=TEXT,
                relief="flat",
                padx=8,
                pady=3,
                cursor="hand2",
                font=("Sans", 9, "bold"),
            ).pack(side="left")
            tk.Button(
                chip,
                text="×",
                command=lambda n=name: self._toggle_skill_favorite(n),
                bg=PANEL_ALT,
                fg=MUTED,
                relief="flat",
                padx=4,
                pady=3,
                cursor="hand2",
                font=("Sans", 9),
            ).pack(side="left")

