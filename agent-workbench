        }
        self.workspaces[workspace_id] = workspace
        self.workspace_order.append(workspace_id)
        return workspace_id

    def _discover_sessions_for_picker(self, cwd, agent_key):
        # Codex native history is SQLite-backed and cheap to read, so keep it in
        # the picker. Claude/Gemini terminal scans stay out of the hot paths that
        # made tab switching laggy.
        if agent_key != "codex":
            return []
        sessions = discover_external_sessions(cwd, agent_key)
        return [
            session for session in sessions if not self._session_is_deleted(session)
        ]

    def _restore_saved_workspaces(self):
        saved = self.config.get("workspace_tabs")
        if not isinstance(saved, list) or not saved:
            return False
        # Collapse duplicate tabs that point at the same underlying session. The (now
        # disabled) live-session auto-open could spawn many tabs for one session; this
        # makes sure they don't pile back up on restart. Blank tabs (no session) kept.
        deduped = []
        seen_sids = set()
        for spec in saved:
            if not isinstance(spec, dict):
                continue
            cs = spec.get("current_session") or {}
            sid = clean_text(cs.get("source_session_id") or cs.get("id"))
            if sid:
                if sid in seen_sids:
                    continue
                seen_sids.add(sid)
            deduped.append(spec)
        saved = deduped
        for spec in saved[:8]:
            if not isinstance(spec, dict):
                continue
            agent = clean_text(spec.get("agent"))
            if agent not in self.agent_map:
                agent = "codex"
            cwd = os.path.abspath(
                os.path.expanduser(clean_text(spec.get("cwd")) or os.path.expanduser("~"))
            )
            workspace_id = self._create_workspace(clean_text(spec.get("title")))
            workspace = self.workspaces[workspace_id]
            settings = self.agent_settings.get(
                agent,
                self._default_settings_for(agent),
            )
            model = clean_text(spec.get("model")) or settings["model"]
            effort = clean_text(spec.get("effort")) or settings["effort"]
            if agent == "codex":
                if model == LEGACY_CODEX_MODEL and settings["model"] != LEGACY_CODEX_MODEL:
                    model = settings["model"]
                    self._needs_codex_workspace_migration = True
                if (
                    effort == LEGACY_CODEX_EFFORT
                    and settings["effort"] != LEGACY_CODEX_EFFORT
                ):
                    effort = settings["effort"]
                    self._needs_codex_workspace_migration = True
            workspace["agent"] = agent
            workspace["cwd"] = cwd
            workspace["model"] = model
            workspace["effort"] = effort
            workspace["queued_prompts"] = [
                item
                for item in spec.get("queued_prompts") or []
                if isinstance(item, dict) and clean_text(item.get("prompt"))
            ]
            workspace["local_sessions"] = self.store.list_all_local(agent)
            workspace["external_sessions"] = self._discover_sessions_for_picker(
                cwd, agent
            )
            workspace["sessions"] = self._merge_session_lists(
                workspace["local_sessions"], workspace["external_sessions"]
            )
            workspace["input_text"] = clean_text(spec.get("input_text"))
            selected_id = clean_text(spec.get("session_id"))
            workspace["current_session"] = next(
                (
                    deepcopy(session)
                    for session in workspace["sessions"]
                    if session.get("id") == selected_id
                ),
                deepcopy(workspace["sessions"][0]) if workspace["sessions"] else None,
            )
        if not self.workspace_order:
            return False
        active_index = int(self.config.get("active_workspace_index") or 0)
        active_index = min(max(active_index, 0), len(self.workspace_order) - 1)
        self.active_workspace_id = self.workspace_order[active_index]
        return True

    def _evict_subagent_workspace_tabs(self):
        """Remove any restored workspace tabs whose current session is a sub-agent
        or workflow (worker_job_id / worker_parent_session_id set). Hard rule: those
        sessions belong in the Spawned panel only, never the workspace tab bar."""
        to_evict = []
        for wid in list(self.workspace_order):
            ws = self.workspaces.get(wid) or {}
            cs = ws.get("current_session") or {}
            if cs.get("worker_job_id") or cs.get("worker_parent_session_id"):
                to_evict.append(wid)
        if not to_evict:
            return
        keep = [wid for wid in self.workspace_order if wid not in set(to_evict)]
        if not keep:
            return  # don't evict ALL tabs (leave at least one)
        for wid in to_evict:
            ws = self.workspaces.pop(wid, None)
            if ws:
                for backend in (ws.get("backends") or {}).values():
                    try:
                        backend.close()
                    except Exception:
                        pass
        self.workspace_order = [wid for wid in self.workspace_order if wid in self.workspaces]
        if self.active_workspace_id not in self.workspaces and self.workspace_order:
            self.active_workspace_id = self.workspace_order[-1]

    def _workspace_specs(self):
        specs = []
        for workspace_id in self.workspace_order:
            workspace = self.workspaces[workspace_id]
            session = workspace.get("current_session") or {}
            specs.append(
                {
                    "title": workspace.get("title"),
                    "agent": workspace.get("agent"),
                    "cwd": workspace.get("cwd"),
                    "model": workspace.get("model"),
                    "effort": workspace.get("effort"),
                    "session_id": session.get("id"),
                    "queued_prompts": workspace.get("queued_prompts") or [],
                    "input_text": workspace.get("input_text") or "",
                }
            )
        return specs

