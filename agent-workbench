    def _artifact_session_key(self, session):
        raw = clean_text(
            (session or {}).get("id")
            or (session or {}).get("source_session_id")
            or "unassigned"
        )
        label = re.sub(r"[^A-Za-z0-9._-]+", "-", raw).strip("-")[:48] or "session"
        return f"{label}-{hashlib.sha1(raw.encode('utf-8')).hexdigest()[:8]}"

    def _artifact_directory(self, session=None):
        directory = os.path.join(
            ARTIFACTS_DIR,
            self._artifact_session_key(session or self.current_session),
        )
        ensure_dir(directory)
        return directory

    def _write_handoff_artifact(self, session, packet):
        packet = clean_text(packet)
        if not session or not packet:
            return ""
        path = os.path.join(self._artifact_directory(session), "HANDOFF.md")
        temporary = f"{path}.tmp-{os.getpid()}-{threading.get_ident()}"
        try:
            with open(temporary, "w", encoding="utf-8") as handle:
                handle.write(packet.rstrip() + "\n")
                handle.flush()
                os.fsync(handle.fileno())
            os.replace(temporary, path)
        except OSError:
            try:
                os.unlink(temporary)
            except OSError:
                pass
            return ""
        return path

    def _staged_handoff_packet(self, session):
        artifact = clean_text((session or {}).get("handoff_stage_artifact"))
        if artifact and os.path.isfile(artifact):
            try:
                with open(artifact, encoding="utf-8") as handle:
                    return clean_text(handle.read())
            except OSError:
                pass
        return clean_text((session or {}).get("handoff_stage_packet"))

