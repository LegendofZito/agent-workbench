            source = self.current_session
            if not source:
                messagebox.showinfo("Workers", "Open a session first.", parent=dialog)
                return
            prompt = "Continue from the inherited state and work the latest unresolved objective."
            self.spawn_worker_job(source, prompt, auto=False)
            render()

        def open_selected():
            selection = worker_list.curselection()
            jobs = displayed_jobs
            if not selection or not jobs:
                return
            job = jobs[selection[0]]
            session_id = clean_text(job.get("session_id"))
            if session_id:
                self.open_session(session_id)

        def stop_selected():
            selection = worker_list.curselection()
            jobs = displayed_jobs
            if not selection or selection[0] >= len(jobs):
                return
            job = jobs[selection[0]]
            if clean_text(job.get("status")) not in {"queued", "starting", "running"}:
                return
            workspace = self.workspaces.get(clean_text(job.get("workspace_id")))
            if workspace:
                backend = (workspace.get("backends") or {}).get(
                    workspace.get("agent")
                )
                if backend:
                    backend.interrupt()
                workspace["busy"] = False
                workspace["activity_state"] = "error"
                workspace["activity_text"] = "Cancelled"
                workspace["status"] = "Worker cancelled."
            session = self.store.get(clean_text(job.get("session_id")))
            self._mark_worker_job(session or {"worker_job_id": job.get("id")}, "cancelled")
