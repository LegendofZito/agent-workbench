        pop.configure(bg=PANEL)
        pop.transient(self.win)
        self._skills_menu = pop

        # Position near the skills bar
        self.win.update_idletasks()
        try:
            bx = self.skills_bar.winfo_rootx()
            by = self.skills_bar.winfo_rooty()
        except tk.TclError:
            bx, by = 100, 100

        # Search entry
        search_var = tk.StringVar()
        search_frame = tk.Frame(pop, bg=PANEL_ALT)
        search_frame.pack(fill="x", padx=0, pady=0)
        tk.Label(
            search_frame,
            text="Search skills:",
            bg=PANEL_ALT,
            fg=MUTED,
            font=("Sans", 9),
            padx=8,
            pady=6,
        ).pack(side="left")
