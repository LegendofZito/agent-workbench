    def check_client_updates(self):
        """Background read-only check of each client's current vs latest version."""
        def work():
            results = {}
            for spec in CLIENT_UPDATE_SPECS:
                key = spec["key"]
                entry = {"label": spec["label"], "note": spec.get("note", ""),
                         "current": "", "latest": "", "available": False, "error": ""}
                vbin = spec["version_cmd"][0]
                if not os.path.exists(vbin):
                    entry["error"] = "not installed"
                    results[key] = entry
                    continue
                ok, out = _run_capture(spec["version_cmd"], timeout=15)
                cur = _semver_tuple(out)
                entry["current"] = ".".join(map(str, cur)) if cur else (clean_text(out)[:40] or "?")
                if spec.get("latest_cmd"):
                    ok2, out2 = _run_capture(spec["latest_cmd"], timeout=25)
                    latest = _semver_tuple(out2)
                    if latest:
                        entry["latest"] = ".".join(map(str, latest))
                        if cur:
                            entry["available"] = latest > cur
                    elif not ok2:
                        entry["error"] = "version check failed"
                results[key] = entry
            self.win.after(0, lambda: self._apply_client_updates(results))
        threading.Thread(target=work, daemon=True).start()

    def _apply_client_updates(self, results):
        self.client_updates = results
        self._update_options_btn_marker()
        # Refresh the dialog if it is open
        dlg = getattr(self, "_client_updates_dialog", None)
        if dlg and dlg.winfo_exists():
            render = getattr(dlg, "_render_client_updates", None)
            if callable(render):
                render()

    def _update_options_btn_marker(self):
        """Recolor the Options button (no size change) when any update is available."""
        if not hasattr(self, "options_btn"):
            return
        n = sum(1 for e in (self.client_updates or {}).values() if e.get("available"))
        try:
            self.options_btn.configure(fg=("#fde047" if n else TEXT))
        except tk.TclError:
            pass

    def open_client_updates_dialog(self):
        if getattr(self, "_client_updates_dialog", None) and self._client_updates_dialog.winfo_exists():
            self._client_updates_dialog.lift(); self._client_updates_dialog.focus_force(); return
        dialog = tk.Toplevel(self.win)
        self._client_updates_dialog = dialog
        dialog.title("Client updates")
        dialog.configure(bg=BG); dialog.transient(self.win); dialog.resizable(True, True)
        dialog.minsize(520, 360)
        body = tk.Frame(dialog, bg=BG, padx=16, pady=14); body.pack(fill="both", expand=True)
        tk.Label(body, text="CLI client updates", bg=BG, fg=TEXT, font=("Sans", 14, "bold")).pack(anchor="w")
        status_var = tk.StringVar(master=dialog, value="")
        tk.Label(body, textvariable=status_var, bg=BG, fg=MUTED, anchor="w").pack(fill="x", pady=(2, 8))
        rows_frame = tk.Frame(body, bg=BG); rows_frame.pack(fill="x")
        out_text = tk.Text(body, height=8, bg=PANEL, fg=TEXT, relief="flat", wrap="word",
                           insertbackground=TEXT, highlightthickness=1, highlightbackground=BORDER)
        out_text.pack(fill="both", expand=True, pady=(10, 0))

        def log(msg):
            out_text.insert("end", msg + "\n"); out_text.see("end")

        def run_update(spec):
            log(f"Updating {spec['label']}…  ($ {' '.join(spec['update_cmd'])})")
            status_var.set(f"Updating {spec['label']}…")
            def work():
                ok, out = _run_capture(spec["update_cmd"], timeout=600)
                def done():
                    log(out.strip()[-4000:] or "(no output)")
                    log(f"{'✓' if ok else '✗'} {spec['label']} update {'finished' if ok else 'failed'}.")
                    status_var.set("")
                    self.check_client_updates()  # re-check so the row/marker refresh
                self.win.after(0, done)
            threading.Thread(target=work, daemon=True).start()

        def render():
            for w in rows_frame.winfo_children():
                w.destroy()
            data = self.client_updates or {}
            if not data:
                status_var.set("Checking…")
            else:
                n = sum(1 for e in data.values() if e.get("available"))
                status_var.set(f"{n} update{'s' if n != 1 else ''} available" if n else "All clients up to date")
            for spec in CLIENT_UPDATE_SPECS:
                e = data.get(spec["key"], {})
                row = tk.Frame(rows_frame, bg=BG); row.pack(fill="x", pady=3)
                if e.get("error"):
                    txt = f"{spec['label']}: {e['error']}"
                elif e.get("available"):
                    txt = f"{spec['label']}: {e.get('current','?')} → {e.get('latest','?')}  (update available)"
                elif e.get("latest"):
                    txt = f"{spec['label']}: {e.get('current','?')}  (up to date)"
                else:
                    txt = f"{spec['label']}: {e.get('current','?')}"
                fg = "#fde047" if e.get("available") else TEXT
                tk.Label(row, text=txt, bg=BG, fg=fg, anchor="w", font=("Sans", 10)).pack(side="left", fill="x", expand=True)
                # claude has no remote 'latest' check → always offer Update (it self-checks).
                offer = e.get("available") or (spec.get("latest_cmd") is None and not e.get("error"))
                btn = tk.Button(row, text="Update", command=lambda s=spec: run_update(s),
                                bg=ACCENT, fg="white", relief="flat", padx=12, pady=4, cursor="hand2",
                                state=("normal" if offer else "disabled"),
                                disabledforeground="#64748b", activebackground="#6aa0ff")
                btn.pack(side="right")
            if data.get("claude", {}).get("note"):
                tk.Label(rows_frame, text=data["claude"]["note"], bg=BG, fg=MUTED,
                         font=("Sans", 8), anchor="w").pack(fill="x", pady=(2, 0))

        dialog._render_client_updates = render
        btn_row = tk.Frame(body, bg=BG); btn_row.pack(fill="x", pady=(10, 0))
        tk.Button(btn_row, text="Check now", command=self.check_client_updates,
                  bg=PANEL_ALT, fg=TEXT, relief="flat", padx=12, pady=5, cursor="hand2",
                  activebackground=SIDEBAR_SEL).pack(side="left")
        tk.Button(btn_row, text="Close", command=dialog.destroy,
                  bg=PANEL_ALT, fg=TEXT, relief="flat", padx=12, pady=5, cursor="hand2",
                  activebackground=SIDEBAR_SEL).pack(side="right")
        render()
        self.check_client_updates()

