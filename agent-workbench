def rename_claude_session_title(path, session_id, title):
    title = clean_text(title)
    if not path or not session_id or not title or not os.path.isfile(path):
        return False
    records = (
        {
            "type": "custom-title",
            "customTitle": title,
            "sessionId": session_id,
        },
        {
            "type": "agent-name",
            "agentName": title,
            "sessionId": session_id,
        },
        {
            "type": "ai-title",
            "aiTitle": title,
            "sessionId": session_id,
        },
    )
    try:
        with open(path, "a", encoding="utf-8") as handle:
            fcntl.flock(handle.fileno(), fcntl.LOCK_EX)
            for record in records:
                handle.write(json.dumps(record, separators=(",", ":")) + "\n")
            handle.flush()
            os.fsync(handle.fileno())
            fcntl.flock(handle.fileno(), fcntl.LOCK_UN)
        return True
    except OSError:
        return False


def normalize_claude_session_for_picker(path, session_id):
    if not path or not session_id or not os.path.isfile(path):
        return False
    try:
        with open(path, encoding="utf-8") as handle:
            raw_lines = handle.readlines()
        normalized = []
        changed = False
        first_type = ""
        for raw_line in raw_lines:
            if not raw_line.strip():
                continue
            try:
                event = json.loads(raw_line)
            except ValueError:
                normalized.append(raw_line if raw_line.endswith("\n") else raw_line + "\n")
                continue
            if not first_type and isinstance(event, dict):
                first_type = clean_text(event.get("type"))
            if isinstance(event, dict) and event.get("entrypoint") == "sdk-cli":
                event["entrypoint"] = "cli"
                changed = True
            normalized.append(json.dumps(event, separators=(",", ":")) + "\n")
        if first_type != "mode":
            normalized[0:0] = [
                json.dumps(
                    {"type": "mode", "mode": "normal", "sessionId": session_id},
                    separators=(",", ":"),
                )
                + "\n",
                json.dumps(
                    {
                        "type": "permission-mode",
                        "permissionMode": "bypassPermissions",
                        "sessionId": session_id,
                    },
                    separators=(",", ":"),
                )
                + "\n",
            ]
            changed = True
        if not changed:
            return False
        directory = os.path.dirname(path)
        descriptor, temporary = tempfile.mkstemp(
            prefix=f".{session_id}.",
            suffix=".jsonl",
            dir=directory,
        )
        try:
            with os.fdopen(descriptor, "w", encoding="utf-8") as handle:
                handle.writelines(normalized)
                handle.flush()
                os.fsync(handle.fileno())
            os.chmod(temporary, os.stat(path).st_mode)
            os.replace(temporary, path)
        finally:
            try:
                os.unlink(temporary)
            except FileNotFoundError:
                pass
        return True
    except OSError:
        return False


def claude_session_path(session_id, cwd=""):
