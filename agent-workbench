        settings = self.agent_settings[self.active_agent.get()]
        self.selected_model.set(settings["model"])
        self.selected_effort.set(settings["effort"])
        self.refresh_agent_controls()
        self.apply_agent_theme(self.active_agent.get())
        self.refresh_sessions()

    def refresh_agent_controls(self):
        agent_key = self.active_agent.get()
        model_options = MODEL_OPTIONS.get(agent_key, ("Default",))
        effort_options = EFFORT_OPTIONS.get(agent_key, ("Default",))
        defaults = DEFAULT_AGENT_SETTINGS.get(
            agent_key, {"model": "Default", "effort": "Default"}
        )
        self.model_picker.configure(values=model_options)
        self.effort_picker.configure(values=effort_options)
        if self.selected_model.get() not in model_options:
            self.selected_model.set(defaults["model"])
        if self.selected_effort.get() not in effort_options:
            self.selected_effort.set(defaults["effort"])
        custom = bool(self._agent_spec(agent_key).get("custom"))
        self.model_picker.configure(state="disabled" if custom else "readonly")
        self.effort_picker.configure(state="disabled" if custom else "readonly")
        self.effort_label.configure(text="Effort")

    def on_agent_setting_changed(self):
        agent_key = self.active_agent.get()
        self.agent_settings[agent_key] = {
            "model": self.selected_model.get(),
            "effort": self.selected_effort.get(),
        }
        if self.current_session and self.current_session.get("agent") == agent_key:
            backend = self.current_session.setdefault("backend", {})
            backend["model"] = self.selected_model.get()
            effort = self.selected_effort.get()
            if agent_key == "gemini" or effort == "Default":
                backend.pop("effort", None)
            else:
                backend["effort"] = effort
            self._persist_current()
        self.status.set(
            f"{self._agent_spec(agent_key)['label']}: {self.selected_model.get()} · {self.selected_effort.get()}"
        )

    def apply_agent_theme(self, agent_key):
        background = AGENT_BACKGROUNDS.get(agent_key, PANEL)
        accents = AGENT_ACCENTS.get(agent_key, (ACCENT,) * 4)
        self.chat_tab.configure(bg=background)
        self.agent_accent_bar.configure(bg=background)
        for segment, color in zip(self.agent_accent_segments, accents):
            segment.configure(bg=color)
        self.chat.configure(bg=background)
        self.input.configure(bg=background)

    def refresh_sessions(self):
        self.status.set("Loading sessions…")
        self._remember_project(self.cwd.get())
        if getattr(self, "terminal_shell", None) and self.terminal_shell.cwd != self.cwd.get():
            self.restart_terminal()
        self.local_sessions = self.store.list_for(self.cwd.get(), self.active_agent.get())
        self.external_sessions = discover_external_sessions(self.cwd.get(), self.active_agent.get())
        self.sessions = list(self.local_sessions) + list(self.external_sessions)
        if not self.sessions:
            self.current_session = self.store.new_session(self.active_agent.get(), self.cwd.get())
            self.local_sessions = [self.current_session]
            self.sessions = list(self.local_sessions)
            self.external_sessions = []
            self.transfer_source_session_id = None
        self._render_session_list()
        self.open_session(self.sessions[0]["id"], remember=False)

    def _render_session_list(self):
        self._hide_session_tooltip()
        selected_id = self.current_session.get("id") if self.current_session else None
        self.session_list.delete(0, "end")
        query = clean_text(self.session_filter.get()).lower()
        self.visible_sessions = list(self.sessions)
        self.visible_sessions.sort(key=lambda s: s.get("updated_at") or "", reverse=True)
        if query:
            self.visible_sessions = [
                session
                for session in self.visible_sessions
                if query in session_search_blob(session, self._session_alias(session))
            ]
        for session in self.visible_sessions:
            title = self._session_list_label(session)
            self.session_list.insert("end", title)
        if self.visible_sessions:
            self.session_list.selection_clear(0, "end")
            selected_idx = next(
                (
                    idx
                    for idx, session in enumerate(self.visible_sessions)
                    if session.get("id") == selected_id
                ),
                0,
            )
            self.session_list.selection_set(selected_idx)
            self.session_list.see(selected_idx)

    def open_session_finder(self):
        self.session_search.focus_set()
        self.session_search.select_range(0, "end")
        self.status.set("Search all local and imported sessions in the sidebar.")

    def rename_selected_session(self):
        selection = self.session_list.curselection()
        if not selection:
            messagebox.showinfo("Rename", "Select a session first.")
            return
        idx = selection[0]
        if idx >= len(self.visible_sessions):
            return
        session = self.visible_sessions[idx]
        current = self._display_session_title(session)
        alias = simpledialog.askstring(
            "Rename session",
            "Choose a shorter label for this session:",
            initialvalue=current,
            parent=self.win,
        )
        if alias is None:
            return
        alias = clean_text(alias)
        if not alias:
            messagebox.showinfo("Rename", "Name cannot be blank.")
            return
        source_updated = False
        if session.get("origin") == "codex-terminal":
            source_updated = rename_codex_thread_title(session.get("source_session_id"), alias)
        elif session.get("origin") == "claude-terminal":
            source_updated = rename_claude_session_title(
                session.get("source_path"),
                session.get("source_session_id"),
                alias,
            )
        if source_updated:
            session["title"] = alias
            self.session_aliases.pop(session_alias_key(session), None)
            self.config["session_aliases"] = self.session_aliases
            save_json(CONFIG_FILE, self.config)
        else:
            self._set_session_alias(session, alias)
        if session.get("origin", "local") == "local":
            self.session_title.set(alias)
        self._render_session_list()
        self.open_session(session["id"], remember=False)
        if source_updated:
            agent = self._agent_spec(session.get("agent", ""))["label"]
            self.status.set(f"Renamed session to '{alias}' in {agent} and Workbench.")
        else:
            self.status.set(f"Renamed session to '{alias}' in Workbench.")

    def select_session(self):
        selection = self.session_list.curselection()
        if not selection:
            return
        idx = selection[0]
        if idx < len(self.visible_sessions):
            selected_id = self.visible_sessions[idx]["id"]
            if self.current_session and self.current_session.get("id") == selected_id:
                return
            self.open_session(selected_id, remember=True)

    def _restore_last_session(self):
        last_id = self.config.get("last_session_id")
        if last_id and self.store.get(last_id):
            self.open_session(last_id, remember=False)

    def open_session(self, session_id, remember=True):
        session = self.store.get(session_id)
        if not session:
            for candidate in self.external_sessions:
                if candidate.get("id") == session_id:
                    session = candidate
                    break
        if not session:
            return
        if self.busy:
            messagebox.showinfo("Busy", "Wait for the current turn to finish before switching sessions.")
            return
        if remember and self.current_session and self.current_session.get("id") != session_id:
            self.transfer_source_session_id = self.current_session.get("id")
        self.current_session = deepcopy(session)
        agent_key = session.get("agent", self.active_agent.get())
        settings = self.agent_settings.get(
            agent_key,
            DEFAULT_AGENT_SETTINGS.get(
                agent_key, {"model": "Default", "effort": "Default"}
            ),
        )
        backend = session.get("backend") or {}
        model = backend.get("model") or settings["model"]
        effort = backend.get("effort") or settings["effort"]
        if model in MODEL_OPTIONS.get(agent_key, ("Default",)):
            self.selected_model.set(model)
        if effort in EFFORT_OPTIONS.get(agent_key, ("Default",)):
            self.selected_effort.set(effort)
        self.refresh_agent_controls()
        self.apply_agent_theme(session.get("agent", self.active_agent.get()))
        self.live_source_signature = self._source_signature(
            self.current_session.get("source_path")
        )
        self.current_turn = None
        self.session_backend_id = session.get("backend", {}).get("thread_id") or session.get("backend", {}).get("session_id")
        origin = session.get("origin", "local")
        title = self._display_session_title(session)
        if origin != "local" and not self._session_alias(session):
            title = f"{title} (imported)"
        self.session_title.set(shorten(title, 110))
        self.session_label.set(
            f"{self._agent_spec(session.get('agent')).get('label', session.get('agent'))} · {project_label(session.get('cwd'))}"
        )
        self._clear_views()
        loading_transcript = origin == "claude-terminal" and not session.get("transcript_loaded")
        if loading_transcript:
            self._show_transcript_loading(session)
            self._load_external_session(session)
        else:
            self._render_session(session)
        self.refresh_artifacts_view(session)
        self.scroll_chat_to_latest()
        if loading_transcript:
            pass
        elif origin == "local":
            self.status.set("Ready. Send a prompt to continue this session.")
        else:
            self.status.set("Live terminal mirror. Send a prompt to create a continuation.")
        if not loading_transcript:
            self.set_activity(
                "idle",
                "Live mirror" if origin in {"codex-terminal", "claude-terminal"} else None,
            )
        self._persist_current()

    def _show_transcript_loading(self, session):
        self.chat.configure(state="normal")
        self.chat.insert(
            "end",
            "Loading conversation…\n\n"
            "The complete Claude transcript is being reconstructed in the background.",
            "assistant",
        )
        self.chat.configure(state="disabled")
        self.status.set("Loading complete Claude conversation…")
        self.set_activity("starting", "Loading")

    def _load_external_session(self, session):
        session_id = session.get("id")
        path = session.get("source_path")
        if not session_id or not path or session_id in self.loading_external_sessions:
            return
        self.loading_external_sessions.add(session_id)
        origin = session.get("origin")

        def load():
            if origin == "claude-terminal":
                turns = claude_jsonl_turns(path)
                title = title_from_claude_jsonl(path)
            else:
                turns = codex_rollout_turns(path)
                title = ""
            self.events.put(
                {
                    "kind": "external_session_loaded",
                    "session_id": session_id,
                    "turns": turns,
                    "title": title,
                    "signature": self._source_signature(path),
                }
            )

        threading.Thread(target=load, daemon=True).start()

    def _source_signature(self, path):
        if not path:
            return None
        try:
            stat = os.stat(path)
            return (stat.st_mtime_ns, stat.st_size)
        except OSError:
            return None

    def poll_external_session(self):
        try:
            session = self.current_session
            if session and session.get("origin") in {"codex-terminal", "claude-terminal"}:
                path = session.get("source_path")
                signature = self._source_signature(path)
                if signature and signature != self.live_source_signature:
                    self.live_source_signature = signature
                    self._load_external_session(session)
        finally:
            self.win.after(500, self.poll_external_session)

    def _clear_views(self):
        self.render_generation += 1
        for card in self.report_cards:
            try:
                card["frame"].destroy()
            except tk.TclError:
                pass
        self.report_cards = []
        for widget in (self.chat, self.work):
            widget.configure(state="normal")
            widget.delete("1.0", "end")
            widget.configure(state="disabled")

    def _render_session(self, session):
        self.render_generation += 1
        generation = self.render_generation
        turns = list(session.get("turns") or [])
        agent = session.get("agent", "agent")

        def render_batch(index=0):
            if generation != self.render_generation:
                return
            end = min(index + 12, len(turns))
            for turn in turns[index:end]:
                self._render_turn(turn, agent)
            if end < len(turns):
                self.win.after(1, lambda: render_batch(end))

        render_batch()

    def _render_turn(self, turn, agent_key):
        for item in turn.get("items") or []:
            self._render_item(item, agent_key)

    def _render_item(self, item, agent_key):
        typ = item.get("type", "")
        if typ == "userMessage":
            text = self._extract_user_text(item)
            if text:
                self.append_chat("YOU", text, "user")
        elif typ == "agentMessage":
            text = self._extract_agent_text(item)
            if text:
                self.append_chat(self._agent_spec(agent_key)["label"].upper(), text, "assistant")
        elif typ == "report":
            self.append_report(
                clean_text(item.get("title")) or "Agent report",
                clean_text(item.get("text")),
            )
        elif typ == "commandExecution":
            command = clean_text(item.get("command"))
            if command:
                self.append_work(f"$ {command}", "command")
            output = clean_text(item.get("aggregatedOutput"))
            if output:
                self.append_work(output, "system")
        elif typ == "fileChange":
            paths = []
            for change in item.get("changes") or []:
                path = change.get("path") or change.get("filePath")
                if path:
                    paths.append(str(path))
            if paths:
                self.append_work("files: " + ", ".join(paths), "fileChange")
        elif typ == "reasoning":
            summary = " ".join(item.get("summary") or [])
            if summary:
                self.append_work(summary, "reasoning")
        elif typ == "plan":
            text = clean_text(item.get("text"))
            if text:
                self.append_work(text, "plan")
        elif typ == "mcpToolCall":
            self.append_work(
                f"{clean_text(item.get('server'))}.{clean_text(item.get('tool'))}",
                "tool",
            )
        elif typ == "system":
            text = clean_text(item.get("text") or item.get("message"))
            if text:
                self.append_work(text, item.get("tag") or "system")
        elif typ == "note":
            text = clean_text(item.get("text"))
            if text:
                self.append_work(text, "system")

    def _extract_user_text(self, item):
        content = item.get("content") or []
        parts = []
        for bit in content:
            if isinstance(bit, dict) and bit.get("type") == "text":
                parts.append(bit.get("text", ""))
        return clean_text(" ".join(parts))

    def _extract_agent_text(self, item):
        text = item.get("text") or item.get("content") or ""
        if isinstance(text, list):
            parts = []
            for bit in text:
                if isinstance(bit, dict) and bit.get("type") == "text":
                    parts.append(bit.get("text", ""))
            return clean_text(" ".join(parts))
        return clean_text(text)

    def append_chat(self, speaker, text, tag="assistant"):
        if not text:
            return
        widget = self.chat
        at_bottom = widget.yview()[1] >= 0.995
        widget.configure(state="normal")
        head_tag = "assistant_head"
        if speaker == "YOU":
            head_tag = "user_head"
        elif speaker == "CLAUDE":
            head_tag = "claude_head"
        elif speaker == "GEMINI":
            head_tag = "gemini_head"
        widget.insert("end", speaker + "\n", head_tag)
        if tag == "assistant":
            self._insert_formatted_chat(text)
        else:
            widget.insert("end", text.rstrip() + "\n\n", tag)
        widget.configure(state="disabled")
        if at_bottom:
            widget.see("end")

    def append_report(self, title, text):
        if not text:
            return
        widget = self.chat
        at_bottom = widget.yview()[1] >= 0.995
        widget.configure(state="normal")
        width = max(420, widget.winfo_width() - 90)
        frame = tk.Frame(
            widget,
            bg="#111c27",
            highlightbackground="#35506a",
            highlightthickness=1,
            width=width,
            cursor="arrow",
        )
        frame.pack_propagate(False)
        header = tk.Frame(frame, bg="#111c27")
        header.pack(fill="x")
        header.configure(cursor="arrow")
        content = ScrolledText(
            frame,
            wrap="word",
            height=14,
            bg="#0d151e",
            fg=TEXT,
            relief="flat",
            borderwidth=0,
            padx=16,
            pady=14,
            font=("Sans", 10),
        )
        content.insert("1.0", text)
        content.configure(state="disabled")
        card_state = {"expanded": False}

        def toggle():
            if card_state["expanded"]:
                content.pack_forget()
                button.configure(text=f">  View {title}")
                frame.configure(height=44)
                card_state["expanded"] = False
            else:
                content.pack(fill="both", expand=True)
                button.configure(text=f"v  Hide {title}")
                frame.configure(height=340)
                card_state["expanded"] = True
            widget.see("end")

        button = tk.Button(
            header,
            text=f">  View {title}",
            command=toggle,
            bg="#111c27",
            fg="#93c5fd",
            activebackground="#17283a",
            activeforeground="#bfdbfe",
            relief="flat",
            anchor="w",
            font=("Sans", 10, "bold"),
            padx=14,
            pady=10,
            cursor="hand2",
        )
        button.pack(fill="x")
        frame.configure(height=44)
        widget.window_create("end", window=frame, padx=18, pady=8)
        widget.insert("end", "\n")
        self.report_cards.append({"frame": frame, "content": content, "button": button})
        widget.configure(state="disabled")
        if at_bottom:
            widget.see("end")

    def _insert_inline_chat(self, text, base_tag="assistant"):
        cursor = 0
        pattern = re.compile(r"(`[^`\n]+`|\*\*[^*\n]+\*\*)")
        for match in pattern.finditer(text):
            if match.start() > cursor:
                self.chat.insert("end", text[cursor:match.start()], base_tag)
            token = match.group(0)
            if token.startswith("`"):
                self.chat.insert("end", token[1:-1], "chat_code")
            else:
                self.chat.insert("end", token[2:-2], "chat_bold")
            cursor = match.end()
        if cursor < len(text):
            self.chat.insert("end", text[cursor:], base_tag)

    def _insert_formatted_chat(self, text):
        lines = text.rstrip().splitlines()
        in_code_block = False
        for line in lines:
            stripped = line.strip()
            if stripped.startswith("```"):
                in_code_block = not in_code_block
                continue
            if in_code_block:
                self.chat.insert("end", line + "\n", "chat_code")
                continue
            if stripped.startswith("### "):
                self.chat.insert("end", stripped[4:] + "\n", "chat_h2")
            elif stripped.startswith("## "):
                self.chat.insert("end", stripped[3:] + "\n", "chat_h2")
            elif stripped.startswith("# "):
                self.chat.insert("end", stripped[2:] + "\n", "chat_h1")
            elif re.match(r"^[-*]\s+\[[xX]\]\s+", stripped):
                label = re.sub(r"^[-*]\s+\[[xX]\]\s+", "", stripped)
                self.chat.insert("end", "✓ ", "chat_check_done")
                self._insert_inline_chat(label, "chat_check_done")
                self.chat.insert("end", "\n", "chat_check_done")
            elif re.match(r"^[-*]\s+\[\s\]\s+", stripped):
                label = re.sub(r"^[-*]\s+\[\s\]\s+", "", stripped)
                self.chat.insert("end", "□ ", "chat_check_open")
                self._insert_inline_chat(label, "chat_check_open")
                self.chat.insert("end", "\n", "chat_check_open")
            elif re.match(r"^[-*]\s+", stripped):
                label = re.sub(r"^[-*]\s+", "", stripped)
                self.chat.insert("end", "• ", "chat_bullet")
                self._insert_inline_chat(label, "assistant")
                self.chat.insert("end", "\n", "assistant")
            elif re.match(r"^\d+\.\s+", stripped):
                marker, label = stripped.split(" ", 1)
                self.chat.insert("end", marker + " ", "chat_bullet")
                self._insert_inline_chat(label, "assistant")
                self.chat.insert("end", "\n", "assistant")
            else:
                self._insert_inline_chat(line, "assistant")
                self.chat.insert("end", "\n", "assistant")
        self.chat.insert("end", "\n", "assistant")

    def append_work(self, text, tag="system"):
        if not text:
            return
        widget = self.work
        at_bottom = widget.yview()[1] >= 0.995
        widget.configure(state="normal")
        widget.insert("end", text.rstrip() + "\n", tag)
        widget.configure(state="disabled")
        if at_bottom:
            widget.see("end")

    def new_session(self):
        if self.busy:
            messagebox.showinfo("Busy", "Wait for the current turn to finish before starting a new session.")
            return
        session = self.store.new_session(self.active_agent.get(), self.cwd.get())
        self.local_sessions.insert(0, session)
        self.sessions = list(self.local_sessions) + list(self.external_sessions)
        self.transfer_source_session_id = None
        self._render_session_list()
        self.open_session(session["id"], remember=False)

    def _persist_current(self):
        if not self.current_session:
            return
        self.store.save(self.current_session)

    def _current_backend(self):
        return self.backends[self.active_agent.get()]

    def _current_agent_label(self):
        return self._agent_spec(self.active_agent.get())["label"]

    def _agent_executable(self, agent_key):
        if agent_key in {"codex", "claude", "gemini"}:
            return agent_key
        client = next(
            (item for item in self.custom_clients if item.get("key") == agent_key),
            None,
        )
        if not client:
            return ""
        try:
            return shlex.split(clean_text(client.get("command")).replace("{prompt}", "prompt"))[0]
        except (ValueError, IndexError):
            return ""

    def _self_project_context(self, prompt):
        if not re.search(
            r"\b(agent workbench|this app|the app|itself|yourself|self)\b",
            prompt,
            flags=re.IGNORECASE,
        ):
            return ""
        source_dir = clean_text(self.install_info.get("source_dir"))
        if not source_dir or not os.path.isdir(source_dir):
            return ""
        return (
            "Agent Workbench self-maintenance context:\n"
            f"- Editable source project: {source_dir}\n"
            f"- Running installed executable: {os.path.abspath(__file__)}\n"
            "- Make changes in the editable source project, test them, then run its installer.\n"
            "- Do not terminate or restart the current Agent Workbench process during this turn; "
            "finish the response first and state when a restart is required."
        )

    def _make_turn(self, prompt):
        turn = self.store.ensure_turn(self.current_session, prompt=prompt)
        self.current_turn = turn
        if not self.current_session.get("title") or self.current_session.get("title", "").startswith("New "):
            self.store.set_title_from_prompt(self.current_session, prompt)
        return turn

    def send(self):
        prompt = clean_text(self.input.get("1.0", "end"))
        if not prompt:
            return
        if self.pending_user_input:
            pending = self.pending_user_input
            self.pending_user_input = None
            self.input.delete("1.0", "end")
            self.append_chat("YOU", prompt, "user")
            if self.current_turn is not None:
                self.store.add_item(
                    self.current_session,
                    self.current_turn,
                    {"type": "userMessage", "content": [{"type": "text", "text": prompt}]},
                )
            self.backends["codex"].answer_user_input(
                pending["request_id"], pending["questions"], prompt
            )
            self.send_btn.configure(text="Send", state="disabled")
            self.stop_btn.configure(state="normal")
            self.status.set("Codex received your reply and is continuing…")
            self.set_activity("working")
            return
        if self.busy:
            self.status.set("The agent is still working. Use Stop if you need to interrupt it.")
            return
        agent_key = self.active_agent.get()
        executable = self._agent_executable(agent_key)
        if not executable or not shutil.which(executable):
            self.status.set(
                f"{self._current_agent_label()} is not installed. Use Add client to connect it."
            )
            self.open_add_client_dialog()
            return
        if agent_key == "codex":
            codex_backend = self.backends["codex"]
            if codex_backend.proc is None or codex_backend.proc.poll() is not None:
                codex_backend.stop_flag.clear()
                codex_backend.ready.clear()
                codex_backend.start(self.cwd.get())
                if not codex_backend.ready.wait(timeout=15):
                    self.status.set("Codex installed, but its local service did not start.")
                    return
        if prompt.startswith("/resume"):
            self.input.delete("1.0", "end")
            self.open_session_finder()
            return
        if prompt.startswith("/sessions"):
            self.input.delete("1.0", "end")
            self.open_session_finder()
            return
        if not os.path.isdir(self.cwd.get()):
            messagebox.showerror("Invalid directory", "Choose an existing working directory.")
            return
        if not self.current_session:
            self.current_session = self.store.new_session(self.active_agent.get(), self.cwd.get())
        if self.current_session.get("origin", "local") != "local":
            self.transfer_source_session_id = self.current_session.get("source_session_id") or self.current_session.get("id")
            self.current_session = self.store.clone_for_continuation(self.current_session)
            self.local_sessions.insert(0, self.current_session)
            self.sessions = list(self.local_sessions) + list(self.external_sessions)
            self._render_session_list()
        backend_settings = self.current_session.setdefault("backend", {})
        backend_settings["model"] = self.selected_model.get()
        effort = self.selected_effort.get()
        if self.active_agent.get() == "gemini" or effort == "Default":
            backend_settings.pop("effort", None)
        else:
            backend_settings["effort"] = effort
        self._remember_project(self.cwd.get())
        self.input.delete("1.0", "end")
        self.busy = True
        self.send_btn.configure(text="Send", state="disabled")
        self.stop_btn.configure(state="normal")
        self.stop_btn.pack(side="right", padx=(0, 6))

        if self.transfer_source_session_id and self.transfer_source_session_id != self.current_session.get("id"):
            source = self.store.get(self.transfer_source_session_id)
            if source and not self.current_session.get("turns"):
                context_text = self.store.summary_for_handoff(source)
            else:
                context_text = ""
        else:
            context_text = ""
        self_context = self._self_project_context(prompt)
        if self_context:
            context_text = "\n\n".join(part for part in (context_text, self_context) if part)

        turn = self._make_turn(prompt)
        user_item = {"type": "userMessage", "content": [{"type": "text", "text": prompt}]}
        self.store.add_item(self.current_session, turn, user_item)
        self.append_chat("YOU", prompt, "user")
        self.append_work("--- New turn ---", "system")
        self.status.set(f"{self._current_agent_label()} is working…")
        self.set_activity("working")
        self._persist_current()

        backend = self._current_backend()
        backend.start_turn(self.current_session, turn, prompt, context_text=context_text)
        self.transfer_source_session_id = None

    def stop(self):
        self._current_backend().interrupt()
        self.stop_btn.configure(state="disabled")
        self.status.set("Stopping current turn…")

    def _append_assistant_chunk(self, text, speaker):
        if not text:
            return
        if not self.live_speaker:
            self.live_speaker = speaker
            widget = self.chat
            at_bottom = widget.yview()[1] >= 0.995
            widget.configure(state="normal")
            head_tag = "assistant_head"
            if speaker == "CLAUDE":
                head_tag = "claude_head"
            elif speaker == "GEMINI":
                head_tag = "gemini_head"
            widget.insert("end", speaker + "\n", head_tag)
            widget.insert("end", text, "assistant")
            widget.configure(state="disabled")
            if at_bottom:
                widget.see("end")
            if self.current_turn is not None:
                self.store.add_item(self.current_session, self.current_turn, {"type": "agentMessage", "text": text})
            return
        widget = self.chat
        widget.configure(state="normal")
        widget.insert("end", text)
        widget.configure(state="disabled")
        widget.see("end")
        if self.current_turn is not None:
            items = self.current_turn.setdefault("items", [])
            if items and items[-1].get("type") == "agentMessage":
                items[-1]["text"] = clean_text(items[-1].get("text", "") + text)
                self.store.save(self.current_session)

    def handle_event(self, event):
        kind = event.get("kind")
        if kind == "status":
            self.status.set(event.get("text", "Ready"))
        elif kind == "work":
            self.append_work(event.get("text", ""), event.get("tag", "system"))
            if self.current_turn is not None:
                self.store.add_item(
                    self.current_session,
                    self.current_turn,
                    {"type": "system", "text": event.get("text", ""), "tag": event.get("tag", "system")},
                )
        elif kind == "assistant_begin":
            pass
        elif kind == "assistant_delta":
            speaker = event.get("speaker") or self._current_agent_label().upper()
            self._append_assistant_chunk(event.get("text", ""), speaker)
        elif kind == "assistant":
            speaker = event.get("speaker") or self._current_agent_label().upper()
            text = event.get("text", "")
            self._append_assistant_chunk(text, speaker)
        elif kind == "assistant_message":
            speaker = event.get("speaker") or self._current_agent_label().upper()
            text = clean_text(event.get("text"))
            if text:
                self.append_chat(speaker, text, "assistant")
                if self.current_turn is not None:
                    self.store.add_item(
                        self.current_session,
                        self.current_turn,
                        {"type": "agentMessage", "text": text},
                    )
        elif kind == "assistant_done":
            if self.live_speaker:
                widget = self.chat
                widget.configure(state="normal")
                widget.insert("end", "\n\n")
                widget.configure(state="disabled")
                widget.see("end")
            self.live_speaker = None
            self._persist_current()
        elif kind == "user_input_request":
            params = event.get("params") or {}
            questions = params.get("questions") or []
            lines = []
            for index, question in enumerate(questions, start=1):
                prefix = f"{index}. " if len(questions) > 1 else ""
                lines.append(prefix + clean_text(question.get("question")))
                options = question.get("options") or []
                if options:
                    labels = [clean_text(option.get("label")) for option in options]
                    lines.append("Options: " + " | ".join(label for label in labels if label))
            if len(questions) > 1:
                lines.append("Reply with one answer per line.")
            text = "\n".join(line for line in lines if line)
            self.pending_user_input = {
                "request_id": event.get("request_id"),
                "questions": questions,
            }
            self.append_chat("CODEX NEEDS INPUT", text, "assistant")
            if self.current_turn is not None:
                self.store.add_item(
                    self.current_session,
                    self.current_turn,
                    {"type": "agentMessage", "text": text},
                )
            self.send_btn.configure(text="Reply", state="normal")
            self.stop_btn.pack_forget()
            self.status.set("Codex is waiting for your answer.")
            self.set_activity("input")
            self.notebook.select(self.chat_tab)
            self.input.focus_set()
        elif kind == "turn_done":
            status = event.get("status", "completed")
            if self.current_turn is not None:
                self.store.finish_turn(self.current_session, self.current_turn, status=status)
            self.busy = False
            self.pending_user_input = None
            self.send_btn.configure(text="Send", state="normal")
            self.stop_btn.pack_forget()
            self.status.set("Ready" if status == "completed" else f"Turn {status}")
            self.set_activity("idle")
            self._persist_current()
            self.refresh_artifacts_view(self.current_session)
            self.scroll_chat_to_latest()
            self._render_session_list()
        elif kind == "error":
            text = event.get("text", "Error")
            self.status.set("Error: " + text)
            self.append_work("ERROR: " + text, "system")
            if self.current_turn is not None:
                self.store.add_item(self.current_session, self.current_turn, {"type": "note", "text": "ERROR: " + text})
                self.store.finish_turn(self.current_session, self.current_turn, status="error")
            self.busy = False
            self.pending_user_input = None
            self.send_btn.configure(text="Send", state="normal")
            self.stop_btn.pack_forget()
            self.set_activity("error")
            self._persist_current()
            self.refresh_artifacts_view(self.current_session)
            self._render_session_list()
        elif kind == "backend_exit":
            self.status.set(event.get("text", "Backend stopped"))
            if self.busy:
                self.busy = False
                self.pending_user_input = None
                self.send_btn.configure(text="Send", state="normal")
                self.stop_btn.pack_forget()
                self.set_activity("error")
        elif kind == "external_session_loaded":
            session_id = event.get("session_id")
            self.loading_external_sessions.discard(session_id)
            turns = event.get("turns") or []
            source_title = clean_text(event.get("title"))
            for session in self.external_sessions:
                if session.get("id") == session_id:
                    session["turns"] = turns
                    session["transcript_loaded"] = True
                    if source_title:
                        session["title"] = source_title
                    break
            if self.current_session and self.current_session.get("id") == session_id:
                chat_at_bottom = self.chat.yview()[1] >= 0.995
                work_at_bottom = self.work.yview()[1] >= 0.995
                chat_position = self.chat.yview()[0]
                work_position = self.work.yview()[0]
                self.current_session["turns"] = turns
                self.current_session["transcript_loaded"] = True
                if source_title:
                    self.current_session["title"] = source_title
                self.current_session["updated_at"] = now_iso()
                self.live_source_signature = event.get("signature")
                self._clear_views()
                self._render_session(self.current_session)
                self._render_session_list()
                self.refresh_artifacts_view(self.current_session)
                if not chat_at_bottom:
                    self.chat.yview_moveto(chat_position)
                if not work_at_bottom:
                    self.work.yview_moveto(work_position)
                self.status.set("Live Claude terminal mirror updated.")
                self.set_activity("idle", "Live mirror")
        elif kind == "terminal_output":
            self.append_terminal(event.get("text", ""))
        elif kind == "terminal_clear":
            self.clear_terminal()
        elif kind == "terminal_exit":
            status = event.get("status")
            self.append_terminal(f"\n[Shell exited{'' if status is None else f' with status {status}'}]\n")

    def drain_events(self):
        try:
            while True:
                event = self.events.get_nowait()
                self.handle_event(event)
        except queue.Empty:
            pass
        self.win.after(50, self.drain_events)

    def close(self):
        self._hide_session_tooltip()
        self.config.update(
            {
                "cwd": self.cwd.get(),
                "geometry": self.win.geometry(),
                "recent_projects": self.recent_projects,
                "active_agent": self.active_agent.get(),
                "agent_settings": self.agent_settings,
                "last_session_id": self.current_session.get("id") if self.current_session else None,
                "session_aliases": self.session_aliases,
                "custom_clients": self.custom_clients,
            }
        )
        save_json(CONFIG_FILE, self.config)
        self._persist_current()
        for backend in self.backends.values():
            try:
                backend.close()
            except Exception:
                pass
        self.terminal_shell.close()
        self.win.destroy()

