def _humanize_skill_desc(raw):
    """Turn a model-facing SKILL.md description into a short human one: strip the
    'This skill should be used when…' boilerplate and keep the first sentence."""
    text = clean_text(raw)
    if not text:
        return ""
    low = text.lower()
    for prefix in (
        "this skill should be used when the user asks to",
        "this skill should be used when the user",
        "this skill should be used when",
        "this skill should be used to",
        "use this skill when the user",
        "use this skill to",
        "use this skill when",
        "use when the user asks",
        "use when the user",
        "use when",
        "use this when",
    ):
        if low.startswith(prefix):
            text = text[len(prefix):].lstrip(" ,:-")
            break
    for sep in (". ", ".\n", "; "):
        idx = text.find(sep)
        if idx != -1:
            text = text[: idx + 1]
            break
    text = text.strip().strip('"')
    if text and text[0].islower():
        text = text[0].upper() + text[1:]
    return text[:120]


def _parse_skill_md_frontmatter(path, fallback_name):
    """Parse name/description from a SKILL.md YAML frontmatter block.

    Returns (name, description) strings; falls back to fallback_name / "".
    Never raises.
    """
    try:
        with open(path, encoding="utf-8", errors="replace") as fh:
            lines = fh.readlines()
        name = None
        desc = None
        in_front = False
        dash_count = 0
        for raw_line in lines:
            stripped = raw_line.strip()
            if stripped == "---":
                dash_count += 1
                if dash_count == 1:
                    in_front = True
                    continue
                if dash_count == 2:
                    break
            if not in_front:
                continue
            if stripped.startswith("name:"):
                name = stripped[5:].strip().strip('"').strip("'")
            elif stripped.startswith("description:"):
                desc = stripped[12:].strip().strip('"').strip("'")
        if not name:
            name = fallback_name
        return name, (desc or "")[:140]
    except Exception:
        return fallback_name, ""


def discover_skills(cwd, agent_key="claude"):
    """Return a sorted, de-duped list of skill dicts {name, description, source}.

    agent_key controls which client's skills are scanned:
      "claude"  — BUILTIN_SKILLS + ~/.claude/skills + project .claude/skills + plugins
      "codex"   — ~/.codex/skills/** recursive SKILL.md scan
      "gemini"  — ~/.gemini/commands/** recursive *.toml scan (may be empty)
      anything else (ollama/local/custom) — returns []

    Never raises; returns what it can find.
    """
    home = os.path.expanduser("~")

    # ------------------------------------------------------------------ Codex
    if agent_key == "codex":
        try:
            seen = {}
            codex_skills_root = os.path.join(home, ".codex", "skills")
            if os.path.isdir(codex_skills_root):
                for dirpath, _dirnames, filenames in os.walk(codex_skills_root):
                    if "SKILL.md" in filenames:
                        skill_md = os.path.join(dirpath, "SKILL.md")
                        # Use the immediate directory name as the fallback skill name.
                        fallback = os.path.basename(dirpath)
                        try:
                            name, desc = _parse_skill_md_frontmatter(skill_md, fallback)
                            if name and name not in seen:
                                seen[name] = {"name": name, "description": desc, "source": "codex"}
                        except Exception:
                            pass
            return sorted(seen.values(), key=lambda s: s["name"])
        except Exception:
            return []

    # ------------------------------------------------------------------ Gemini
    if agent_key == "gemini":
        try:
            seen = {}
            gemini_commands_root = os.path.join(home, ".gemini", "commands")
            if os.path.isdir(gemini_commands_root):
                for dirpath, _dirnames, filenames in os.walk(gemini_commands_root):
                    for fname in filenames:
                        if not fname.endswith(".toml"):
                            continue
                        stem = fname[:-5]  # strip .toml
                        # If the file lives in a subdirectory of commands/, prefix with
                        # the relative subdir path using ":" as separator (e.g. "ns:cmd").
                        rel = os.path.relpath(dirpath, gemini_commands_root)
                        if rel == ".":
                            skill_name = stem
                        else:
                            skill_name = rel.replace(os.sep, ":") + ":" + stem
                        if skill_name in seen:
                            continue
                        # Parse description from the TOML file without adding a dep.
                        desc = ""
                        try:
                            toml_path = os.path.join(dirpath, fname)
                            with open(toml_path, encoding="utf-8", errors="replace") as fh:
                                for line in fh:
                                    m = re.match(
                                        r"""^\s*description\s*=\s*["'](.+?)["']\s*$""", line
                                    )
                                    if m:
                                        desc = m.group(1)[:140]
                                        break
                        except Exception:
                            pass
                        seen[skill_name] = {
                            "name": skill_name,
                            "description": desc,
                            "source": "gemini",
                        }
            return sorted(seen.values(), key=lambda s: s["name"])
        except Exception:
            return []

    # ------------------------------------------------------------------ Claude (default)
    if agent_key != "claude":
        # Custom/local/unknown client — no skills concept.
        return []

    try:
        seen = {}  # name -> dict; first-seen wins
        # Built-ins first (win over plugins on collision)
        for name, desc in BUILTIN_SKILLS:
            seen[name] = {"name": name, "description": desc, "source": "built-in"}

        scan_dirs = []
        # personal skills
        scan_dirs.append((os.path.join(home, ".claude", "skills"), "personal"))
        # project skills
        if cwd:
            scan_dirs.append((os.path.join(cwd, ".claude", "skills"), "project"))
        # plugin skills (two sub-layouts)
        plugins_root = os.path.join(home, ".claude", "plugins", "marketplaces")
        if os.path.isdir(plugins_root):
            for mp in os.listdir(plugins_root):
                mp_path = os.path.join(plugins_root, mp)
                for sub in ("plugins", "external_plugins"):
                    sub_path = os.path.join(mp_path, sub)
                    if os.path.isdir(sub_path):
                        for plugin in os.listdir(sub_path):
                            skills_dir = os.path.join(sub_path, plugin, "skills")
                            scan_dirs.append((skills_dir, "plugin"))

        for skills_root, source in scan_dirs:
            if not os.path.isdir(skills_root):
                continue
            try:
                for skill_dir in os.listdir(skills_root):
                    skill_md = os.path.join(skills_root, skill_dir, "SKILL.md")
                    if not os.path.isfile(skill_md):
                        continue
                    try:
                        name, desc = _parse_skill_md_frontmatter(skill_md, skill_dir)
                        if name not in seen:
                            seen[name] = {"name": name, "description": desc, "source": source}
                    except Exception:
                        pass
            except Exception:
                pass

        # Prefer a clear human blurb; otherwise strip boilerplate from the raw text.
        for entry in seen.values():
            entry["description"] = SKILL_BLURBS.get(entry["name"]) or _humanize_skill_desc(
                entry["description"]
            )
        return sorted(seen.values(), key=lambda s: s["name"])
    except Exception:
        return [{"name": n, "description": d, "source": "built-in"} for n, d in BUILTIN_SKILLS]


def discover_external_sessions(cwd, agent_key):
    if agent_key == "codex":
        return codex_sessions_for_cwd(cwd)
    if agent_key == "claude":
        return claude_sessions_for_cwd(cwd)
    if agent_key == "gemini":
        return gemini_sessions_for_cwd(cwd)
    return []


def summarize_turn_items(turns, max_chars=7000):
    lines = []
    remaining = max_chars
    for turn in turns[-12:]:
        for item in turn.get("items") or []:
            typ = item.get("type", "")
            text = ""
            if typ == "userMessage":
                parts = []
                for bit in item.get("content") or []:
                    if isinstance(bit, dict) and bit.get("type") == "text":
                        parts.append(bit.get("text", ""))
                text = visible_user_prompt_text(" ".join(parts))
                prefix = "USER"
            elif typ == "agentMessage":
                text = item.get("text") or item.get("content") or ""
                prefix = "AGENT"
            elif typ == "commandExecution":
                text = item.get("command") or ""
                prefix = "COMMAND"
            elif typ == "fileChange":
                paths = []
                for change in item.get("changes") or []:
                    path = change.get("path") or change.get("filePath")
                    if path:
                        paths.append(str(path))
                text = ", ".join(paths)
                prefix = "FILES"
            elif typ == "reasoning":
                text = " ".join(item.get("summary") or [])
                prefix = "REASONING"
            elif typ == "plan":
                text = item.get("text") or ""
                prefix = "PLAN"
            else:
                text = item.get("text") or item.get("summary") or ""
                prefix = typ.upper() or "NOTE"
            text = clean_text(text)
            if not text:
                continue
            line = f"{prefix}: {text}"
            if len(line) > remaining:
                lines.append(line[: max(0, remaining - 1)] + "…")
                return "\n".join(lines)
            lines.append(line)
            remaining -= len(line) + 1
            if remaining <= 0:
                return "\n".join(lines)
    return "\n".join(lines)


def item_text(item):
    typ = item.get("type", "")
    if typ == "userMessage":
        return visible_user_prompt_text(
            " ".join(
                bit.get("text", "")
                for bit in item.get("content") or []
                if isinstance(bit, dict) and bit.get("type") == "text"
            )
        )
    if typ == "fileChange":
        return clean_text(
            ", ".join(
                str(change.get("path") or change.get("filePath") or "")
                for change in item.get("changes") or []
                if change.get("path") or change.get("filePath")
            )
        )
    if typ == "reasoning":
        return clean_text(" ".join(item.get("summary") or []))
    return clean_text(
        item.get("text")
        or item.get("content")
        or item.get("command")
        or item.get("summary")
        or ""
    )


def _path_has_project_marker(path):
    if not path or not os.path.isdir(path):
        return False
    for marker in PROJECT_ROOT_MARKERS:
        marker_path = os.path.join(path, marker)
        if os.path.isdir(marker_path) or os.path.isfile(marker_path):
            return True
    return False


def find_project_root(path):
    path = os.path.abspath(os.path.expanduser(clean_text(path) or os.path.expanduser("~")))
    if os.path.isfile(path):
        path = os.path.dirname(path)
    while path and not os.path.isdir(path):
        parent = os.path.dirname(path)
        if parent == path:
            return ""
        path = parent
    current = path
    first_marker = ""
    while current and os.path.isdir(current):
        if os.path.isdir(os.path.join(current, ".git")):
            return current
        if not first_marker and _path_has_project_marker(current):
            first_marker = current
        parent = os.path.dirname(current)
        if parent == current:
            break
        current = parent
    return first_marker or (path if os.path.isdir(path) else "")


def _clean_candidate_path(value):
    value = urllib.parse.unquote(clean_text(value))
    if value.startswith("file://"):
        value = urllib.parse.urlparse(value).path
    value = re.sub(r"\s+\(\d+\s+bytes\)$", "", value)
    return value.strip().strip("`'\"[]{}<>.,;:")


def _resolve_candidate_path(value, cwd):
    value = _clean_candidate_path(value)
    if not value or value in {".", ".."}:
        return ""
    if value.startswith("~"):
        value = os.path.expanduser(value)
    elif not os.path.isabs(value):
        value = os.path.join(
            os.path.abspath(os.path.expanduser(clean_text(cwd) or os.path.expanduser("~"))),
            value,
        )
    value = os.path.abspath(value)
    probe = value
    while probe and not os.path.exists(probe):
        parent = os.path.dirname(probe)
        if parent == probe:
            return ""
        probe = parent
    return value if probe else ""


def _paths_from_filechange_text(text):
    text = clean_text(text)
    if not text:
        return []
    lowered = text.lower()
    if lowered.startswith("files:"):
        return [part.strip() for part in text.split(":", 1)[1].split(",")]
    match = re.match(r"^(?:write|read)\s+(.+?)(?:\s+\(\d+\s+bytes\))?$", text)
    if match:
        return [match.group(1)]
    absolute = []
    for match in re.finditer(r"(?<!\S)(/[^,\n\r]+)", text):
        candidate = match.group(1).strip()
        if candidate:
            absolute.append(candidate)
    return absolute


def _paths_from_command(command):
    command = clean_text(command)
    if not command:
        return []
    paths = []
    try:
        parts = shlex.split(command)
    except ValueError:
        parts = command.split()
    if len(parts) >= 2 and parts[0] == "cd":
        paths.append(parts[1])
    for part in parts:
        if part.startswith("/") or part.startswith("~/") or "/" in part:
            paths.append(part)
    return paths


def session_candidate_paths(session):
    session = session or {}
    cwd = clean_text(session.get("cwd")) or os.path.expanduser("~")
    result = []
    for key in ("handoff_context", "handoff_stage_packet"):
        for path in _paths_from_filechange_text(session.get(key)):
            resolved = _resolve_candidate_path(path, cwd)
            if resolved:
                result.append(resolved)
    for key in ("handoff_artifact", "handoff_stage_artifact"):
        artifact = clean_text(session.get(key))
        if artifact and os.path.isfile(artifact):
            try:
                with open(artifact, encoding="utf-8", errors="replace") as handle:
                    artifact_text = handle.read(40000)
            except OSError:
                artifact_text = ""
            for path in _paths_from_filechange_text(artifact_text):
                resolved = _resolve_candidate_path(path, cwd)
                if resolved:
                    result.append(resolved)
    for turn in session.get("turns") or []:
        for item in turn.get("items") or []:
            typ = item.get("type")
            if typ == "fileChange":
                for change in item.get("changes") or []:
                    path = change.get("path") or change.get("filePath")
                    resolved = _resolve_candidate_path(path, cwd)
                    if resolved:
                        result.append(resolved)
            elif typ == "commandExecution":
                for path in _paths_from_command(item.get("command")):
                    resolved = _resolve_candidate_path(path, cwd)
                    if resolved:
                        result.append(resolved)
            elif typ == "system" and item.get("tag") == "fileChange":
                for path in _paths_from_filechange_text(item.get("text")):
                    resolved = _resolve_candidate_path(path, cwd)
                    if resolved:
                        result.append(resolved)
            elif typ in {"agentMessage", "userMessage"}:
                for path in _paths_from_filechange_text(item_text(item)):
                    resolved = _resolve_candidate_path(path, cwd)
                    if resolved:
                        result.append(resolved)
    return result


def _project_title_slugs(session):
    raw = clean_text(
        (session or {}).get("title")
        or (session or {}).get("preview")
        or (session or {}).get("handoff_base_title")
    )
    _, visible = strip_session_context(raw)
    raw = visible or raw
    raw = re.sub(
        r"^(?:codex|claude|gemini|ollama|openai|anthropic|google)\s*:\s*",
        "",
        raw,
        flags=re.IGNORECASE,
    )
    raw = re.sub(
        r"\s+(?:session|day|week|part|chapter|round|run|iteration|episode)\s+\d+\s*$",
        "",
        raw,
        flags=re.IGNORECASE,
    ).strip()
    raw = re.sub(r"\b\d+$", "", raw).strip()
    if not raw:
        return []
    slug = re.sub(r"[^a-z0-9]+", "-", raw.lower()).strip("-")
    if not slug:
        return []
    candidates = [slug]
    if not slug.startswith("the-"):
        candidates.append("the-" + slug)
    # Also try rotating the first word to the end:
    # "Next Agent Workbench" → "agent-workbench-next" matches dir "Agent Workbench Next"
    words = raw.lower().split()
    if len(words) > 1:
        rotated = " ".join(words[1:] + [words[0]])
        rotated_slug = re.sub(r"[^a-z0-9]+", "-", rotated).strip("-")
        if rotated_slug and rotated_slug not in candidates:
            candidates.append(rotated_slug)
            if not rotated_slug.startswith("the-"):
                candidates.append("the-" + rotated_slug)
    return candidates


def _project_root_from_registry_aliases(session):
    """Find project root by matching session title against registered project aliases."""
    raw = clean_text(
        (session or {}).get("title")
        or (session or {}).get("preview")
        or (session or {}).get("handoff_base_title")
    )
    if not raw:
        return ""
    raw = re.sub(
        r"^(?:codex|claude|gemini|ollama|openai|anthropic|google)\s*:\s*",
        "",
        raw,
        flags=re.IGNORECASE,
    ).strip()
    raw = re.sub(
        r"\s+(?:session|day|week|part|chapter|round|run|iteration|episode)\s+\d+\s*$",
        "",
        raw,
        flags=re.IGNORECASE,
    ).strip()
    raw = re.sub(r"\b\d+$", "", raw).strip()
    if not raw:
        return ""
    raw_lower = raw.lower()
    home = os.path.abspath(os.path.expanduser("~"))
    search_roots = [
        home,
        os.path.join(home, "Projects"),
        os.path.join(home, "Projects", "Open Projects"),
        os.path.join(home, "Projects", "Open Games"),
        os.path.join(home, "Projects", "Scratch"),
    ]
    seen = set()
    for base in search_roots:
        if not os.path.isdir(base) or base in seen:
            continue
        seen.add(base)
        try:
            for entry in os.scandir(base):
                if not entry.is_dir():
                    continue
                registry_file = os.path.join(
                    entry.path, PROJECT_REGISTRY_DIRNAME, PROJECT_REGISTRY_FILENAME
                )
                if not os.path.isfile(registry_file):
                    continue
                data = load_json(registry_file, {})
                if not isinstance(data, dict):
                    continue
                for alias in data.get("aliases") or []:
                    if clean_text(alias).lower() == raw_lower:
                        # Prefer the registry's ACTUAL on-disk location (entry.path —
                        # the dir holding .agent-workbench/) over the stored "root",
                        # which is stale after the project is moved. Falling back to the
                        # stale path silently failed to re-link a moved project; using
                        # entry.path lets AWB re-route, and ensure_project_registry then
                        # heals the stored path on the next touch.
                        stored = clean_text(data.get("root"))
                        root = stored if (stored and os.path.isdir(stored)) else entry.path
                        if root and os.path.isdir(root):
                            return os.path.abspath(root)
                        break
        except OSError:
            continue
    return ""


def _project_root_from_title(session, cwd):
    slugs = _project_title_slugs(session)
    if not slugs:
        return ""
    home = os.path.abspath(os.path.expanduser("~"))
    search_roots = [
        cwd,
        home,
        os.path.join(home, "Projects"),
        os.path.join(home, "Projects", "Open Projects"),
        os.path.join(home, "Projects", "Open Games"),
        os.path.join(home, "Projects", "Scratch"),
    ]
    seen = set()
    for base in search_roots:
        base = os.path.abspath(os.path.expanduser(clean_text(base)))
        if not base or base in seen or not os.path.isdir(base):
            continue
        seen.add(base)
        for slug in slugs:
            path = os.path.join(base, slug)
            if os.path.isdir(path):
                root = find_project_root(path)
                if root and os.path.abspath(root) != home:
                    return root
    return ""


def _self_maintenance_project_root(session):
    session = session or {}
    fragments = [
        session.get("title"),
        session.get("preview"),
        session.get("handoff_context"),
        session.get("handoff_stage_packet"),
    ]
    for turn in session.get("turns") or []:
        for item in turn.get("items") or []:
            typ = item.get("type")
            if typ in {"userMessage", "agentMessage", "system", "note"}:
                fragments.append(item_text(item))
    text = "\n".join(clean_text(fragment) for fragment in fragments if clean_text(fragment))
    if "Agent Workbench self-maintenance context" not in text:
        return ""
    match = re.search(r"Editable source project:\s*(.+)", text)
    if not match:
        return ""
    path = _clean_candidate_path(match.group(1))
    if not path:
        return ""
    root = find_project_root(path)
    return root if root and os.path.isdir(root) else ""


def _roots_related(a, b):
    a = os.path.abspath(os.path.expanduser(clean_text(a)))
    b = os.path.abspath(os.path.expanduser(clean_text(b)))
    if not a or not b:
        return False
    try:
        return os.path.commonpath([a, b]) in {a, b}
    except ValueError:
        return False


def _project_related_roots(root):
    root = os.path.abspath(os.path.expanduser(clean_text(root)))
    if not root:
        return []
    roots = [root] if os.path.isdir(root) else []
    try:
        _, registry = read_project_registry(root)
    except Exception:
        registry = {}
    for field in ("related_roots", "related_projects", "allowed_roots"):
        values = registry.get(field) if isinstance(registry, dict) else []
        if isinstance(values, str):
            values = [values]
        elif isinstance(values, dict):
            values = list(values.values())
        if not isinstance(values, list):
            continue
        for value in values:
            if isinstance(value, dict):
                value = value.get("root") or value.get("path")
            path = os.path.abspath(os.path.expanduser(clean_text(value)))
            if path and os.path.isdir(path):
                roots.append(path)
    return list(dict.fromkeys(roots))


def _project_roots_related(a, b):
    a = os.path.abspath(os.path.expanduser(clean_text(a)))
    b = os.path.abspath(os.path.expanduser(clean_text(b)))
    if not a or not b:
        return False
    if _roots_related(a, b):
        return True
    for base, other in ((a, b), (b, a)):
        for related in _project_related_roots(base):
            if _roots_related(related, other):
                return True
    return False


def session_candidate_root_scores(session, expected_root=""):
    scores = {}
    home = os.path.abspath(os.path.expanduser("~"))
    expected_root = os.path.abspath(os.path.expanduser(clean_text(expected_root))) if expected_root else ""
    for path in session_candidate_paths(session):
        root = find_project_root(path)
        if not root:
            continue
        root = os.path.abspath(root)
        if root == home and os.path.abspath(path) != home:
            continue
        # Only use unmarked roots if they are clearly inside the expected project.
        if (
            not _path_has_project_marker(root)
            and not (expected_root and _project_roots_related(expected_root, root))
        ):
            continue
        scores[root] = scores.get(root, 0) + 1
    return scores


def _infer_expected_root(session, fallback_cwd=""):
    """Shared helper: compute the single authoritative expected project root for
    a session. Used by both project_scope_conflict and infer_project_root so both
    agree on the expected root for the same session input."""
    return infer_project_root(session, fallback_cwd)


def project_scope_conflict(session=None, fallback_cwd=""):
    session = session or {}
    expected = _infer_expected_root(session, fallback_cwd)
    if not expected:
        return {}
    scores = session_candidate_root_scores(session, expected)
    conflicts = {
        root: count
        for root, count in scores.items()
        if not _project_roots_related(expected, root)
    }
    if not conflicts:
        return {}
    conflict_root, conflict_count = max(
        conflicts.items(),
        key=lambda item: (item[1], len(item[0])),
    )
    expected_hits = sum(
        count for root, count in scores.items() if _project_roots_related(expected, root)
    )
    # Handoff chains can mention older tool/project paths. Do not block recovery when
    # the current session is overwhelmingly anchored in the titled project.
    if expected_hits >= max(3, conflict_count * 3):
        return {}
    return {
        "expected_root": expected,
        "conflict_root": conflict_root,
        "conflict_count": conflict_count,
        "expected_hits": expected_hits,
        "title": clean_text(session.get("title") or session.get("preview")),
    }


def infer_project_root(session=None, fallback_cwd=""):
    session = session or {}
    stored_root = clean_text(session.get("project_root"))
    stored_root = (
        os.path.abspath(os.path.expanduser(stored_root))
        if stored_root and os.path.isdir(os.path.expanduser(stored_root))
        else ""
    )
    cwd = os.path.abspath(
        os.path.expanduser(
            clean_text(session.get("cwd")) or clean_text(fallback_cwd) or os.path.expanduser("~")
        )
    )
    home = os.path.abspath(os.path.expanduser("~"))
    self_root = _self_maintenance_project_root(session)
    if self_root:
        return self_root
    title_root = _project_root_from_title(session, cwd)
    if title_root:
        if (
            not stored_root
            or stored_root == home
            or not _project_roots_related(title_root, stored_root)
        ):
            return title_root
        try:
            if (
                stored_root != title_root
                and os.path.commonpath([stored_root, title_root]) == stored_root
            ):
                return title_root
        except ValueError:
            return title_root
    if stored_root:
        return stored_root
    # Registry alias lookup: check all known project.json files for a matching alias.
    # Catches cases where the session title matches a registered alias but the directory
    # name differs (e.g. "Next Agent Workbench" title → "Agent Workbench Next" dir).
    alias_root = _project_root_from_registry_aliases(session)
    if alias_root:
        return alias_root
    scored = session_candidate_root_scores(session)
    if scored:
        best = max(scored, key=lambda root: (scored[root], len(root)))
        if os.path.abspath(best) != home:
            return best
    root = find_project_root(cwd)
    if root and os.path.abspath(root) != home:
        return root
    # Never return bare home dir — it's not a real project root and reading
    # AGENT_STATE.md from there would cross-contaminate unrelated sessions.
    return ""


def project_state_path_for_session(session=None, fallback_cwd=""):
    return project_state_path(infer_project_root(session, fallback_cwd))


def project_state_context_for_session(session=None, fallback_cwd=""):
    return project_state_context(infer_project_root(session, fallback_cwd))


def project_state_path(cwd):
    cwd = os.path.abspath(os.path.expanduser(clean_text(cwd) or os.path.expanduser("~")))
    if not os.path.isdir(cwd):
        return ""
    # Never treat bare home dir as a project — AGENT_STATE.md there is spurious.
    if cwd == os.path.abspath(os.path.expanduser("~")):
        return ""
    return os.path.join(cwd, PROJECT_STATE_FILENAME)


def project_registry_path(cwd):
    cwd = os.path.abspath(os.path.expanduser(clean_text(cwd) or os.path.expanduser("~")))
    if not os.path.isdir(cwd):
        return ""
    # Never treat bare home dir as a project registry location.
    if cwd == os.path.abspath(os.path.expanduser("~")):
        return ""
    return os.path.join(cwd, PROJECT_REGISTRY_DIRNAME, PROJECT_REGISTRY_FILENAME)


def project_memory_dir(cwd):
    cwd = os.path.abspath(os.path.expanduser(clean_text(cwd) or os.path.expanduser("~")))
    if not os.path.isdir(cwd):
        return ""
    # Never treat bare home dir as a project memory location.
    if cwd == os.path.abspath(os.path.expanduser("~")):
        return ""
    return os.path.join(cwd, PROJECT_REGISTRY_DIRNAME)


def project_handoffs_dir(cwd):
    memory_dir = project_memory_dir(cwd)
    return os.path.join(memory_dir, PROJECT_HANDOFFS_DIRNAME) if memory_dir else ""


def project_registry_id(root):
    root = os.path.abspath(os.path.expanduser(clean_text(root) or os.path.expanduser("~")))
    label = re.sub(r"[^a-z0-9]+", "-", project_label(root).lower()).strip("-")
    digest = hashlib.sha1(root.encode("utf-8")).hexdigest()[:10]
    return f"{label or 'project'}-{digest}"


def read_project_registry(cwd):
    path = project_registry_path(cwd)
    if not path or not os.path.isfile(path):
        return "", {}
    data = load_json(path, {})
    return path, data if isinstance(data, dict) else {}


def ensure_project_registry(cwd, session=None, agent_key="", title="", state_path="", sequence=None):
    root = os.path.abspath(os.path.expanduser(clean_text(cwd) or os.path.expanduser("~")))
    if not os.path.isdir(root):
        return ""
    path = project_registry_path(root)
    if not path:
        # No registry location for this root (e.g. the bare home dir is guarded).
        # Bail BEFORE save_json — saving to "" raises [Errno 2] '' and broke Hand Off
        # Deploy for any session whose cwd is the home directory.
        return ""
    existing = load_json(path, {})
    if not isinstance(existing, dict):
        existing = {}
    now = now_iso()
    aliases = [
        clean_text(project_label(root)),
        clean_text(title),
        clean_text((session or {}).get("handoff_base_title")),
        clean_text((session or {}).get("title")),
        clean_text((session or {}).get("preview")),
    ]
    aliases = [
        alias
        for alias in dict.fromkeys(aliases)
        if alias and not alias.lower().startswith("new ")
    ]
    registry = {
        **existing,
        "schema": 1,
        "project_id": clean_text(existing.get("project_id")) or project_registry_id(root),
        "display_name": clean_text(existing.get("display_name")) or project_label(root),
        "root": root,
        "state_file": clean_text(state_path) or project_state_path(root),
        "updated_at": now,
    }
    if not registry.get("created_at"):
        registry["created_at"] = now
    merged_aliases = list(dict.fromkeys((existing.get("aliases") or []) + aliases))
    registry["aliases"] = [clean_text(alias) for alias in merged_aliases if clean_text(alias)]
    related_roots = []
    values = existing.get("related_roots") or []
    if isinstance(values, str):
        values = [values]
    elif isinstance(values, dict):
        values = list(values.values())
    if isinstance(values, list):
        for value in values:
            if isinstance(value, dict):
                value = value.get("root") or value.get("path")
            if not value:
                # clean_text(None) -> "" and abspath("") resolves to the process
                # CWD, which would get spuriously added as a related root.
                continue
            path_value = os.path.abspath(os.path.expanduser(clean_text(value)))
            if path_value and os.path.isdir(path_value) and path_value != root:
                related_roots.append(path_value)
    registry["related_roots"] = list(dict.fromkeys(related_roots))
    clients = existing.get("clients") if isinstance(existing.get("clients"), dict) else {}
    agent_key = clean_text(agent_key or (session or {}).get("agent"))
    if agent_key:
        client = clients.get(agent_key) if isinstance(clients.get(agent_key), dict) else {}
        client.update(
            {
                "last_session_id": clean_text((session or {}).get("id")),
                "last_title": clean_text(title or (session or {}).get("title")),
                "updated_at": now,
            }
        )
        if sequence is not None:
            try:
                client["last_handoff_sequence"] = int(sequence)
            except (TypeError, ValueError):
                pass
        clients[agent_key] = client
        registry["clients"] = clients
    save_json(path, registry)
    return path


def read_project_state(cwd, max_chars=PROJECT_STATE_MAX_CHARS):
    path = project_state_path(cwd)
    if not path or not os.path.isfile(path):
        return "", ""
    try:
        with open(path, encoding="utf-8", errors="replace") as handle:
            return path, handle.read(max_chars)
    except OSError:
        return "", ""


def project_state_context(cwd):
    path, text = read_project_state(cwd)
    if not path:
        return ""
    registry_path, registry = read_project_registry(cwd)
    root = clean_text(registry.get("root")) or os.path.abspath(
        os.path.expanduser(clean_text(cwd) or os.path.expanduser("~"))
    )
    registry_line = f"- Project registry: {registry_path}\n" if registry_path else ""
    project_id_line = (
        f"- Project id: {clean_text(registry.get('project_id'))}\n"
        if registry.get("project_id")
        else ""
    )
    related = [
        os.path.abspath(os.path.expanduser(clean_text(value)))
        for value in (registry.get("related_roots") or [])
        if clean_text(value)
    ] if isinstance(registry.get("related_roots"), list) else []
    related_line = (
        "- Related roots: " + ", ".join(related) + "\n"
        if related
        else ""
    )
    truncated = ""
    if os.path.getsize(path) > len(text.encode("utf-8", errors="ignore")):
        truncated = (
            "\n\n[Excerpt truncated. Read the file directly before making "
            "decisions that depend on older project history.]"
        )
    body = (
        "PROJECT SHARED STATE — read before acting:\n"
        f"- Canonical file: {path}\n"
        f"- Project root: {root}\n"
        f"{registry_line}"
        f"{project_id_line}"
        f"{related_line}"
        "- Treat this as cross-client project memory shared by Claude, Codex, Gemini, and local models.\n"
        "- If this turn changes durable project facts, update this file before finishing.\n\n"
        f"{text.strip()}{truncated}"
    )
    # Wrap in session_context so visible_user_prompt_text can reliably strip the
    # entire block from the rendered conversation (it already handles this tag).
    return f"{SESSION_CONTEXT_OPEN}\n{body}\n{SESSION_CONTEXT_CLOSE}"


def strip_prior_state_snapshots(text):
    text = clean_text(text)
    if not text:
        return ""
    return re.split(r"\n## Prior State Snapshot\b", text, maxsplit=1)[0].strip()


def local_project_state_summary(existing_state, handoff_packet, cwd, model=None):
    """Use Ollama for the mechanical summarization step when available; callers
    verify/write the result. Returns empty string on any local-model failure."""
    model = clean_text(model) or LOCAL_DELEGATE_DEFAULT_MODEL
    existing_state = strip_prior_state_snapshots(existing_state)
    prompt = f"""Update a cross-agent project state file.

Project directory: {cwd}

Existing AGENT_STATE.md:
{existing_state or '(none yet)'}

Latest session handoff:
{handoff_packet}

Write a concise Markdown AGENT_STATE.md that any coding model can use later.
Use these headings exactly:
# Agent State
## Project
## Current Objective
## Durable Facts
## Recent Changes
## Open Tasks
## Known Risks
## Verification Commands
## Last Updated

Prefer stable project facts over chat transcript detail. Do not invent details.
"""
    if not _OLLAMA_INFERENCE_SEM.acquire(blocking=False):
        # Another Ollama inference is already running; skip to avoid GPU pile-up.
        return ""
    try:
        body = json.dumps(
            {
                "model": model,
                "messages": [
                    {
                        "role": "system",
                        "content": (
                            "You update a durable project state Markdown file. "
                            "Be concise, factual, and preserve important existing facts."
                        ),
                    },
                    {"role": "user", "content": prompt},
                ],
                "stream": False,
            }
        ).encode()
        base_url = os.environ.get("OLLAMA_HOST", "http://localhost:11434").rstrip("/")
        request = urllib.request.Request(
            f"{base_url}/api/chat",
            data=body,
            headers={"Content-Type": "application/json"},
        )
        with urllib.request.urlopen(request, timeout=180) as response:
            payload = json.loads(response.read().decode("utf-8"))
        return clean_text((payload.get("message") or {}).get("content"))
    except Exception:
        return ""
    finally:
        _OLLAMA_INFERENCE_SEM.release()


def fallback_project_state(existing_state, handoff_packet, cwd):
