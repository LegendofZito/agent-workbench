    def handle_prompt_return(self, event):
        if event.state & 0x0001:
            return None
        self.send()
        return "break"

    def set_activity(self, state, text=None):
        self.activity_state = state
        colors = {
            "idle": ("#16351f", "#86efac"),
            "working": ("#3b2c0b", "#facc15"),
            "input": ("#3b1d4a", "#e9a8ff"),
            "error": ("#4a1d1d", "#fca5a5"),
            "starting": ("#24303c", "#cbd5e1"),
        }
        bg, fg = colors.get(state, colors["starting"])
        self.activity_badge.configure(bg=bg, fg=fg)
        if text is not None:
            self.activity_text.set(text)
        elif state == "idle":
            self.activity_text.set("Ready")
        elif state == "input":
            self.activity_text.set("Needs input")
        elif state == "error":
            self.activity_text.set("Error")

    def animate_activity(self):
        if self.activity_state == "working":
            dots = "." * ((self.activity_frame % 3) + 1)
            self.activity_text.set(f"Working{dots}")
            self.activity_frame += 1
        self.win.after(350, self.animate_activity)

    def on_notebook_tab_changed(self, _event=None):
        selected = self.notebook.select()
        if selected == str(self.terminal_tab):
            self.composer.grid_remove()
            self.terminal_input.focus_set()
        else:
            self.composer.grid()

