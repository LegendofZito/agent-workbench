                self.agent_settings[key] = {"model": "Default", "effort": "Default"}
        for agent_key, settings in saved_agent_settings.items():
            if agent_key in self.agent_settings and isinstance(settings, dict):
                self.agent_settings[agent_key].update(settings)
        if not self.config.get("client_default_models_v1"):
            if self.agent_settings["claude"].get("model") == "sonnet":
                self.agent_settings["claude"]["model"] = "Default"
            self.config["client_default_models_v1"] = True
        for agent_key in ("codex", "claude", "gemini"):
            settings = self.agent_settings[agent_key]
            model_options = self._model_options_for(agent_key)
            effort_options = self._effort_options_for(agent_key)
            if settings.get("model") not in model_options:
                settings["model"] = self._default_settings_for(agent_key)["model"]
            if settings.get("effort") not in effort_options:
                settings["effort"] = self._default_settings_for(agent_key)["effort"]
        for job in self.worker_jobs:
            session = self.store.get(clean_text(job.get("session_id")))
            if not session:
                continue
            backend = session.get("backend") or {}
            native_id = clean_text(
                backend.get("session_id") or backend.get("thread_id")
            )
            session["title"] = clean_text(job.get("title")) or session.get("title")
            if native_id:
                session["source_session_id"] = native_id
                source_path = claude_session_path(native_id, session.get("cwd"))
                if source_path:
                    session["source_path"] = source_path
            self.store.save(session)
            sync_claude_session_title(session)
        for session in self.store.sessions.values():
            changed = False
            stage_packet = clean_text(session.get("handoff_stage_packet"))
            handoff_packet = clean_text(session.get("handoff_context"))
            if stage_packet:
                artifact = self._write_handoff_artifact(session, stage_packet)
                if artifact:
                    session["handoff_stage_artifact"] = artifact
                    session.pop("handoff_stage_packet", None)
                    changed = True
            if handoff_packet and len(handoff_packet) > 4000:
                artifact = self._write_handoff_artifact(session, handoff_packet)
                if artifact:
                    session["handoff_artifact"] = artifact
                    session["handoff_context"] = (
                        "Read the authoritative continuation handoff before acting:\n"
                        f"{artifact}"
                    )
                    changed = True
            if changed:
                self.store.save(session)
            sync_claude_session_title(session)
        self.config["agent_settings"] = self.agent_settings
        self.config["claude_orchestration"] = self.claude_orchestration
        self.config["worker_jobs"] = self.worker_jobs
        save_json(CONFIG_FILE, self.config)
        self.cwd = tk.StringVar(master=self.win, value=self.config.get("cwd", os.path.expanduser("~")))
        self.active_agent = tk.StringVar(master=self.win, value=self.config.get("active_agent", "codex"))
        if self.active_agent.get() not in self.agent_map:
