    def open_handoff_dialog(self):
        if self.handoff_dialog and self.handoff_dialog.winfo_exists():
            self.handoff_dialog.lift()
            return
        if not self.current_session:
            messagebox.showinfo(
                "Hand off session",
                "Open a session before creating a handoff.",
                parent=self.win,
            )
            return
        source = self.current_session
        self._refresh_handoff_stage(source, force=True)
        default_agent, default_model, default_effort = self._default_handoff_target(
            source.get("agent") or self.active_agent.get()
        )
        dialog = tk.Toplevel(self.win)
        self.handoff_dialog = dialog
        dialog.title("Hand off session")
        dialog.configure(bg=BG)
