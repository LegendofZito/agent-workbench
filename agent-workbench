    def handle_prompt_return(self, event):
        if event.state & 0x0001:
            return None
        self.send()
        return "break"

    def _on_input_modified(self, _event=None):
        try:
            if not self.input.edit_modified():
                return None
            self.input.edit_modified(False)
        except tk.TclError:
            return None
        if self._input_save_suppressed:
            return None
        self._schedule_workspace_config_save()
        return None

