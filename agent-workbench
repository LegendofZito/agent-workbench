                        "the current conversation and report their routing in "
                        "Conversation and Work Log."
                    ),
                )
                detail.configure(state="disabled")
                return
            index = selection[0]
            if index >= len(jobs):
                return
            job = jobs[index]
            detail_text = [
                f"Title: {clean_text(job.get('title')) or 'Worker'}",
                f"Status: {clean_text(job.get('status')) or 'queued'}",
                f"Agent: {self._agent_spec(job.get('agent') or 'claude')['label']}",
                f"Model: {clean_text(job.get('model')) or 'Default'}",
                f"Effort: {clean_text(job.get('effort')) or 'Default'}",
