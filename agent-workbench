        def render_queue():
            queue_list.delete(0, "end")
            queued = list(workspace.get("queued_prompts") or [])
            summary_var.set(
                f"{len(queued)} message{'s' if len(queued) != 1 else ''} waiting. "
                "You can inspect or remove items before they run."
            )
            for index, item in enumerate(queued, start=1):
                prompt = clean_text(item.get("prompt"))
                attachments = item.get("attachments") or []
                suffix = f" · {len(attachments)} file{'s' if len(attachments) != 1 else ''}" if attachments else ""
                queue_list.insert("end", f"{index}. {shorten(prompt, 54)}{suffix}")
            if queued:
                queue_list.selection_set(0)
                queue_list.activate(0)
                queue_list.see(0)
                show_selected()
            else:
                detail_title.configure(text="Queue is empty")
                detail_meta.configure(text="")
                detail_text.configure(state="normal")
                detail_text.delete("1.0", "end")
                detail_text.insert("1.0", "There are no queued prompts.")
                detail_text.configure(state="disabled")

        _edit_saved = [True]   # True = clean, False = unsaved edits
        _loaded_text = [""]     # the prompt text as last loaded/saved

        def _mark_dirty():
            if _edit_saved[0]:
                _edit_saved[0] = False
                save_btn.configure(
                    text="Save edit",
                    state="normal",
                    bg=ACCENT,
                    fg="white",
                    cursor="hand2",
                )

        def _mark_saved():
            _edit_saved[0] = True
            save_btn.configure(
                text="Saved",
                state="disabled",
                bg=PANEL,
                fg="#64748b",
                cursor="arrow",
            )

        def _refresh_dirty(_event=None):
            # Compare actual content to the loaded text so navigation keys, Ctrl+C,
            # and modifier presses never produce a false "unsaved" state. An edit that
            # is undone back to the original correctly flips the button back to "Saved".
            current = detail_text.get("1.0", "end-1c")
            if current == _loaded_text[0]:
                if not _edit_saved[0]:
                    _mark_saved()
            else:
                if _edit_saved[0]:
                    _mark_dirty()

        # Explicit clipboard handlers — Tkinter's defaults are inconsistent on Linux
        # (PRIMARY vs CLIPBOARD), so we drive copy/cut/paste/select-all ourselves and
        # return "break" to stop the class binding from double-handling the event.
        def _detail_copy(_e=None):
            try:
                sel = detail_text.get("sel.first", "sel.last")
            except tk.TclError:
                return "break"
            detail_text.clipboard_clear()
            detail_text.clipboard_append(sel)
            return "break"

        def _detail_cut(_e=None):
            try:
                sel = detail_text.get("sel.first", "sel.last")
            except tk.TclError:
                return "break"
            detail_text.clipboard_clear()
            detail_text.clipboard_append(sel)
            detail_text.delete("sel.first", "sel.last")
            _refresh_dirty()
            return "break"

        def _detail_paste(_e=None):
            try:
                clip = detail_text.clipboard_get()
            except tk.TclError:
                return "break"
            try:
                detail_text.delete("sel.first", "sel.last")
            except tk.TclError:
                pass
            detail_text.insert("insert", clip)
            detail_text.see("insert")
            _refresh_dirty()
            return "break"

        def _detail_select_all(_e=None):
            detail_text.tag_add("sel", "1.0", "end-1c")
            detail_text.mark_set("insert", "1.0")
            return "break"

        def show_selected(_event=None):
            selection = queue_list.curselection()
            queued = list(workspace.get("queued_prompts") or [])
            if not selection or not queued:
                return
            index = int(selection[0])
            if index >= len(queued):
                return
            item = queued[index]
            prompt = clean_text(item.get("prompt"))
            attachments = [clean_text(path) for path in item.get("attachments") or [] if clean_text(path)]
            detail_title.configure(text=f"Queued item {index + 1} — editable")
            meta = (
                f"{len(prompt)} characters · {len(attachments)} attachment"
                f"{'s' if len(attachments) != 1 else ''} · edit below, then Save"
            )
            if attachments:
                meta += "\nAttachments: " + ", ".join(os.path.basename(p) for p in attachments)
            detail_meta.configure(text=meta)
            detail_text.configure(state="normal")
            detail_text.delete("1.0", "end")
            detail_text.insert("1.0", prompt)
            detail_text.focus_set()
            _loaded_text[0] = prompt  # baseline for dirty comparison
            _mark_saved()  # freshly loaded = clean state

        def save_edit():
            selection = queue_list.curselection()
            queued = list(workspace.get("queued_prompts") or [])
            if not selection or not queued:
                return
            index = int(selection[0])
            if index >= len(queued):
                return
            new_prompt = clean_text(detail_text.get("1.0", "end"))
            if not new_prompt:
                self.status.set("Queued prompt can't be empty — use Delete instead.")
                return
            queued[index]["prompt"] = new_prompt
            workspace["queued_prompts"] = queued
            self.queued_prompts = list(queued)
            self._save_active_workspace()
            self._schedule_workspace_config_save(immediate=True)
            self._update_queue_indicator()
            # Update the list label without re-rendering the whole dialog (keeps focus)
            queue_list.delete(index)
            queue_list.insert(index, f"{index + 1}. {shorten(new_prompt, 54)}")
            queue_list.selection_set(index)
            _loaded_text[0] = new_prompt  # new saved baseline (matches what was stored)
            _mark_saved()
            self.status.set(f"Queued item {index + 1} updated.")

        def delete_selected():
            selection = queue_list.curselection()
            queued = list(workspace.get("queued_prompts") or [])
            if not selection or not queued:
                return
            index = int(selection[0])
            if index >= len(queued):
                return
            queued.pop(index)
            workspace["queued_prompts"] = queued
            self.queued_prompts = list(queued)
            self._save_active_workspace()
            self._schedule_workspace_config_save(immediate=True)
            self._update_queue_indicator()
            render_queue()

        def clear_queue():
            queued = list(workspace.get("queued_prompts") or [])
            if not queued:
                return
            workspace["queued_prompts"] = []
            self.queued_prompts = []
