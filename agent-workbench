        def _on_close():
            self._hide_skill_name_overlay()
            try:
                search_var.trace_remove("write", _search_trace_id)
            except Exception:
                pass
            if pop.winfo_exists():
                pop.destroy()
            self._skills_menu = None

        pop.protocol("WM_DELETE_WINDOW", _on_close)

    def _toggle_skill_favorite(self, name):
        """Add or remove a skill from the active agent's favorites, persist, and re-render chips."""
        active_agent = self.active_agent.get() if hasattr(self, "active_agent") else "claude"
        favs = self._agent_favorites(active_agent)
        if name in favs:
            favs.remove(name)
        else:
            favs.append(name)
        self._save_skill_favorites()
        self._render_skill_chips()

    def _open_skill_prompt(self, name):
        """Open a prompt popover hard-anchored above THIS skill's chip, visually joined
        to it so it's clear which skill the box belongs to."""
        accent = "#1a56db"
        chip = getattr(self, "_skill_chip_widgets", {}).get(name)

        # Toggle: clicking the SAME chip closes its popover; clicking a DIFFERENT
        # chip closes the open one and falls through to open the new chip's popover
        # (previously it always closed and returned, so you had to click twice).
        if getattr(self, "_skill_popover", None) and self._skill_popover.winfo_exists():
            old_name = getattr(self, "_skill_popover_name", None)
            self._skill_popover.destroy()
            self._skill_popover = None
            self._skill_popover_name = None
            self._unhighlight_skill_chip()
            if old_name == name:
                return

        pop = tk.Toplevel(self.win)
        pop.overrideredirect(True)
        pop.configure(bg=accent, highlightbackground=accent, highlightthickness=2)
        self._skill_popover = pop
        self._skill_popover_name = name

        # Colored header bearing the skill name — ties the box to its chip.
        tk.Label(
            pop,
            text=f"✦ {name}",
            bg=accent,
            fg="white",
            font=("Sans", 10, "bold"),
            padx=10,
            pady=5,
            anchor="w",
        ).pack(fill="x")
        body = tk.Frame(pop, bg=PANEL)
        body.pack(fill="both", expand=True)
        tk.Label(
            body,
            text="Tell it what to do — or leave blank to let the skill ask you / use its defaults.",
            bg=PANEL,
            fg=MUTED,
            font=("Sans", 8),
            anchor="w",
            padx=10,
        ).pack(fill="x", pady=(6, 0))

        text_widget = tk.Text(
            body,
            height=3,
            bg=PANEL_ALT,
            fg=TEXT,
            insertbackground=TEXT,
            relief="flat",
            padx=10,
            pady=8,
            font=("Sans", 10),
            wrap="word",
        )
        text_widget.pack(fill="x", padx=8, pady=(4, 0))

        btn_row = tk.Frame(body, bg=PANEL)
        btn_row.pack(fill="x", padx=8, pady=6)

        def _close():
            if pop.winfo_exists():
                pop.destroy()
            self._skill_popover = None
            self._skill_popover_name = None
            self._unhighlight_skill_chip()

        def _run():
            typed = clean_text(text_widget.get("1.0", "end"))
            _close()
            self._run_skill(name, typed)

        tk.Button(
            btn_row, text="Run", command=_run, bg=accent, fg="white",
            activebackground="#1e40af", activeforeground="white", relief="flat",
            padx=14, pady=4, cursor="hand2", font=("Sans", 9, "bold"),
        ).pack(side="right")
        tk.Button(
            btn_row, text="Cancel", command=_close, bg=PANEL_ALT, fg=MUTED,
            relief="flat", padx=10, pady=4, cursor="hand2", font=("Sans", 9),
        ).pack(side="right", padx=(0, 6))

        text_widget.bind("<Return>", lambda e: (_run(), "break")[1])
        pop.bind("<Escape>", lambda e: _close())

        # Anchor flush above the chip (overlap 2px so the accent borders merge into one
        # connected unit). Highlight the chip with the same accent. Clamp on-screen.
        self.win.update_idletasks()
        pop.update_idletasks()
        pw = max(pop.winfo_reqwidth(), 360)
        ph = pop.winfo_reqheight()
        anchor_widget = chip if (chip and chip.winfo_exists()) else self.skills_bar
        try:
            ax = anchor_widget.winfo_rootx()
            ay = anchor_widget.winfo_rooty()
        except tk.TclError:
            ax, ay = 100, 200
        screen_w = self.win.winfo_screenwidth()
        x = max(6, min(ax, screen_w - pw - 6))
        y = max(10, ay - ph + 2)
        pop.geometry(f"{pw}x{ph}+{x}+{y}")
        if chip and chip.winfo_exists():
            self._active_skill_chip = chip
            # Only recolor the existing 1px border — never change its thickness, or
            # the chip resizes and the whole composer/background shifts.
            chip.configure(highlightbackground=accent)
        pop.lift()
        text_widget.focus_set()

    def _unhighlight_skill_chip(self):
        chip = getattr(self, "_active_skill_chip", None)
        if chip:
            try:
                if chip.winfo_exists():
                    chip.configure(highlightbackground=BORDER)  # recolor only; keep 1px (no shift)
            except tk.TclError:
                pass
        self._active_skill_chip = None

    def _schedule_skill_name_reveal(self, widget, full_text, box_bg):
        self._cancel_skill_name_reveal()
        self._skill_name_after = self.win.after(
            143, lambda: self._show_skill_name_overlay(widget, full_text, box_bg)
        )

    def _cancel_skill_name_reveal(self):
        after = getattr(self, "_skill_name_after", None)
        if after:
            try:
                self.win.after_cancel(after)
            except tk.TclError:
                pass
        self._skill_name_after = None

    def _hide_skill_name_overlay(self):
        overlay = getattr(self, "_skill_name_overlay", None)
        if overlay is not None:
            try:
                if overlay.winfo_exists():
                    overlay.destroy()
            except tk.TclError:
                pass
        self._skill_name_overlay = None

    def _show_skill_name_overlay(self, widget, full_text, box_bg):
        """Reveal a too-long skill title by overlaying a box that extends right (over the
        description) from the chip's exact position. Same 143ms delay as session hover."""
        self._skill_name_after = None
        if not widget.winfo_exists():
            return
        self._hide_skill_name_overlay()
        overlay = tk.Toplevel(self.win)
        overlay.overrideredirect(True)
        overlay.configure(bg=box_bg)
        self._skill_name_overlay = overlay
        tk.Label(
            overlay,
            text=full_text,
            bg=box_bg,
            fg="#ffffff",
            font=("Sans", 9, "bold"),
            anchor="w",
            padx=10,
            pady=6,
            justify="left",
        ).pack()
        overlay.update_idletasks()
        try:
            x = widget.winfo_rootx()
            y = widget.winfo_rooty()
        except tk.TclError:
            self._hide_skill_name_overlay()
            return
        overlay.geometry(f"+{x}+{y}")
        overlay.lift()
        overlay.bind("<Leave>", lambda _e: self._hide_skill_name_overlay())
        overlay.bind("<Button-1>", lambda _e: self._hide_skill_name_overlay())

    def _run_skill(self, name, text):
        """Invoke a skill via the active agent's send path. An EMPTY box runs the skill
        bare (just /name) so it uses its own prerequisites/defaults and asks you itself —
        your text never overrides the skill's own questionnaire."""
        if self.active_agent.get() != "claude":
            self.append_work("Skills run best on the Claude agent.", "system")
        body = text.strip()
        self.append_work(f"✦ Skill: {name}", "system")
        self.set_activity("working")
        self.send(prompt=f"/{name} {body}".strip())
        self._log_event("skill_run", skill=name, chars=len(body))

    def set_activity(self, state, text=None):
        self.activity_state = state
        colors = {
            "idle": ("#16351f", "#86efac"),
            "working": ("#3b2c0b", "#facc15"),
            "input": ("#3b1d4a", "#e9a8ff"),
            "warning": ("#4a2b0b", "#fed7aa"),
            "error": ("#4a1d1d", "#fca5a5"),
            "stalled": ("#4a1d1d", "#fecaca"),
            "starting": ("#24303c", "#cbd5e1"),
        }
        bg, fg = colors.get(state, colors["starting"])
        self.activity_badge.configure(bg=bg)
        self.activity_word_label.configure(bg=bg, fg=fg)
        self.activity_dots_label.configure(bg=bg, fg=fg)
        if text is not None:
            self.activity_word.set(text)
        elif state == "idle":
            self.activity_word.set("Ready")
        elif state == "input":
            self.activity_word.set("Needs input")
        elif state == "error":
            self.activity_word.set("Error")
        elif state == "warning":
            self.activity_word.set("No output")
        elif state == "stalled":
            self.activity_word.set("Stalled")
        elif state == "working":
            self.activity_word.set("Working")
        else:
            self.activity_word.set("Starting")

    def _ollama_model_options(self):
        """Installed Ollama models for the picker, cached for a few seconds so the
        agent/model UI never blocks on the network. 'Default' = let the backend pick."""
        now = time.monotonic()
        cached = getattr(self, "_ollama_models_cache", None)
        cached_at = getattr(self, "_ollama_models_cache_at", 0.0)
        if cached is None or (now - cached_at) > 8.0:
            models = self._list_ollama_models()  # None = unreachable, [] = none installed
            cached = models or []
            self._ollama_models_cache = cached
            self._ollama_models_cache_at = now
        return ["Default"] + list(cached)

    def _model_options_for(self, agent_key):
        if agent_key == "codex":
            options = [
                self.codex_default_model,
                "gpt-5.3-spark",
                "gpt-5.4",
                "gpt-5.4-mini",
                "gpt-5.5",
            ]
        elif agent_key == "ollama":
            options = self._ollama_model_options()
        else:
            options = list(MODEL_OPTIONS.get(agent_key, ("Default",)))
        deduped = []
        seen = set()
        for option in options:
            option = clean_text(option)
            if option and option not in seen:
                seen.add(option)
                deduped.append(option)
        return tuple(deduped or ["Default"])

    def _effort_options_for(self, agent_key):
        if agent_key == "claude":
            help_text = self.runtime_help.get("claude", "")
            options = parse_effort_options(help_text, EFFORT_OPTIONS.get(agent_key, ("Default",)))
            options = tuple(options) or tuple(EFFORT_OPTIONS.get(agent_key, ("Default",)))
            # "Ultracode" is a synthetic top tier above "max": selecting it maps at
            # launch to --effort max + ultra multi-agent orchestration (see the
            # command builder). It is not a real CLI --effort value.
            if "Ultracode" not in options:
                options = options + ("Ultracode",)
            return options
        if agent_key == "gemini":
            return ("Default",)
        return tuple(EFFORT_OPTIONS.get(agent_key, ("Default",)))

    def _default_settings_for(self, agent_key):
        defaults = deepcopy(
            DEFAULT_AGENT_SETTINGS.get(agent_key, {"model": "Default", "effort": "Default"})
        )
        if agent_key == "codex":
            defaults["model"] = self.codex_default_model
        return defaults

    def _preferred_worker_model(self, agent_key):
        if agent_key == "codex":
            candidates = (
                self.codex_default_model,
                "gpt-5.3-spark",
                "gpt-5.4-mini",
                "gpt-5.4",
                "gpt-5.5",
            )
        else:
            candidates = PREFERRED_WORKER_MODELS.get(agent_key, ())
        for candidate in candidates:
            if candidate in self._model_options_for(agent_key):
                return candidate
        return self._model_options_for(agent_key)[0]

    def _worker_label(self, agent_key=None, model=None):
        agent_key = clean_text(agent_key or self.active_agent.get())
        spec = self._agent_spec(agent_key)
        label = spec.get("label") or agent_key.capitalize()
        model = clean_text(model or self.selected_model.get())
        if model and model not in {"Default", "Auto"}:
            return f"{label} · {model}"
        return label

    def _active_worker_jobs(self):
        active = []
        for job in self.worker_jobs:
            if clean_text(job.get("status")) in {"queued", "starting", "running"}:
                active.append(job)
        return active

    def _compact_worker_job(self, job):
        allowed = {
            "id",
            "source_session_id",
            "source_title",
            "session_id",
            "workspace_id",
            "title",
            "prompt",
            "agent",
            "model",
            "effort",
            "status",
            "created_at",
            "updated_at",
            "completed_at",
            "auto",
            "reason",
            "error",
            "request_signature",
        }
        return {
            key: value
            for key, value in dict(job or {}).items()
            if key in allowed and value not in (None, "")
        }

    def _save_worker_jobs(self):
        self.worker_jobs = [
            self._compact_worker_job(job)
            for job in self.worker_jobs[:100]
            if isinstance(job, dict)
        ]
        self.config["worker_jobs"] = self.worker_jobs
        save_json(CONFIG_FILE, self.config)

    def _record_worker_job(self, job):
        job = self._compact_worker_job(job)
        job_id = clean_text(job.get("id"))
        if not job_id:
            return
        for index, existing in enumerate(self.worker_jobs):
            if clean_text(existing.get("id")) == job_id:
                self.worker_jobs[index] = job
                break
        else:
            self.worker_jobs.insert(0, job)
        self._save_worker_jobs()
        self._update_worker_indicator()
        self._refresh_worker_dialog()

    def _mark_worker_job(self, session, status, error=None):
        job_id = clean_text((session or {}).get("worker_job_id"))
        if not job_id:
            return
        for job in self.worker_jobs:
            if clean_text(job.get("id")) != job_id:
                continue
            job["status"] = status
            job["updated_at"] = now_iso()
            if status in {"completed", "error", "cancelled", "interrupted"}:
                job["completed_at"] = now_iso()
            if error:
                job["error"] = clean_text(error)
            if session.get("id"):
                job["session_id"] = session.get("id")
            self._save_worker_jobs()
            self._update_worker_indicator()
            self._refresh_worker_dialog()
            return

    def _live_subagents(self):
        subs = self.workspaces.get(self.active_workspace_id, {}).get("live_subagents", [])
        return [s for s in subs if s.get("status", "running") == "running"]

    def _session_subagents(self):
        subs = self.workspaces.get(self.active_workspace_id, {}).get("live_subagents", [])
        return [s for s in subs if not s.get("model_inferred")]

    def _update_worker_indicator(self):
        workspace = self.workspaces.get(self.active_workspace_id) or {}
        agent_key = workspace.get("agent") or self.active_agent.get()
        model = workspace.get("model") or self.selected_model.get()
        active_count = len(self._active_worker_jobs()) + len(self._live_subagents())
        label = f"Sub-agents {active_count}"
        if len(self._active_worker_jobs()):
            label += f" · {self._worker_label(agent_key, model)}"
        self.worker_text.set(label)

    def _update_queue_indicator(self):
        workspace = self.workspaces.get(self.active_workspace_id) or {}
        queued = len(workspace.get("queued_prompts") or [])
        if queued:
            self.queue_text.set(f"Queue {queued}")
