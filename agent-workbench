    def _refresh_keys_dialog(self):
        """Rebuild the saved-keys list and MCP list in the open dialog."""
        refs = getattr(self, "_keys_dialog_refs", {})
        if not refs:
            return
        dialog = refs.get("dialog")
        if not dialog or not dialog.winfo_exists():
            return

        # ── Keys list (Section C) ──
        kf = refs.get("keys_list_frame")
        if kf and kf.winfo_exists():
            for child in kf.winfo_children():
                child.destroy()
            keys = self.secrets.get("keys", [])
            if not keys:
                tk.Label(kf, text="No keys saved yet.", bg=BG, fg=MUTED, font=("Sans", 9)).pack(anchor="w")
            for idx, entry in enumerate(keys):
                provider = entry.get("provider", "Unknown")
                env_var = entry.get("env", "")
                raw_val = entry.get("value", "")
                # Masked value: first 6 + "…" + last 4
                if len(raw_val) > 12:
                    masked = raw_val[:6] + "…" + raw_val[-4:]
                elif len(raw_val) > 4:
                    masked = raw_val[:3] + "…" + raw_val[-2:]
                else:
                    masked = "••••"
                inject_var = tk.BooleanVar(master=dialog, value=bool(entry.get("inject", False)))

                row = tk.Frame(kf, bg=PANEL, pady=3)
                row.pack(fill="x", pady=2)

                tk.Label(
                    row,
                    text=provider,
                    bg=PANEL,
                    fg=TEXT,
                    font=("Sans", 9, "bold"),
                    width=22,
                    anchor="w",
                ).pack(side="left", padx=(8, 0))
                tk.Label(
                    row,
                    text=env_var,
                    bg=PANEL,
                    fg=MUTED,
                    font=("Monospace", 8),
                    width=26,
                    anchor="w",
                ).pack(side="left", padx=(4, 0))
                tk.Label(
                    row,
                    text=masked,
                    bg=PANEL,
                    fg=MUTED,
                    font=("Monospace", 8),
                    width=16,
                    anchor="w",
                ).pack(side="left", padx=(4, 0))

                # LLM override warning
                if provider in _LLM_PROVIDER_LABELS:
                    tk.Label(
                        row,
                        text="(overrides account login)",
                        bg=PANEL,
                        fg=MUTED,
                        font=("Sans", 8),
                        anchor="w",
                    ).pack(side="left", padx=(2, 0))

                def _make_inject_toggle(i, ivar):
                    def _toggle():
                        self.secrets["keys"][i]["inject"] = ivar.get()
                        self._save_secrets()
                        self._apply_secrets_env()
                    return _toggle

                inject_cb = tk.Checkbutton(
                    row,
                    text="inject at launch",
                    variable=inject_var,
                    bg=PANEL,
                    fg=TEXT,
                    selectcolor=PANEL,
                    activebackground=PANEL,
                    activeforeground=TEXT,
                    font=("Sans", 9),
                    command=_make_inject_toggle(idx, inject_var),
                )
                inject_cb.pack(side="left", padx=(4, 0))

                def _make_remove_key(i):
                    def _remove():
                        removed_env = self.secrets["keys"][i].get("env", "")
                        del self.secrets["keys"][i]
                        # un-inject if currently injected
                        if removed_env and removed_env in self._injected_env:
                            os.environ.pop(removed_env, None)
                            self._injected_env.discard(removed_env)
                        self._save_secrets()
                        self._apply_secrets_env()
                        self._refresh_keys_dialog()
                    return _remove

                tk.Button(
                    row,
                    text="Remove",
                    bg=PANEL,
                    fg="#e57373",
                    activebackground=PANEL_ALT,
                    activeforeground="#e57373",
                    relief="flat",
                    padx=6,
                    pady=2,
                    cursor="hand2",
                    command=_make_remove_key(idx),
                ).pack(side="right", padx=(0, 6))

        # ── MCP list (Section D) ──
        mf = refs.get("mcp_list_frame")
        if mf and mf.winfo_exists():
            for child in mf.winfo_children():
                child.destroy()
            mcp_list = self.secrets.get("mcp", [])
            if not mcp_list:
                tk.Label(mf, text="No MCP servers saved.", bg=BG, fg=MUTED, font=("Sans", 9)).pack(anchor="w")
            for idx, srv in enumerate(mcp_list):
                name = srv.get("name", "")
                cmd = srv.get("command", "")
                row = tk.Frame(mf, bg=PANEL, pady=3)
                row.pack(fill="x", pady=2)
                tk.Label(
                    row,
                    text=name,
                    bg=PANEL,
                    fg=TEXT,
                    font=("Sans", 9, "bold"),
                    width=18,
                    anchor="w",
                ).pack(side="left", padx=(8, 0))
                tk.Label(
                    row,
                    text=cmd,
                    bg=PANEL,
                    fg=MUTED,
                    font=("Monospace", 8),
                    anchor="w",
                ).pack(side="left", padx=(6, 0), fill="x", expand=True)

                def _make_remove_mcp(i, sname):
                    def _remove():
                        del self.secrets["mcp"][i]
                        self._save_secrets()
                        # Best-effort deregister from Claude Code
                        try:
                            subprocess.run(
                                ["claude", "mcp", "remove", "-s", "user", sname],
                                capture_output=True,
                                timeout=8,
                            )
                        except Exception:
                            pass
                        self._refresh_keys_dialog()
                    return _remove

                tk.Button(
                    row,
                    text="Remove",
                    bg=PANEL,
                    fg="#e57373",
                    activebackground=PANEL_ALT,
                    activeforeground="#e57373",
                    relief="flat",
                    padx=6,
                    pady=2,
                    cursor="hand2",
                    command=_make_remove_mcp(idx, name),
                ).pack(side="right", padx=(0, 6))

