    def _list_ollama_models(self):
        """Return installed Ollama model names, [] if none, or None if Ollama
        is not reachable."""
        try:
            import urllib.request

            with urllib.request.urlopen(
                "http://localhost:11434/api/tags", timeout=1.5
            ) as resp:
                data = json.loads(resp.read().decode("utf-8"))
            return [m["name"] for m in data.get("models", []) if m.get("name")]
        except Exception:
            return None

    def connect_ollama_model(self, model, parent):
        """One-click connect a local Ollama model with full streaming support."""
        base = re.sub(r"[^a-z0-9]+", "-", model.lower()).strip("-") or "ollama"
        key = "ollama-" + base
        suffix = 2
        while key in self.agent_map:
            key = f"ollama-{base}-{suffix}"
            suffix += 1

        client = {
            "key": key,
            "label": model,
            "model": f"ollama_chat/{model}",  # For OllamaBackend to use
        }
        self.custom_clients.append(client)
        spec = {"key": key, "label": model, "color": "#10b981", "custom": True}
        self.agent_specs.append(spec)
        self.agent_map[key] = spec
        self.agent_settings[key] = {"model": "Default", "effort": "Default"}
        for workspace_id, workspace in self.workspaces.items():
            workspace["backends"][key] = OllamaBackend(self.events, client, workspace_id)
        self.agent_picker.configure(values=[item["key"] for item in self.agent_specs])
        self.config["custom_clients"] = self.custom_clients
        save_json(CONFIG_FILE, self.config)
        self.active_agent.set(key)
        if parent is not None:
            parent.destroy()
        self.on_agent_changed()
        self.status.set(f"Added {model}. Multi-turn streaming via Ollama.")

    def _register_custom_client(self, label, command, parent):
        """Validate and register a custom CLI client; shared by manual add and
        one-click Ollama connect."""
        label = clean_text(label)
        command = clean_text(command)
        if not label or not command:
            return
        try:
            executable = shlex.split(command.replace("{prompt}", "prompt"))[0]
        except (ValueError, IndexError):
            messagebox.showerror("Add custom CLI", "The command template is not valid.", parent=parent)
            return
        if not shutil.which(executable):
            messagebox.showerror(
                "Add custom CLI",
                f"'{executable}' was not found on this machine.",
                parent=parent,
            )
            return
        base = re.sub(r"[^a-z0-9]+", "-", label.lower()).strip("-") or "custom"
        key = "custom-" + base
        suffix = 2
        while key in self.agent_map:
            key = f"custom-{base}-{suffix}"
            suffix += 1
        client = {"key": key, "label": label, "command": command}
        self.custom_clients.append(client)
        spec = {"key": key, "label": label, "color": "#67e8f9", "custom": True}
        self.agent_specs.append(spec)
        self.agent_map[key] = spec
        self.agent_settings[key] = {"model": "Default", "effort": "Default"}
        for workspace_id, workspace in self.workspaces.items():
            workspace["backends"][key] = CustomCliBackend(
                self.events, client, workspace_id
            )
        self.agent_picker.configure(values=[item["key"] for item in self.agent_specs])
        self.config["custom_clients"] = self.custom_clients
        save_json(CONFIG_FILE, self.config)
        self.active_agent.set(key)
        if parent is not None:
            parent.destroy()
        self.on_agent_changed()
        self.status.set(f"Added {label}. Prompts will run through its local CLI command.")

    def remove_custom_client(self, key, parent):
        if self.busy and self.active_agent.get() == key:
            messagebox.showinfo(
                "Remove custom CLI",
                "Wait for the current turn to finish before removing this client.",
                parent=parent,
            )
            return
        for workspace in self.workspaces.values():
            backend = workspace["backends"].pop(key, None)
            if backend:
                backend.close()
        self.custom_clients = [
            client for client in self.custom_clients if client.get("key") != key
        ]
        self.agent_specs = [spec for spec in self.agent_specs if spec.get("key") != key]
        self.agent_map.pop(key, None)
        self.agent_settings.pop(key, None)
        self.config["custom_clients"] = self.custom_clients
        save_json(CONFIG_FILE, self.config)
        self.agent_picker.configure(values=[item["key"] for item in self.agent_specs])
        if self.active_agent.get() == key:
            self.active_agent.set("codex")
            self.on_agent_changed()
        parent.destroy()
        self.status.set("Custom client registration removed. Saved sessions were kept.")

    def launch_client_setup(self, command, dialog=None):
        if dialog is not None:
            dialog.destroy()
        terminals = (
            ("konsole", ["konsole", "-e", "bash", "-lc"]),
            ("gnome-terminal", ["gnome-terminal", "--", "bash", "-lc"]),
            ("xterm", ["xterm", "-e", "bash", "-lc"]),
        )
        script = f"{command}; printf '\\nSetup finished. Press Enter to close.\\n'; read"
        for executable, prefix in terminals:
            if shutil.which(executable):
                subprocess.Popen(prefix + [script], cwd=self.cwd.get())
                self.status.set("Client setup opened. Complete the vendor sign-in there.")
                return
        self.notebook.select(self.terminal_tab)
        self.terminal_shell.send(command + "\n")
        self.status.set("Client setup started in Terminal.")

    def show_session_menu(self, event):
        index = self.session_list.nearest(event.y)
        bounds = self.session_list.bbox(index)
        if not bounds or not (bounds[1] <= event.y < bounds[1] + bounds[3]):
            return
        self.session_list.selection_clear(0, "end")
        self.session_list.selection_set(index)
        self.session_list.activate(index)
        self.session_menu.tk_popup(event.x_root, event.y_root)

    def _agent_spec(self, key):
        return self.agent_map.get(key, {"key": key, "label": key.title(), "color": TEXT})

    def _deleted_bucket(self, agent_key):
        bucket = self.deleted_session_tombstones.setdefault(agent_key, {})
        bucket.setdefault("ids", [])
        bucket.setdefault("paths", [])
        return bucket

    def _record_deleted_session(self, session):
        agent_key = clean_text((session or {}).get("agent"))
        if agent_key not in self.agent_map:
            return
        bucket = self._deleted_bucket(agent_key)
        session_id = clean_text(
            (session or {}).get("source_session_id")
            or ((session or {}).get("backend") or {}).get("session_id")
            or ((session or {}).get("backend") or {}).get("thread_id")
        )
        path = clean_text((session or {}).get("source_path"))
        changed = False
        if session_id and session_id not in bucket["ids"]:
            bucket["ids"].append(session_id)
            changed = True
        if path and path not in bucket["paths"]:
            bucket["paths"].append(path)
            changed = True
        if changed:
            self.config["deleted_session_tombstones"] = self.deleted_session_tombstones
            save_json(CONFIG_FILE, self.config)

    def _session_is_deleted(self, session):
        agent_key = clean_text((session or {}).get("agent"))
        bucket = self.deleted_session_tombstones.get(agent_key) or {}
        deleted_ids = set(bucket.get("ids") or [])
        deleted_paths = set(bucket.get("paths") or [])
        session_id = clean_text(
            (session or {}).get("source_session_id")
            or ((session or {}).get("backend") or {}).get("session_id")
            or ((session or {}).get("backend") or {}).get("thread_id")
        )
        source_path = clean_text((session or {}).get("source_path"))
        return bool(
            (session_id and session_id in deleted_ids)
            or (source_path and source_path in deleted_paths)
        )

    def _filter_deleted_sessions(self, sessions):
        return [session for session in sessions if not self._session_is_deleted(session)]

    def _session_alias(self, session):
        return clean_text(self.session_aliases.get(session_alias_key(session), ""))

    def _display_session_title(self, session):
        title = clean_text(session.get("title") or session.get("preview") or "Untitled")
        _, visible_title = strip_session_context(title)
        if visible_title:
            title = visible_title
        elif title.lower().startswith(SESSION_CONTEXT_OPEN):
            title = clean_text(session.get("preview") or "Untitled")
        if session.get("origin") == "claude-terminal":
            return title
        alias = self._session_alias(session)
        if alias:
            return alias
        return title

    def _session_list_label(self, session):
        title = shorten(self._display_session_title(session), 48)
        timestamp = clean_text(session.get("updated_at"))
        try:
            moment = datetime.fromisoformat(timestamp.replace("Z", "+00:00")).astimezone()
            today = datetime.now().astimezone().date()
            if moment.date() == today:
                stamp = moment.strftime("%H:%M")
            else:
                stamp = moment.strftime("%b %d")
        except (ValueError, TypeError):
            stamp = ""
        return f"{stamp}  {title}" if stamp else title

    def _session_source_label(self, session):
        agent = self._agent_spec(session.get("agent"))["label"]
        backend = session.get("backend") or {}
        if clean_text(
            session.get("source_session_id")
            or backend.get("session_id")
            or backend.get("thread_id")
        ):
            return f"Connected to {agent} session"
        return f"New {agent} session"

    def _schedule_session_tooltip(self, event):
        if not self.visible_sessions:
            self._hide_session_tooltip()
            return
        index = self.session_list.nearest(event.y)
        bounds = self.session_list.bbox(index)
        if not bounds or not (bounds[1] <= event.y < bounds[1] + bounds[3]):
            self._hide_session_tooltip()
            return
        if index == self.session_tooltip_index:
            return
        self._hide_session_tooltip()
        self.session_tooltip_index = index
        self.session_tooltip_after = self.win.after(
            143, lambda: self._show_session_tooltip(index)
        )

    def _show_session_tooltip(self, index):
        self.session_tooltip_after = None
        if index != self.session_tooltip_index or index >= len(self.visible_sessions):
            return
        bounds = self.session_list.bbox(index)
        if not bounds:
            return
        session = self.visible_sessions[index]
        tooltip = tk.Toplevel(self.win)
        tooltip.overrideredirect(True)
        tooltip.attributes("-topmost", True)
        frame = tk.Frame(
            tooltip,
            bg="#202833",
            highlightbackground="#4b5b6b",
            highlightthickness=1,
            padx=12,
            pady=10,
        )
        frame.pack()
        tk.Label(
            frame,
            text=self._display_session_title(session),
            bg="#202833",
            fg=TEXT,
            justify="left",
            anchor="w",
            wraplength=560,
            font=("Sans", 10, "bold"),
        ).pack(anchor="w")
        tk.Label(
            frame,
            text=self._session_source_label(session),
            bg="#202833",
            fg=MUTED,
            justify="left",
            anchor="w",
        ).pack(anchor="w", pady=(4, 0))
        x = self.session_list.winfo_rootx() + self.session_list.winfo_width() + 8
        y = self.session_list.winfo_rooty() + bounds[1]
        screen_width = self.win.winfo_screenwidth()
        tooltip.update_idletasks()
        if x + tooltip.winfo_reqwidth() > screen_width - 12:
            x = max(12, self.session_list.winfo_rootx() - tooltip.winfo_reqwidth() - 8)
        tooltip.geometry(f"+{x}+{y}")
        self.session_tooltip = tooltip

    def _hide_session_tooltip(self):
        if self.session_tooltip_after is not None:
            self.win.after_cancel(self.session_tooltip_after)
            self.session_tooltip_after = None
        if self.session_tooltip is not None:
            self.session_tooltip.destroy()
            self.session_tooltip = None
        self.session_tooltip_index = None

    def _collect_artifact_paths(self, value, out):
        if isinstance(value, dict):
            for key, child in value.items():
                if key in {"path", "filePath", "file_path", "fileName", "file_name"}:
                    text = clean_text(child)
                    if text:
                        out.add(text)
                self._collect_artifact_paths(child, out)
        elif isinstance(value, list):
            for child in value:
                self._collect_artifact_paths(child, out)

    def _artifact_items_for_session(self, session):
        paths = set()
        directories = [self._artifact_directory(session)]
        legacy_raw = clean_text((session or {}).get("source_session_id"))
        if legacy_raw and legacy_raw != clean_text((session or {}).get("id")):
            legacy_label = (
                re.sub(r"[^A-Za-z0-9._-]+", "-", legacy_raw).strip("-")[:48]
                or "session"
            )
            legacy_key = (
                f"{legacy_label}-"
                f"{hashlib.sha1(legacy_raw.encode('utf-8')).hexdigest()[:8]}"
            )
            legacy_directory = os.path.join(ARTIFACTS_DIR, legacy_key)
            if os.path.isdir(legacy_directory):
                directories.append(legacy_directory)
        items = []
        for directory in directories:
            for name in sorted(os.listdir(directory), key=str.lower):
                path = os.path.join(directory, name)
                if os.path.isfile(path) and not any(
                    existing["path"] == path for existing in items
                ):
                    items.append(
                        {
                            "path": path,
                            "label": name,
                            "stored": True,
                        }
                    )
        for turn in session.get("turns") or []:
            for item in turn.get("items") or []:
                if item.get("type") == "fileChange":
                    for change in item.get("changes") or []:
                        path = clean_text(change.get("path") or change.get("filePath") or change.get("file_path"))
                        if path:
                            paths.add(path)
                self._collect_artifact_paths(item, paths)
        for path in sorted(paths, key=lambda p: p.lower()):
            resolved = os.path.expanduser(path)
            if not os.path.isabs(resolved):
                resolved = os.path.join(session.get("cwd") or self.cwd.get(), resolved)
            resolved = os.path.abspath(resolved)
            if not os.path.exists(resolved):
                continue
            if any(existing["path"] == resolved for existing in items):
                continue
            items.append(
                {
                    "path": resolved,
                    "label": os.path.basename(resolved) or resolved,
                    "stored": False,
                }
            )
        return items

    def _set_session_alias(self, session, alias):
        key = session_alias_key(session)
        alias = clean_text(alias)
        if alias:
            self.session_aliases[key] = alias
        else:
            self.session_aliases.pop(key, None)
        if session.get("origin", "local") == "local":
            session["title"] = alias or clean_text(session.get("title") or session.get("preview") or "Untitled")
            self.store.save(session)
        self.config["session_aliases"] = self.session_aliases
        save_json(CONFIG_FILE, self.config)

    def _refresh_project_list(self):
