            if not selection or not queued:
                return
            index = int(selection[0])
            if index >= len(queued):
                return
            item = queued[index]
            prompt = clean_text(item.get("prompt"))
            attachments = [clean_text(path) for path in item.get("attachments") or [] if clean_text(path)]
            detail_title.configure(text=f"Queued item {index + 1} — editable")
            meta = (
                f"{len(prompt)} characters · {len(attachments)} attachment"
                f"{'s' if len(attachments) != 1 else ''} · edit below, then Save edit"
            )
            if attachments:
                meta += "\nAttachments: " + ", ".join(os.path.basename(p) for p in attachments)
            detail_meta.configure(text=meta)
            # It hasn't been sent yet, so let the user fix it in place rather than
            # delete + re-queue. Stays editable (state normal).
            detail_text.configure(state="normal")
            detail_text.delete("1.0", "end")
            detail_text.insert("1.0", prompt)

        def save_edit():
            selection = queue_list.curselection()
            queued = list(workspace.get("queued_prompts") or [])
            if not selection or not queued:
                return
            index = int(selection[0])
            if index >= len(queued):
                return
            new_prompt = clean_text(detail_text.get("1.0", "end"))
            if not new_prompt:
                self.status.set("Queued prompt can't be empty — use Delete instead.")
                return
            queued[index]["prompt"] = new_prompt
            workspace["queued_prompts"] = queued
            self.queued_prompts = list(queued)
            self._save_active_workspace()
            self._schedule_workspace_config_save(immediate=True)
            self._update_queue_indicator()
            render_queue()
            if 0 <= index < queue_list.size():
                queue_list.selection_clear(0, "end")
                queue_list.selection_set(index)
                show_selected()
            self.status.set(f"Queued item {index + 1} updated.")

        def delete_selected():
            selection = queue_list.curselection()
            queued = list(workspace.get("queued_prompts") or [])
            if not selection or not queued:
                return
            index = int(selection[0])
            if index >= len(queued):
                return
            queued.pop(index)
            workspace["queued_prompts"] = queued
            self.queued_prompts = list(queued)
            self._save_active_workspace()
            self._schedule_workspace_config_save(immediate=True)
            self._update_queue_indicator()
            render_queue()

        def clear_queue():
            queued = list(workspace.get("queued_prompts") or [])
            if not queued:
                return
            workspace["queued_prompts"] = []
            self.queued_prompts = []
            self._save_active_workspace()
            self._schedule_workspace_config_save(immediate=True)
            self._update_queue_indicator()
            render_queue()

        queue_list.bind("<<ListboxSelect>>", show_selected)

        button_row = tk.Frame(body, bg=BG)
        button_row.pack(fill="x", pady=(12, 0))
        tk.Button(
            button_row,
            text="Save edit",
            command=save_edit,
            bg=ACCENT,
            fg="white",
            activebackground=SIDEBAR_SEL,
            activeforeground="white",
            relief="flat",
            padx=12,
            pady=6,
            cursor="hand2",
        ).pack(side="left")
        tk.Button(
            button_row,
            text="Delete selected",
            command=delete_selected,
            bg="#7f1d1d",
            fg="white",
            activebackground="#991b1b",
            activeforeground="white",
            relief="flat",
            padx=12,
            pady=6,
            cursor="hand2",
        ).pack(side="right")
        tk.Button(
            button_row,
            text="Clear queue",
            command=clear_queue,
            bg=PANEL,
            fg=TEXT,
            activebackground=SIDEBAR_SEL,
            activeforeground=TEXT,
            relief="flat",
            padx=12,
            pady=6,
            cursor="hand2",
        ).pack(side="right", padx=(0, 8))
        tk.Button(
            button_row,
            text="Close",
            command=dialog.destroy,
            bg=PANEL,
            fg=TEXT,
            activebackground=SIDEBAR_SEL,
            activeforeground=TEXT,
            relief="flat",
            padx=12,
            pady=6,
            cursor="hand2",
        ).pack(side="right", padx=(0, 8))

        def on_close():
            if self.queue_dialog is dialog:
                self.queue_dialog = None
            dialog.destroy()

        dialog.bind("<Escape>", lambda _e: on_close())
        dialog.protocol("WM_DELETE_WINDOW", on_close)
        dialog.update_idletasks()
        x = self.win.winfo_rootx() + (self.win.winfo_width() - dialog.winfo_reqwidth()) // 2
        y = self.win.winfo_rooty() + (self.win.winfo_height() - dialog.winfo_reqheight()) // 3
        dialog.geometry(f"+{max(0, x)}+{max(0, y)}")
        dialog._refresh_queue_render = render_queue
        render_queue()

    def _active_model_alias(self, workspace):
        agent = clean_text(workspace.get("agent")) or clean_text(self.active_agent.get())
        if agent == "claude":
            live = clean_text(workspace.get("live_model")) or clean_text(
                (workspace.get("current_session") or {}).get("backend", {}).get("model") or ""
            )
            alias = claude_model_alias(live).title()
            return alias if alias != "Default" else "Claude"
        spec = self._agent_spec(agent)
        return clean_text(spec.get("label")) or agent.title()

    def refresh_prompt_state(self):
        workspace = self.workspaces.get(self.active_workspace_id)
        if not workspace or self.finalizing_close:
            return
        self._update_worker_indicator()
        self._update_queue_indicator()
        token_text = format_token_usage(workspace.get("last_token_usage") or self.last_token_usage)
        if self.pending_user_input:
            text = "Awaiting your reply"
            bg, fg = "#3b1d4a", "#e9a8ff"
        elif self.busy or workspace.get("busy"):
            started = float(workspace.get("turn_started_at") or 0.0)
            last_event = float(workspace.get("last_event_at") or 0.0)
            elapsed = format_duration(time.monotonic() - started) if started else "0s"
            silence = time.monotonic() - last_event if last_event else 0.0
            queued = len(workspace.get("queued_prompts") or [])
            queue_text = f" · {queued} queued" if queued else ""
            live_tokens = int(workspace.get("live_token_count") or self.live_token_count or 0)
            token_suffix = (
                f" · streamed ~{format_token_count(live_tokens)} out"
                if live_tokens > 0
                else (f" · {token_text}" if token_text else "")
            )
            model = self._active_model_alias(workspace)
            if silence >= TURN_STALLED_SECONDS:
                text = f"{model} Working · {elapsed}{token_suffix}{queue_text}"
                bg, fg = "#4a2b0b", "#fed7aa"
            else:
                text = f"{model} Working · {elapsed}{token_suffix}{queue_text}"
                bg, fg = "#3b2c0b", "#facc15"
        else:
            # The green activity badge already shows "Ready"; don't duplicate the
            # word here — show only the token / queue readout (blank when idle and
            # no turn has run yet).
            queued = len(workspace.get("queued_prompts") or [])
            parts = []
            if token_text:
                parts.append(token_text)
            if queued:
                parts.append(f"{queued} queued")
            text = " · ".join(parts)
            bg, fg = "#101824", "#cbd5e1"
        self.prompt_state_text.set(text)
        self.prompt_state_label.configure(bg=bg, fg=fg)
        self.win.after(1000, self.refresh_prompt_state)

    def animate_activity(self):
        if self.activity_state == "working":
            dots = "." * ((self.activity_frame % 3) + 1)
            self.activity_dots.set(dots)
            self.activity_frame += 1
        else:
            self.activity_dots.set("")
        self.win.after(350, self.animate_activity)

    def update_context_indicator(self, context=None):
        context = context or {}
        used = int(context.get("used") or 0)
        limit = int(context.get("limit") or 0)
        compact_count = int(context.get("compact_count") or 0)
        if used <= 0 or limit <= 0:
            self.context_text.set("Context Limit --")
            bg, fg, thumb = "#24303c", "#cbd5e1", "#64748b"
        else:
            percent = min(100, round(used * 100 / limit))
            used_label = f"{used / 1_000_000:.1f}M" if used >= 1_000_000 else f"{round(used / 1000)}K"
            limit_label = f"{limit // 1_000_000}M" if limit >= 1_000_000 else f"{limit // 1000}K"
            compact_label = f" · compacted {compact_count}×" if compact_count else ""
            self.context_text.set(
                f"Context Limit {percent}% · {used_label}/{limit_label}{compact_label}"
            )
            if percent < 40:
                bg, fg, thumb = "#16351f", "#bbf7d0", "#22c55e"
            elif percent < 60:
                bg, fg, thumb = "#3b350b", "#fef08a", "#eab308"
            elif percent < 80:
                bg, fg, thumb = "#4a2b0b", "#fed7aa", "#f97316"
            else:
                bg, fg, thumb = "#4a1d1d", "#fecaca", "#ef4444"
        self.context_badge.configure(bg=bg, fg=fg)
        self.chat.vbar.configure(background=thumb, activebackground=fg)
        percent = min(100, round(used * 100 / limit)) if used > 0 and limit > 0 else 0
        handoff_available = percent >= CONTEXT_WARNING_PERCENT or compact_count > 0
        self.topbar_handoff_btn.configure(
            state="normal" if handoff_available else "disabled",
            cursor="hand2" if handoff_available else "arrow",
            bg="#c2410c" if handoff_available else "#24303c",
            fg="white" if handoff_available else "#64748b",
            activebackground="#ea580c",
        )
        if handoff_available:
            if percent >= CONTEXT_CRITICAL_PERCENT:
                self.context_warning.configure(bg="#4a1d1d")
                self.context_warning_text.set(
                    f"Context is {percent}% full. Response quality and recall may degrade. "
                    "Hand off now to preserve the full working history."
                )
                self.topbar_handoff_btn.configure(
                    bg="#b91c1c", activebackground="#dc2626"
                )
                for child in self.context_warning.winfo_children():
                    if isinstance(child, tk.Label):
                        child.configure(bg="#4a1d1d", fg="#fecaca")
            elif compact_count > 0 and percent < CONTEXT_WARNING_PERCENT:
                self.context_warning.configure(bg="#3b2c0b")
                self.context_warning_text.set(
                    f"This session has compacted {compact_count}×. The active window is "
                    f"{percent}% full, but older detail now depends on a summary. Hand Off "
                    "is available if you want a lossless continuation packet."
                )
                for child in self.context_warning.winfo_children():
                    if isinstance(child, tk.Label):
                        child.configure(bg="#3b2c0b", fg="#fef3c7")
            else:
                self.context_warning.configure(bg="#4a2b0b")
                self.context_warning_text.set(
                    f"Context is {percent}% full. A fresh session is recommended before "
                    "quality begins to decline."
                )
                for child in self.context_warning.winfo_children():
                    if isinstance(child, tk.Label):
                        child.configure(bg="#4a2b0b", fg="#ffedd5")
            self.context_warning.grid(row=0, column=0, sticky="ew", pady=(0, 3))
        else:
            self.context_warning.grid_remove()

    def _display_usage(self, usage):
        windows = usage.get("windows") or []
        if not windows:
            self.usage_text.set("Usage: --")
            self.usage_badge.configure(bg="#1a2432", fg="#dbeafe")
            return
        shown = [
            f"{int(window.get('used_percent') or 0)}% {window.get('label')}"
            for window in windows
            if window.get("label") in {"5h", "week"}
        ]
        if not shown:
            shown = [
                f"{int(window.get('used_percent') or 0)}% {window.get('label')}"
                for window in windows[:2]
            ]
        self.usage_text.set("Usage: " + " · ".join(shown))
        peak = max(int(window.get("used_percent") or 0) for window in windows)
        if peak >= 90:
            colors = ("#4a1d1d", "#fecaca")
        elif peak >= 70:
            colors = ("#4a2b0b", "#fed7aa")
        else:
            colors = ("#16351f", "#bbf7d0")
        self.usage_badge.configure(bg=colors[0], fg=colors[1])
        # Update the limits popover if it is open
        populate = getattr(self, "_limits_popover_populate", None)
        if callable(populate):
            populate(usage)

    def refresh_usage(self, manual=True):
        workspace = self.workspaces.get(self.active_workspace_id)
        if not workspace:
            return
        agent = workspace.get("agent")
        if agent not in {"claude", "codex"}:
            if manual:
                self.status.set(
                    f"Account-limit telemetry is not available for "
                    f"{self._agent_spec(agent)['label']}."
                )
            return
        if workspace.get("usage_refreshing"):
            if manual:
                cached_usage = workspace.get("usage") or {}
                if cached_usage:
                    self._display_usage(cached_usage)
                self.status.set(
                    f"{self._agent_spec(agent)['label']} limits are already refreshing…"
                )
            return
        cached_usage = workspace.get("usage") or {}
        if cached_usage:
            self._display_usage(cached_usage)
        workspace["usage_refreshing"] = True
        if manual:
            if cached_usage:
                self.status.set(
                    f"Refreshing {self._agent_spec(agent)['label']} account limits in the background…"
                )
            else:
                self.status.set(
                    f"Loading {self._agent_spec(agent)['label']} account limits…"
                )
        session = workspace.get("current_session") or {}
        source_path = clean_text(session.get("source_path"))
        workspace_id = workspace["id"]

        def load():
            usage = (
                claude_usage_limits()
                if agent == "claude"
                else codex_usage_limits(source_path)
            )
            self.events.put(
                {
                    "kind": "usage_updated",
                    "workspace_id": workspace_id,
                    "usage": usage,
                    "manual": manual,
                }
            )

        threading.Thread(target=load, daemon=True).start()

    def poll_usage(self):
        if self.finalizing_close:
            return
        self.refresh_usage(manual=False)
        self.win.after(90000, self.poll_usage)

    def _open_limits_popover(self):
        """Open a small popover below the Limits badge showing reset times."""
        # Dismiss any existing popover
        if hasattr(self, "_limits_popover") and self._limits_popover and self._limits_popover.winfo_exists():
            self._limits_popover.destroy()
            self._limits_popover = None
            return
        pop = tk.Toplevel(self.win)
        pop.overrideredirect(True)
        pop.configure(bg=PANEL, highlightbackground=BORDER, highlightthickness=1)
        self._limits_popover = pop

        tk.Label(
            pop,
            text="Account Usage",
            bg=PANEL,
            fg=TEXT,
            font=("Sans", 10, "bold"),
            anchor="w",
            padx=10,
            pady=6,
        ).pack(fill="x")
        tk.Frame(pop, bg=BORDER, height=1).pack(fill="x")

        body = tk.Frame(pop, bg=PANEL)
        body.pack(fill="x", padx=10, pady=8)
        self._limits_popover_body = body

        def _populate_limits_body(usage):
            if not hasattr(self, "_limits_popover_body"):
                return
            if not self._limits_popover_body.winfo_exists():
                return
            b = self._limits_popover_body
            for child in b.winfo_children():
                child.destroy()
            windows = usage.get("windows") or []
            if usage.get("error") and not windows:
                tk.Label(
                    b,
                    text=usage.get("error", "No limit data available."),
                    bg=PANEL,
                    fg=MUTED,
                    font=("Sans", 9),
                    anchor="w",
                    wraplength=280,
                    justify="left",
                ).pack(fill="x", pady=(0, 4))
            else:
                for window in windows:
                    lbl = clean_text(window.get("label")) or ""
                    pct = int(window.get("used_percent") or 0)
                    reset = clean_text(window.get("reset")) or "—"
                    row = tk.Frame(b, bg=PANEL)
                    row.pack(fill="x", pady=2)
                    tk.Label(
                        row,
                        text=f"{lbl}:",
                        bg=PANEL,
                        fg=MUTED,
                        font=("Sans", 9),
                        anchor="w",
                        width=10,
                    ).pack(side="left")
                    tk.Label(
                        row,
                        text=f"{pct}% used · resets {reset}",
                        bg=PANEL,
                        fg=TEXT,
                        font=("Sans", 9),
                        anchor="w",
                    ).pack(side="left", fill="x", expand=True)
            # Re-fit the popover to its content (usage arrives async, so the body can
            # grow after the window was first sized — otherwise the buttons get clipped).
            try:
                pop.update_idletasks()
                pop.geometry(
                    f"{max(pop.winfo_reqwidth(), 300)}x{pop.winfo_reqheight()}"
                )
            except tk.TclError:
                pass

        # Store the populator so _display_usage can call it
        self._limits_popover_populate = _populate_limits_body

        # Show cached data immediately if available
        workspace = self.workspaces.get(self.active_workspace_id) or {}
        cached = workspace.get("usage") or {}
        if cached.get("windows"):
            _populate_limits_body(cached)
        else:
            tk.Label(
                body,
                text="Loading…",
                bg=PANEL,
                fg=MUTED,
                font=("Sans", 9),
                anchor="w",
            ).pack(fill="x")

        tk.Frame(pop, bg=BORDER, height=1).pack(fill="x")
        btn_row = tk.Frame(pop, bg=PANEL)
        btn_row.pack(fill="x", padx=8, pady=6)
        tk.Button(
            btn_row,
            text="Refresh",
            command=lambda: self.refresh_usage(manual=True),
            bg=PANEL_ALT,
            fg=MUTED,
            activebackground=SIDEBAR_SEL,
            activeforeground=TEXT,
            font=("Sans", 9),
            relief="flat",
            padx=10,
            pady=4,
            cursor="hand2",
        ).pack(side="left")
        tk.Button(
            btn_row,
            text="Close",
            command=pop.destroy,
            bg=PANEL_ALT,
            fg=MUTED,
            activebackground=SIDEBAR_SEL,
            activeforeground=TEXT,
            font=("Sans", 9),
            relief="flat",
            padx=10,
            pady=4,
            cursor="hand2",
        ).pack(side="right")

        # Position below the badge
        self.win.update_idletasks()
        bx = self.usage_badge.winfo_rootx()
        by = self.usage_badge.winfo_rooty() + self.usage_badge.winfo_height() + 4
        pop.update_idletasks()
        pw = pop.winfo_reqwidth()
        pop.geometry(f"{max(pw, 300)}x{pop.winfo_reqheight()}+{bx}+{by}")
        pop.lift()
        pop.focus_force()

        def _dismiss(event=None):
            if pop.winfo_exists():
                pop.destroy()
            self._limits_popover = None
            self._limits_popover_populate = None
            self._limits_popover_body = None

        pop.bind("<FocusOut>", _dismiss)
        pop.bind("<Escape>", _dismiss)

        # Kick off a refresh so the popover gets live data
        self.refresh_usage(manual=False)

    def on_notebook_tab_changed(self, _event=None):
        selected = self.notebook.select()
        if selected == str(self.terminal_tab):
            self.composer.grid_remove()
            self.terminal.focus_set()
        else:
            self.composer.grid()
            # Any non-terminal tab (Conversation, Work Log, Artifacts, Spawned): the
            # composer owns the keyboard so everything you type goes to the conversation.
            self.input.focus_set()
        if hasattr(self, "spawned_tab") and selected == str(self.spawned_tab):
            self._refresh_spawned_tab()

    def _scale_font_spec(self, spec, delta):
        """Return `spec` with its size nudged by `delta`, preserving family and
        bold/italic. Powers Ctrl+wheel text zoom."""
        import tkinter.font as tkfont
        try:
            actual = tkfont.Font(font=spec).actual()
        except tk.TclError:
            return spec
        size = int(actual.get("size") or 11)
        # Tk sizes: positive = points, negative = pixels. Keep the sign, clamp magnitude.
        sign = -1 if size < 0 else 1
        new_mag = max(6, min(72, abs(size) + delta))
        styles = []
        if actual.get("weight") == "bold":
            styles.append("bold")
        if actual.get("slant") == "italic":
            styles.append("italic")
        return (actual.get("family") or "Sans", sign * new_mag, *styles)

    def _zoom_text_widget(self, widget, delta):
        """Nudge a Text widget's base font and every font-bearing tag by `delta`,
        so the whole view scales uniformly (relative sizes preserved)."""
        try:
            widget.configure(font=self._scale_font_spec(widget.cget("font"), delta))
            for tag in widget.tag_names():
                spec = clean_text(widget.tag_cget(tag, "font"))
                if spec:
                    widget.tag_configure(tag, font=self._scale_font_spec(spec, delta))
        except tk.TclError:
            pass

    def _on_ctrl_wheel_zoom(self, event, widget):
        # Linux/X11 wheel = Button-4 (up) / Button-5 (down); Win/Mac use event.delta.
        up = getattr(event, "num", 0) == 4 or getattr(event, "delta", 0) > 0
        self._zoom_text_widget(widget, 1 if up else -1)
        return "break"  # zoom instead of scrolling while Ctrl is held

    def _enable_text_zoom(self, widget):
        for seq in ("<Control-MouseWheel>", "<Control-Button-4>", "<Control-Button-5>"):
            widget.bind(seq, lambda e, w=widget: self._on_ctrl_wheel_zoom(e, w))

    def scroll_chat_to_latest(self):
        self._flush_deferred_chat_updates()
        self.chat.see("end")
        self.chat.yview_moveto(1.0)
        self.chat_updates_pending = False
        self._update_chat_update_indicator()
        self._save_active_workspace()

    def scroll_work_to_latest(self):
        # Jump to the live (last) page, then to its end.
        if hasattr(self, "work_pages") and self.work_pages:
            self._show_work_page(len(self.work_pages) - 1)
        try:
            self.work.see("end")
            self.work.yview_moveto(1.0)
        except tk.TclError:
            pass

    def _chat_is_at_bottom(self):
        try:
            return self.chat.yview()[1] >= 0.995
        except tk.TclError:
            return True

    def _update_chat_update_indicator(self):
        if not hasattr(self, "chat_bottom_btn"):
            return
        if self.chat_updates_pending:
            self.chat_bottom_btn.configure(
                text="↓ New",
                bg="#1d4f7a",
                fg="white",
            )
        else:
            self.chat_bottom_btn.configure(
                text="↓",
                bg=PANEL_ALT,
                fg=TEXT,
            )

    def _sync_chat_update_indicator(self):
        if self._chat_is_at_bottom() and self.chat_updates_pending:
            self.chat_updates_pending = False
            self._update_chat_update_indicator()
            self._save_active_workspace()

    def _finish_chat_append(self, was_at_bottom):
        # Re-check current position after insert to guard against
        # the user scrolling away between the pre-insert check and here.
        if was_at_bottom and not self.chat_updates_pending:
            try:
                now_at_bottom = self.chat.yview()[1] >= 0.995
            except tk.TclError:
                now_at_bottom = True
            if now_at_bottom:
                self.chat.see("end")
                return
        self.chat_updates_pending = True
        self._update_chat_update_indicator()

    def _flush_deferred_chat_updates(self):
        if not self.deferred_chat_updates:
            return
        updates = self.deferred_chat_updates
        self.deferred_chat_updates = []
        self.flushing_deferred_chat = True
        try:
            for update in updates:
                kind = update.get("kind")
                if kind == "chat":
                    self.append_chat(
                        update.get("speaker"),
                        update.get("text"),
                        update.get("tag", "assistant"),
                    )
                elif kind == "report":
                    self.append_report(
                        update.get("title"),
                        update.get("text"),
                    )
                elif kind == "stream":
                    self._append_stream_visual(
                        update.get("text", ""),
                        update.get("speaker", "AGENT"),
                        update.get("start", False),
                    )
                elif kind == "separator":
                    self.chat.configure(state="normal")
                    self.chat.insert("end", "\n\n")
                    self.chat.configure(state="disabled")
        finally:
            self.flushing_deferred_chat = False

