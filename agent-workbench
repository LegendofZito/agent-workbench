    def _load_secrets(self):
        """Load secrets.json into self.secrets; initialise tracking set."""
        self.secrets = load_json(SECRETS_FILE, {"keys": [], "mcp": []})
        if "keys" not in self.secrets:
            self.secrets["keys"] = []
        if "mcp" not in self.secrets:
            self.secrets["mcp"] = []
        if not hasattr(self, "_injected_env"):
            self._injected_env = set()

    def _save_secrets(self):
        """Persist self.secrets to SECRETS_FILE with mode 0600."""
        save_json(SECRETS_FILE, self.secrets)
        try:
            os.chmod(SECRETS_FILE, 0o600)
        except OSError:
            pass

    def _apply_secrets_env(self):
        """Inject/un-inject env vars based on current self.secrets[keys]."""
        if not hasattr(self, "_injected_env"):
            self._injected_env = set()
        # Build the desired inject map
        desired = {}
        for entry in self.secrets.get("keys", []):
            if entry.get("inject") and entry.get("env") and entry.get("value"):
                desired[entry["env"]] = entry["value"]
        # Remove vars we previously set that are no longer inject=True
        for env_var in list(self._injected_env):
            if env_var not in desired:
                os.environ.pop(env_var, None)
                self._injected_env.discard(env_var)
        # Set/update desired vars
        for env_var, value in desired.items():
            os.environ[env_var] = value
            self._injected_env.add(env_var)

    def _create_backend_set(self, workspace_id):
        backends = {
            "codex": CodexBackend(self.events, workspace_id),
            "claude": ClaudeBackend(self.events, workspace_id),
            "gemini": GeminiBackend(self.events, workspace_id),
        }
        for client in self.custom_clients:
            key = clean_text(client.get("key"))
            if key in self.agent_map:
                # Use OllamaBackend for Ollama models, CustomCliBackend for others
                if "ollama_chat" in client.get("model", ""):
                    backends[key] = OllamaBackend(self.events, client, workspace_id)
                else:
                    backends[key] = CustomCliBackend(self.events, client, workspace_id)
        return backends

