        initial_settings = self.agent_settings[self.active_agent.get()]
        self.selected_model = tk.StringVar(master=self.win, value=initial_settings["model"])
        self.selected_effort = tk.StringVar(master=self.win, value=initial_settings["effort"])
        self.status = tk.StringVar(master=self.win, value="Starting…")
        self.activity_text = tk.StringVar(master=self.win, value="Starting")
        self.worker_text = tk.StringVar(master=self.win, value="Worker --")
