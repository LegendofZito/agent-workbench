    def _deleted_bucket(self, agent_key):
        bucket = self.deleted_session_tombstones.setdefault(agent_key, {})
        bucket.setdefault("ids", [])
        bucket.setdefault("paths", [])
        return bucket

    def _record_deleted_session(self, session):
        agent_key = clean_text((session or {}).get("agent"))
        if agent_key not in self.agent_map:
            return
        bucket = self._deleted_bucket(agent_key)
        session_id = clean_text(
            (session or {}).get("source_session_id")
            or ((session or {}).get("backend") or {}).get("session_id")
            or ((session or {}).get("backend") or {}).get("thread_id")
        )
        path = clean_text((session or {}).get("source_path"))
        changed = False
        if session_id and session_id not in bucket["ids"]:
            bucket["ids"].append(session_id)
            changed = True
        if path and path not in bucket["paths"]:
            bucket["paths"].append(path)
            changed = True
        if changed:
            self.config["deleted_session_tombstones"] = self.deleted_session_tombstones
            save_json(CONFIG_FILE, self.config)

    def _session_is_deleted(self, session):
        agent_key = clean_text((session or {}).get("agent"))
        bucket = self.deleted_session_tombstones.get(agent_key) or {}
        deleted_ids = set(bucket.get("ids") or [])
        deleted_paths = set(bucket.get("paths") or [])
        session_id = clean_text(
            (session or {}).get("source_session_id")
            or ((session or {}).get("backend") or {}).get("session_id")
            or ((session or {}).get("backend") or {}).get("thread_id")
        )
        source_path = clean_text((session or {}).get("source_path"))
        return bool(
            (session_id and session_id in deleted_ids)
            or (source_path and source_path in deleted_paths)
        )

    def _session_alias(self, session):
        return clean_text(self.session_aliases.get(session_alias_key(session), ""))

    def _display_session_title(self, session):
        title = clean_text(session.get("title") or session.get("preview") or "Untitled")
        _, visible_title = strip_session_context(title)
        if visible_title:
            title = visible_title
        elif title.lower().startswith(SESSION_CONTEXT_OPEN):
            title = clean_text(session.get("preview") or "Untitled")
        if session.get("origin") == "claude-terminal":
            return title
        alias = self._session_alias(session)
        if alias:
            return alias
        return title

    def _session_list_label(self, session):
        title = shorten(self._display_session_title(session), 48)
        timestamp = clean_text(session.get("updated_at"))
        try:
            moment = datetime.fromisoformat(timestamp.replace("Z", "+00:00")).astimezone()
            today = datetime.now().astimezone().date()
            if moment.date() == today:
                stamp = moment.strftime("%H:%M")
            else:
                stamp = moment.strftime("%b %d")
        except (ValueError, TypeError):
            stamp = ""
        return f"{stamp}  {title}" if stamp else title

    def _session_source_label(self, session):
        agent = self._agent_spec(session.get("agent"))["label"]
        backend = session.get("backend") or {}
        if clean_text(
            session.get("source_session_id")
            or backend.get("session_id")
            or backend.get("thread_id")
        ):
            return f"Connected to {agent} session"
        return f"New {agent} session"

    def _schedule_session_tooltip(self, event):
        if not self.visible_sessions:
            self._hide_session_tooltip()
            return
        index = self.session_list.nearest(event.y)
        bounds = self.session_list.bbox(index)
        if not bounds or not (bounds[1] <= event.y < bounds[1] + bounds[3]):
            self._hide_session_tooltip()
            return
        if index == self.session_tooltip_index:
            return
        self._hide_session_tooltip()
        self.session_tooltip_index = index
        self.session_tooltip_after = self.win.after(
            143, lambda: self._show_session_tooltip(index)
        )

    def _show_session_tooltip(self, index):
        self.session_tooltip_after = None
        if index != self.session_tooltip_index or index >= len(self.visible_sessions):
            return
        bounds = self.session_list.bbox(index)
        if not bounds:
            return
        session = self.visible_sessions[index]
        tooltip = tk.Toplevel(self.win)
        tooltip.overrideredirect(True)
        tooltip.attributes("-topmost", True)
        frame = tk.Frame(
            tooltip,
            bg="#202833",
            highlightbackground="#4b5b6b",
            highlightthickness=1,
            padx=12,
            pady=10,
        )
        frame.pack()
        tk.Label(
            frame,
            text=self._display_session_title(session),
            bg="#202833",
            fg=TEXT,
            justify="left",
            anchor="w",
            wraplength=560,
            font=("Sans", 10, "bold"),
        ).pack(anchor="w")
        tk.Label(
            frame,
            text=self._session_source_label(session),
            bg="#202833",
            fg=MUTED,
            justify="left",
            anchor="w",
        ).pack(anchor="w", pady=(4, 0))
        x = self.session_list.winfo_rootx() + self.session_list.winfo_width() + 8
        y = self.session_list.winfo_rooty() + bounds[1]
        screen_width = self.win.winfo_screenwidth()
        tooltip.update_idletasks()
        if x + tooltip.winfo_reqwidth() > screen_width - 12:
            x = max(12, self.session_list.winfo_rootx() - tooltip.winfo_reqwidth() - 8)
        tooltip.geometry(f"+{x}+{y}")
        self.session_tooltip = tooltip

    def _hide_session_tooltip(self):
        if self.session_tooltip_after is not None:
            self.win.after_cancel(self.session_tooltip_after)
            self.session_tooltip_after = None
        if self.session_tooltip is not None:
            self.session_tooltip.destroy()
            self.session_tooltip = None
        self.session_tooltip_index = None

    def _collect_artifact_paths(self, value, out):
        if isinstance(value, dict):
            for key, child in value.items():
                if key in {"path", "filePath", "file_path", "fileName", "file_name"}:
                    text = clean_text(child)
                    if text:
                        out.add(text)
                self._collect_artifact_paths(child, out)
        elif isinstance(value, list):
            for child in value:
                self._collect_artifact_paths(child, out)

    def _artifact_items_for_session(self, session):
        paths = set()
        directories = [self._artifact_directory(session)]
        legacy_raw = clean_text((session or {}).get("source_session_id"))
        if legacy_raw and legacy_raw != clean_text((session or {}).get("id")):
            legacy_label = (
                re.sub(r"[^A-Za-z0-9._-]+", "-", legacy_raw).strip("-")[:48]
                or "session"
            )
            legacy_key = (
                f"{legacy_label}-"
                f"{hashlib.sha1(legacy_raw.encode('utf-8')).hexdigest()[:8]}"
            )
            legacy_directory = os.path.join(ARTIFACTS_DIR, legacy_key)
            if os.path.isdir(legacy_directory):
                directories.append(legacy_directory)
        items = []
        for directory in directories:
            for name in sorted(os.listdir(directory), key=str.lower):
                path = os.path.join(directory, name)
                if os.path.isfile(path) and not any(
                    existing["path"] == path for existing in items
                ):
                    items.append(
                        {
                            "path": path,
                            "label": name,
                            "stored": True,
                        }
                    )
        for turn in session.get("turns") or []:
            for item in turn.get("items") or []:
                if item.get("type") == "fileChange":
                    for change in item.get("changes") or []:
                        path = clean_text(change.get("path") or change.get("filePath") or change.get("file_path"))
                        if path:
                            paths.add(path)
                self._collect_artifact_paths(item, paths)
        for path in sorted(paths, key=lambda p: p.lower()):
            resolved = os.path.expanduser(path)
            if not os.path.isabs(resolved):
                resolved = os.path.join(session.get("cwd") or self.cwd.get(), resolved)
            resolved = os.path.abspath(resolved)
            if not os.path.exists(resolved):
                continue
            if any(existing["path"] == resolved for existing in items):
                continue
            items.append(
                {
                    "path": resolved,
                    "label": os.path.basename(resolved) or resolved,
                    "stored": False,
                }
            )
        return items

    def _set_session_alias(self, session, alias):
        key = session_alias_key(session)
        alias = clean_text(alias)
        if alias:
            self.session_aliases[key] = alias
        else:
            self.session_aliases.pop(key, None)
        if session.get("origin", "local") == "local":
            session["title"] = alias or clean_text(session.get("title") or session.get("preview") or "Untitled")
            self.store.save(session)
        self.config["session_aliases"] = self.session_aliases
        save_json(CONFIG_FILE, self.config)

    def _refresh_project_list(self):
        if hasattr(self, "cwd_entry"):
            self.cwd_entry.configure(values=self.recent_projects)

    def choose_cwd(self):
        chosen = filedialog.askdirectory(initialdir=self.cwd.get(), parent=self.win)
        if chosen:
            self.cwd.set(chosen)
            self._remember_project(chosen)
            self.refresh_sessions()

    def _remember_project(self, cwd):
        cwd = cwd.rstrip(os.sep)
        self.recent_projects = [cwd] + [item for item in self.recent_projects if item != cwd]
        self.recent_projects = self.recent_projects[:10]
        self._refresh_project_list()

    def on_agent_changed(self):
        # Always allow switching — even while a turn is running. We don't touch the
        # current session/conversation or interrupt the turn (the backend keeps going;
        # sending while busy still queues). Switching just shows the chosen agent's
        # sessions so you can click one to open it in a new tab on the fly.
        requested_agent = self.active_agent.get()
        settings = self.agent_settings.get(requested_agent) or self._default_settings_for(
            requested_agent
        )
        self.selected_model.set(settings["model"])
        self.selected_effort.set(settings["effort"])
        self.refresh_agent_controls()
        self.apply_agent_theme(requested_agent)
        self.store.load()
        self.local_sessions = self.store.list_all_local(requested_agent)
        self.external_sessions = []  # picker is local-only; skip the slow CLI scan
        self.sessions = self._combined_sessions()
        self._render_session_list()
        self._save_active_workspace()
        self._render_workspace_tabs()
        label = self._agent_spec(requested_agent).get("label", requested_agent)
        self.status.set(
            f"{label} selected — its sessions are listed. Click one to open it in a tab."
        )

    def refresh_agent_controls(self):
        agent_key = self.active_agent.get()
        model_options = self._model_options_for(agent_key)
        effort_options = self._effort_options_for(agent_key)
        defaults = self._default_settings_for(agent_key)
        self.model_picker.configure(values=model_options)
        self.effort_picker.configure(values=effort_options)
        if self.selected_model.get() not in model_options:
            self.selected_model.set(defaults["model"])
        if self.selected_effort.get() not in effort_options:
            self.selected_effort.set(defaults["effort"])
        custom = bool(self._agent_spec(agent_key).get("custom"))
        self.model_picker.configure(state="disabled" if custom else "readonly")
        self.effort_picker.configure(state="disabled" if custom else "readonly")
        self.effort_label.configure(text="Effort")
        self._update_worker_indicator()

    def on_agent_setting_changed(self):
        agent_key = self.active_agent.get()
        self.agent_settings[agent_key] = {
            "model": self.selected_model.get(),
            "effort": self.selected_effort.get(),
        }
        if self.current_session and self.current_session.get("agent") == agent_key:
            backend = self.current_session.setdefault("backend", {})
            backend["model"] = self.selected_model.get()
            effort = self.selected_effort.get()
            if agent_key == "gemini" or effort == "Default":
                backend.pop("effort", None)
            else:
                backend["effort"] = effort
            self._persist_current()
        self.status.set(
            f"{self._agent_spec(agent_key)['label']}: {self.selected_model.get()} · {self.selected_effort.get()}"
        )
        self._update_worker_indicator()

    def apply_agent_theme(self, agent_key):
        background = AGENT_BACKGROUNDS.get(agent_key, PANEL)
        accents = AGENT_ACCENTS.get(agent_key, (ACCENT,) * 4)
        self.chat_tab.configure(bg=background)
        self.agent_accent_bar.configure(bg=background)
        for segment, color in zip(self.agent_accent_segments, accents):
            segment.configure(bg=color)
        self.chat.configure(bg=background)
        self.input.configure(bg=background)

    def refresh_sessions(self):
        self.status.set("Loading sessions…")
        self._remember_project(self.cwd.get())
        if getattr(self, "terminal_shell", None) and self.terminal_shell.cwd != self.cwd.get():
            self.restart_terminal()
        self.local_sessions = self.store.list_all_local(self.active_agent.get())
        self.external_sessions = []  # picker is local-only; skip the slow CLI scan
        self.sessions = self._combined_sessions()
        if not self.sessions:
            self.current_session = self.store.new_session(self.active_agent.get(), self.cwd.get())
            self.local_sessions = [self.current_session]
            self.sessions = list(self.local_sessions)
            self.transfer_source_session_id = None
        self._render_session_list()
        if self.visible_sessions:
            self.open_session(self.visible_sessions[0]["id"], remember=False)
        elif self.sessions:
            self.open_session(self.sessions[0]["id"], remember=False)
        else:
            self.open_session(self.current_session["id"], remember=False)

    def refresh_workspace(self):
        self.status.set("Refreshing workspace state…")
        self._save_active_workspace()
        workspace = self.workspaces.get(self.active_workspace_id)
        if not workspace:
            return
        current_id = (
            workspace.get("current_session", {}).get("id")
            if workspace.get("current_session")
            else None
        )
        self.store.load()
        workspace["live_source_signature"] = ""
        workspace["local_sessions"] = self.store.list_all_local(workspace["agent"])
        workspace["external_sessions"] = []  # local-only picker; skip CLI scan
        workspace["sessions"] = self._merge_session_lists(
            workspace["local_sessions"], workspace["external_sessions"]
        )
        if workspace.get("busy"):
            self.local_sessions = workspace["local_sessions"]
            self.external_sessions = workspace["external_sessions"]
            self.sessions = workspace["sessions"]
            self._render_session_list()
            self.status.set(
                "Session list refreshed. Active work was left untouched."
            )
            self._check_workspace_backend(workspace, manual=True)
            self.refresh_usage(manual=False)
            return
        target = next(
            (
                session
                for session in workspace["sessions"]
                if session.get("id") == current_id
            ),
            None,
        )
        if target is None and workspace["sessions"]:
            target = workspace["sessions"][0]
        self.local_sessions = workspace["local_sessions"]
        self.external_sessions = workspace["external_sessions"]
        self.sessions = workspace["sessions"]
        self._check_workspace_backend(workspace, manual=True)
        self._render_session_list()
        if target:
            self.open_session(target["id"], remember=False)
            path = linked_claude_session_path(target) or target.get("source_path")
            if path:
                self._load_external_session(target, self.active_workspace_id)
        self.refresh_usage(manual=False)
        self.status.set("Workspace, session history, and client health refreshed.")

    def _check_workspace_backend(self, workspace, manual=False):
        agent = workspace.get("agent")
        backend = (workspace.get("backends") or {}).get(agent)
        if not backend:
            return
        if agent == "codex":
            dead = backend.proc is None or backend.proc.poll() is not None
            if dead and not workspace.get("busy") and manual:
                try:
                    backend.restart(workspace.get("cwd") or os.path.expanduser("~"))
                    if not backend.ready.wait(timeout=15):
                        raise RuntimeError("Codex service did not become ready.")
                    workspace["status"] = "Codex service restarted."
                except Exception as exc:
                    workspace["status"] = "Error restarting Codex: " + str(exc)
                    workspace["activity_state"] = "error"
                    workspace["activity_text"] = "Client offline"
            elif (
                dead
                and workspace.get("busy")
                and not workspace.get("backend_failure_reported")
            ):
                workspace["backend_failure_reported"] = True
                self.events.put(
                    {
                        "kind": "error",
                        "workspace_id": workspace.get("id"),
                        "text": "Codex service stopped during the active turn.",
                    }
                )
            return
        if isinstance(backend, StreamCliBackend) and workspace.get("busy"):
            started = float(workspace.get("turn_started_at") or 0.0)
            if (
                started
                and time.monotonic() - started >= TURN_ORPHAN_GRACE_SECONDS
                and backend.running is None
                and not workspace.get("backend_failure_reported")
            ):
                workspace["backend_failure_reported"] = True
                self.events.put(
                    {
                        "kind": "error",
                        "workspace_id": workspace.get("id"),
                        "text": f"{self._agent_spec(agent)['label']} process ended without a completion event.",
                    }
                )

    def watchdog(self):
        try:
            self._save_active_workspace()
            now = time.monotonic()
            for workspace in self.workspaces.values():
                self._check_workspace_backend(workspace)
                if not workspace.get("busy"):
                    continue
                silence = now - float(workspace.get("last_event_at") or now)
                if (
                    silence >= TURN_STALE_NOTICE_SECONDS
                    and not workspace.get("stale_notice_shown")
                ):
                    workspace["stale_notice_shown"] = True
                    workspace["status"] = (
                        f"Still working; no client update for {round(silence)} seconds. "
                        "Refresh can verify state without stopping the turn."
                    )
                    workspace["activity_text"] = "Still working"
                    if workspace.get("id") == self.active_workspace_id:
                        self.status.set(workspace["status"])
                        self.set_activity("working", "Still working")
                    self._render_workspace_tabs()
                if (
                    silence >= TURN_STALLED_SECONDS
                    and not workspace.get("stalled_notice_shown")
                ):
                    workspace["stalled_notice_shown"] = True
                    workspace["status"] = (
                        f"No client output for {round(silence)} seconds. "
                        "The agent may still be running, but no progress is visible yet."
                    )
                    workspace["activity_text"] = "No output"
                    if workspace.get("id") == self.active_workspace_id:
                        self.status.set(workspace["status"])
                        self.set_activity("warning", "No output")
                    self._render_workspace_tabs()
        finally:
            self.win.after(2000, self.watchdog)

    def _combined_sessions(self):
        return self._merge_session_lists(
            self.local_sessions, self.external_sessions
        )

    def _merge_session_lists(self, local_sessions, external_sessions):
        local_backend_ids = set()
        worker_backend_ids = set()
        local = []
        for session in local_sessions:
            backend = session.get("backend") or {}
            backend_id = clean_text(
                backend.get("session_id") or backend.get("thread_id")
            )
            if session.get("worker_job_id"):
                if backend_id:
                    worker_backend_ids.add(backend_id)
                continue
            if backend_id:
                local_backend_ids.add(backend_id)
            local.append(session)
        # Discovered / imported CLI sessions never belong in the picker.
        return local

    def _is_picker_session(self, session):
        """True only for focused sessions created in the workbench (new / created /
        handoff). Excludes spawned workers and children, and imported or discovered
        CLI sessions (origin ends in '-terminal'), which belong in the per-session
        Spawned tab — not the main session picker."""
        if session.get("worker_job_id") or session.get("worker_parent_session_id"):
            return False
        origin = str(session.get("origin") or "local").strip().lower()
        if origin.endswith("-terminal"):
            return False
        return True

    def _render_session_list(self):
        self._hide_session_tooltip()
        selected_id = self.current_session.get("id") if self.current_session else None
        self.session_list.delete(0, "end")
        query = clean_text(self.session_filter.get()).lower()
        # The picker shows ONLY focused sessions created here (new / created /
        # handoff): origin "local", never imported/discovered CLI sessions
        # (*-terminal origin) and never spawned workers/children. Those live in
        # the per-session "Spawned" tab.
        self.visible_sessions = [
            s for s in self.sessions if self._is_picker_session(s)
        ]
        # Stable order: each session holds its slot. A brand-new session lands at
        # the TOP and pushes the rest down; merely opening/touching a session never
        # reorders it. The ↑/↓ buttons and the Organize button rewrite this order.
        self.visible_sessions = self._apply_stable_session_order(self.visible_sessions)
        if query:
            self.visible_sessions = [
                session
                for session in self.visible_sessions
                if query in session_search_blob(session, self._session_alias(session))
            ]
        for session in self.visible_sessions:
            title = self._session_list_label(session)
            self.session_list.insert("end", title)
        if self.visible_sessions:
            self.session_list.selection_clear(0, "end")
            selected_idx = next(
                (
                    idx
                    for idx, session in enumerate(self.visible_sessions)
                    if session.get("id") == selected_id
                ),
                0,
            )
            self.session_list.selection_set(selected_idx)
            self.session_list.see(selected_idx)
        self._render_recent_sessions()

    def _session_order_key(self):
        return f"{self.active_agent.get()}|{os.path.abspath(self.cwd.get())}"

    def _apply_stable_session_order(self, sessions):
        """Return picker sessions in their remembered order. Sessions already known
        keep their saved slot; sessions not seen before are inserted at the TOP
        (newest first), so a brand-new session pushes the rest down but nothing
        reorders just because it was opened. Dead ids are dropped. The merged order
        is persisted only when it actually changed (no disk churn on every render)."""
        key = self._session_order_key()
        stored = list(self.session_order.get(key, []))
        stored_set = set(stored)
        by_id = {s.get("id"): s for s in sessions if s.get("id")}
        ordered_ids = []
        seen = set()
        # Brand-new sessions (never ordered before) go on top, newest first.
        fresh = [
            s for s in sessions if s.get("id") and s.get("id") not in stored_set
        ]
        fresh.sort(key=lambda s: s.get("updated_at") or "", reverse=True)
        for s in fresh:
            ordered_ids.append(s.get("id"))
            seen.add(s.get("id"))
        # Then everything previously known, in its saved order.
        for sid in stored:
            if sid in by_id and sid not in seen:
                ordered_ids.append(sid)
                seen.add(sid)
        if ordered_ids != stored:
            self.session_order[key] = ordered_ids
            self.config["session_order"] = self.session_order
            save_json(CONFIG_FILE, self.config)
        return [by_id[sid] for sid in ordered_ids]

    def _open_organize_menu(self):
        """Drop-down for the Organize button: one-shot sort of the session list by
        date or title. The chosen order is written into the saved session_order so
        it persists; the list then stays stable until the next Organize / new
        session / manual ↑↓ move."""
        menu = tk.Menu(
            self.win,
            tearoff=0,
            bg=PANEL,
            fg=TEXT,
            activebackground=SIDEBAR_SEL,
            activeforeground="white",
        )
        menu.add_command(
            label="By date (newest first)",
            command=lambda: self.organize_sessions("date"),
        )
        menu.add_command(
            label="By title (A–Z)",
            command=lambda: self.organize_sessions("title"),
        )
        try:
            x = self.organize_btn.winfo_rootx()
            y = self.organize_btn.winfo_rooty() + self.organize_btn.winfo_height()
            menu.tk_popup(x, y)
        finally:
            menu.grab_release()

    def organize_sessions(self, mode):
        """Sort all picker sessions by the chosen key and persist that as the new
        saved order, then re-render. After this the list is stable again."""
        key = self._session_order_key()
        picker = [s for s in self.sessions if self._is_picker_session(s)]
        if mode == "title":
            picker.sort(key=lambda s: self._display_session_title(s).lower())
            label = "title"
        else:
            picker.sort(key=lambda s: s.get("updated_at") or "", reverse=True)
            label = "date"
        self.session_order[key] = [s.get("id") for s in picker if s.get("id")]
        self.config["session_order"] = self.session_order
        save_json(CONFIG_FILE, self.config)
        self._render_session_list()
        self.status.set(f"Sessions organized by {label}.")

    def _render_recent_sessions(self):
        """Populate the Recent box with the 2 most-recently-used local sessions."""
        if not hasattr(self, "recent_session_list"):
            return
        # Collect local sessions sorted by updated_at descending
        candidates = [
            s for s in self.local_sessions
            if self._is_picker_session(s)
        ]
        candidates.sort(key=lambda s: s.get("updated_at") or "", reverse=True)
        self._recent_sessions = candidates[:2]
        self.recent_session_list.delete(0, "end")
        for s in self._recent_sessions:
            self.recent_session_list.insert("end", self._session_list_label(s))

    def _select_recent_session(self):
        """Open the session selected in the Recent box."""
        sel = self.recent_session_list.curselection()
        if not sel:
            return
        idx = sel[0]
        if idx < len(self._recent_sessions):
            sid = self._recent_sessions[idx].get("id")
            if sid:
                self.open_session(sid)

    def _refresh_spawned_tab(self):
        """Populate the Spawned tab: in-turn sub-agents + worker sessions for the current session."""
        if not hasattr(self, "spawned_list"):
            return
        self.spawned_list.delete(0, "end")
        self._spawned_rows = []
        subs = list(reversed(self._session_subagents()))  # newest first

        def _add(text, row, color=None):
            i = self.spawned_list.size()
            self.spawned_list.insert("end", text)
            if color:
                try: self.spawned_list.itemconfig(i, foreground=color)
                except Exception: pass
            self._spawned_rows.append(row)

        # --- Sub-agents group ---
        _add("— Sub-agents (this session) —", {"type": "header"}, MUTED)
        if not subs:
            _add("   (none yet)", {"type": "blank"}, MUTED)
        else:
            for s in subs:
                name = clean_text(s.get("name")) or "sub-agent"
                status = clean_text(s.get("status")) or "running"
                detail = clean_text(s.get("detail")) or ""
                running = status in ("running", "in_progress", "pending")
                icon = "●" if running else ("✓" if status in ("completed", "success", "done") else "✗")
                meta = ""
                if not running:
                    dur = s.get("duration_ms") or 0
                    tok = s.get("total_tokens") or 0
                    bits = []
                    if dur: bits.append(f"{dur/1000:.0f}s")
                    if tok: bits.append(f"{tok} tok")
                    if bits: meta = "  ·  " + " · ".join(bits)
                summary = clean_text(s.get("summary")) or detail
                line = f"{icon} {name} — {status}{meta}"
                if summary:
                    line += f"  ·  {shorten(summary, 80)}"
                color = "#facc15" if running else ("#4ade80" if icon == "✓" else "#f87171")
                _add(line, {"type": "subagent"}, color)

        # --- Worker sessions group ---
        parent_id = (self.current_session or {}).get("id")
        spawned = []
        if parent_id:
            spawned = [s for s in self.local_sessions if s.get("worker_parent_session_id") == parent_id]
            spawned.sort(key=lambda s: s.get("updated_at") or "", reverse=True)
        self._spawned_sessions = spawned
        _add("— Worker sessions —", {"type": "header"}, MUTED)
        if not spawned:
            _add("   (none)", {"type": "blank"}, MUTED)
        else:
            for s in spawned:
                title = self._session_list_label(s)
                status = ""
                if s.get("worker_job_id"):
                    for job in self._active_worker_jobs():
                        if job.get("session_id") == s.get("id"):
                            status = "  [running]"
                            break
                _add(title + status, {"type": "session", "session": s})

    def _open_selected_spawned(self):
        """Open the session selected in the Spawned tab."""
        sel = self.spawned_list.curselection()
        if not sel:
            return
        idx = sel[0]
        rows = getattr(self, "_spawned_rows", [])
        if idx < len(rows) and rows[idx].get("type") == "session":
            sid = (rows[idx].get("session") or {}).get("id")
            if sid:
                self.open_session_in_new_tab(sid)

    def move_selected_session(self, direction):
        selection = self.session_list.curselection()
        if not selection or clean_text(self.session_filter.get()):
            self.status.set("Clear session search before reordering.")
            return
        index = selection[0]
        target = index + direction
        if target < 0 or target >= len(self.visible_sessions):
            return
        ordered = [session.get("id") for session in self.visible_sessions]
        ordered[index], ordered[target] = ordered[target], ordered[index]
        self.session_order[self._session_order_key()] = ordered
        self.config["session_order"] = self.session_order
        save_json(CONFIG_FILE, self.config)
        selected_id = ordered[target]
        self._render_session_list()
        for row, session in enumerate(self.visible_sessions):
            if session.get("id") == selected_id:
                self.session_list.selection_clear(0, "end")
                self.session_list.selection_set(row)
                self.session_list.see(row)
                break

    def delete_selected_session(self):
        selection = self.session_list.curselection()
        if not selection or selection[0] >= len(self.visible_sessions):
            self.status.set("Select a session to delete.")
            return
        session = self.visible_sessions[selection[0]]
        if (
            self.busy
            and self.current_session
            and self.current_session.get("id") == session.get("id")
        ):
            self.status.set("Stop the active turn before deleting this session.")
            return
        title = self._display_session_title(session)
        backend = session.get("backend") or {}
        client_backed = bool(
            clean_text(
                session.get("source_session_id")
                or backend.get("session_id")
                or backend.get("thread_id")
            )
        )
        detail = (
            (
                "\n\nThis also removes it from the agent client's session history. "
                "Codex sessions are archived using Codex's native command."
            )
            if client_backed
            else ""
        )
        if not messagebox.askyesno(
            "Delete session",
            f"Delete '{title}'?{detail}",
            parent=self.win,
        ):
            return
        linked, deleted, error = delete_client_session(session)
        if linked and not deleted:
            messagebox.showerror(
                "Delete session",
                f"The client session was not removed:\n\n{error}",
                parent=self.win,
            )
            return
        if linked:
            self._record_deleted_session(session)
        self.store.delete(session.get("id"))
        order_key = self._session_order_key()
        self.session_order[order_key] = [
            item for item in self.session_order.get(order_key, []) if item != session.get("id")
        ]
        self.config["session_order"] = self.session_order
        save_json(CONFIG_FILE, self.config)
        if self.current_session and self.current_session.get("id") == session.get("id"):
            self.current_session = None
            self.current_turn = None
        self.refresh_sessions()
        self.status.set(
            f"Deleted {title} from Workbench"
            + (" and the client." if linked else ".")
        )

    def open_session_finder(self):
        self.session_search.focus_set()
        self.session_search.select_range(0, "end")
        self.status.set("Search the connected client's sessions in the sidebar.")

    def rename_selected_session(self):
        selection = self.session_list.curselection()
        if not selection:
            messagebox.showinfo("Rename", "Select a session first.")
            return
        idx = selection[0]
        if idx >= len(self.visible_sessions):
            return
        session = self.visible_sessions[idx]
        current = self._display_session_title(session)
        alias = simpledialog.askstring(
            "Rename session",
            "Choose a shorter label for this session:",
            initialvalue=current,
            parent=self.win,
        )
        if alias is None:
            return
        alias = clean_text(alias)
        if not alias:
            messagebox.showinfo("Rename", "Name cannot be blank.")
            return
        source_updated = False
        origin = session.get("origin", "local")
        if origin == "local":
            session["title"] = alias
            self.session_aliases.pop(session_alias_key(session), None)
            self.store.save(session)
            if session.get("agent") == "claude":
                source_updated = sync_claude_session_title(session)
            elif session.get("agent") == "codex":
                source_updated = rename_codex_thread_title(
                    (session.get("backend") or {}).get("thread_id"),
                    alias,
                )
        elif origin == "codex-terminal":
            source_updated = rename_codex_thread_title(session.get("source_session_id"), alias)
        elif origin == "claude-terminal":
            source_updated = rename_claude_session_title(
                session.get("source_path"),
                session.get("source_session_id"),
                alias,
            )
        if source_updated:
            session["title"] = alias
            self.session_aliases.pop(session_alias_key(session), None)
            self.config["session_aliases"] = self.session_aliases
            save_json(CONFIG_FILE, self.config)
        elif origin != "local":
            self._set_session_alias(session, alias)
        # Update the new label everywhere it's shown WITHOUT reloading the
        # session. open_session() re-renders the conversation from the saved
        # copy, which erases a turn that is still streaming — renaming a chat
        # while it was processing made "everything in the window disappear".
        for ws in self.workspaces.values():
            cs = ws.get("current_session")
            if cs and cs.get("id") == session["id"]:
                cs["title"] = alias
        if self.current_session and self.current_session.get("id") == session["id"]:
            self.current_session["title"] = alias
            self.session_title.set(shorten(self._display_session_title(self.current_session), 110))
        self._render_session_list()
        self._save_active_workspace()
        self._render_workspace_tabs()
        if source_updated:
            agent = self._agent_spec(session.get("agent", ""))["label"]
            self.status.set(f"Renamed session to '{alias}' in {agent} and Workbench.")
        else:
            self.status.set(f"Renamed session to '{alias}' in Workbench.")

    def select_session(self):
        selection = self.session_list.curselection()
        if not selection:
            return
        idx = selection[0]
        if idx >= len(self.visible_sessions):
            return
        selected_id = self.visible_sessions[idx]["id"]
        if self.current_session and self.current_session.get("id") == selected_id:
            return  # already showing in the active tab — nothing to do
        # Paint the selection highlight NOW, before the heavier open work (create
        # workspace, re-render list, load transcript, rebuild tabs) blocks the event
        # loop. Without this flush Tk defers the highlight redraw until that work
        # returns, so the click feels laggy. update_idletasks flushes the pending
        # redraw without processing further user events.
        self.session_list.update_idletasks()
        # Every picker click opens the session in its OWN tab; never swap/replace the
        # current tab. If that exact session (matched by id, not title) is already open
        # in some tab, focus that tab instead of opening a duplicate. So distinct
        # sessions that share a title each get a tab, but one session is never opened twice.
        self.open_session_in_new_tab(selected_id)

    def open_session_in_new_tab(self, session_id):
        """Open a session in its own workspace tab, leaving the current tab — and any
        turn running there — untouched. If it's already open in a tab, focus that tab."""
        for wid in self.workspace_order:
            cur = (self.workspaces.get(wid) or {}).get("current_session") or {}
            if cur.get("id") == session_id:
                self.switch_workspace(wid)
                self.input.focus_set()
                return
        if self._at_tab_limit():
            self._notify_tab_limit()
            return
        session = self.store.get(session_id)
        if not session:
            for candidate in self.external_sessions:
                if candidate.get("id") == session_id:
                    session = candidate
                    break
        if not session:
            return
        if self.close_when_idle and not self.restart_after_close:
            self.status.set("Workbench is waiting for active tasks to finish before closing.")
            return
        agent_key = session.get("agent") or self.active_agent.get()
        if agent_key not in self.agent_map:
            agent_key = self.active_agent.get()
        cwd = session.get("cwd") or self.cwd.get()
        self._save_active_workspace()
        self._schedule_workspace_config_save(immediate=True)
        previous_agent = self.active_agent.get()
        previous_cwd = self.cwd.get()
        settings = self.agent_settings.get(
            agent_key, self._default_settings_for(agent_key)
        )
        self.active_agent.set(agent_key)
        self.cwd.set(cwd)
        self.selected_model.set(settings["model"])
        self.selected_effort.set(settings["effort"])
        workspace_id = self._create_workspace()
        self.active_agent.set(previous_agent)
        self.cwd.set(previous_cwd)
        self.active_workspace_id = workspace_id
        self._restore_workspace(self.workspaces[workspace_id])
        # Populate this tab's picker without auto-opening the top session (which
        # would bump an unrelated session's timestamp); open only the target.
        self.local_sessions = self.store.list_all_local(self.active_agent.get())
        self.external_sessions = []  # picker is local-only; skip the slow CLI scan
        self.sessions = self._combined_sessions()
        self._render_session_list()
        self.open_session(session_id, remember=False)
        self._save_active_workspace()
        self._render_workspace_tabs()
        self.input.focus_set()

    def _open_selected_session_new_tab(self):
        selection = self.session_list.curselection()
        if not selection:
            return
        idx = selection[0]
        if idx < len(self.visible_sessions):
            self.open_session_in_new_tab(self.visible_sessions[idx]["id"])

    def _restore_last_session(self):
        last_id = self.config.get("last_session_id")
        if last_id and self.store.get(last_id):
            self.open_session(last_id, remember=False)

    def open_session(self, session_id, remember=True):
        session = self.store.get(session_id)
        if not session:
            for candidate in self.external_sessions:
                if candidate.get("id") == session_id:
                    session = candidate
                    break
        if not session:
            return
        if self.busy:
            messagebox.showinfo("Busy", "Wait for the current turn to finish before switching sessions.")
            return
        if remember and self.current_session and self.current_session.get("id") != session_id:
            self.transfer_source_session_id = self.current_session.get("id")
        self.current_session = deepcopy(session)
        # Update last-use timestamp so sessions sort by most-recently-opened
        if session.get("origin", "local") == "local":
            session["updated_at"] = now_iso()
            self.store.save(session)
            self.current_session["updated_at"] = session["updated_at"]
        linked_path = linked_claude_session_path(self.current_session)
        if linked_path:
            self.current_session["source_path"] = linked_path
            self.current_session["source_session_id"] = clean_text(
                (self.current_session.get("backend") or {}).get("session_id")
                or self.current_session.get("source_session_id")
            )
        agent_key = session.get("agent", self.active_agent.get())
        settings = self.agent_settings.get(
            agent_key,
            self._default_settings_for(agent_key),
        )
        backend = session.get("backend") or {}
        model = backend.get("model") or settings["model"]
        effort = backend.get("effort") or settings["effort"]
        if model in self._model_options_for(agent_key):
            self.selected_model.set(model)
        if effort in self._effort_options_for(agent_key):
            self.selected_effort.set(effort)
        self.refresh_agent_controls()
        self.apply_agent_theme(session.get("agent", self.active_agent.get()))
        self.update_context_indicator(session.get("context"))
        self.live_source_signature = self._source_signature(
            self.current_session.get("source_path")
        )
        self.current_turn = None
        self.session_backend_id = session.get("backend", {}).get("thread_id") or session.get("backend", {}).get("session_id")
        origin = session.get("origin", "local")
        title = self._display_session_title(session)
        self.session_title.set(shorten(title, 110))
        self.session_label.set(
            f"{self._agent_spec(session.get('agent')).get('label', session.get('agent'))} · {project_label(session.get('cwd'))}"
        )
        self.chat_updates_pending = False
        self._update_chat_update_indicator()
        self._clear_views()
        loading_transcript = (
            origin in {"claude-terminal", "gemini-terminal"}
            and not session.get("transcript_loaded")
            and bool(clean_text(session.get("source_path")))
        )
        if loading_transcript:
            self._show_transcript_loading(session)
            self._load_external_session(session, self.active_workspace_id)
        else:
            self._render_session(
                self.current_session,
                on_complete=self.scroll_chat_to_latest,
            )
            if linked_path:
                signature = self._source_signature(linked_path)
                if signature and signature != self.live_source_signature:
                    self.live_source_signature = signature
                    self._load_external_session(
                        self.current_session, self.active_workspace_id
                    )
        self.refresh_artifacts_view(session)
        self.scroll_chat_to_latest()
        self._refresh_spawned_tab()
        if loading_transcript:
            pass
        else:
            self.status.set("Ready. Send a prompt to continue this client session.")
        if not loading_transcript:
            self.set_activity(
                "idle",
                "Ready",
            )
        self._persist_current()

    def _show_transcript_loading(self, session):
        self.chat.configure(state="normal")
        self.chat.insert(
            "end",
            "Loading conversation…\n\n"
            "The complete Claude transcript is being reconstructed in the background.",
            "assistant",
        )
        self.chat.configure(state="disabled")
        self.status.set("Loading complete Claude conversation…")
        self.set_activity("starting", "Loading")

    def _load_external_session(self, session, workspace_id=None):
        session_id = session.get("id")
        path = linked_claude_session_path(session) or session.get("source_path")
        load_key = f"{workspace_id or 'active'}:{session_id}"
        if (
            not session_id
            or not path
            or load_key in self.loading_external_sessions
            or self._session_is_deleted(session)
        ):
            return
        self.loading_external_sessions.add(load_key)
        origin = session.get("origin")

        def load():
            if session.get("agent") == "claude":
                turns = claude_jsonl_turns(path)
                metadata = claude_session_metadata(path)
                title = metadata["title"]
                context = metadata["context"]
            elif session.get("agent") == "gemini":
                turns = gemini_jsonl_turns(path)
                title = session.get("title") or session.get("preview") or ""
                context = {}
            else:
                turns = codex_rollout_turns(path)
                title = ""
                context = codex_context_from_rollout(path)
            self.events.put(
                {
                    "kind": "external_session_loaded",
                    "session_id": session_id,
                    "turns": turns,
                    "title": title,
                    "context": context,
                    "signature": self._source_signature(path),
                    "workspace_id": workspace_id,
                    "load_key": load_key,
                }
            )

        threading.Thread(target=load, daemon=True).start()

    def _source_signature(self, path):
        if not path:
            return None
        try:
            stat = os.stat(path)
            return (stat.st_mtime_ns, stat.st_size)
        except OSError:
            return None

    def poll_external_session(self):
        try:
            self._save_active_workspace()
            for workspace_id, workspace in self.workspaces.items():
                session = workspace.get("current_session")
                if not session:
                    continue
                path = (
                    linked_claude_session_path(session)
                    if session.get("agent") == "claude"
                    else session.get("source_path")
                )
                if not path or (
                    session.get("origin")
                    not in {"codex-terminal", "claude-terminal", "local"}
                ):
                    continue
                signature = self._source_signature(path)
                if signature and signature != workspace.get("live_source_signature"):
                    if self._session_is_deleted(session):
                        continue
                    workspace["live_source_signature"] = signature
                    self._load_external_session(session, workspace_id)
        finally:
            self.win.after(500, self.poll_external_session)

    def _clear_views(self, clear_attachments=True):
        self.render_generation += 1
        if clear_attachments:
            self.clear_attachments()
        for card in self.report_cards:
            try:
                card["frame"].destroy()
            except tk.TclError:
                pass
        self.report_cards = []
        self.latest_agent_text = ""
        self.chat.configure(state="normal")
        self.chat.delete("1.0", "end")
        self.chat.configure(state="disabled")
        self._reset_work_pages()

    def _render_session(self, session, on_complete=None):
        self.render_generation += 1
        generation = self.render_generation
        turns = list(session.get("turns") or [])
        agent = session.get("agent", "agent")
        self.rendering_chat = True

        def render_batch(index=0):
            if generation != self.render_generation:
                self.rendering_chat = False
                return
            end = min(index + 12, len(turns))
            for turn in turns[index:end]:
                self._render_turn(turn, agent)
            if end < len(turns):
                self.win.after(1, lambda: render_batch(end))
            else:
                self.rendering_chat = False
                if on_complete:
                    self.win.after_idle(on_complete)

        render_batch()

    def _render_turn(self, turn, agent_key):
        turn_time = turn.get("created_at")
        items = turn.get("items") or []
        # One request → ONE response bubble. The agent narrates in several blocks
        # between tool calls, which are persisted as separate agentMessage items;
        # rendering each as its own bubble made a single reply look like many. Merge
        # this turn's assistant text into one bubble (shown at the first block's
        # timestamp). Non-chat items (commands, file changes, system output) still
        # render in order — they go to the Work Log, not the conversation.
        agent_parts = [
            t for t in (
                self._extract_agent_text(it)
                for it in items
                if it.get("type") == "agentMessage"
            ) if t
        ]
        merged_agent = "\n\n".join(agent_parts)
        agent_ts = next(
            (it.get("created_at") for it in items if it.get("type") == "agentMessage"),
            turn_time,
        )
        rendered_agent = False
        for item in items:
            if item.get("type") == "agentMessage":
                if not rendered_agent:
                    rendered_agent = True
                    self._render_item(
                        {"type": "agentMessage", "text": merged_agent, "created_at": agent_ts},
                        agent_key,
                        turn_time,
                    )
                continue
            self._render_item(item, agent_key, turn_time)

    def _render_item(self, item, agent_key, turn_time=None):
        typ = item.get("type", "")
        ts = item.get("created_at") or turn_time
        if typ == "userMessage":
            text = self._extract_user_text(item)
            if text:
                self.append_chat("YOU", text, "user", ts)
        elif typ == "agentMessage":
            text = self._extract_agent_text(item)
            if text:
                thought_text, visible_text = (
                    split_gemini_visible_text(text) if agent_key == "gemini" else ("", text)
                )
                if thought_text:
                    self.append_work(thought_text, "reasoning")
                if visible_text:
                    self.latest_agent_text = visible_text
                    self.append_chat(
                        self._agent_spec(agent_key)["label"].upper(),
                        visible_text,
                        "assistant",
                        ts,
                    )
        elif typ == "report":
            self.append_report(
                clean_text(item.get("title")) or "Agent report",
                clean_text(item.get("text")),
            )
        elif typ == "commandExecution":
            command = clean_text(item.get("command"))
            if command:
                self.append_work(f"$ {command}", "command")
            output = clean_text(item.get("aggregatedOutput"))
            if output:
                self.append_work(output, "system")
        elif typ == "fileChange":
            paths = []
            for change in item.get("changes") or []:
                path = change.get("path") or change.get("filePath")
                if path:
                    paths.append(str(path))
            if paths:
                self.append_work("files: " + ", ".join(paths), "fileChange")
        elif typ == "reasoning":
            summary = " ".join(item.get("summary") or [])
            if summary:
                self.append_work(summary, "reasoning")
        elif typ == "plan":
            text = clean_text(item.get("text"))
            if text:
                self.append_work(text, "plan")
        elif typ == "mcpToolCall":
            self.append_work(
                f"{clean_text(item.get('server'))}.{clean_text(item.get('tool'))}",
                "tool",
            )
        elif typ == "system":
            text = clean_text(item.get("text") or item.get("message"))
            if text:
                self.append_work(text, item.get("tag") or "system")
        elif typ == "note":
            text = clean_text(item.get("text"))
            if text:
                self.append_work(text, "system")

    def _extract_user_text(self, item):
        content = item.get("content") or []
        parts = []
        for bit in content:
            if isinstance(bit, dict) and bit.get("type") == "text":
                parts.append(bit.get("text", ""))
        return clean_text(" ".join(parts))

    def _extract_agent_text(self, item):
        text = item.get("text") or item.get("content") or ""
        if isinstance(text, list):
            parts = []
            for bit in text:
                if isinstance(bit, dict) and bit.get("type") == "text":
                    parts.append(bit.get("text", ""))
            return clean_text(" ".join(parts))
        return clean_text(text)

    def _format_msg_time(self, iso=None):
        """Short clock stamp for a message header, from the system's local time.
        Parses a stored ISO timestamp when given; otherwise stamps 'now'."""
        moment = None
        if iso:
            try:
                moment = datetime.fromisoformat(str(iso).replace("Z", "+00:00"))
            except (ValueError, TypeError):
                moment = None
            if moment is not None and moment.tzinfo is not None:
                moment = moment.astimezone()
        if moment is None:
            moment = datetime.now()
        return moment.strftime("%-I:%M:%S %p")

    def _copy_message(self, text):
        try:
            self.win.clipboard_clear()
            self.win.clipboard_append(text)
            self.status.set("Message copied to clipboard.")
        except tk.TclError:
            pass

    def _insert_copy_button(self, text):
        """Embed a small inline Copy button at the current end of the chat that
        copies this message's text. Works on the read-only Text because embedded
        widgets stay interactive."""
        if not clean_text(text):
            return
        btn = tk.Button(
            self.chat,
            text="⧉ Copy",
            command=lambda t=text: self._copy_message(t),
            bg=PANEL_ALT,
            fg=MUTED,
            activebackground=SIDEBAR_SEL,
            activeforeground="white",
            relief="flat",
            font=("Sans", 8),
            padx=6,
            pady=0,
            cursor="hand2",
            borderwidth=0,
            takefocus=0,
        )
        self.chat.window_create("end", window=btn)
        self.chat.insert("end", "\n")

    def append_chat(self, speaker, text, tag="assistant", timestamp=None):
        if not text:
            return
        raw_text, visible_text = strip_session_context(text)
        if raw_text and not visible_text:
            self.append_work(raw_text, "system")
            return
        if raw_text and visible_text:
            self.append_work(raw_text, "system")
            text = visible_text
        widget = self.chat
        at_bottom = widget.yview()[1] >= 0.995
        widget.configure(state="normal")
        head_tag = "assistant_head"
        if speaker == "YOU":
            head_tag = "user_head"
        elif speaker == "CLAUDE":
            head_tag = "claude_head"
        elif speaker == "GEMINI":
            head_tag = "gemini_head"
        if speaker != "YOU":
            self.latest_agent_text = text
        widget.insert("end", speaker, head_tag)
        widget.insert(
            "end", "   " + self._format_msg_time(timestamp) + "\n", (head_tag, "msg_time")
        )
        content_start = widget.index("end-1c")
        if tag == "assistant":
            self._insert_formatted_chat(text)
        else:
            widget.insert("end", text.rstrip() + "\n\n", tag)
        content_end = widget.index("end-1c")
        self._linkify_chat_range(content_start, content_end)
        self._insert_copy_button(text)
        widget.tag_raise("sel")
        widget.configure(state="disabled")
        self._finish_chat_append(at_bottom)

