def is_auto_launch_session(session):
    """True if a session was started by an automated/unattended launcher (matched by
    its first-prompt fingerprint), not opened by the user. Such runs — e.g. Pig Farm's
    autonomous trading agent — flood the picker with near-duplicates, so they're kept
    out of it and filed under SESSIONS_ARCHIVE_DIR. Only terminal-discovered sessions
    can match; the user's own Workbench ("local") sessions are always treated as real."""
    if not isinstance(session, dict):
        return False
    origin = str(session.get("origin") or "local")
    if not origin.endswith("-terminal"):
        return False
    blob = " ".join(
        str(session.get(key) or "")
        for key in ("preview", "first_user_message", "title")
    ).lower()
    return any(marker in blob for marker in AUTO_LAUNCH_PROMPT_MARKERS)


def session_alias_key(session):
