def cached_cli_help(command):
    try:
        completed = subprocess.run(
            [command, "--help"],
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            check=False,
            timeout=10,
        )
    except (OSError, subprocess.TimeoutExpired):
        return ""
    return clean_text(completed.stdout)


def parse_effort_options(help_text, fallback=("Default",)):
    help_text = help_text or ""
    lines = help_text.splitlines()
    for index, line in enumerate(lines):
        if "Effort level for the current session" not in line:
            continue
        snippet = "\n".join(lines[index : index + 4])
        match = re.search(r"\(low,\s*medium,\s*high,\s*xhigh,\s*max\)", snippet, flags=re.IGNORECASE)
        if match:
            return ("low", "medium", "high", "xhigh", "max")
        match = re.search(r"\(choices:\s*([^)]+)\)", snippet, flags=re.IGNORECASE)
        if match:
            options = []
            for item in match.group(1).split(","):
                value = clean_text(item.strip().strip('"').strip("'"))
                if value:
                    options.append(value)
            if options:
                return tuple(options)
    return tuple(fallback)


def prompt_with_attachments(prompt, paths):
    readable = []
    for path in paths:
        candidate = os.path.abspath(os.path.expanduser(str(path)))
        if os.path.isfile(candidate):
            readable.append(candidate)
    if not readable:
        return prompt
    files = "\n".join(f"- {path}" for path in readable)
    return (
        "The user attached the following local files. Inspect each relevant file "
        "with the appropriate file or image-reading tool before answering:\n"
        f"{files}\n\nUser request:\n{prompt}"
    )


def ensure_dir(path):
    os.makedirs(path, exist_ok=True)


def safe_filename(name):
    name = os.path.basename(clean_text(name))
    name = re.sub(r"[^A-Za-z0-9._ -]+", "_", name).strip(" .")
    return name or "artifact"


def unique_destination(directory, name):
    base, ext = os.path.splitext(safe_filename(name))
    candidate = os.path.join(directory, base + ext)
    counter = 2
    while os.path.exists(candidate):
        candidate = os.path.join(directory, f"{base} {counter}{ext}")
        counter += 1
    return candidate


