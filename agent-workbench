    def _project_handoff_filename(self, session):
        timestamp = datetime.now().astimezone().strftime("%Y%m%d-%H%M%S")
        agent = clean_text((session or {}).get("agent")) or "agent"
        title = clean_text((session or {}).get("title") or (session or {}).get("preview"))
        title = safe_filename(title or "handoff")
        title = re.sub(r"\s+", "-", title)[:64].strip("-_.") or "handoff"
        session_id = clean_text((session or {}).get("id"))[:8] or uuid.uuid4().hex[:8]
        return f"{timestamp}-{safe_filename(agent)}-{title}-{session_id}.md"

    def _write_project_handoff_artifact(self, session, packet):
        root = infer_project_root(session, (session or {}).get("cwd") or self.cwd.get())
        directory = project_handoffs_dir(root)
        if not directory:
            return ""
        ensure_dir(directory)
        archive_path = os.path.join(directory, self._project_handoff_filename(session))
        latest_path = os.path.join(directory, "latest.md")
        agent = safe_filename(clean_text((session or {}).get("agent")) or "agent")
        agent_latest_path = os.path.join(directory, f"{agent}-latest.md")
        content = clean_text(packet).rstrip() + "\n"
        for path in (archive_path, latest_path, agent_latest_path):
            temporary = f"{path}.tmp-{os.getpid()}-{threading.get_ident()}"
            try:
                with open(temporary, "w", encoding="utf-8") as handle:
                    handle.write(content)
                    handle.flush()
                    os.fsync(handle.fileno())
                os.replace(temporary, path)
            except OSError:
                try:
                    os.unlink(temporary)
                except OSError:
                    pass
                if path == archive_path:
                    return ""
        try:
            registry_path, registry = read_project_registry(root)
            registry = registry if isinstance(registry, dict) else {}
            registry.update(
                {
                    "latest_handoff": archive_path,
                    "latest_handoff_updated_at": now_iso(),
                    "updated_at": now_iso(),
                }
            )
            if registry_path:
                save_json(registry_path, registry)
        except Exception:
            pass
        return archive_path

    def _write_handoff_artifact(self, session, packet):
        packet = clean_text(packet)
        if not session or not packet:
            return ""
        project_path = self._write_project_handoff_artifact(session, packet)
        path = os.path.join(self._artifact_directory(session), "HANDOFF.md")
        temporary = f"{path}.tmp-{os.getpid()}-{threading.get_ident()}"
        try:
            with open(temporary, "w", encoding="utf-8") as handle:
                handle.write(packet.rstrip() + "\n")
                handle.flush()
                os.fsync(handle.fileno())
            os.replace(temporary, path)
        except OSError:
            try:
                os.unlink(temporary)
            except OSError:
                pass
            return project_path
        return project_path or path

