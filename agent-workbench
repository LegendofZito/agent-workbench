        y = self.win.winfo_rooty() + (self.win.winfo_height() - dialog.winfo_reqheight()) // 3
        dialog.geometry(f"+{max(0, x)}+{max(0, y)}")

    def _persist_current(self):
        if not self.current_session:
            return
        self.store.save(self.current_session)

    def _current_backend(self):
        return self.backends[self.active_agent.get()]

    def _current_agent_label(self):
        return self._agent_spec(self.active_agent.get())["label"]

    def _agent_executable(self, agent_key):
        if agent_key in {"codex", "claude", "gemini"}:
            return agent_key
        client = next(
            (item for item in self.custom_clients if item.get("key") == agent_key),
            None,
        )
        if not client:
            return ""
        try:
            return shlex.split(clean_text(client.get("command")).replace("{prompt}", "prompt"))[0]
        except (ValueError, IndexError):
            return ""

    def _self_project_context(self, prompt):
        if not re.search(
            r"\b(agent workbench|this app|the app|itself|yourself|self)\b",
            prompt,
            flags=re.IGNORECASE,
        ):
            return ""
        source_dir = clean_text(self.install_info.get("source_dir"))
        if not source_dir or not os.path.isdir(source_dir):
            return ""
        return (
            "Agent Workbench self-maintenance context:\n"
            f"- Editable source project: {source_dir}\n"
            f"- Running installed executable: {os.path.abspath(__file__)}\n"
            "- Make changes in the editable source project, test them, then run its installer.\n"
            "- Do not terminate or restart the current Agent Workbench process during this turn; "
            "finish the response first and state when a restart is required."
        )

    def _make_turn(self, prompt):
        turn = self.store.ensure_turn(self.current_session, prompt=prompt)
        self.current_turn = turn
        if not self.current_session.get("title") or self.current_session.get("title", "").startswith("New "):
            self.store.set_title_from_prompt(self.current_session, prompt)
        return turn

    def _queue_prompt(self, prompt, attachments):
        self.queued_prompts.append(
            {
                "prompt": prompt,
                "attachments": list(attachments),
            }
        )
        self.input.delete("1.0", "end")
        self.clear_attachments()
        count = len(self.queued_prompts)
        self.status.set(
            f"Queued {count} message{'s' if count != 1 else ''}; "
            "the next one will send when this turn finishes."
        )
        self._update_queue_indicator()
        self._refresh_queue_dialog()
        self.append_work(
            f"Queued next message: {shorten(prompt, 100)}",
            "system",
        )
        self._log_event("queue_add", depth=count, session=(self.current_session or {}).get("id"))
        self._save_active_workspace()
        self._render_workspace_tabs()

    def _send_next_queued_prompt(self):
        if (
            self.busy
            or self.pending_user_input
            or (self.close_when_idle and not self.restart_after_close)
            or not self.queued_prompts
        ):
            return
        queued = self.queued_prompts.pop(0)
        self._log_event("queue_drain", scope="active", remaining=len(self.queued_prompts))
        self._update_queue_indicator()
        self._refresh_queue_dialog()
        self._save_active_workspace()
        self._render_workspace_tabs()
        # Send the queued message DIRECTLY — never load it into the composer, so a
        # draft the user is typing right now is preserved instead of overwritten.
        self.send(
            prompt=queued.get("prompt", ""),
            attachments=queued.get("attachments"),
        )

    def _drain_workspace_queue(self, workspace):
        """Advance a BACKGROUND tab's queue when its turn finishes, so queued work
        runs across tabs instead of sitting until you switch back. Operates only on
        the given workspace's own session/backend; never touches the active UI."""
        if not workspace or workspace is self.workspaces.get(self.active_workspace_id):
            return  # the active tab uses _send_next_queued_prompt (with rendering)
        if workspace.get("busy") or (self.close_when_idle and not self.restart_after_close):
            return
        queue_list = workspace.get("queued_prompts") or []
        if not queue_list:
            return
        session = workspace.get("current_session")
        agent = workspace.get("agent")
        backend = (workspace.get("backends") or {}).get(agent)
        if not session or not backend or session.get("origin", "local") != "local":
            return
        queued = queue_list.pop(0)
        prompt = clean_text(queued.get("prompt", ""))
        attachments = [
            p for p in (queued.get("attachments") or []) if p and os.path.isfile(p)
        ]
        if not prompt and not attachments:
            return
        if not prompt:
            names = ", ".join(os.path.basename(p) for p in attachments)
            prompt = f"Please inspect and respond to the attached file(s): {names}"
        turn = {"id": str(uuid.uuid4()), "created_at": now_iso(), "status": "running", "items": []}
        session.setdefault("turns", []).append(turn)
        self.store.add_item(
            session, turn, {"type": "userMessage", "content": [{"type": "text", "text": prompt}]}
        )
        workspace["current_turn"] = turn
        workspace["busy"] = True
        workspace["tab_done"] = False  # new work → yellow, clear any prior green
        now = time.monotonic()
        workspace["turn_started_at"] = now
        workspace["last_event_at"] = now
        workspace["last_progress_at"] = now
        workspace["live_token_count"] = 0
        workspace["status"] = f"{self._agent_spec(agent).get('label', agent)} is working…"
        workspace["activity_state"] = "working"
        workspace["activity_text"] = "Working"
        backend_settings = session.setdefault("backend", {})
        backend_settings["model"] = workspace.get("model")
        if agent == "claude":
            backend_settings["orchestration_mode"] = clean_text(
                self.claude_orchestration.get("mode") or "smart"
            )
        effort = workspace.get("effort")
        if agent == "gemini" or effort in (None, "", "Default"):
            backend_settings.pop("effort", None)
        else:
            backend_settings["effort"] = effort
        backend_prompt = prompt_with_authoritative_time(
            prompt_with_attachments(prompt, attachments)
        )
        self._log_event(
            "queue_drain",
            scope="background",
            agent=agent,
            session=session.get("id"),
            remaining=len(queue_list),
        )
        self.store.save(session, durable=False)
        backend.start_turn(session, turn, backend_prompt, context_text="")
        self._render_workspace_tabs()

    def send(self, prompt=None, attachments=None):
        if (
            self.close_when_idle
            and not self.restart_after_close
            and not self.pending_user_input
        ):
            self.status.set("Workbench is waiting for active tasks to finish before closing.")
            return
        # prompt=None => send the live composer draft (and clear it afterward).
        # An explicit prompt (e.g. a queued message) is sent WITHOUT reading or
        # clearing the composer, so text the user is typing right now is never lost.
        from_composer = prompt is None
        if from_composer:
            prompt = clean_text(self.input.get("1.0", "end"))
            attachments = [
                path for path in self.pending_attachments if path and os.path.isfile(path)
            ]
        else:
            prompt = clean_text(prompt)
            attachments = [
                path for path in (attachments or []) if path and os.path.isfile(path)
            ]
        if not prompt and not attachments:
            return
        if not prompt:
            names = ", ".join(os.path.basename(path) for path in attachments)
            prompt = f"Please inspect and respond to the attached file{'s' if len(attachments) != 1 else ''}: {names}"
        if self.pending_user_input:
            pending = self.pending_user_input
            self.pending_user_input = None
            if from_composer:
                self.input.delete("1.0", "end")
            reply = prompt_with_attachments(prompt, attachments)
            raw_prompt, visible_prompt = strip_session_context(prompt)
            if raw_prompt and not visible_prompt:
                self.append_work(raw_prompt, "system")
                visible_prompt = ""
            elif raw_prompt and visible_prompt:
                self.append_work(raw_prompt, "system")
            if attachments:
                visible_prompt += "\n\nAttached: " + ", ".join(
                    os.path.basename(path) for path in attachments
                )
                if from_composer:
                    self.clear_attachments()
            self.append_chat("YOU", visible_prompt, "user")
            if self.current_turn is not None:
                self.store.add_item(
                    self.current_session,
                    self.current_turn,
                    {
                        "type": "userMessage",
                        "content": [{"type": "text", "text": visible_prompt}],
                    },
                )
            self.backends["codex"].answer_user_input(
                pending["request_id"], pending["questions"], reply
            )
            self.send_btn.configure(text="Send", state="disabled")
            self.stop_btn.configure(state="normal")
            self.status.set("Codex received your reply and is continuing…")
            self.set_activity("working")
            return
        if self.busy:
            self._queue_prompt(prompt, attachments)
            return
        agent_key = self.active_agent.get()
        # Local-model clients (Ollama) reach a local HTTP API through OllamaBackend —
        # they have NO CLI executable, so the "is it installed?" gate below (which only
        # makes sense for CLI agents) must be skipped. Otherwise every send to a local
        # model wrongly pops the Add-client dialog and the message never goes out.
        backend = self.backends.get(agent_key)
        client = next(
            (c for c in self.custom_clients if c.get("key") == agent_key), None
        )
        is_local_http = isinstance(backend, OllamaBackend) or (
            client is not None and "ollama_chat/" in clean_text(client.get("model"))
        )
        if not is_local_http:
            executable = self._agent_executable(agent_key)
            if not executable or not shutil.which(executable):
                self.status.set(
                    f"{self._current_agent_label()} is not installed. Use Add client to connect it."
                )
                self.open_add_client_dialog()
                return
        if agent_key == "codex":
            codex_backend = self.backends["codex"]
            if codex_backend.proc is None or codex_backend.proc.poll() is not None:
                codex_backend.stop_flag.clear()
                codex_backend.ready.clear()
                codex_backend.start(self.cwd.get())
                if not codex_backend.ready.wait(timeout=15):
                    self.status.set("Codex installed, but its local service did not start.")
                    return
        if prompt.startswith("/resume"):
            if from_composer:
                self.input.delete("1.0", "end")
            self.open_session_finder()
            return
        if prompt.startswith("/sessions"):
            if from_composer:
                self.input.delete("1.0", "end")
            self.open_session_finder()
            return
        if not os.path.isdir(self.cwd.get()):
            messagebox.showerror("Invalid directory", "Choose an existing working directory.")
            return
        if not self.current_session:
            self.current_session = self.store.new_session(self.active_agent.get(), self.cwd.get())
        if self.current_session.get("origin", "local") != "local":
            self.transfer_source_session_id = self.current_session.get("source_session_id") or self.current_session.get("id")
            self.current_session = self.store.adopt_external(self.current_session)
            self.local_sessions = self.store.list_all_local(self.active_agent.get())
            self.sessions = self._combined_sessions()
            self._render_session_list()
        backend_settings = self.current_session.setdefault("backend", {})
        backend_settings["model"] = self.selected_model.get()
        if self.active_agent.get() == "claude":
            backend_settings["orchestration_mode"] = clean_text(
                self.claude_orchestration.get("mode") or "smart"
            )
        effort = self.selected_effort.get()
        if self.active_agent.get() == "gemini" or effort == "Default":
            backend_settings.pop("effort", None)
        else:
            backend_settings["effort"] = effort
        self._remember_project(self.cwd.get())
        if from_composer:
            self.input.delete("1.0", "end")
            self._paste_stack = []  # cleared box → no pastes to undo for the next message
            self._paste_redo = []
        backend_prompt = prompt_with_authoritative_time(
            prompt_with_attachments(prompt, attachments)
        )
        if from_composer:
            self.clear_attachments()
        self.busy = True
        self._log_event(
            "turn_start",
            scope="active",
            agent=self.active_agent.get(),
            model=self.selected_model.get(),
            session=(self.current_session or {}).get("id"),
            prompt_chars=len(prompt or ""),
            from_composer=from_composer,
        )
        workspace = self.workspaces.get(self.active_workspace_id)
        if workspace:
            workspace["turn_started_at"] = time.monotonic()
            workspace["last_event_at"] = time.monotonic()
            workspace["last_progress_at"] = time.monotonic()
            workspace["live_token_count"] = 0
            workspace["stale_notice_shown"] = False
            workspace["stalled_notice_shown"] = False
            workspace["backend_failure_reported"] = False
            workspace["session_context_active"] = False
            workspace["session_context_buffer"] = ""
            self.live_token_count = 0
        self.send_btn.configure(text="Send", state="normal")
        self.stop_btn.configure(state="normal")
        self.stop_btn.pack(side="right", padx=(0, 6))

        handoff_context = clean_text(self.current_session.get("handoff_context"))
        if handoff_context and not self.current_session.get("turns"):
            context_text = handoff_context
        elif self.transfer_source_session_id and self.transfer_source_session_id != self.current_session.get("id"):
            source = self.store.get(self.transfer_source_session_id)
            if source and not self.current_session.get("turns"):
                context_text = self.store.summary_for_handoff(source)
            else:
                context_text = ""
        else:
            context_text = ""
        self_context = self._self_project_context(prompt)
        if self_context:
            context_text = "\n\n".join(part for part in (context_text, self_context) if part)

        turn = self._make_turn(prompt)
        user_item = {"type": "userMessage", "content": [{"type": "text", "text": prompt}]}
        raw_prompt, visible_prompt = strip_session_context(prompt)
        if raw_prompt and not visible_prompt:
            self.append_work(raw_prompt, "system")
            visible_prompt = ""
        elif raw_prompt and visible_prompt:
            self.append_work(raw_prompt, "system")
        user_item["content"] = [{"type": "text", "text": visible_prompt or prompt}]
        self.store.add_item(self.current_session, turn, user_item)
        if attachments:
            names = ", ".join(os.path.basename(path) for path in attachments)
            visible_prompt += f"\n\nAttached: {names}"
        self.append_chat("YOU", visible_prompt, "user")
        self.append_work("--- New turn ---", "system")
        if attachments:
            self.append_work(
                "Attached files:\n" + "\n".join(attachments),
                "fileChange",
            )
        self.status.set(f"{self._current_agent_label()} is working…")
        self.set_activity("working")
        self._persist_current()

        backend = self._current_backend()
        backend.start_turn(
            self.current_session,
            turn,
            backend_prompt,
            context_text=context_text,
        )
        self.transfer_source_session_id = None
        self._save_active_workspace()
        self._render_workspace_tabs()

    def stop(self):
        self._current_backend().interrupt()
        self.stop_btn.configure(state="disabled")
        self.status.set("Stopping current turn…")

    def _append_assistant_chunk(self, text, speaker):
        if not text:
            return
        workspace = self.workspaces.get(self.active_workspace_id)
        raw_text, visible_text = sanitize_session_context_stream(workspace, text)
        if raw_text and not visible_text:
            self.append_work(raw_text, "system")
            return
        if raw_text and visible_text:
            self.append_work(raw_text, "system")
            text = visible_text
        starts_message = not self.live_speaker
        if starts_message:
            self.live_speaker = speaker
            if self.current_turn is not None:
                self.store.add_item(self.current_session, self.current_turn, {"type": "agentMessage", "text": text})
        elif self.current_turn is not None:
            items = self.current_turn.setdefault("items", [])
            if items and items[-1].get("type") == "agentMessage":
                items[-1]["text"] = clean_text(items[-1].get("text", "") + text)
                self._autosave_stream_session()
        self._append_stream_visual(text, speaker, starts_message)

    def _log_event(self, kind, **fields):
        """Append one timestamped JSON line to debug.jsonl. Cheap (no fsync), never
        raises. This is the accurate activity log: turn timings, queue moves, errors."""
        try:
            record = {"t": now_iso(), "kind": kind}
            record.update(fields)
            with open(DEBUG_LOG_FILE, "a", encoding="utf-8") as handle:
                handle.write(json.dumps(record, default=str) + "\n")
            self._log_count = getattr(self, "_log_count", 0) + 1
            if self._log_count % 200 == 0:
                try:
                    if os.path.getsize(DEBUG_LOG_FILE) > 5_000_000:
                        os.replace(DEBUG_LOG_FILE, DEBUG_LOG_FILE + ".1")
                except OSError:
                    pass
        except Exception:
            pass

    def _autosave_stream_session(self):
        # Stream deltas update the item in memory; persist at most every 2s without
        # fsync instead of rewriting the whole session file on every token (which was
        # O(n^2) and fsync-blocked the UI). The durable save happens at turn_done.
        now = time.monotonic()
        if now - getattr(self, "_last_stream_save", 0.0) < 2.0:
            return
        self._last_stream_save = now
        if self.current_session:
            self.store.save(self.current_session, durable=False)

    def _append_stream_visual(self, text, speaker, starts_message):
        widget = self.chat
        at_bottom = widget.yview()[1] >= 0.995
        widget.configure(state="normal")
        if starts_message:
            head_tag = "assistant_head"
            if speaker == "CLAUDE":
                head_tag = "claude_head"
            elif speaker == "GEMINI":
                head_tag = "gemini_head"
            widget.insert("end", speaker, head_tag)
            widget.insert(
                "end", "   " + self._format_msg_time() + "\n", (head_tag, "msg_time")
            )
        widget.insert("end", text, "assistant")
        widget.configure(state="disabled")
        self._finish_chat_append(at_bottom)

    def _handle_background_event(self, workspace, event):
        kind = event.get("kind")
        if kind != "usage_updated":
            workspace["last_event_at"] = time.monotonic()
            workspace["stale_notice_shown"] = False
            workspace["stalled_notice_shown"] = False
        session = workspace.get("current_session")
        turn = workspace.get("current_turn")
        if kind == "usage_updated":
            workspace["usage_refreshing"] = False
            workspace["usage"] = event.get("usage") or {}
            workspace["usage_last_updated"] = now_iso()
        elif kind == "token_usage":
            usage = event.get("usage") or {}
            if usage:
                workspace["last_token_usage"] = usage
        elif kind == "external_session_loaded":
            self.loading_external_sessions.discard(
                event.get("load_key") or event.get("session_id")
            )
            if workspace.get("busy"):
                return
            session_id = event.get("session_id")
            turns = event.get("turns") or []
            title = clean_text(event.get("title"))
            _, visible_title = strip_session_context(title)
            if visible_title:
                title = visible_title
            context = event.get("context") or {}
            for candidate in workspace.get("external_sessions") or []:
                if candidate.get("id") == session_id:
                    candidate["turns"] = turns
                    candidate["transcript_loaded"] = True
                    if title:
                        candidate["title"] = title
                    if context:
                        candidate["context"] = context
            if session and session.get("id") == session_id:
                session["turns"] = turns
                session["transcript_loaded"] = True
                if title:
                    session["title"] = title
                if context:
                    session["context"] = context
                workspace["live_source_signature"] = event.get("signature")
                workspace["status"] = "Client session synchronized."
                if session.get("origin", "local") == "local":
                    self.store.save(session)
        elif kind == "status":
            workspace["status"] = event.get("text", "Ready")
        elif kind == "work" and session and turn:
            self.store.add_item(
                session,
                turn,
                {
                    "type": "system",
                    "text": event.get("text", ""),
                    "tag": event.get("tag", "system"),
                },
            )
        elif kind in {"assistant_delta", "assistant"} and session and turn:
            raw_text, text = sanitize_session_context_stream(workspace, event.get("text", ""))
            if raw_text and not text:
                self.append_work(raw_text, "system")
                text = ""
            elif raw_text and text:
                self.append_work(raw_text, "system")
            if text:
                workspace["chat_updates_pending"] = True
                items = turn.setdefault("items", [])
                if workspace.get("live_speaker") and items and items[-1].get("type") == "agentMessage":
                    items[-1]["text"] = clean_text(items[-1].get("text", "") + text)
                    self.store.save(session)
                else:
                    workspace["live_speaker"] = event.get("speaker") or "AGENT"
                    self.store.add_item(
                        session, turn, {"type": "agentMessage", "text": text}
                    )
        elif kind == "assistant_message" and session and turn:
            raw_text, text = sanitize_session_context_stream(workspace, event.get("text"))
            if raw_text and not text:
                self.append_work(raw_text, "system")
                text = ""
            elif raw_text and text:
                self.append_work(raw_text, "system")
            if text:
                workspace["chat_updates_pending"] = True
                workspace["latest_agent_text"] = text
                self.store.add_item(
                    session, turn, {"type": "agentMessage", "text": text}
                )
        elif kind == "assistant_done":
            workspace["live_speaker"] = None
            workspace["session_context_active"] = False
            workspace["session_context_buffer"] = ""
            if session:
                self._refresh_handoff_stage(session)
        elif kind == "user_input_request":
            questions = (event.get("params") or {}).get("questions") or []
            text = "\n".join(
                clean_text(question.get("question")) for question in questions
            )
            workspace["pending_user_input"] = {
                "request_id": event.get("request_id"),
                "questions": questions,
            }
            workspace["status"] = "Codex is waiting for your answer."
            workspace["activity_state"] = "input"
            workspace["activity_text"] = "Needs input"
            if session and turn and text:
                self.store.add_item(
                    session, turn, {"type": "agentMessage", "text": text}
                )
        elif kind == "turn_done":
            status = event.get("status", "completed")
            if session and turn:
                self.store.finish_turn(session, turn, status=status)
                sync_claude_session_title(session)
                self._refresh_handoff_stage(session)
                self._mark_worker_job(
                    session,
                    "completed" if status == "completed" else "error",
                    event.get("error"),
                )
            workspace["busy"] = False
            workspace["tab_done"] = True  # finished → green until this tab is viewed
            workspace["turn_started_at"] = 0.0
            workspace["pending_user_input"] = None
            workspace["live_speaker"] = None
            # Preserve finished sub-agents for the Spawned tab; only clear
            # entries that are still "running" (stale state from aborted turns).
            workspace["live_subagents"] = [
                s for s in (workspace.get("live_subagents") or [])
                if s.get("status", "running") not in ("running", "in_progress", "pending")
            ]
            workspace["primary_model"] = ""
            workspace["session_context_active"] = False
            workspace["session_context_buffer"] = ""
            workspace["live_token_count"] = 0
            self.live_token_count = 0
            self._update_worker_indicator()
            if status == "completed":
                workspace["status"] = "Ready"
                workspace["activity_state"] = "idle"
                workspace["activity_text"] = "Ready"
            else:
                failure = turn_failure_text(status, event.get("error"), session)
                workspace["status"] = "Error: " + failure
                workspace["activity_state"] = "error"
                workspace["activity_text"] = "Turn failed"
                if session and turn:
                    self.store.add_item(
                        session,
                        turn,
                        {"type": "note", "text": "ERROR: " + failure},
                    )
            # Advance this background tab's queue so queued work runs across tabs.
            self.win.after(0, lambda ws=workspace: self._drain_workspace_queue(ws))
        elif kind == "error":
            text = event.get("text", "Error")
            if session and turn:
                self.store.add_item(
                    session, turn, {"type": "note", "text": "ERROR: " + text}
                )
                self.store.finish_turn(session, turn, status="error")
                self._refresh_handoff_stage(session)
                self._mark_worker_job(session, "error", text)
            workspace["busy"] = False
            workspace["turn_started_at"] = 0.0
            workspace["pending_user_input"] = None
            workspace["session_context_active"] = False
            workspace["session_context_buffer"] = ""
            workspace["live_token_count"] = 0
            self.live_token_count = 0
            workspace["status"] = "Error: " + text
            workspace["activity_state"] = "error"
            workspace["activity_text"] = "Error"
        elif kind == "backend_exit":
            workspace["status"] = event.get("text", "Backend stopped")
            workspace["busy"] = False
            workspace["turn_started_at"] = 0.0
            workspace["session_context_active"] = False
            workspace["session_context_buffer"] = ""
            workspace["live_token_count"] = 0
            self.live_token_count = 0
            workspace["activity_state"] = "error"
            workspace["activity_text"] = "Error"
            if session:
                self._mark_worker_job(
                    session,
                    "interrupted",
                    event.get("text", "Backend stopped"),
                )
        elif kind == "context_usage" and session:
            context = event.get("context") or {}
            if context:
                previous = session.get("context") or {}
                context["compact_count"] = previous.get("compact_count", 0)
                session["context"] = context
                self.store.save(session)
                self._refresh_handoff_stage(session)
        self._render_workspace_tabs()

    def handle_event(self, event):
        workspace_id = event.get("workspace_id")
        if workspace_id and workspace_id != self.active_workspace_id:
            workspace = self.workspaces.get(workspace_id)
            if workspace:
                self._handle_background_event(workspace, event)
            return
        kind = event.get("kind")
        # Session isolation: a session-mutating event that is NOT attributed to a
        # workspace must never be written into whatever session is in the
        # foreground. Every real backend/app event carries workspace_id, so this
        # only fires on a bug/regression — drop + log rather than let one
        # session's turns leak into another (Pig Farm ↔ Agent Workbench audit).
        if not workspace_id and kind in SESSION_MUTATING_KINDS:
            self._log_event("dropped_unattributed_event", kind=kind)
            return
        active_workspace = self.workspaces.get(self.active_workspace_id)
        if active_workspace and kind != "usage_updated":
            active_workspace["last_event_at"] = time.monotonic()
            active_workspace["stale_notice_shown"] = False
            active_workspace["stalled_notice_shown"] = False
        if kind == "usage_updated":
            usage = event.get("usage") or {}
            if active_workspace:
                active_workspace["usage_refreshing"] = False
                active_workspace["usage"] = usage
                active_workspace["usage_last_updated"] = now_iso()
            self._display_usage(usage)
            if event.get("manual"):
                windows = usage.get("windows") or []
                if windows:
                    details = []
                    for window in windows:
                        detail = (
                            f"{window.get('label')} "
                            f"{int(window.get('used_percent') or 0)}% used"
                        )
                        if window.get("reset"):
                            detail += f" · resets {window.get('reset')}"
                        details.append(detail)
                    self.status.set(
                        f"{usage.get('provider', 'Client')} limits: "
                        + "; ".join(details)
                    )
                else:
                    self.status.set(
                        f"{usage.get('provider', 'Client')} limits unavailable: "
                        f"{usage.get('error', 'no telemetry returned')}"
                    )
        elif kind == "token_usage":
            usage = event.get("usage") or {}
            if usage and active_workspace:
                active_workspace["last_token_usage"] = usage
                self.last_token_usage = usage
        elif kind == "status":
            self.status.set(event.get("text", "Ready"))
        elif kind == "work":
            if active_workspace:
                active_workspace["last_progress_at"] = time.monotonic()
            self.append_work(event.get("text", ""), event.get("tag", "system"))
            if self.current_turn is not None:
                self.store.add_item(
                    self.current_session,
                    self.current_turn,
                    {"type": "system", "text": event.get("text", ""), "tag": event.get("tag", "system")},
                )
        elif kind == "active_model":
            model = event.get("model") or ""
            if active_workspace:
                active_workspace["live_model"] = model
                # Establish the turn's primary (main-agent) model from the first
                # model seen this turn.
                if not active_workspace.get("primary_model") and model:
                    active_workspace["primary_model"] = model
                primary = active_workspace.get("primary_model") or ""
                # A streamed model different from the primary means an in-turn
                # subagent is running (e.g. Opus delegating to Sonnet). Claude
                # Code doesn't reliably emit a Task tool_use we can catch, so
                # infer the subagent from the model handoff — but only as a
                # fallback when no explicit (Task-based) subagent is tracked, to
                # avoid double-counting.
                live = active_workspace.setdefault("live_subagents", [])
                live[:] = [s for s in live if not s.get("model_inferred")]
                has_explicit = any(not s.get("model_inferred") for s in live)
                if model and primary and model != primary and not has_explicit:
                    live.append({
                        "name": claude_model_alias(model).title() or "sub-agent",
                        "detail": "model handoff",
                        "started_at": now_iso(),
                        "model_inferred": True,
                    })
                self._update_worker_indicator()
            self.live_model = model
        elif kind == "subagent_start":
            if active_workspace:
                live = active_workspace.setdefault("live_subagents", [])
                aid = event.get("agent_id") or ""
                existing = next((s for s in live if aid and s.get("id") == aid and not s.get("model_inferred")), None)
                if existing:
                    if event.get("name"): existing["name"] = event.get("name")
                    if event.get("detail"): existing["detail"] = event.get("detail")
                    if event.get("task_id"): existing["task_id"] = event.get("task_id")
                else:
                    live.append({
                        "id": aid,
                        "task_id": event.get("task_id") or "",
                        "name": event.get("name") or "sub-agent",
                        "detail": event.get("detail") or "",
                        "status": "running",
                        "started_at": now_iso(),
                    })
                    if len(live) > 50:
                        active_workspace["live_subagents"] = live[-50:]
                self._update_worker_indicator()
                self._refresh_spawned_tab()
        elif kind == "subagent_update":
            if active_workspace:
                live = active_workspace.get("live_subagents") or []
                tid = event.get("task_id") or ""
                status = event.get("status") or ""
                if tid and status:
                    for s in live:
                        if s.get("task_id") == tid:
                            was_running = s.get("status", "running") in ("running", "in_progress", "pending")
                            s["status"] = status
                            if status not in ("running", "in_progress", "pending"):
                                s["ended_at"] = now_iso()
                                # task_updated usually reports completion before
                                # task_notification, so log the finish here on the
                                # running→done transition (subagent_done/_stop guard
                                # against a duplicate line).
                                if was_running:
                                    self.append_work(f"✓ Sub-agent finished: {clean_text(s.get('name')) or 'sub-agent'}", "done")
                            break
                self._update_worker_indicator()
                self._refresh_spawned_tab()
        elif kind == "subagent_done":
            if active_workspace:
                live = active_workspace.get("live_subagents") or []
                aid = event.get("agent_id") or ""
                tid = event.get("task_id") or ""
                target = next((s for s in live if (aid and s.get("id") == aid) or (tid and s.get("task_id") == tid)), None)
                if target:
                    already_done = target.get("status", "running") not in ("running", "in_progress", "pending")
                    target["status"] = event.get("status") or "completed"
                    target["ended_at"] = now_iso()
                    if event.get("summary"): target["summary"] = event.get("summary")
                    target["total_tokens"] = event.get("total_tokens") or 0
                    target["duration_ms"] = event.get("duration_ms") or 0
                    if not already_done:
                        self.append_work(f"✓ Sub-agent finished: {clean_text(target.get('name')) or 'sub-agent'}", "done")
                self._update_worker_indicator()
                self._refresh_spawned_tab()
        elif kind == "subagent_stop":
            if active_workspace:
                live = active_workspace.get("live_subagents") or []
                target_id = event.get("agent_id") or ""
                if target_id:
                    for s in live:
                        if s.get("id") == target_id and s.get("status", "running") == "running":
                            s["status"] = "completed"
                            s["ended_at"] = now_iso()
                            self.append_work(f"✓ Sub-agent finished: {clean_text(s.get('name')) or 'sub-agent'}", "done")
                            break
                self._update_worker_indicator()
                self._refresh_spawned_tab()
        elif kind == "assistant_begin":
            pass
        elif kind == "assistant_delta":
            speaker = event.get("speaker") or self._current_agent_label().upper()
            if active_workspace:
                active_workspace["last_progress_at"] = time.monotonic()
                active_workspace["live_token_count"] = int(active_workspace.get("live_token_count") or 0) + estimate_tokens(event.get("text", ""))
                self.live_token_count = active_workspace["live_token_count"]
            self._append_assistant_chunk(event.get("text", ""), speaker)
        elif kind == "assistant":
            speaker = event.get("speaker") or self._current_agent_label().upper()
            text = event.get("text", "")
            if active_workspace:
                active_workspace["last_progress_at"] = time.monotonic()
                if int(active_workspace.get("live_token_count") or 0) <= 0:
                    active_workspace["live_token_count"] = estimate_tokens(text)
                self.live_token_count = active_workspace["live_token_count"]
            self._append_assistant_chunk(text, speaker)
        elif kind == "assistant_message":
            speaker = event.get("speaker") or self._current_agent_label().upper()
            raw_text, text = sanitize_session_context_stream(active_workspace, event.get("text"))
            if text:
                if active_workspace:
                    active_workspace["last_progress_at"] = time.monotonic()
                    if int(active_workspace.get("live_token_count") or 0) <= 0:
                        active_workspace["live_token_count"] = estimate_tokens(text)
                    self.live_token_count = active_workspace["live_token_count"]
                self.append_chat(speaker, text, "assistant")
                if self.current_turn is not None:
                    self.store.add_item(
                        self.current_session,
                        self.current_turn,
                        {"type": "agentMessage", "text": text},
                    )
            elif raw_text:
                self.append_work(raw_text, "system")
        elif kind == "assistant_done":
            if self.live_speaker:
                widget = self.chat
                at_bottom = widget.yview()[1] >= 0.995
                widget.configure(state="normal")
                # Copy button for the just-finished streamed message — pull its full
                # text from the turn's stored agentMessage so the button copies it all.
                streamed = ""
                if self.current_turn:
                    for it in reversed(self.current_turn.get("items") or []):
                        if it.get("type") == "agentMessage":
                            streamed = clean_text(it.get("text"))
                            break
                if streamed:
                    self._insert_copy_button(streamed)
                    widget.insert("end", "\n")
                else:
                    widget.insert("end", "\n\n")
                widget.configure(state="disabled")
                self._finish_chat_append(at_bottom)
            self.live_speaker = None
            if active_workspace:
                active_workspace["session_context_active"] = False
                active_workspace["session_context_buffer"] = ""
            self._persist_current()
        elif kind == "user_input_request":
            params = event.get("params") or {}
            questions = params.get("questions") or []
            lines = []
            for index, question in enumerate(questions, start=1):
                prefix = f"{index}. " if len(questions) > 1 else ""
                lines.append(prefix + clean_text(question.get("question")))
                options = question.get("options") or []
                if options:
                    labels = [clean_text(option.get("label")) for option in options]
                    lines.append("Options: " + " | ".join(label for label in labels if label))
            if len(questions) > 1:
                lines.append("Reply with one answer per line.")
            text = "\n".join(line for line in lines if line)
            self.pending_user_input = {
                "request_id": event.get("request_id"),
                "questions": questions,
            }
            self.append_chat("CODEX NEEDS INPUT", text, "assistant")
            if self.current_turn is not None:
                self.store.add_item(
                    self.current_session,
                    self.current_turn,
                    {"type": "agentMessage", "text": text},
                )
            self.send_btn.configure(text="Reply", state="normal")
            self.stop_btn.pack_forget()
            self.status.set("Codex is waiting for your answer.")
            self.set_activity("input")
            self.notebook.select(self.chat_tab)
            self.input.focus_set()
        elif kind == "turn_done":
            status = event.get("status", "completed")
            _ws = self.workspaces.get(self.active_workspace_id) or {}
            _started = float(_ws.get("turn_started_at") or 0.0)
            self._log_event(
                "turn_done",
                scope="active",
                status=status,
                elapsed_ms=int((time.monotonic() - _started) * 1000) if _started else None,
                queued=len(self.queued_prompts or []),
                session=(self.current_session or {}).get("id"),
            )
            if self.current_turn is not None:
                self.store.finish_turn(self.current_session, self.current_turn, status=status)
            sync_claude_session_title(self.current_session)
            self._refresh_handoff_stage(self.current_session)
            self._mark_worker_job(
                self.current_session,
                "completed" if status == "completed" else "error",
                event.get("error"),
            )
            self.busy = False
            self.refresh_usage(manual=False)  # refresh 5h/weekly usage right after a turn
            active_workspace = self.workspaces.get(self.active_workspace_id)
            if active_workspace:
                active_workspace["turn_started_at"] = 0.0
                active_workspace["tab_done"] = True  # finished → green (clears on next view)
                active_workspace["session_context_active"] = False
                active_workspace["session_context_buffer"] = ""
            self.pending_user_input = None
            self.send_btn.configure(text="Send", state="normal")
            self.stop_btn.pack_forget()
            if status == "completed":
                self.status.set("Ready")
                self.set_activity("idle")
            else:
                failure = turn_failure_text(
                    status,
                    event.get("error"),
                    self.current_session,
                )
                self.status.set("Error: " + failure)
                self.append_work("ERROR: " + failure, "system")
                if self.current_turn is not None:
                    self.store.add_item(
                        self.current_session,
                        self.current_turn,
                        {"type": "note", "text": "ERROR: " + failure},
                    )
                self.set_activity("error", "Turn failed")
            self._persist_current()
            self.refresh_artifacts_view(self.current_session)
            self._render_session_list()
            self.refresh_usage(manual=False)
            if not self._maybe_auto_deploy_handoff(self.current_session):
                self.win.after(0, self._send_next_queued_prompt)
        elif kind == "error":
            text = event.get("text", "Error")
            self.status.set("Error: " + text)
            self.append_work("ERROR: " + text, "system")
            if self.current_turn is not None:
                self.store.add_item(self.current_session, self.current_turn, {"type": "note", "text": "ERROR: " + text})
                self.store.finish_turn(self.current_session, self.current_turn, status="error")
            self._mark_worker_job(self.current_session, "error", text)
            self.busy = False
            active_workspace = self.workspaces.get(self.active_workspace_id)
            if active_workspace:
                active_workspace["turn_started_at"] = 0.0
                active_workspace["session_context_active"] = False
                active_workspace["session_context_buffer"] = ""
            self.pending_user_input = None
            self.send_btn.configure(text="Send", state="normal")
            self.stop_btn.pack_forget()
            self.set_activity("error")
            self._persist_current()
            self.refresh_artifacts_view(self.current_session)
            self._render_session_list()
            self.win.after(0, self._send_next_queued_prompt)
        elif kind == "backend_exit":
            self.status.set(event.get("text", "Backend stopped"))
            self._mark_worker_job(
                self.current_session,
                "interrupted",
                event.get("text", "Backend stopped"),
            )
            if self.busy:
                self.busy = False
                active_workspace = self.workspaces.get(self.active_workspace_id)
                if active_workspace:
                    active_workspace["turn_started_at"] = 0.0
                    active_workspace["session_context_active"] = False
                    active_workspace["session_context_buffer"] = ""
                self.pending_user_input = None
                self.send_btn.configure(text="Send", state="normal")
                self.stop_btn.pack_forget()
                self.set_activity("error")
        elif kind == "context_usage":
            context = event.get("context") or {}
            if self.current_session and context:
                previous = self.current_session.get("context") or {}
                context["compact_count"] = previous.get("compact_count", 0)
                self.current_session["context"] = context
                if self.current_session.get("origin", "local") == "local":
                    self.store.save(self.current_session)
                self.update_context_indicator(context)
        elif kind == "external_session_loaded":
            session_id = event.get("session_id")
            self.loading_external_sessions.discard(
                event.get("load_key") or session_id
            )
            if self.busy:
                return
            turns = event.get("turns") or []
            source_title = clean_text(event.get("title"))
            _, visible_title = strip_session_context(source_title)
            if visible_title:
                source_title = visible_title
            context = event.get("context") or {}
            for session in self.external_sessions:
                if session.get("id") == session_id:
                    session["turns"] = turns
                    session["transcript_loaded"] = True
                    if source_title:
                        session["title"] = source_title
                    if context:
                        session["context"] = context
                    break
            if self.current_session and self.current_session.get("id") == session_id:
                chat_at_bottom = self.chat.yview()[1] >= 0.995
                work_at_bottom = self.work.yview()[1] >= 0.995
                self.current_session["turns"] = turns
                self.current_session["transcript_loaded"] = True
                if source_title:
                    self.current_session["title"] = source_title
                if context:
                    self.current_session["context"] = context
                    self.update_context_indicator(context)
                self.current_session["updated_at"] = now_iso()
                self.live_source_signature = event.get("signature")
                if self.current_session.get("origin", "local") == "local":
                    self.store.save(self.current_session)
                    if not chat_at_bottom:
                        self.chat_updates_pending = True
                        self._update_chat_update_indicator()
                    self.status.set("Claude session synchronized.")
                    if not self.busy:
                        self.set_activity("idle", "Ready")
                    return
                chat_anchor = self.chat.index("@0,0")
                work_anchor = self.work.index("@0,0")

                def restore_reading_position():
                    if not chat_at_bottom:
                        self.chat.yview(chat_anchor)
                        self.chat_updates_pending = True
                        self._update_chat_update_indicator()
                    else:
                        self.scroll_chat_to_latest()
                    if not work_at_bottom:
                        self.work.yview(work_anchor)

                self._clear_views(clear_attachments=False)
                self._render_session(
                    self.current_session,
                    on_complete=restore_reading_position,
                )
                self._render_session_list()
                self.refresh_artifacts_view(self.current_session)
                self.status.set("Claude session synchronized.")
                self.set_activity("idle", "Ready")
        elif kind == "terminal_output":
            self.append_terminal(event.get("text", ""))
        elif kind == "terminal_clear":
            self.clear_terminal()
        elif kind == "terminal_exit":
            status = event.get("status")
            self.append_terminal(f"\n[Shell exited{'' if status is None else f' with status {status}'}]\n")

    def drain_events(self):
        processed = False
        try:
            while True:
                event = self.events.get_nowait()
                try:
                    self.handle_event(event)
                except Exception as exc:
                    # Never let one bad event kill the loop or stall the queue.
                    self._log_event("handler_error", kind=event.get("kind"), error=repr(exc))
                processed = True
                self._maybe_finish_deferred_close()
                if self.finalizing_close:
                    return
        except queue.Empty:
            pass
        # Persist + re-render at most ONCE per drain tick (every 50ms), not once per
        # event. During streaming that's hundreds of events per second — doing disk
        # writes and tab rebuilds per event was the main source of stalling.
        if processed:
            self._schedule_workspace_config_save()
            self._render_workspace_tabs()
        self.win.after(50, self.drain_events)

    def request_close(self):
        if self.finalizing_close:
            return
        self._save_active_workspace()
        self._schedule_workspace_config_save(immediate=True)
        working = self._working_workspace_labels()
        if not working:
            self.finalize_close()
            return
        if self.close_when_idle:
            messagebox.showinfo(
                "Waiting for active tasks",
                (
                    "Agent Workbench will close automatically after the current "
                    "tasks finish.\n\nStill running:\n- "
                    + "\n- ".join(working)
                ),
                parent=self.win,
            )
            return
        if not messagebox.askyesno(
            "Tasks are still running",
            (
                "Closing now would stop active agent work.\n\n"
                "Wait for these tasks to finish, then close automatically?\n\n- "
                + "\n- ".join(working)
            ),
            parent=self.win,
        ):
            return
        self.close_when_idle = True
        self.win.title(f"{APP_NAME} · Waiting for {len(working)} task(s)")
        self.status.set(
            "Close queued. Workbench will exit after all active tasks finish."
        )
        if not self.pending_user_input:
            self.send_btn.configure(state="disabled")
        self._render_workspace_tabs()

    def request_restart(self):
        if self.finalizing_close:
            return
        self.restart_after_close = True
        self._save_active_workspace()
        self._schedule_workspace_config_save(immediate=True)
        working = self._working_workspace_labels()
        if not working:
            self.finalize_close()
            return
        self.close_when_idle = True
        self.win.title(f"{APP_NAME} · Update waiting for {len(working)} task(s)")
        self.status.set(
            "Update installed. Restart queued after all active tasks finish."
        )
        if not self.pending_user_input:
            self.send_btn.configure(state="disabled")
        self._render_workspace_tabs()

    def finalize_close(self):
        if self.finalizing_close:
            return
        self.finalizing_close = True
        self._hide_session_tooltip()
        self._save_active_workspace()
        self._persist_workspace_config()
        self._persist_current()
        for workspace in self.workspaces.values():
            for backend in workspace["backends"].values():
                try:
                    backend.close()
                except Exception:
                    pass
        self.terminal_shell.close()
        if self.restart_after_close:
            try:
                fcntl.flock(INSTANCE_LOCK, fcntl.LOCK_UN)
                executable = os.path.abspath(__file__)
                subprocess.Popen(
                    [
                        "/bin/bash",
                        "-c",
                        'sleep 0.5; exec "$1" "$2"',
                        "agent-workbench-restart",
                        sys.executable,
                        executable,
                    ],
                    cwd=os.path.expanduser("~"),
                    start_new_session=True,
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                )
            except OSError:
                pass
        self.win.destroy()

if __name__ == "__main__":
    app = App()
    app.win.mainloop()
