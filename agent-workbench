    def refresh_artifacts_view(self, session=None):
        session = session or self.current_session
        self.artifact_list.delete(0, "end")
        self.artifacts = self._artifact_items_for_session(session) if session else []
        for item in self.artifacts:
            self.artifact_list.insert("end", item["label"])
        if self.artifacts:
            self.artifact_list.selection_set(0)

    def open_selected_artifact(self):
        if not getattr(self, "artifacts", None):
            return
        selection = self.artifact_list.curselection()
        if not selection:
            return
        idx = selection[0]
        if idx >= len(self.artifacts):
            return
        path = self.artifacts[idx]["path"]
        if not path:
            return
        try:
            subprocess.Popen(["xdg-open", path])
        except Exception as exc:
            messagebox.showerror("Open artifact", str(exc))

    def append_terminal(self, text):
        if not text:
            return
        at_bottom = self.terminal.yview()[1] >= 0.995
        self.terminal.configure(state="normal")
        self.terminal.insert("end", text)
        self.terminal.configure(state="disabled")
        if at_bottom:
            self.terminal.see("end")

    def clear_terminal(self):
        self.terminal.configure(state="normal")
        self.terminal.delete("1.0", "end")
        self.terminal.configure(state="disabled")

    def submit_terminal_command(self, _event=None):
        command = self.terminal_input.get()
        self.terminal_input.delete(0, "end")
        if not command.strip():
            self.terminal_shell.send("\n")
            return "break"
        if command.strip() in {"clear", "reset"}:
            self.clear_terminal()
        self.terminal_history.append(command)
        self.terminal_history = self.terminal_history[-200:]
        self.terminal_history_index = len(self.terminal_history)
        if not self.terminal_shell.send(command + "\n"):
            self.restart_terminal()
            self.terminal_shell.send(command + "\n")
        return "break"

    def recall_terminal_history(self, direction):
        if not self.terminal_history:
            return "break"
        self.terminal_history_index = max(
            0,
            min(
                len(self.terminal_history),
                self.terminal_history_index + direction,
            ),
        )
        text = (
            self.terminal_history[self.terminal_history_index]
            if self.terminal_history_index < len(self.terminal_history)
            else ""
        )
        self.terminal_input.delete(0, "end")
        self.terminal_input.insert(0, text)
        self.terminal_input.icursor("end")
        return "break"

    def interrupt_terminal(self):
        self.terminal_shell.interrupt()
        return "break"

    def restart_terminal(self):
        self.append_terminal("\n[Restarting shell]\n")
        self.terminal_shell.start(self.cwd.get())

