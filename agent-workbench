def delete_client_session(session):
    agent = clean_text((session or {}).get("agent"))
    backend = (session or {}).get("backend") or {}
    session_id = clean_text(
        (session or {}).get("source_session_id")
        or backend.get("session_id")
        or backend.get("thread_id")
    )
    if not session_id:
        return False, True, ""

    if agent == "claude":
        try:
            session_id = clean_text(session_id)
            path = linked_claude_session_path(session)
            marker = os.path.splitext(os.path.basename(path))[0] if path else session_id
            cache_root = claude_session_cache_root((session or {}).get("cwd"))
            candidates = [Path(path)] if path else []
            if os.path.isdir(cache_root):
                candidates.extend(Path(cache_root).glob(f"{marker}.jsonl"))
            project_root = Path(os.path.expanduser("~/.claude/projects"))
            if project_root.is_dir():
                candidates.extend(project_root.glob(f"*/{marker}.jsonl"))
            if not candidates:
                return True, True, ""
            for candidate in {candidate for candidate in candidates if candidate.is_file()}:
                try:
                    candidate.unlink()
                except OSError:
                    pass
            return True, True, ""
        except OSError as exc:
            return True, False, str(exc)

    if agent == "codex":
        try:
            result = subprocess.run(
                ["codex", "archive", session_id],
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                timeout=15,
                check=False,
            )
        except (OSError, subprocess.TimeoutExpired) as exc:
            return True, False, str(exc)
        if result.returncode == 0:
            return True, True, ""
        return True, False, clean_text(result.stdout) or "Codex could not archive the session."

    if agent == "gemini":
        cwd = clean_text((session or {}).get("cwd")) or os.path.expanduser("~")
        command = [
            "gemini",
            "--list-sessions",
            "--skip-trust",
            "--yolo",
            "--include-directories",
            cwd,
        ]
        try:
            listed = subprocess.run(
                command,
                cwd=cwd,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                timeout=15,
                check=False,
            )
        except (OSError, subprocess.TimeoutExpired) as exc:
            return True, False, str(exc)
        index = ""
        for line in (listed.stdout or "").splitlines():
            if f"[{session_id}]" not in line:
                continue
            match = re.match(r"\s*(\d+)\.", line)
            if match:
                index = match.group(1)
                break
        if not index:
            return True, False, "Gemini session was not found in its session list."
        try:
            deleted = subprocess.run(
                [
                    "gemini",
                    "--delete-session",
                    index,
                    "--skip-trust",
                    "--yolo",
                    "--include-directories",
                    cwd,
                ],
                cwd=cwd,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                timeout=15,
                check=False,
            )
        except (OSError, subprocess.TimeoutExpired) as exc:
            return True, False, str(exc)
        if deleted.returncode == 0:
            return True, True, ""
        return True, False, clean_text(deleted.stdout) or "Gemini could not delete the session."

    return False, True, ""


def gemini_sessions_for_cwd(cwd):
    cmd = [
        "gemini",
        "--list-sessions",
        "--skip-trust",
        "--yolo",
        "--include-directories",
        cwd,
    ]
    try:
        result = subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=12,
            check=False,
        )
    except Exception:
        return []
    title_cache = load_json(GEMINI_TITLE_CACHE_FILE, {})
    if not isinstance(title_cache, dict):
        title_cache = {}
    cache_changed = False
    sessions = []
    seen = set()
    for line in (result.stdout or "").splitlines():
        line = clean_text(ANSI_ESCAPE.sub("", line))
        if not line:
            continue
        if line.startswith("Available sessions for this project"):
            continue
        if line.startswith("YOLO mode is enabled"):
            continue
        if line.startswith("[SessionSummary]"):
            continue
        match = re.match(
            r"^\s*\d+\.\s+(.*?)\s+\(([^()]*)\)\s+"
            r"\[([0-9a-fA-F-]{36})\]\s*$",
            line,
        )
        if not match:
            continue
        title, age, sid = (clean_text(value) for value in match.groups())
        if sid in seen:
            continue
        seen.add(sid)
        _, visible_title = strip_session_context(title)
        if visible_title:
            title = visible_title
        elif title.lower().startswith(SESSION_CONTEXT_OPEN):
            title = "Gemini session"
        if title and title != "Gemini session":
            if clean_text(title_cache.get(sid)) != title:
                title_cache[sid] = title
                cache_changed = True
        source_path = gemini_session_path(sid)
        try:
            mtime = os.path.getmtime(source_path) if source_path else time.time()
        except OSError:
            mtime = time.time()
        sessions.append(
            {
                "id": f"gemini-terminal:{sid}",
                "source_session_id": sid,
                "agent": "gemini",
                "origin": "gemini-terminal",
                "cwd": cwd,
                "title": title or "Gemini session",
                "preview": title or "Gemini session",
                "created_at": iso_from_unix(mtime),
                "updated_at": iso_from_unix(mtime),
                "age": age,
                "source_path": source_path,
                "backend": {"session_id": sid},
                "turns": [],
                "transcript_loaded": not bool(source_path),
            }
        )
    project_hash = hashlib.sha256(
        os.path.abspath(os.path.expanduser(cwd)).encode("utf-8")
    ).hexdigest()
    for sid, metadata in gemini_session_index().items():
        if sid in seen or metadata.get("project_hash") != project_hash:
            continue
        source_path = metadata.get("path") or ""
        title = (
            clean_text(title_cache.get(sid))
            or gemini_title_from_jsonl(source_path)
            or "Gemini session"
        )
        sessions.append(
            {
                "id": f"gemini-terminal:{sid}",
                "source_session_id": sid,
                "agent": "gemini",
                "origin": "gemini-terminal",
                "cwd": cwd,
                "title": title,
                "preview": title,
                "created_at": metadata.get("start_time") or now_iso(),
                "updated_at": metadata.get("last_updated") or now_iso(),
                "age": "",
                "source_path": source_path,
                "backend": {"session_id": sid},
                "turns": [],
                "transcript_loaded": not bool(source_path),
            }
        )
    if cache_changed:
        save_json(GEMINI_TITLE_CACHE_FILE, title_cache)
    sessions.sort(key=lambda session: session.get("updated_at") or "", reverse=True)
    return sessions


@lru_cache(maxsize=1)
def gemini_session_index():
    home = Path(os.path.expanduser("~/.gemini"))
    index = {}
    for root in (home / "tmp", home / "history"):
        if not root.is_dir():
            continue
        for candidate in root.glob("*/chats/session-*.jsonl"):
            try:
                with candidate.open(encoding="utf-8") as handle:
                    header = json.loads(handle.readline())
                sid = clean_text(header.get("sessionId"))
                if not sid:
                    continue
                mtime = candidate.stat().st_mtime_ns
            except (OSError, ValueError, TypeError):
                continue
            existing = index.get(sid)
            if existing and int(existing.get("mtime") or 0) >= mtime:
                continue
            index[sid] = {
                "path": str(candidate),
                "project_hash": clean_text(header.get("projectHash")),
                "start_time": clean_text(header.get("startTime")),
                "last_updated": iso_from_unix(candidate.stat().st_mtime),
                "mtime": mtime,
            }
    return index


@lru_cache(maxsize=256)
def gemini_session_path(session_id):
    sid = clean_text(session_id)
    if not sid:
        return ""
    return clean_text((gemini_session_index().get(sid) or {}).get("path"))


@lru_cache(maxsize=256)
def gemini_title_from_jsonl(path):
    if not path or not os.path.isfile(path):
        return ""

    def visible_user_text(message):
        if not isinstance(message, dict) or message.get("type") != "user":
            return ""
        parts = []
        for block in message.get("content") or []:
            if isinstance(block, dict) and block.get("text"):
                parts.append(clean_text(block.get("text")))
        prompt = clean_text("\n".join(parts))
        _, visible = strip_session_context(prompt)
        visible = visible or (
            "" if prompt.lower().startswith(SESSION_CONTEXT_OPEN) else prompt
        )
        visible = re.sub(
            r"^Previous\s+\w+\s+session\s+for\s+[^:]+:\s*"
            r"No prior details available\.\s*",
            "",
            visible,
            flags=re.IGNORECASE,
        )
        return clean_text(visible)

    try:
        with open(path, encoding="utf-8") as handle:
            for index, line in enumerate(handle):
                if index > 500:
                    break
                try:
                    obj = json.loads(line)
                except ValueError:
                    continue
                messages = []
                if isinstance(obj, dict) and isinstance(obj.get("$set"), dict):
                    value = obj["$set"].get("messages")
                    if isinstance(value, list):
                        messages = value
                elif isinstance(obj, dict):
                    messages = [obj]
                for message in messages:
                    text = visible_user_text(message)
                    if text:
                        return shorten(text, 80)
    except OSError:
        pass
    return ""


def gemini_jsonl_turns(path):
    if not path or not os.path.isfile(path):
        return []
    try:
        with open(path, encoding="utf-8") as handle:
            messages = []
            seen_message_ids = set()
            for line in handle:
                try:
                    obj = json.loads(line)
                except ValueError:
                    continue
                if isinstance(obj, dict) and isinstance(obj.get("$set"), dict):
                    payload = obj["$set"].get("messages")
                    if isinstance(payload, list):
                        messages = payload
                        seen_message_ids = {
                            clean_text(message.get("id"))
                            for message in messages
                            if isinstance(message, dict)
                            and clean_text(message.get("id"))
                        }
                    continue
                if not isinstance(obj, dict) or obj.get("type") not in {
                    "user",
                    "gemini",
                }:
                    continue
                message_id = clean_text(obj.get("id"))
                if message_id and message_id in seen_message_ids:
                    continue
                messages.append(obj)
                if message_id:
                    seen_message_ids.add(message_id)
    except OSError:
        return []
    turns = []
    current = None

    def ensure_turn(timestamp=""):
        nonlocal current
        if current is None:
            current = {
                "id": str(uuid.uuid4()),
                "created_at": clean_text(timestamp) or now_iso(),
                "status": "completed",
                "items": [],
            }
            turns.append(current)
        return current

    def append_reasoning(text):
        if isinstance(text, list):
            text = "\n".join(clean_text(part) for part in text if clean_text(part))
        text = clean_text(text)
        if text:
            ensure_turn().setdefault("items", []).append(
                {"type": "reasoning", "summary": [text]}
            )

    def append_system(text, tag="system"):
        text = clean_text(text)
        if text:
            ensure_turn().setdefault("items", []).append(
                {"type": "system", "text": text, "tag": tag}
            )

    for message in messages:
        if not isinstance(message, dict):
            continue
        message_type = message.get("type")
        timestamp = clean_text(message.get("timestamp"))
        content = message.get("content") or []
        if not isinstance(content, list):
            content = []
        if message_type == "user":
            text_parts = []
            tool_results = []
            for block in content:
                if not isinstance(block, dict):
                    continue
                if block.get("text"):
                    text_parts.append(clean_text(block.get("text")))
                elif block.get("functionResponse"):
                    tool_results.append(block["functionResponse"])
                elif block.get("type") == "tool_result":
                    tool_results.append(block)
            prompt = clean_text("\n".join(part for part in text_parts if part))
            raw_prompt, visible_prompt = strip_session_context(prompt)
            if raw_prompt and not visible_prompt:
                append_system(raw_prompt, "system")
                prompt = ""
            elif raw_prompt and visible_prompt:
                append_system(raw_prompt, "system")
                prompt = visible_prompt
            if prompt:
                current = {
                    "id": message.get("id") or str(uuid.uuid4()),
                    "created_at": timestamp or now_iso(),
                    "status": "completed",
                    "items": [
                        {
                            "type": "userMessage",
                            "content": [{"type": "text", "text": prompt}],
                        }
                    ],
                }
                turns.append(current)
            if tool_results:
                ensure_turn(timestamp)
                for tool_result in tool_results:
                    response = tool_result.get("response") or tool_result.get("content") or tool_result
                    text = ""
                    if isinstance(response, dict):
                        text = clean_text(
                            response.get("output")
                            or response.get("text")
                            or response.get("message")
                            or response.get("error")
                        )
                    elif isinstance(response, list):
                        text = "\n".join(
                            clean_text(bit.get("text"))
                            for bit in response
                            if isinstance(bit, dict) and bit.get("text")
                        )
                    else:
                        text = clean_text(response)
                    if text:
                        append_system(text, "tool")
            continue
        if message_type != "gemini":
            continue
        ensure_turn(timestamp)
        for thought in message.get("thoughts") or []:
            if isinstance(thought, dict):
                append_reasoning(
                    thought.get("description")
                    or thought.get("thinking")
                    or thought.get("summary")
                    or thought.get("subject")
                )
        assistant_text = []
        for block in content:
            if not isinstance(block, dict):
                continue
            if block.get("text"):
                assistant_text.append(clean_text(block.get("text")))
                continue
            if block.get("functionCall"):
                call = block["functionCall"]
                name = clean_text(call.get("name"))
                args = call.get("args") or {}
                detail = clean_text(
                    args.get("command")
                    or args.get("file_path")
                    or args.get("path")
                    or args.get("url")
                    or args.get("query")
                    or call.get("id")
                )
                if name == "run_shell_command":
                    label = f"$ {detail}" if detail else "$ shell command"
                    append_system(label, "command")
                elif name in {"read_file", "list_directory", "glob"}:
                    append_system(
                        f"{name} {detail}".strip(),
                        "tool",
                    )
                else:
                    append_system(
                        f"Tool: {name}" + (f" — {detail}" if detail else ""),
                        "tool",
                    )
        text = clean_text("\n".join(part for part in assistant_text if part))
        raw_text, visible_text = split_gemini_visible_text(text)
        if raw_text and not visible_text:
            append_system(raw_text, "reasoning")
            continue
        if raw_text and visible_text:
            append_system(raw_text, "reasoning")
            text = visible_text
        if text:
            current.setdefault("items", []).append(
                {"type": "agentMessage", "text": text}
            )
    return [turn for turn in turns if turn.get("items")]


def claude_sessions_for_cwd(cwd):
    root = os.path.expanduser("~/.claude/projects/" + project_key(cwd))
    sessions = []
    if not os.path.isdir(root):
        return sessions
    for path in sorted(Path(root).glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True):
        if not claude_session_is_resumable(str(path)):
            continue
        sid = path.stem
        preview = first_text_from_claude_jsonl(str(path))
        metadata = claude_session_metadata(str(path))
        generated_title = metadata["title"]
        try:
            mtime = path.stat().st_mtime
        except OSError:
            mtime = time.time()
        sessions.append(
            {
                "id": f"claude-terminal:{sid}",
                "source_session_id": sid,
                "agent": "claude",
                "origin": "claude-terminal",
                "cwd": cwd,
                "title": generated_title or preview or path.stem,
                "preview": preview or path.stem,
                "created_at": iso_from_unix(mtime),
                "updated_at": iso_from_unix(mtime),
                "source_path": str(path),
                "backend": {
                    "session_id": sid,
                    "model": claude_model_alias(
                        (metadata.get("context") or {}).get("model")
                    ),
                },
                "context": metadata["context"],
                "turns": [],
                "transcript_loaded": False,
            }
        )
    return sessions


def codex_sessions_for_cwd(cwd):
    db = os.path.expanduser("~/.codex/state_5.sqlite")
    if not os.path.exists(db):
        return []
    try:
        import sqlite3

        con = sqlite3.connect(db)
        con.row_factory = sqlite3.Row
        rows = con.execute(
            "select id, rollout_path, cwd, title, preview, created_at, updated_at, source, archived "
            "from threads where cwd = ? and archived = 0 order by updated_at desc limit 100",
            (cwd,),
        ).fetchall()
    except Exception:
        return []
    history = codex_history_prompts()
    sessions = []
    for row in rows:
        sid = row["id"]
        turns = codex_rollout_turns(row["rollout_path"])
        prompts = history.get(sid) or []
        if not turns and prompts:
            transcript = []
            for _, text in prompts[:8]:
                transcript.append(
                    {
                        "type": "userMessage",
                        "content": [{"type": "text", "text": text}],
                    }
                )
            turns = [
                {
                    "id": sid,
                    "created_at": iso_from_unix(row["created_at"]),
                    "status": "completed",
                    "items": transcript,
                }
            ]
        preview = clean_text(row["preview"] or row["title"] or "")
        if not preview and prompts:
            preview = prompts[0][1]
        sessions.append(
            {
                "id": f"codex-terminal:{sid}",
                "source_session_id": sid,
                "agent": "codex",
                "origin": "codex-terminal",
                "cwd": row["cwd"],
                "title": row["title"] or preview or "Codex session",
                "preview": preview or "Codex session",
                "created_at": iso_from_unix(row["created_at"]),
                "updated_at": iso_from_unix(row["updated_at"]),
                "source_path": row["rollout_path"],
                "backend": {"thread_id": sid},
                "context": codex_context_from_rollout(row["rollout_path"]),
                "turns": turns,
            }
        )
    return sessions


def discover_external_sessions(cwd, agent_key):
    if agent_key == "codex":
        return codex_sessions_for_cwd(cwd)
    if agent_key == "claude":
        return claude_sessions_for_cwd(cwd)
    if agent_key == "gemini":
        return gemini_sessions_for_cwd(cwd)
    return []


def summarize_turn_items(turns, max_chars=7000):
    lines = []
    remaining = max_chars
    for turn in turns[-12:]:
        for item in turn.get("items") or []:
            typ = item.get("type", "")
            text = ""
            if typ == "userMessage":
                parts = []
                for bit in item.get("content") or []:
                    if isinstance(bit, dict) and bit.get("type") == "text":
                        parts.append(bit.get("text", ""))
                text = " ".join(parts)
                prefix = "USER"
            elif typ == "agentMessage":
                text = item.get("text") or item.get("content") or ""
                prefix = "AGENT"
            elif typ == "commandExecution":
                text = item.get("command") or ""
                prefix = "COMMAND"
            elif typ == "fileChange":
                paths = []
                for change in item.get("changes") or []:
                    path = change.get("path") or change.get("filePath")
                    if path:
                        paths.append(str(path))
                text = ", ".join(paths)
                prefix = "FILES"
            elif typ == "reasoning":
                text = " ".join(item.get("summary") or [])
                prefix = "REASONING"
            elif typ == "plan":
                text = item.get("text") or ""
                prefix = "PLAN"
            else:
                text = item.get("text") or item.get("summary") or ""
                prefix = typ.upper() or "NOTE"
            text = clean_text(text)
            if not text:
                continue
            line = f"{prefix}: {text}"
            if len(line) > remaining:
                lines.append(line[: max(0, remaining - 1)] + "…")
                return "\n".join(lines)
            lines.append(line)
            remaining -= len(line) + 1
            if remaining <= 0:
                return "\n".join(lines)
    return "\n".join(lines)


def item_text(item):
    typ = item.get("type", "")
    if typ == "userMessage":
        return clean_text(
            " ".join(
                bit.get("text", "")
                for bit in item.get("content") or []
                if isinstance(bit, dict) and bit.get("type") == "text"
            )
        )
    if typ == "fileChange":
        return clean_text(
            ", ".join(
                str(change.get("path") or change.get("filePath") or "")
                for change in item.get("changes") or []
                if change.get("path") or change.get("filePath")
            )
        )
    if typ == "reasoning":
        return clean_text(" ".join(item.get("summary") or []))
    return clean_text(
        item.get("text")
        or item.get("content")
        or item.get("command")
        or item.get("summary")
        or ""
    )


def structured_handoff_packet(session, max_chars=HANDOFF_MAX_CHARS):
    title = clean_text(session.get("title") or session.get("preview") or "Untitled")
    agent = clean_text(session.get("agent") or "agent").title()
    cwd = clean_text(session.get("cwd") or os.path.expanduser("~"))
    context = session.get("context") or {}
    requests = []
    conclusions = []
    upgrades = []
    failures = []
    unresolved = []
    technical = []
    chronology = []

    for turn_index, turn in enumerate(session.get("turns") or [], start=1):
        user_texts = []
        agent_texts = []
        for item in turn.get("items") or []:
            typ = item.get("type", "")
            text = item_text(item)
            if not text:
                continue
            if typ == "userMessage":
                user_texts.append(text)
                requests.append(text)
                chronology.append(f"{turn_index}. USER: {text}")
            elif typ == "agentMessage":
                agent_texts.append(text)
                conclusions.append(text)
                chronology.append(f"{turn_index}. AGENT: {text}")
                lowered = text.lower()
                if re.search(
                    r"\b(added|built|implemented|upgraded|updated|fixed|created|installed|"
                    r"changed|wired|enabled|completed|now supports)\b",
                    lowered,
                ):
                    upgrades.append(text)
                if re.search(
                    r"\b(failed|failure|error|blocked|unable|could not|couldn't|"
                    r"timeout|timed out|stalled|broken|regression)\b",
                    lowered,
                ):
                    failures.append(text)
                if re.search(
                    r"\b(todo|remaining|unresolved|not yet|still needs|follow[- ]?up|"
                    r"deferred|later|next step|open question)\b",
                    lowered,
                ):
                    unresolved.append(text)
            elif typ in {"commandExecution", "fileChange", "plan", "note"}:
                label = {
                    "commandExecution": "COMMAND",
                    "fileChange": "FILES",
                    "plan": "PLAN",
                    "note": "NOTE",
                }[typ]
                technical.append(f"{label}: {text}")
        if user_texts and not agent_texts:
            unresolved.extend(user_texts)
        if turn.get("status") not in {None, "completed"}:
            prompt = clean_text(turn.get("prompt")) or "Turn had no saved prompt."
            failures.append(f"Turn {turn_index} ended as {turn.get('status')}: {prompt}")

    def unique(values, limit=None, item_limit=1400):
        result = []
        seen = set()
        for value in values:
            normalized = re.sub(r"\s+", " ", clean_text(value))
            if not normalized or normalized in seen:
                continue
            seen.add(normalized)
            if len(value) > item_limit:
                value = value[: item_limit - 1].rstrip() + "…"
            result.append(value)
            if limit and len(result) >= limit:
                break
        return result

    def section(name, values, fallback="None recorded.", limit=None, item_limit=1400):
        values = unique(values, limit=limit, item_limit=item_limit)
        body = "\n".join(f"- {value}" for value in values) if values else f"- {fallback}"
        return f"## {name}\n{body}"

    used = int(context.get("used") or 0)
    limit = int(context.get("limit") or 0)
    context_line = (
        f"{round(used * 100 / limit)}% ({used:,}/{limit:,} tokens)"
        if used > 0 and limit > 0
        else "unknown"
    )
    parts = [
        "# Automatic Session Handoff",
        f"- Source title: {title}",
        f"- Source client: {agent}",
        f"- Project directory: {cwd}",
        f"- Source context usage: {context_line}",
        f"- Generated: {now_iso()}",
        "",
        section("User Goals And Requests", requests, limit=80, item_limit=900),
        "",
        section(
            "Decisions And Important Conclusions",
            conclusions[-40:],
            limit=40,
            item_limit=1200,
        ),
        "",
        section(
            "Upgrades And Completed Changes",
            upgrades[-30:],
            limit=30,
            item_limit=1200,
        ),
        "",
        section(
            "Failures, Dead Ends, And Blockers",
            failures[-30:],
            limit=30,
            item_limit=1200,
        ),
        "",
        section(
            "Unresolved Questions And Forgotten Follow-Ups",
            unresolved[-40:],
            limit=40,
            item_limit=1000,
        ),
        "",
        section(
            "Important Technical Details",
            technical[-60:],
            limit=60,
            item_limit=800,
        ),
        "",
        "## Chronological Conversation Record",
        "\n".join(unique(chronology[-80:], item_limit=700))
        or "- No conversation text was available.",
        "",
        "## Continuation Instructions",
        "- Treat this packet as authoritative context from the previous session.",
        "- Preserve completed work and do not repeat failed approaches without a reason.",
        "- Address unresolved items when they are relevant, even if the prior conversation moved on.",
        "- Inspect the current filesystem before assuming recorded file state is still current.",
        "- Continue the user's latest objective directly after a brief acknowledgment.",
    ]
    packet = "\n".join(parts)
    if len(packet) > max_chars:
        packet = packet[: max_chars - 160].rstrip() + (
            "\n\n[Handoff truncated at the configured safety limit. "
            "The categorized sections above take priority.]"
        )
    return packet


def turn_failure_text(status, error, session):
    error = clean_text(error)
    if error:
        return error
    backend = (session or {}).get("backend") or {}
    model = clean_text(backend.get("model"))
    model_note = f" using {model}" if model else ""
    return (
        f"The client ended this turn as '{status}'{model_note} without producing "
        "an assistant response. Retry the turn or choose another supported model."
    )


def format_reset_time(timestamp):
    try:
        moment = datetime.fromtimestamp(float(timestamp), tz=timezone.utc).astimezone()
        return moment.strftime("%b %-d, %-I:%M%p").replace("AM", "am").replace("PM", "pm")
    except (TypeError, ValueError, OSError):
        return ""


def codex_usage_limits(source_path=""):
    candidates = []
    if source_path and os.path.isfile(source_path):
        candidates.append(source_path)
    root = Path(os.path.expanduser("~/.codex/sessions"))
    try:
        candidates.extend(
            str(path)
            for path in sorted(
                root.rglob("*.jsonl"),
                key=lambda path: path.stat().st_mtime_ns,
                reverse=True,
            )[:12]
            if str(path) not in candidates
        )
    except OSError:
        pass
    for path in candidates:
        latest = None
        try:
            with open(path, encoding="utf-8") as handle:
                for line in handle:
                    if '"rate_limits"' not in line:
                        continue
                    try:
                        event = json.loads(line)
                    except ValueError:
                        continue
                    rate_limits = (event.get("payload") or {}).get("rate_limits")
                    if isinstance(rate_limits, dict):
                        latest = rate_limits
        except OSError:
            continue
        if not latest:
            continue
        windows = []
        for key in ("primary", "secondary"):
            value = latest.get(key) or {}
            if not isinstance(value, dict) or value.get("used_percent") is None:
                continue
            minutes = int(value.get("window_minutes") or 0)
            label = "5h" if minutes and minutes <= 360 else "week"
            windows.append(
                {
                    "label": label,
                    "used_percent": round(float(value.get("used_percent") or 0)),
                    "reset": format_reset_time(value.get("resets_at")),
                }
            )
        if windows:
            return {"provider": "Codex", "windows": windows}
    return {"provider": "Codex", "windows": [], "error": "No rate-limit telemetry yet."}


def claude_usage_limits():
    try:
        result = subprocess.run(
            [
                "claude",
                "-p",
                "/usage",
                "--output-format",
                "json",
                "--permission-mode",
                "default",
                "--tools",
                "",
                "--no-session-persistence",
            ],
            cwd=os.path.expanduser("~"),
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=20,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired) as exc:
        return {"provider": "Claude", "windows": [], "error": str(exc)}
    try:
        payload = json.loads(result.stdout or "{}")
        text = clean_text(payload.get("result"))
    except ValueError:
        text = clean_text(result.stdout)
    windows = []
    patterns = (
        ("5h", r"Current session:\s*(\d+)% used\s*·\s*resets\s*(.+)"),
        ("week", r"Current week \(all models\):\s*(\d+)% used\s*·\s*resets\s*(.+)"),
        ("sonnet", r"Current week \(Sonnet only\):\s*(\d+)% used\s*·\s*resets\s*(.+)"),
    )
    for label, pattern in patterns:
        match = re.search(pattern, text, flags=re.IGNORECASE)
        if match:
            windows.append(
                {
                    "label": label,
                    "used_percent": int(match.group(1)),
                    "reset": clean_text(match.group(2)),
                }
            )
    if windows:
        return {"provider": "Claude", "windows": windows}
    return {
        "provider": "Claude",
        "windows": [],
        "error": text or "Claude did not return usage details.",
    }


class SessionStore:
    def __init__(self):
        ensure_dir(CONFIG_DIR)
        ensure_dir(SESSIONS_DIR)
        ensure_dir(ARTIFACTS_DIR)
        self.sessions = {}
        self.load()

    def load(self):
        self.sessions = {}
        for name in sorted(os.listdir(SESSIONS_DIR)):
            if not name.endswith(".json"):
                continue
            path = os.path.join(SESSIONS_DIR, name)
            data = load_json(path, None)
            if isinstance(data, dict) and data.get("id"):
                changed = False
                for turn in data.get("turns") or []:
                    if turn.get("status") == "running":
                        turn["status"] = "interrupted"
                        changed = True
                if not data.get("origin"):
                    data["origin"] = "local"
                self.sessions[data["id"]] = data
                if changed:
                    save_json(path, data)
        self.compact_linked_duplicates()

    def save(self, session):
        if session.get("origin", "local") != "local":
            return
        session["updated_at"] = now_iso()
        if not session.get("created_at"):
            session["created_at"] = session["updated_at"]
        self.sessions[session["id"]] = session
        save_json(os.path.join(SESSIONS_DIR, session["id"] + ".json"), session)

    def delete(self, session_id):
        self.sessions.pop(session_id, None)
        path = os.path.join(SESSIONS_DIR, session_id + ".json")
        try:
            os.unlink(path)
        except OSError:
            pass

    def new_session(self, agent_key, cwd, title=""):
        session = self._make_session(
            agent_key=agent_key,
            cwd=cwd,
            title=clean_text(title) or f"New {agent_key} session",
            backend={},
            turns=[],
            origin="local",
        )
        self.save(session)
        return session

    def _make_session(self, agent_key, cwd, title, backend, turns, origin="local", source_session_id=None):
        session = {
            "id": str(uuid.uuid4()),
            "agent": agent_key,
            "cwd": cwd,
            "title": title,
            "created_at": now_iso(),
            "updated_at": now_iso(),
            "backend": backend or {},
            "turns": turns or [],
            "origin": origin,
        }
        if source_session_id:
            session["source_session_id"] = source_session_id
        return session

    def linked_session(self, agent_key, cwd, client_id):
        client_id = clean_text(client_id)
        if not client_id:
            return None
        candidates = []
        for session in self.sessions.values():
            if (
                session.get("origin", "local") != "local"
                or session.get("agent") != agent_key
                or session.get("cwd") != cwd
            ):
                continue
            backend = session.get("backend") or {}
            linked_id = clean_text(
                backend.get("session_id")
                or backend.get("thread_id")
                or session.get("source_session_id")
            )
            if linked_id == client_id:
                candidates.append(session)
        if not candidates:
            return None
        return max(
            candidates,
            key=lambda session: (
                len(session.get("turns") or []),
                session.get("updated_at") or "",
            ),
        )

    def adopt_external(self, source):
        backend = deepcopy(source.get("backend") or {})
        client_id = clean_text(
            backend.get("session_id")
            or backend.get("thread_id")
            or source.get("source_session_id")
        )
        existing = self.linked_session(
            source.get("agent", "codex"),
            source.get("cwd") or os.path.expanduser("~"),
            client_id,
        )
        if existing:
            existing["title"] = clean_text(
                source.get("title") or source.get("preview")
            ) or existing.get("title")
            existing["backend"] = backend or existing.get("backend") or {}
            existing["source_session_id"] = client_id
            existing["source_path"] = clean_text(source.get("source_path"))
            if source.get("turns"):
                existing["turns"] = deepcopy(source.get("turns") or [])
            existing["transcript_loaded"] = bool(source.get("transcript_loaded"))
            self.save(existing)
            return existing
        session = self._make_session(
            agent_key=source.get("agent", "codex"),
            cwd=source.get("cwd") or os.path.expanduser("~"),
            title=clean_text(source.get("title") or source.get("preview"))
            or f"New {source.get('agent', 'agent')} session",
            backend=backend,
            turns=deepcopy(source.get("turns") or []),
            origin="local",
            source_session_id=client_id,
        )
        session["source_path"] = clean_text(source.get("source_path"))
        session["transcript_loaded"] = bool(source.get("transcript_loaded"))
        self.save(session)
        return session

    def compact_linked_duplicates(self):
        groups = {}
        for session in self.sessions.values():
            if session.get("origin", "local") != "local":
                continue
            backend = session.get("backend") or {}
            client_id = clean_text(
                backend.get("session_id") or backend.get("thread_id")
            )
            if not client_id:
                continue
            key = (
                session.get("agent"),
                session.get("cwd"),
                client_id,
            )
            groups.setdefault(key, []).append(session)
        for group in groups.values():
            if len(group) < 2:
                continue
            keep = max(
                group,
                key=lambda session: (
                    len(session.get("turns") or []),
                    session.get("updated_at") or "",
                ),
            )
            for duplicate in group:
                if duplicate.get("id") == keep.get("id"):
                    continue
                self.sessions.pop(duplicate.get("id"), None)
                try:
                    os.unlink(
                        os.path.join(
                            SESSIONS_DIR,
                            duplicate.get("id") + ".json",
                        )
                    )
                except OSError:
                    pass

    def clone_for_continuation(self, source):
        backend = deepcopy(source.get("backend") or {})
        turns = deepcopy(source.get("turns") or [])
        title = source.get("title") or source.get("preview") or f"New {source.get('agent', 'agent')} session"
        session = self._make_session(
            agent_key=source.get("agent", "codex"),
            cwd=source.get("cwd") or os.path.expanduser("~"),
            title=title,
            backend=backend,
            turns=turns,
            origin="local",
            source_session_id=source.get("source_session_id") or source.get("id"),
        )
        self.save(session)
        return session

    def new_handoff_session(self, source, title, packet, agent_key=None, backend=None):
        session = self._make_session(
            agent_key=agent_key or source.get("agent", "codex"),
            cwd=source.get("cwd") or os.path.expanduser("~"),
            title=title,
            backend=backend or {},
            turns=[],
            origin="local",
        )
        session["handoff_context"] = packet
        session["handoff_from"] = source.get("id")
        self.save(session)
        return session

    def list_for(self, cwd, agent_key):
        items = [
            s
            for s in self.sessions.values()
            if s.get("cwd") == cwd and s.get("agent") == agent_key
        ]
        items.sort(key=lambda s: s.get("updated_at") or "", reverse=True)
        unique = []
        seen = set()
        kept_empty_draft = False
        for session in items:
            backend = session.get("backend") or {}
            client_id = clean_text(
                backend.get("session_id") or backend.get("thread_id")
            )
            empty_draft = not client_id and not (session.get("turns") or [])
            if empty_draft:
                if kept_empty_draft:
                    continue
                kept_empty_draft = True
            key = client_id or session.get("source_session_id") or session.get("id")
            if key in seen:
                continue
            seen.add(key)
            unique.append(session)
        return unique

    def get(self, session_id):
        return self.sessions.get(session_id)

    def set_title_from_prompt(self, session, prompt):
        _, visible = strip_session_context(prompt)
        title = shorten(visible or prompt, 60)
        if title:
            session["title"] = title
            self.save(session)

    def ensure_turn(self, session, prompt=None):
        turns = session.setdefault("turns", [])
        turn = {
            "id": str(uuid.uuid4()),
            "created_at": now_iso(),
            "status": "running",
            "items": [],
        }
        if prompt:
            turn["prompt"] = prompt
        turns.append(turn)
        self.save(session)
        return turn

    def add_item(self, session, turn, item):
        turn.setdefault("items", []).append(item)
        self.save(session)

    def finish_turn(self, session, turn, status="completed"):
        turn["status"] = status
        turn["completed_at"] = now_iso()
        self.save(session)

    def summary_for_handoff(self, session, max_chars=7000):
        header = f"Previous {session.get('agent', 'agent')} session for {project_label(session.get('cwd'))}:\n"
        body = summarize_turn_items(session.get("turns") or [], max_chars=max_chars)
        return header + body if body else header + "No prior details available."


class BaseBackend:
    def __init__(self, events, workspace_id=None):
        self.events = events
        self.workspace_id = workspace_id
        self.stop_flag = threading.Event()
        self.active = False

    def emit(self, kind, **payload):
        event = {"kind": kind, **payload}
        if self.workspace_id:
            event["workspace_id"] = self.workspace_id
        self.events.put(event)

    def stop(self):
        self.stop_flag.set()


class CodexBackend(BaseBackend):
    def __init__(self, events, workspace_id=None):
        super().__init__(events, workspace_id)
        self.proc = None
        self.cwd = None
        self.thread_id = None
        self.turn_id = None
        self.next_id = 1
        self.pending = {}
        self.lock = threading.Lock()
        self.ready = threading.Event()
        self.active_threads = set()

    def start(self, cwd):
        self.cwd = cwd
        self.proc = subprocess.Popen(
            ["codex", "app-server"],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,
        )
        threading.Thread(target=self._read_stdout, daemon=True).start()
        threading.Thread(target=self._read_stderr, daemon=True).start()
        self.request(
            "initialize",
            {
                "clientInfo": {
                    "name": "agent_workbench",
                    "title": APP_NAME,
                    "version": "0.2.0",
                }
            },
            self._on_initialized,
        )

    def _on_initialized(self, _result):
        self.notify("initialized", {})
        self.ready.set()

    def request(self, method, params, callback=None, error_callback=None):
        with self.lock:
            req_id = self.next_id
            self.next_id += 1
            if callback or error_callback:
                self.pending[req_id] = (callback, error_callback)
        message = {"method": method, "id": req_id, "params": params}
        self._send(message)
        return req_id

    def notify(self, method, params):
        self._send({"method": method, "params": params})

    def respond(self, req_id, result):
        self._send({"id": req_id, "result": result})

    def _send(self, message):
        try:
            self.proc.stdin.write(json.dumps(message) + "\n")
            self.proc.stdin.flush()
        except Exception as exc:
            self.emit("error", text=str(exc))

    def _read_stdout(self):
        proc = self.proc
        for line in proc.stdout:
            if self.stop_flag.is_set():
                break
            try:
                message = json.loads(line)
            except ValueError:
                self.emit("work", text=line.rstrip(), tag="system")
                continue

            req_id = message.get("id")
            if req_id is not None and message.get("method"):
                self._handle_server_request(message)
                continue
            if req_id is not None:
                callbacks = self.pending.pop(req_id, (None, None))
                callback, error_callback = callbacks
                if "error" in message:
                    err = message["error"]
                    text = err.get("message", "Codex error")
                    if error_callback:
                        error_callback(text)
                    else:
                        self.emit("error", text=text)
                elif callback:
                    callback(message.get("result") or {})
                continue

            self._handle_notification(message)
        if self.proc is proc and not self.stop_flag.is_set():
            self.emit("backend_exit", text="Codex app server stopped")

    def _handle_server_request(self, message):
        method = message.get("method", "")
        if method == "item/tool/requestUserInput":
            self.emit(
                "user_input_request",
                request_id=message.get("id"),
                params=message.get("params") or {},
            )
            return
        self.respond(message.get("id"), {})

    def _read_stderr(self):
        proc = self.proc
        for line in proc.stderr:
            if self.stop_flag.is_set():
                break
            line = line.strip()
            if line:
                self.emit("work", text=line, tag="system")

    def _handle_notification(self, message):
        method = message.get("method", "")
        params = message.get("params") or {}
        item = params.get("item") or {}
        typ = item.get("type", "")

        if method == "turn/started":
            turn = params.get("turn") or {}
            self.turn_id = turn.get("id") or self.turn_id
            self.emit("work", text="--- New turn ---", tag="system")
        elif method == "item/started":
            if typ and typ != "agentMessage":
                self.emit("work", text="▶ " + typ, tag="tool")
        elif method == "item/completed":
            if typ == "agentMessage":
                text = item.get("text") or item.get("content") or ""
                if not text:
                    content = []
                    for bit in item.get("content") or []:
                        if isinstance(bit, dict) and bit.get("type") == "text":
                            content.append(bit.get("text", ""))
                    text = " ".join(content)
                if text:
                    if item.get("phase") == "commentary":
                        self.emit("work", text=text, tag="progress")
                    else:
                        self.emit("assistant_message", text=text, speaker="CODEX")
            elif typ == "userMessage":
                self.emit("user", text=self._extract_text(item))
            elif typ == "commandExecution":
                command = clean_text(item.get("command"))
                if command:
                    self.emit("work", text=f"$ {command}", tag="command")
                output = clean_text(item.get("aggregatedOutput"))
                if output:
                    self.emit("work", text=output, tag="system")
            elif typ == "fileChange":
                paths = []
                for change in item.get("changes") or []:
                    path = change.get("path") or change.get("filePath")
                    if path:
                        paths.append(str(path))
                if paths:
                    self.emit("work", text="files: " + ", ".join(paths), tag="fileChange")
            elif typ == "reasoning":
                summary = " ".join(item.get("summary") or [])
                if summary:
                    self.emit("work", text=summary, tag="reasoning")
            elif typ == "plan":
                text = clean_text(item.get("text"))
                if text:
                    self.emit("work", text=text, tag="plan")
            elif typ == "mcpToolCall":
                self.emit(
                    "work",
                    text=f"{clean_text(item.get('server'))}.{clean_text(item.get('tool'))}",
                    tag="tool",
                )
        elif method == "item/commandExecution/outputDelta":
            delta = clean_text(params.get("delta"))
            if delta:
                self.emit("work", text=delta, tag="system")
        elif method == "item/fileChange/outputDelta":
            delta = clean_text(params.get("delta"))
            if delta:
                self.emit("work", text=delta, tag="fileChange")
        elif method == "turn/completed":
            turn = params.get("turn") or {}
            error = turn.get("error") or {}
            error_text = clean_text(
                error.get("message") if isinstance(error, dict) else error
            )
            self.emit(
                "turn_done",
                status=(turn.get("status") or "completed"),
                error=error_text,
            )
        elif method == "thread/tokenUsage/updated":
            token_usage = params.get("tokenUsage") or {}
            usage = token_usage.get("last") or {}
            used = int(usage.get("inputTokens") or usage.get("totalTokens") or 0)
            limit = int(token_usage.get("modelContextWindow") or 0)
            if used > 0 and limit > 0:
                self.emit("token_usage", usage={
                    "used": used,
                    "limit": limit,
                    "input_tokens": int(usage.get("inputTokens") or 0),
                    "output_tokens": int(usage.get("outputTokens") or 0),
                    "total_tokens": int(usage.get("totalTokens") or 0),
                    "provider": "Codex",
                })
                self.emit(
                    "context_usage",
                    context={
                        "used": used,
                        "limit": limit,
                        "percent": min(100.0, used * 100.0 / limit),
                        "model": "Codex",
                        "compact_count": 0,
                    },
                )
        elif method == "thread/created" or method == "thread/resumed":
            thread = params.get("thread") or {}
            self.thread_id = thread.get("id") or self.thread_id

    def _extract_text(self, item):
        parts = []
        for bit in item.get("content") or []:
            if isinstance(bit, dict) and bit.get("type") == "text":
                parts.append(bit.get("text", ""))
        return clean_text(" ".join(parts))

    def ensure_session(self, session):
        backend = session.setdefault("backend", {})
        backend.setdefault("kind", "codex")
        existing_thread_id = backend.get("thread_id")
        if existing_thread_id and existing_thread_id in self.active_threads:
            self.thread_id = existing_thread_id
            return

        result_holder = {}
        error_holder = {}
        done = threading.Event()

        def on_ready(result):
            result_holder.update(result)
            done.set()

        def on_error(text):
            error_holder["text"] = text
            done.set()

        params = {
            "cwd": session["cwd"],
            "approvalPolicy": "never",
            "sandbox": "danger-full-access",
            "personality": "pragmatic",
        }
        model = clean_text(backend.get("model"))
        if model:
            params["model"] = model
        method = "thread/start"
        if existing_thread_id:
            method = "thread/resume"
            params["threadId"] = existing_thread_id
        self.request(method, params, on_ready, on_error)
        if not done.wait(timeout=30):
            raise RuntimeError(f"Timed out while trying to {method.replace('/', ' ')}")
        if error_holder:
            raise RuntimeError(error_holder["text"])
        thread = result_holder.get("thread") or {}
        thread_id = thread.get("id") or existing_thread_id
        if not thread_id:
            raise RuntimeError("Codex did not return a thread ID")
        backend["thread_id"] = thread_id
        self.thread_id = thread_id
        self.active_threads.add(thread_id)
        session["backend"] = backend

    def start_turn(self, session, turn, prompt, context_text=""):
        try:
            self.ensure_session(session)
        except Exception as exc:
            self.emit("error", text=str(exc))
            return
        self.turn_id = None
        payload_text = prompt
        if context_text:
            payload_text = context_text.strip() + "\n\n" + prompt.strip()
        done = threading.Event()

        def on_turn(result):
            turn_obj = result.get("turn") or {}
            self.turn_id = turn_obj.get("id")
            backend = session.setdefault("backend", {})
            backend["thread_id"] = backend.get("thread_id") or self.thread_id
            backend["turn_id"] = self.turn_id
            done.set()

        def on_error(text):
            self.emit("error", text=text)
            done.set()

        request = {
            "threadId": self.thread_id,
            "cwd": session["cwd"],
            "input": [{"type": "text", "text": payload_text}],
        }
        backend = session.get("backend") or {}
        if clean_text(backend.get("model")):
            request["model"] = backend["model"]
        if clean_text(backend.get("effort")):
            request["effort"] = backend["effort"]
        self.request(
            "turn/start",
            request,
            on_turn,
            on_error,
        )
        if not done.wait(timeout=30):
            self.emit("error", text="Codex timed out while starting the turn")

    def answer_user_input(self, request_id, questions, text):
        lines = [line.strip() for line in text.splitlines() if line.strip()]
        answers = {}
        for index, question in enumerate(questions):
            answer = lines[index] if index < len(lines) else (text.strip() if index == 0 else "")
            answers[question.get("id", str(index))] = {"answers": [answer]}
        self.respond(request_id, {"answers": answers})

    def interrupt(self):
        if self.thread_id and self.turn_id:
            self.request(
                "turn/interrupt",
                {"threadId": self.thread_id, "turnId": self.turn_id},
            )

    def restart(self, cwd):
        self.stop_flag.set()
        if self.proc and self.proc.poll() is None:
            self.proc.terminate()
        self.stop_flag.clear()
        self.ready.clear()
        self.pending.clear()
        self.active_threads.clear()
        self.thread_id = None
        self.turn_id = None
        self.start(cwd)

    def close(self):
        self.stop_flag.set()
        if self.proc and self.proc.poll() is None:
            self.proc.terminate()


class StreamCliBackend(BaseBackend):
    def __init__(self, events, kind, workspace_id=None):
        super().__init__(events, workspace_id)
        self.kind = kind
        self.running = None
        self.lock = threading.Lock()

    def interrupt(self):
        with self.lock:
            if self.running and self.running.poll() is None:
                self.running.terminate()

    def close(self):
        self.stop_flag.set()
        self.interrupt()


class OllamaBackend(StreamCliBackend):
    """Ollama (local LLM) client handler with multi-turn streaming support."""

    def __init__(self, events, spec, workspace_id=None):
        super().__init__(events, spec.get("key", "ollama"), workspace_id)
        self.spec = spec
        self.base_url = "http://localhost:11434"
        self.model = spec.get("model", "qwen3-coder:30b")
        self.messages = []  # Multi-turn conversation history

    def start_turn(self, session, turn, prompt, context_text=""):
        def run():
            import urllib.request
            import urllib.error

            payload = prompt
            if context_text:
                payload = context_text.strip() + "\n\n" + prompt.strip()

            self.messages.append({"role": "user", "content": payload})

            body = json.dumps(
                {"model": self.model, "messages": self.messages, "stream": True}
            ).encode("utf-8")

            try:
                req = urllib.request.Request(
                    f"{self.base_url}/api/chat",
                    data=body,
                    headers={"Content-Type": "application/json"},
                )
                with urllib.request.urlopen(req, timeout=300) as resp:
                    full_response = ""
                    for line in resp:
                        chunk = json.loads(line.decode("utf-8"))
                        if "message" in chunk and "content" in chunk["message"]:
                            content = chunk["message"]["content"]
                            full_response += content
                            self.emit("work", text=content, tag="stream")

                    if full_response:
                        self.messages.append(
                            {"role": "assistant", "content": full_response}
                        )
                        self.emit("assistant_message", text=full_response,
                                 speaker=self.spec.get("label", "OLLAMA").upper())
                        self.emit("turn_done", status="completed")
                    else:
                        self.emit("error", text="No response from Ollama")
                        self.emit("turn_done", status="error")

            except urllib.error.URLError as e:
                self.emit(
                    "error",
                    text=f"Ollama not reachable at {self.base_url}: {str(e)}",
                )
                self.emit("turn_done", status="error")
            except Exception as e:
                self.emit("error", text=f"Ollama error: {str(e)}")
                self.emit("turn_done", status="error")

        threading.Thread(target=run, daemon=True).start()

    def close(self):
        self.stop_flag.set()


class CustomCliBackend(StreamCliBackend):
    def __init__(self, events, spec, workspace_id=None):
        super().__init__(events, spec["key"], workspace_id)
        self.spec = spec

    def start_turn(self, session, turn, prompt, context_text=""):
        def _find_git_root(path):
            """Walk up from path looking for a .git directory."""
            current = os.path.abspath(path)
            while True:
                if os.path.isdir(os.path.join(current, ".git")):
                    return current
                parent = os.path.dirname(current)
                if parent == current:
                    return None
                current = parent

        def run():
            template = clean_text(self.spec.get("command"))
            payload = prompt
            if context_text:
                payload = context_text.strip() + "\n\n" + prompt.strip()
            if not template:
                self.emit("error", text="Custom client command is empty.")
                self.emit("turn_done", status="error")
                return
            uses_placeholder = "{prompt}" in template
            if uses_placeholder:
                command = template.replace("{prompt}", shlex.quote(payload))
                stdin_data = None
            else:
                command = template
                stdin_data = (payload + "\n").encode()
            self.emit("work", text="$ " + command, tag="command")
            # Aider git-repo hint
            if "aider" in command.lower():
                cwd = session.get("cwd") or os.path.expanduser("~")
                if not _find_git_root(cwd):
                    self.emit(
                        "work",
                        text="[hint] aider needs a git project directory — set this session's working directory to your project, or it can only chat.",
                        tag="system",
                    )
            # Open PTY
            master_fd, slave_fd = pty.openpty()
            try:
                fcntl.ioctl(
                    slave_fd,
                    termios.TIOCSWINSZ,
                    struct.pack("HHHH", 40, 160, 0, 0),
                )
            except OSError:
                pass
            env = os.environ.copy()
            env["TERM"] = env.get("TERM") or "xterm-256color"
            cwd = session.get("cwd") or os.path.expanduser("~")
            try:
                proc = subprocess.Popen(
                    ["bash", "-lc", command],
                    cwd=cwd,
                    stdin=slave_fd,
                    stdout=slave_fd,
                    stderr=slave_fd,
                    env=env,
                    preexec_fn=os.setsid,
                    close_fds=True,
                )
            except Exception as exc:
                os.close(slave_fd)
                os.close(master_fd)
                self.emit("error", text=f"Custom client failed to start: {exc}")
                self.emit("turn_done", status="error")
                return
            os.close(slave_fd)
            with self.lock:
                self.running = proc
            # Write stdin payload if needed
            if stdin_data is not None:
                try:
                    os.write(master_fd, stdin_data)
                except OSError:
                    pass
            # Read output from master_fd
            final_status = "completed"
            try:
                while not self.stop_flag.is_set():
                    try:
                        data = os.read(master_fd, 4096)
                    except OSError:
                        break
                    if not data:
                        break
                    text = data.decode("utf-8", errors="replace").replace("\r\n", "\n").replace("\r", "\n")
                    text = ANSI_ESCAPE.sub("", text)
                    text = text.replace("\\[", "").replace("\\]", "")
                    if text:
                        self.emit("work", text=text, tag="stream")
            finally:
                try:
                    os.close(master_fd)
                except OSError:
                    pass
                with self.lock:
                    running = self.running
                if running is not None:
                    try:
                        running.wait(timeout=5)
                    except Exception:
                        pass
                    rc = running.poll()
                    if rc is not None and rc != 0:
                        final_status = "error"
                with self.lock:
                    self.running = None
                if self.stop_flag.is_set():
                    final_status = "error"
                self.emit("turn_done", status=final_status)

        threading.Thread(target=run, daemon=True).start()


class TerminalShell:
    def __init__(self, events):
        self.events = events
        self.proc = None
        self.master_fd = None
        self.cwd = None
        self.lock = threading.Lock()
        self.generation = 0

    def emit(self, kind, **payload):
        self.events.put({"kind": kind, **payload})

    def start(self, cwd):
        cwd = cwd if os.path.isdir(cwd) else os.path.expanduser("~")
        self.close()
        master_fd, slave_fd = pty.openpty()
        try:
            fcntl.ioctl(
                slave_fd,
                termios.TIOCSWINSZ,
                struct.pack("HHHH", 32, 140, 0, 0),
            )
        except OSError:
            pass
        env = os.environ.copy()
        env["TERM"] = env.get("TERM") or "xterm-256color"
        env["AGENT_WORKBENCH"] = "1"
        shell = env.get("SHELL") or "/bin/bash"
        try:
            with self.lock:
                self.generation += 1
                generation = self.generation
                self.cwd = cwd
                self.master_fd = master_fd
                self.proc = subprocess.Popen(
                    [shell, "-i"],
                    cwd=cwd,
                    stdin=slave_fd,
                    stdout=slave_fd,
                    stderr=slave_fd,
                    env=env,
                    preexec_fn=os.setsid,
                    close_fds=True,
                )
            os.close(slave_fd)
        except Exception as exc:
            self.emit("terminal_output", text=f"[terminal failed to start: {exc}]\n")
            return
        threading.Thread(target=self._read, args=(generation,), daemon=True).start()
        self.emit("terminal_output", text=f"[terminal ready · {cwd}]\n")

    def _read(self, generation):
        while True:
            with self.lock:
                if generation != self.generation:
                    return
                fd = self.master_fd
                proc = self.proc
            if fd is None or proc is None:
                return
            try:
                data = os.read(fd, 4096)
            except OSError:
                break
            if not data:
                break
            text = data.decode("utf-8", errors="replace").replace("\r", "")
            clear_screen = "\x1b[2J" in text or "\x1b[3J" in text
            text = ANSI_ESCAPE.sub("", text)
            text = text.replace("\\[", "").replace("\\]", "")
            if clear_screen:
                self.emit("terminal_clear")
            if text:
                with self.lock:
                    if generation != self.generation:
                        return
                self.emit("terminal_output", text=text)
        with self.lock:
            if generation != self.generation:
                return
            proc = self.proc
        if proc is not None:
            self.emit("terminal_exit", status=proc.poll())

    def send(self, text):
        with self.lock:
            fd = self.master_fd
        if fd is None:
            return False
        try:
            os.write(fd, text.encode("utf-8"))
            return True
        except OSError:
            return False

    def interrupt(self):
        with self.lock:
            proc = self.proc
            fd = self.master_fd
        if proc and proc.poll() is None:
            try:
                foreground_pgid = os.tcgetpgrp(fd) if fd is not None else proc.pid
                os.killpg(foreground_pgid, signal.SIGINT)
            except OSError:
                pass

    def close(self):
        with self.lock:
            self.generation += 1
            proc = self.proc
            fd = self.master_fd
            self.proc = None
            self.master_fd = None
        if proc and proc.poll() is None:
            try:
                os.killpg(proc.pid, signal.SIGHUP)
            except OSError:
                pass
            try:
                proc.wait(timeout=2)
            except subprocess.TimeoutExpired:
                proc.terminate()
        if fd is not None:
            try:
                os.close(fd)
            except OSError:
                pass


class ClaudeBackend(StreamCliBackend):
    def __init__(self, events, workspace_id=None):
        super().__init__(events, "claude", workspace_id)

    def start_turn(self, session, turn, prompt, context_text=""):
        def run():
            session_id = session.setdefault("backend", {}).get("session_id") or str(uuid.uuid4())
            first_turn = not session["backend"].get("session_id")
            cmd = [
                "claude",
                "-p",
                "--output-format",
                "stream-json",
                "--input-format",
                "text",
                "--verbose",
                "--permission-mode",
                "bypassPermissions",
                "--dangerously-skip-permissions",
            ]
            model = clean_text(session["backend"].get("model"))
            effort = clean_text(session["backend"].get("effort"))
            orchestration_mode = clean_text(
                session["backend"].get("orchestration_mode") or "smart"
            )
            if orchestration_mode == "smart":
                cmd += [
                    "--append-system-prompt",
                    CLAUDE_SMART_ORCHESTRATION_PROMPT,
                    "--agents",
                    CLAUDE_SMART_AGENTS_JSON,
                ]
            if model and model != "Default":
                cmd += ["--model", model]
            if effort:
                cmd += ["--effort", effort]
            if first_turn:
                cmd += ["--session-id", session_id]
                title = clean_text(session.get("title"))
                if title and not title.startswith("New "):
                    cmd += ["--name", title]
            else:
                cmd += ["--resume", session_id]

            payload = prompt
            if context_text and first_turn:
                payload = context_text.strip() + "\n\n" + prompt.strip()

            logged_cmd = list(cmd)
            if "--append-system-prompt" in logged_cmd:
                policy_index = logged_cmd.index("--append-system-prompt") + 1
                if policy_index < len(logged_cmd):
                    logged_cmd[policy_index] = "<smart orchestration policy>"
            if "--agents" in logged_cmd:
                agents_index = logged_cmd.index("--agents") + 1
                if agents_index < len(logged_cmd):
                    logged_cmd[agents_index] = "<smart agent profiles>"
            self.emit(
                "work",
                text="$ " + shlex.join(logged_cmd + [payload]),
                tag="command",
            )
            buffer = []
            visible_chunks = []
            emitted_visible = False
            final_status = "completed"
            final_error = ""
            with self.lock:
                self.running = subprocess.Popen(
                    cmd + [payload],
                    cwd=session["cwd"],
                    stdout=subprocess.PIPE,
                    stderr=subprocess.PIPE,
                    text=True,
                    bufsize=1,
                )
            try:
                threading.Thread(target=self._stream_stderr, daemon=True).start()
                for raw in self.running.stdout:
                    if self.stop_flag.is_set():
                        break
                    line = raw.strip()
                    if not line:
                        continue
                    try:
                        event = json.loads(line)
                    except ValueError:
                        self.emit("work", text=line, tag="system")
                        continue
                    etype = event.get("type")
                    if etype == "system" and event.get("subtype") == "init":
                        sid = event.get("session_id")
                        if sid:
                            session.setdefault("backend", {})["session_id"] = sid
                        self.emit(
                            "work",
                            text=f"claude session {sid or session_id}",
                            tag="system",
                        )
                    elif etype == "assistant":
                        message = event.get("message") or {}
                        context = context_from_usage(
                            message.get("usage") or {},
                            message.get("model") or model,
                        )
                        if context:
                            self.emit("context_usage", context=context)
                        actual_model = clean_text(message.get("model"))
                        if actual_model:
                            self.emit("active_model", model=actual_model)
                        for block in message.get("content") or []:
                            if not isinstance(block, dict):
                                continue
                            block_type = block.get("type")
                            content = clean_text(block.get("text"))
                            if block_type == "text" and content:
                                if not buffer:
                                    self.emit("assistant_begin", speaker="CLAUDE")
                                buffer.append(content)
                                self.emit("assistant_delta", text=content, speaker="CLAUDE")
                            elif block_type == "tool_use":
                                self.emit(
                                    "work",
                                    text=f"Tool: {clean_text(block.get('name'))}",
                                    tag="tool",
                                )
                                # Claude Code names the subagent tool "Agent"
                                # (older versions: "Task") — match both, or the
                                # Sub-agents counter never registers a fan-out.
                                if block.get("name") in ("Task", "Agent"):
                                    inp = block.get("input") or {}
                                    self.emit(
                                        "subagent_start",
                                        agent_id=clean_text(block.get("id")),
                                        name=clean_text(inp.get("subagent_type") or inp.get("description") or "sub-agent"),
                                        detail=clean_text(inp.get("description")),
                                    )
                    elif etype == "user":
                        # A tool_result carrying parent_tool_use_id is THAT subagent
                        # finishing — clear the matching one from the live count.
                        parent_id = event.get("parent_tool_use_id")
                        if parent_id:
                            self.emit("subagent_stop", agent_id=clean_text(parent_id))
                        self.emit("work", text=line, tag="system")
                    elif etype == "result":
                        result = event.get("result") or ""
                        if result and not buffer:
                            self.emit("assistant_begin", speaker="CLAUDE")
                            self.emit("assistant_delta", text=clean_text(result), speaker="CLAUDE")
                        status = event.get("subtype") or "success"
                        if status not in {"success", "completed"}:
                            final_status = "error"
                            final_error = clean_text(
                                event.get("error") or event.get("result")
                            )
                        stats = event.get("usage") or {}
                        if stats:
                            self.emit(
                                "token_usage",
                                usage={
                                    "input_tokens": int(stats.get("input_tokens") or 0),
                                    "output_tokens": int(stats.get("output_tokens") or 0),
                                    "total_tokens": int(
                                        stats.get("total_tokens")
                                        or int(stats.get("input_tokens") or 0)
                                        + int(stats.get("output_tokens") or 0)
                                    ),
                                    "provider": "Claude",
                                },
                            )
                        self.emit(
                            "work",
                            text=f"Claude {status} · input {stats.get('input_tokens', 0)} · output {stats.get('output_tokens', 0)}",
                            tag="done" if status == "success" else "system",
                        )
                        break
                    else:
                        self.emit("work", text=line, tag="system")
                if buffer:
                    self.emit("assistant_done", speaker="CLAUDE")
                process = self.running
                if process and process.poll() is None:
                    try:
                        process.wait(timeout=2)
                    except subprocess.TimeoutExpired:
                        pass
                self.emit(
                    "turn_done",
                    status=final_status,
                    error=final_error,
                )
            except Exception as exc:
                self.emit("error", text=str(exc))
                self.emit("turn_done", status="error")
            finally:
                with self.lock:
                    self.running = None

        threading.Thread(target=run, daemon=True).start()

    def _stream_stderr(self):
        proc = self.running
        if not proc or not proc.stderr:
            return
        for raw in proc.stderr:
            if self.stop_flag.is_set():
                break
            line = raw.strip()
            if line:
                self.emit("work", text=line, tag="system")


class GeminiBackend(StreamCliBackend):
    def __init__(self, events, workspace_id=None):
        super().__init__(events, "gemini", workspace_id)

    def start_turn(self, session, turn, prompt, context_text=""):
        def run():
            session_id = session.setdefault("backend", {}).get("session_id") or str(uuid.uuid4())
            first_turn = not session["backend"].get("session_id")
            cmd = [
                "gemini",
                "-p",
                prompt,
                "--output-format",
                "stream-json",
                "--yolo",
                "--skip-trust",
            ]
            model = clean_text(session["backend"].get("model"))
            if model and model != "Auto":
                cmd += ["--model", model]
            if first_turn:
                cmd += ["--session-id", session_id]
            else:
                cmd += ["--resume", session_id]

            payload = prompt
            if context_text and first_turn:
                payload = context_text.strip() + "\n\n" + prompt.strip()
                cmd[2] = payload

            self.emit("work", text="$ " + shlex.join(cmd), tag="command")
            visible_chunks = []
            emitted_visible = False
            with self.lock:
                self.running = subprocess.Popen(
                    cmd,
                    cwd=session["cwd"],
                    stdout=subprocess.PIPE,
                    stderr=subprocess.PIPE,
                    text=True,
                    bufsize=1,
                )
            try:
                threading.Thread(target=self._stream_stderr, daemon=True).start()
                for raw in self.running.stdout:
                    if self.stop_flag.is_set():
                        break
                    line = raw.strip()
                    if not line:
                        continue
                    try:
                        event = json.loads(line)
                    except ValueError:
                        self.emit("work", text=line, tag="system")
                        continue
                    etype = event.get("type")
                    if etype == "init":
                        sid = event.get("session_id")
                        if sid:
                            session.setdefault("backend", {})["session_id"] = sid
                        self.emit(
                            "work",
                            text=f"Gemini session {sid or session_id}",
                            tag="system",
                        )
                    elif etype == "message":
                        role = event.get("role")
                        content = clean_text(event.get("content"))
                        if role == "assistant" and content:
                            thought_text, visible_text = split_gemini_visible_text(content)
                            if thought_text:
                                self.emit("work", text=thought_text, tag="reasoning")
                            if visible_text:
                                visible_chunks.append(visible_text)
                        elif role == "user":
                            self.emit("user", text=content)
                    elif etype == "result":
                        result = clean_text(event.get("result") or "")
                        thought_text, visible_text = split_gemini_visible_text(result)
                        if thought_text:
                            self.emit("work", text=thought_text, tag="reasoning")
                        final_text = visible_text or clean_text(" ".join(visible_chunks))
                        if final_text:
                            emitted_visible = True
                            self.emit("assistant_message", speaker="GEMINI", text=final_text)
                        status = event.get("status") or "success"
                        stats = event.get("stats") or {}
                        if stats:
                            self.emit(
                                "token_usage",
                                usage={
                                    "input_tokens": int(stats.get("input_tokens") or 0),
                                    "output_tokens": int(stats.get("output_tokens") or 0),
                                    "total_tokens": int(
                                        stats.get("total_tokens")
                                        or int(stats.get("input_tokens") or 0)
                                        + int(stats.get("output_tokens") or 0)
                                    ),
                                    "provider": "Gemini",
                                },
                            )
                        self.emit(
                            "work",
                            text=f"Gemini {status} · input {stats.get('input_tokens', 0)} · output {stats.get('output_tokens', 0)}",
                            tag="done" if status == "success" else "system",
                        )
                        break
                    else:
                        self.emit("work", text=line, tag="system")
                if emitted_visible:
                    self.emit("assistant_done", speaker="GEMINI")
                self.emit("turn_done", status="completed")
            except Exception as exc:
                self.emit("error", text=str(exc))
                self.emit("turn_done", status="error")
            finally:
                with self.lock:
                    self.running = None

        threading.Thread(target=run, daemon=True).start()

    def _stream_stderr(self):
        proc = self.running
        if not proc or not proc.stderr:
            return
        for raw in proc.stderr:
            if self.stop_flag.is_set():
                break
            line = raw.strip()
            if line:
                self.emit("work", text=line, tag="system")


