            pass


def acquire_lock():
    runtime = os.environ.get("XDG_RUNTIME_DIR", os.path.expanduser("~/.cache"))
    ensure_dir(runtime)
    handle = open(os.path.join(runtime, APP_ID + ".lock"), "w")
    try:
        fcntl.flock(handle, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        print(f"{APP_NAME} is already running.")
        sys.exit(0)
    return handle


